        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "close" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "close" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "nConstraintRemoveMembers.png" 
        -image1 "nConstraintRemoveMembers.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Close Maya Fast v1.5\n\nglobal proc m341_killMayaFast()\n{\n\t//Save current work space so it loads next time Maya starts\n\tworkspaceLayoutManager -save;\t\n\n\t//Open script editor to prevent losing script tabs\n    scriptEditorInfo -ch;\n\tScriptEditor;\n\n\t//Save script editor tabs to temp folder\n\tsyncExecuterBackupFiles();\n\n\t//Save all preferences\n\tSavePreferences;\n\n\t//Save all shelves\n\tglobal string $gShelfTopLevel;\n\tsaveAllShelves $gShelfTopLevel;\n\n\t//Save MTK shelf\n\tdRSaveShelves;\n\n\t//Save tool settings\n\tsaveToolSettings;\n\tsaveViewportSettings;\n\n\t//Save content browser settings\n\tsaveContentBrowserSettings;\n\n\t//Save plug-in prefs\n\tpluginInfo -savePluginPrefs;\n\n\t//Save menuset prefs\n\tmenuSetPref -saveAll;\n\n\t//Close script editor\t\n\tdeleteUI scriptEditorPanel1Window;\n\t\n\t//Save current work space so it loads next time Maya starts\n\tworkspaceLayoutManager -save;\t\n\n\t//Save Window prefs\n\twindowPref -saveMainWindowState startupMainWindowState;\n\n\t//Save scene if changed\n\t//saveChanges(\"\");\n\t\n\t//Close Maya\n\t//system(\"taskkill /IM maya.exe /f /t\");\n\t\n\t//Query application ID and use that to kill only the currently focused Maya\n\t$mayaInstanceID = `getpid`;\n\t//If Mac\n\tstring $maCurrentMayaVersionMac = `about -mac`;\n\tif( $maCurrentMayaVersionMac == 1)\n\t{\n\t\tsystem(\"kill -9 \"  + $mayaInstanceID);\n\t}\n\n\telse\n\t{\n\t\tsystem(\"taskkill /PID \"  + $mayaInstanceID +\" /f /t\");\t\n\t}\n}\n\n//Check which version of Maya is running\nstring $findMayaYear2020 = `about -product`;\nstring $findMayaYear2019 = `about -product`;\nstring $findMayaYear2018 = `about -product`;\nstring $findMayaYear2017 = `about -product`;\nint $mayaYear2020 = `gmatch $findMayaYear2020 \"*2020*\"`;\nint $mayaYear2019 = `gmatch $findMayaYear2019 \"*2019*\"`;\nint $mayaYear2018 = `gmatch $findMayaYear2018 \"*2018*\"`;\nint $mayaYear2017 = `gmatch $findMayaYear2017 \"*2017*\"`;\n\n//Use fast close for older versions of Maya\nif ($mayaYear2020 == 1 || $mayaYear2019 == 1 || $mayaYear2018 == 1 || $mayaYear2017 == 1)\n{\n\t//Check if scene was modified\n\tint $checkFileDirty = `file -q -modified`;\n\tif ($checkFileDirty == 0)\n\t{\n\t\tm341_killMayaFast();\t\t\n\t}\n\n\telse if ($checkFileDirty == 1)\n\t{\n\t\t//If user cancels don't kill Maya\n\t\tif(!saveChanges(\"\"))\n\t\t{\n\t\t\tprint \"Canceled fast close\";\n\t\t}\n\t\n\t\telse\n\t\t{\n\t\t\tm341_killMayaFast();\n\t\t}\n\t}\n}\n\nelse\n{\n\t//Use regular close for newer versions of Maya\n\tQuit;\n}" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help close" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_helpClose()\n{\n\tglobal string $m341_close_HelpWindow;\n\n\tif (`window -exists $m341_close_HelpWindow`)\n\t{\n\t\tglobal string $m341_close_HelpWindow;\n\t\tdeleteUI $m341_close_HelpWindow;\n\t}\n\t\n\t$m341_close_HelpWindow = `window -title \"Help Fast Close Maya\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable true -resizeToFitChildren false -width 800 -height 115`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CLOSE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Closes Maya much faster than normal and saves all preferences, including preferences Maya should save but doesn't. MTK shelf, recent file history, project etc.\\n\\n\";\t\t\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/mDONY44P4jA?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/mDONY44P4jA?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_close_HelpWindow;\n}\nm341_helpClose();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "sPref" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "sPref" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconEdit.png" 
        -image1 "menuIconEdit.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Special Save Preferences v1.5\n//***********************************************************************************************************************************************************\nglobal proc m341_specialSavePreferences()\n{\n\t//Check if script editor already open\n\tglobal int $m341_scriptEditorOpen;\n\t$m341_scriptEditorOpen = 0;\n\n\t//Check if script editor invisible\n\tstring $scriptEditorInvis[] = `getPanel -invisiblePanels`;\n\t//Convert to string so gmatch works\n\tstring $stringNames = stringArrayToString($scriptEditorInvis, \" \");\n\n\tif (`gmatch $stringNames \"*scriptEditorPanel1*\"`)\n\t{\n\t\t$m341_scriptEditorOpen = 0;\n\t\t//print \"Script window invisible\\n\";\n\t}\n\telse\n\t{\n\t\t$m341_scriptEditorOpen = 1;\n\t\t//print \"Script window open\\n\";\n\t}\n\n\t\n\t//Save current work space so it loads next time Maya starts\n\tworkspaceLayoutManager -save;\n\t\n\t//Open script editor to prevent losing script tabs\n\tscriptEditorInfo -ch;\n\tScriptEditor;\n\n\t//Save script editor tabs to temp folder\n\tstring $mayaPatch = `about -installedVersion`;\n\tstring $array[];\n\t$array = stringToStringArray($mayaPatch, \" \");\n\tfloat $mayaPatchNumber = $array[2];\n\t\n\tif($mayaPatchNumber >= 2022.2)\n\t{\n\t\t//For Maya 2022.2 or higher\n\t\tsaveScriptEditorTabs();\n\t}\n\telse\n\t{\n\t\t//For Maya 2022 or lower\n\t\tsyncExecuterBackupFiles();\t\n\t}\n\t\n\t//Save all preferences\n\tSavePreferences;\n\n\t//Save all shelves\n\tglobal string $gShelfTopLevel;\n\tsaveAllShelves $gShelfTopLevel;\n\n\t//Save MTK shelf\n\tdRSaveShelves;\n\n\t//Save tool settings\n\tsaveToolSettings;\n\tsaveViewportSettings;\n\n\t//Save content browser settings\n\tsaveContentBrowserSettings;\n\n\t//Save plug-in prefs\n\tpluginInfo -savePluginPrefs;\n\n\t//Save menuset prefs\n\tmenuSetPref -saveAll;\n\n\t//Close script editor if it wasn't open to start\n\tif ($m341_scriptEditorOpen == 0)\n\t{\n\t\tevalDeferred \"deleteUI scriptEditorPanel1Window\";\n\t}\n\n\t//Save Window prefs\n\twindowPref -saveMainWindowState startupMainWindowState;\n}\nm341_specialSavePreferences();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help sPref" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_helpSavePreferences()\n{\n\tglobal string $m341_sPref_HelpWindow;\n\n\tif (`window -exists $m341_sPref_HelpWindow`)\n\t{\n\t\tglobal string $m341_sPref_HelpWindow;\n\t\tdeleteUI $m341_sPref_HelpWindow;\n\t}\n\t\n\t$m341_sPref_HelpWindow = `window -title \"Help Special Save Preferences\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable true -resizeToFitChildren false -width 800 -height 125`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SPREF\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Special save preferences tool that saves the contents of the script editor, MTK custom shelf, recent file history, tool settings, and other preferences that were't included in Maya's default save preference command. For example, if you make an edit to the MTK custom shelf and Maya crashes or doesn't close correctly, you'll lose that edit along with a bunch of other settings and menu items you've changed.\\n\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/mDONY44P4jA?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/mDONY44P4jA?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_sPref_HelpWindow;\n}\nm341_helpSavePreferences();" )
    ;
    shelfButton
