        -flat 1
        -mi "" ( "" )
        -mi "Help graph" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_HelpGraphMat()\n{\n\tglobal string $m341_GraphMat_HelpWindow;\n\n\tif (`window -exists $m341_GraphMat_HelpWindow`)\n\t{\n\t\tglobal string $m341_GraphMat_HelpWindow;\n\t\tdeleteUI $m341_GraphMat_HelpWindow;\n\t}\n\t\n\t$m341_GraphMat_HelpWindow = `window -title \"Help Graph Materials\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 125`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"GRAPH\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Graphs materials assigned to selected faces.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If the hypershade isn't open clicking the graph button will open it, but you'll need to click the button a second time to graph the materials.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/BqNJxVBjZyI?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/BqNJxVBjZyI?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_GraphMat_HelpWindow;\n}\nm341_HelpGraphMat();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "checker" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "checker" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconTexturing.png" 
        -image1 "menuIconTexturing.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Checker Map Toolbox\nglobal string $m341_checkerMap_Version;\n$m341_checkerMap_Version = \"checkerMap v2.7\";\n\n\n//***********************************************************************************************************************************************************\n//Check if default checker value is zero and set it to 1 if the tool was loaded from fresh boot\nglobal float $m341_checkerMap_incrementP2DU;\nglobal float $m341_checkerMap_incrementP2DV;\nglobal float $m341_checkerMap_incrementP2DR;\n\nif ($m341_checkerMap_incrementP2DU == \"0\")\n{\n\tglobal float $m341_checkerMap_incrementP2DU;\n\t$m341_checkerMap_incrementP2DU = 1;\n\tglobal float $m341_checkerMap_incrementP2DV;\n\t$m341_checkerMap_incrementP2DV = 1;\n\tglobal float $m341_checkerMap_incrementP2DR;\n\t$m341_checkerMap_incrementP2DR = 0;\n}\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_checkerMap_help()\n{\n\tglobal string $m341_checkerMap_HelpWindow;\n\tglobal string $m341_checkerMap_Version;\n\n\tif (`window -exists $m341_checkerMap_HelpWindow`)\n\t{\n\t\tglobal string $m341_checkerMap_HelpWindow;\n\t\tdeleteUI $m341_checkerMap_HelpWindow;\n\t}\n\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n\t$helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\t$m341_checkerMap_HelpWindow = `window -title (\"Help \" + $m341_checkerMap_Version) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 735`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"ON TOP OF UV EDITOR CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want the toolbox to stay on top of the UV editor when the UV editor is undocked. If you close the UV editor with this checkbox on, the toolbox will also close which is a limitation of how Maya works. If you're primarily working with a docked UV editor I recommend turning this checkbox off.\\n\\n\";\n\t\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"MAP1\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Toggles checker map1 texture on/off for selected objects. If nothing's selected the checker map is applied to all objects.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If checker1.png is not found in folder C:\\\\m341_temp a procedural checker texture will be generated and applied, you can replace this at any time with your own texture by overwriting it.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PLUS, MINUS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Increases or decreases the checker map tiling. If checker map mode is turned off plus and minus will increase or decrease the tiling of any textures applied to the selected objects.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"MAP2\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Toggles checker map2 texture on/off for selected objects. If nothing's selected the checker map is applied to all objects.\\n\";\n\t\n\t\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If checker2.png is not found in folder C:\\\\m341_temp a procedural direction texture will be generated and applied, you can replace this at any time with your own texture by overwriting it.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SPIN, SPIN\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Rotates the checker texture left or right by 45 degrees. If checker map mode is turned off spin and spin will rotate any textures applied to the selected objects.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"BASE COLOR MODE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Toggles base colour mode on/off. Base colour is the actual colour of the texture without any lighting or shading.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CREATE MAP STYLE 1 2 3 4\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Procedurally generates four different built in checker map textures. Each map will overwrite checker1.png and become the main checker texture the tool uses, if you're using a custom checker texture it will be overwritten so make sure to back it up before using this feature.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Procedurally generating checker maps is not supported in Maya LT unfortunately, but you can download the textures here if you want.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing</a><br><br>\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"FIND\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Opens the folder where the checker map textures are stored that the tool uses. Create your own custom checker map textures here and name them checker1.png and checker2.png.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-PC C:\\\\m341_temp\\\\checker1.png\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Mac /Users/Shared/m341_temp/checker1.png\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/tiiLlOA1v9Q?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/tiiLlOA1v9Q?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\t\t\n\t\n\tshowWindow $m341_checkerMap_HelpWindow;\n}\n\n\n//*******************************************************************************************************\n//Update load with UV editor Checkbox Value\nglobal proc m341_checkerMap_loadWithUVEditor_ValueChanged()\n{\n\t//Print value\n\tglobal int $m341_checkerMap_loadWithUVEditor_userInput;\n\t$m341_checkerMap_loadWithUVEditor_userInput = `checkBox -q -value checkerMap_loadWithUVEditor_CheckBoxName`;\n\toptionVar -intValue \"m341_checkerMap_loadWithUVEditorCheckBox_VarName\" $m341_checkerMap_loadWithUVEditor_userInput;\n\n\tif ($m341_checkerMap_loadWithUVEditor_userInput == 0)\n\t{\n\t\tm341_checkerMap_loadToolbox();\n\t\tprint \"On top of UV editor checkbox off\\n\";\n\t}\n\telse\n\t{\n\t\tm341_checkerMap_loadToolbox();\n\t\tprint \"On top of UV editor checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Save Fix Materials\nglobal proc m341_checkerMap_runScriptJobProc_saveFix()\n{\n\tglobal string $m341_checkerImage;\n\tif ($m341_checkerImage == \"checker1.png\")\n\t{\n\t\tevalDeferred \"m341_checkerMap_toggleChecker1()\";\n\t\tevalDeferred \"SaveScene\";\n\t\tevalDeferred \"m341_checkerMap_toggleChecker1()\";\n\t}\n\t\n\tif ($m341_checkerImage == \"checker2.png\")\n\t{\n\t\tevalDeferred \"m341_checkerMap_toggleChecker2()\";\n\t\tevalDeferred \"SaveScene\";\n\t\tevalDeferred \"m341_checkerMap_toggleChecker2()\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Auto Save Fix Materials\nglobal proc m341_checkerMap_runScriptJobProc_autoSaveFix()\n{\n\tglobal string $m341_checkerImage;\n\tif ($m341_checkerImage == \"checker1.png\")\n\t{\n\t\tevalDeferred \"m341_checkerMap_toggleChecker1()\";\n\t\tpause -seconds 1;\n\t\tevalDeferred \"autoSave -perform\";\n\t\tevalDeferred \"m341_checkerMap_toggleChecker1()\";\t\n\t}\n\t\n\tif ($m341_checkerImage == \"checker2.png\")\n\t{\n\t\tevalDeferred \"m341_checkerMap_toggleChecker2()\";\n\t\tpause -seconds 1;\n\t\tevalDeferred \"autoSave -perform\";\n\t\tevalDeferred \"m341_checkerMap_toggleChecker2()\";\t\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//checker map create and toggle\nglobal proc m341_checkerMap_toggleOnOff()\n{\n\t//Switch file name global variables\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\tglobal string $m341_checkerImage;\n\t\n\t$maCheckerOriginalSelection = `ls -sl`;\n\t\n\t//Global variables\n\tglobal string $shadingEngines[];\n\tglobal string $shadingEngineRemoveDupes[];\n\tglobal string $maMaterialsToPasteBack[];\n\tglobal int $m341_toggleCustomChecker;\n\t$m341_toggleCustomChecker = !$m341_toggleCustomChecker;\n\tglobal int $maToggleCheckerBaseColour;\t\t\n\tglobal int $checkIfCheckerMapExists;\n\t$checkIfCheckerMapExists = 0;\n\tglobal int $m341_checkerJobNum;\n\tglobal int $m341_checkerJobNumAutoSaveFix;\n\tglobal string $materials[];\n\tglobal string $m341_checkerComponents[];\n\tglobal int $maCheckerCounter;\n\t$maCheckerCounter = 0;\n\t\n\tif ($m341_toggleCustomChecker == 1)\n\t{\n\t\t//Disconnect initalParticle to keep array from adding two materials instead of one when lambert1 applied to face on selected object\t\t\n\t\tstring $checkerParticleTest[] = `listConnections -d off -s on initialParticleSE`;\n\t\tif (`gmatch $checkerParticleTest[0] \"lambert1\"`)\n\t\t{\n\t\t\tdisconnectAttr lambert1.outColor initialParticleSE.surfaceShader;\n\t\t}\n\t\t\n\t\tif (`gmatch $checkerParticleTest[0] \"standardSurface1\"`)\n\t\t{\n\t\t\tdisconnectAttr standardSurface1.outColor initialParticleSE.surfaceShader;\n\t\t}\n\t\n\t\t//Store components or objects in list so you can just put checker on their materials\n\t\tglobal string $m341_checkerComponents[];\n\t\t$m341_checkerComponents = `ls -sl`;\n\t\n\t\t//Turn on save fix script job incase someone saves the scene with checker map still applied\n\t\tglobal int $m341_checkerJobNum;\n\t\t$m341_checkerJobNum = `scriptJob -runOnce 1 -killWithScene -compressUndo 1 -event \"SceneSaved\" \"m341_checkerMap_runScriptJobProc_saveFix\"`;\n\n\n\t\t//Auto Save fix materials 2019.2 and above\n\t\tstring $mayaPatch = `about -installedVersion`;\n\t\tstring $array[];\n\t\t$array = stringToStringArray($mayaPatch, \" \");\n\t\tfloat $mayaPatchNumber = $array[2];\n\t\t\n\t\tif($mayaPatchNumber < 2019.2)\n\t\t{\n\t\t\t//Do nothing\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Turn on script job incase autosave happens with checker map still applied\n\t\t\tglobal int $m341_checkerJobNumAutoSaveFix;\n\t\t\t$m341_checkerJobNumAutoSaveFix = `scriptJob -runOnce 0 -compressUndo 1 -killWithScene -event renderSetupAutoSave \"m341_checkerMap_runScriptJobProc_autoSaveFix\"`;\n\t\t}\n\t\t\n\t\t//Create folder on hard drive for custom checker texture\n\t\tstring $maCurrentMayaVersionMac = `about -mac`;\n\t\tif($maCurrentMayaVersionMac == 1)\n\t\t{\n\t\t\tsysFile -makeDir \"/Users/Shared/m341_temp\";\n\t\t}\t\n\t\telse\n\t\t{\n\t\t\tsysFile -makeDir \"C:/m341_temp\";\n\t\t}\n\t\t\n\t\t//turn on textures for all modeling windows\n\t\tsetFocus modelPanel1;\n\t\tdisplayStyle -textured;\n\t\tsetFocus modelPanel2;\n\t\tdisplayStyle -textured;\n\t\tsetFocus modelPanel3;\n\t\tdisplayStyle -textured;\n\t\tsetFocus modelPanel4;\n\t\tdisplayStyle -textured;\t\n\t\n\t\t//Delete the checker map rig so it doens't double up\n\t\t//string $maCheckerMapSelectedOBJ[] = `ls -sl -o -dag -s`;\n\t\t//hyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\tstring $searchSceneForCheckerMat[] = `ls -mat`;\n\t\tfor ($Item in $searchSceneForCheckerMat)\n\t\t{\n\t\t\tif (`gmatch $Item \"ma_checker_*\"`)\n\t\t\t{\n\t\t\t\tselect \"ma_checker*\";\n\t\t\t\tdelete;\n\t\t\t}\n\t\t}\n\t\t\n\t\t//Set checker map switch to on\n\t\tglobal int $checkIfCheckerMapExists;\n\t\t$checkIfCheckerMapExists = 1;\n\t\n\t\t//Create checker material\n\t\tstring $mayaYear = `about -product`;\n\t\tstring $array[];\n\t\t$array = stringToStringArray($mayaYear, \" \");\n\t\tint $mayaVersionNumber = $array[1];\n\t\t\n\t\t//If Maya newer than 2023 use standardSurface instead of Lambert for the material\n\t\tif($mayaVersionNumber > 2023)\n\t\t{\n\t\t\t//Set roughness to 0.5 so it looks like initial shading group\n\t\t\tstring $matName = `shadingNode -asShader standardSurface -name ma_checker_map_m`;\n\t\t\tsetAttr ($matName + \".specularRoughness\") 0.5;\n\t\t}\n\t\telse\n\t\t{\n\t\t\tshadingNode -asShader lambert -name ma_checker_map_m;\n\t\t}\n\t\t//setAttr \"ma_checker_map_m.diffuse\" 1;\n\t\t$maUVMaterialSelected = `ls -sl`;\n\t\t\n\t\t//Create checker file node and plug in texture from c:drive\n\t\tshadingNode -asTexture -isColorManaged file;\n\t\trename \"ma_checker_map_f\";\n\t\t$maFileNodeSelected = `ls -sl`;\n\t\tstring $maCurrentMayaVersionMac2 = `about -mac`;\n\t\tif($maCurrentMayaVersionMac2 == 1)\n\t\t{\n\t\t\tsetAttr -type \"string\" ($maFileNodeSelected[0] + \".fileTextureName\") (\"/Users/Shared/m341_temp/\" + $m341_checkerImage);\n\t\t}\t\n\t\telse\n\t\t{\n\t\t\tsetAttr -type \"string\" ($maFileNodeSelected[0] + \".fileTextureName\") (\"C:/m341_temp/\" + $m341_checkerImage);\n\t\t}\n\t\t\n\t\t//If Maya newer than 2023 use standardSurface instead of Lambert for the material\n\t\tif($mayaVersionNumber > 2023)\n\t\t{\n\t\t\tconnectAttr -f ($maFileNodeSelected[0] + \".outColor \") ($maUVMaterialSelected[0] + \".baseColor\");\n\t\t}\n\t\telse\n\t\t{\n\t\t\tconnectAttr -f ($maFileNodeSelected[0] + \".outColor \") ($maUVMaterialSelected[0] + \".color\");\n\t\t}\n\t\t\n\t\t\n\t\t//Create checker place 2D node\n\t\tshadingNode -asUtility place2dTexture;\n\t\trename \"ma_checker_map_p2d\";\n\t\t$place2DNode = `ls -sl`;\n\t\t\n\t\t//Connect place 2D node to file node\n\t\tconnectAttr -f ($place2DNode[0] + \".repeatUV \") ($maFileNodeSelected[0] + \".repeatUV\");\n\t\tconnectAttr -f ($place2DNode[0] + \".outUV \") ($maFileNodeSelected[0] + \".uv\");\n\t\n\t\t\n\t\t//Check if anything selected before script is run\n\t\tfloat $sizeOfmaCheckerComponents = size($m341_checkerComponents);\n\t\tif ($sizeOfmaCheckerComponents == 0)\n\t\t{\n\t\t\t//Select all meshes and get what materials applied to prevent 2020 standard surface bug\n\t\t\tselect `ls -typ mesh`;\t\n\t\t\thyperShade -smn \"\";\n\t\t\tglobal string $materials[];\n\t\t\t$materials = `ls -sl`;\n\t\t\tselect $materials;\n\t\t\tglobal string $maMaterialsToPasteBack[];\n\t\t\t$maMaterialsToPasteBack = `ls -sl`;\n\t\t\tselect -cl;\n\t\t\t\n\t\t\t//Old code before 2020\n\t\t\t//Select all materials and store them in a variable\n\t\t\t//global string $materials[];\n\t\t\t//$materials = `ls -mat`;\n\t\t\t//select $materials;\n\t\t\t//global string $maMaterialsToPasteBack[];\n\t\t\t//$maMaterialsToPasteBack = `ls -sl`;\n\t\t\t//select -cl;\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\t//Select only some materials and store them in a variable\n\t\t\tglobal string $m341_checkerComponents[];\n\t\t\tselect $m341_checkerComponents;\n\t\t\thyperShade -smn \"\";\n\t\t\tglobal string $materials[];\n\t\t\t$materials = `ls -sl`;\n\t\t\tselect $materials;\n\t\t\tglobal string $maMaterialsToPasteBack[];\n\t\t\t$maMaterialsToPasteBack = `ls -sl`;\n\t\t\tselect -cl;\n\t\t}\n\t\n\t\t\n\t\t//get the list of shading groups and store the number of shading groups\n\t\tstring $shadingEngines[] = listConnections(\"-type\",\"shadingEngine\", $materials);\n\t\t$shadingEngineRemoveDupes = stringArrayRemoveDuplicates($shadingEngines);\n\t\n\t\t\n\t\t//Set color management of scene to off \n\t\t//setAttr -type \"string\" ($maFileNodeSelected[0] + \".colorSpace \") sRGB;\n\t\t//setAttr -type \"string\" ($maFileNodeSelected[0] + \".colorSpace \") Raw;\n\t\tcolorManagementPrefs -edit -cmEnabled 0;\n\t\t\n\t\t\n\t\t\n\t\n\t\t//Turn checker map on by plugging checker map into object's shading groups\n\t\tfor ($maCheckerItem in $shadingEngineRemoveDupes)\n\t\t{\n\t\t\tglobal int $maCheckerCounter;\n\t\t\tconnectAttr -f ($maUVMaterialSelected[0] + \".outColor \") ($shadingEngineRemoveDupes[$maCheckerCounter] + \".surfaceShader\");\n\t\t\t$maCheckerCounter = $maCheckerCounter += 1;\n\t\t}\n\t\t\n\t\t//Remember checker tile from last time pull from global variable\n\t\tglobal float $m341_checkerMap_incrementP2DU;\n\t\tglobal float $m341_checkerMap_incrementP2DV;\n\t\tglobal float $m341_checkerMap_incrementP2DR;\n\t\tsetAttr ma_checker_map_p2d.repeatU $m341_checkerMap_incrementP2DU;\n\t\tsetAttr ma_checker_map_p2d.repeatV $m341_checkerMap_incrementP2DV;\n\t\tsetAttr ma_checker_map_p2d.rotateUV $m341_checkerMap_incrementP2DR;\n\t\t\n\t\tglobal int $maRememberBaseColour;\n\t\tif ($maRememberBaseColour == 1)\n\t\t{\n\t\t\tm341_checkerMap_baseColour();\n\t\t}\n\t\t\n\t\t//Turn ON UV editor image options so you can see wireframe 2019\n\t\tstring $maCurrentMayaYearUVFix = `about -product`;\n\t\tif(`gmatch $maCurrentMayaYearUVFix \"*2019*\"`)\n\t\t{\n\t\t\tif ((size(`textureWindow -query -parent polyTexturePlacementPanel1`)) == 0)\n\t\t\t{\n\t\t\t//Do nothing\n\t\t\t}\n\t\t\telse\n\t\t\t{\t\t\n\t\t\t\t//Turn OFF CHECKER\n\t\t\t\ttextureWindowDisplayCheckered(1,0);\n\t\t\t\ttxtWndUpdateEditor(\"polyTexturePlacementPanel1\", \"textureWindow\", \"null\", 101);\n\t\t\t\t//TURN ON SHADED 2019\n\t\t\t\t//textureWindow -edit -solidMapPerShell 0 -displaySolidMap 1 polyTexturePlacementPanel1; DisplayUVShaded;\n\t\t\t\t//DIM IMAGE 2019\n\t\t\t\tif(`getModifiers`%2) performTextureViewDimImageOptions 1; else{textureWindowImageDimming(1,1); performTextureViewDimImageOptions 0;} txtWndUpdateEditor(\"polyTexturePlacementPanel1\", \"textureWindow\", \"null\", 101);\n\t\t\t\tuvTbImageDimmingChangedCallback;\n\t\t\t\ttextureWindow -edit -ibc 0.6 0.6 0.6 polyTexturePlacementPanel1;\n\t\t\t\t//TURN ON IMAGE 2019\n\t\t\t\t$maCheckIfImageOn2019 = `textureWindow -q -imageDisplay polyTexturePlacementPanel1`;\n\t\t\t\tif ($maCheckIfImageOn2019 == 0)\n\t\t\t\t{\n\t\t\t\t\tToggleUVTextureImage;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\t\n\t\t//Turn ON UV editor image options so you can see wireframe 2018\n\t\tif(`gmatch $maCurrentMayaYearUVFix \"*2018*\"`)\n\t\t{\n\t\t\tif ((size(`textureWindow -query -parent polyTexturePlacementPanel1`)) == 0)\n\t\t\t{\n\t\t\t//Do nothing\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//Turn OFF CHECKER\n\t\t\t\ttextureWindow -edit -displayCheckered 0 polyTexturePlacementPanel1;\n\t\t\t\ttxtWndUpdateEditor(\"polyTexturePlacementPanel1\", \"textureWindow\", \"null\", 101);\n\t\t\t\t//TURN ON SHADED 2018\n\t\t\t\t//textureWindow -edit -solidMapPerShell 0 -displaySolidMap 1 polyTexturePlacementPanel1;\n\t\t\t\t//DIM IMAGE 2018\n\t\t\t\ttextureWindow -edit -imageDim 1 polyTexturePlacementPanel1;\n\t\t\t\tperformTextureViewDimImageOptions 0;\n\t\t\t\ttextureWindow -edit -ibc 0.6 0.6 0.6 polyTexturePlacementPanel1;\n\t\t\t\t//TURN ON IMAGE 2018\n\t\t\t\ttextureWindow -edit -imageDisplay 1 polyTexturePlacementPanel1;\n\t\t\t\tstring $texWinName[] = `getPanel -sty polyTexturePlacementPanel`;\n\t\t\t\ttxtWndUpdateEditor( $texWinName[0], \"textureWindow\", \"null\", 101 );\t\n\t\t\t}\n\t\t}\n\t\t\n\t\t//Turn ON UV editor image options so you can see wireframe 2017\n\t\tif(`gmatch $maCurrentMayaYearUVFix \"*2017*\"`)\n\t\t{\n\t\t\tif ((size(`textureWindow -query -parent polyTexturePlacementPanel1`)) == 0)\n\t\t\t{\n\t\t\t//Do nothing\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//TURN OFF CHECKER 2017\n\t\t\t\ttextureWindow -edit -displayCheckered 0 polyTexturePlacementPanel1;\n\t\t\t\ttxtWndUpdateEditor(\"polyTexturePlacementPanel1\", \"textureWindow\", \"null\", 101);\n\t\t\t\t//TURN ON SHADED 2017\n\t\t\t\t//textureWindow -edit -solidMapPerShell 0 -displaySolidMap 1 polyTexturePlacementPanel1;\n\t\t\t\t//DIM IMAGE 2017\n\t\t\t\ttextureWindow -e -imageDim 1 polyTexturePlacementPanel1; performTextureViewDimImageOptions 0;\n\t\t\t\ttextureWindow -edit -ibc 0.6 0.6 0.6 polyTexturePlacementPanel1;\n\t\t\t\t//TURN ON IMAGE 2017\n\t\t\t\ttextureWindow -edit -imageDisplay 1 polyTexturePlacementPanel1;\n\t\t\t\tstring $texWinName[] = `getPanel -sty polyTexturePlacementPanel`;\n\t\t\t\ttxtWndUpdateEditor( $texWinName[0], \"textureWindow\", \"null\", 101 );\n\t\t\t}\n\t\t}\n\t\t\n\t\tprint (\"Custom checker map ON \" + $maCheckerCounter + \" materials\\n\");    \n\t}\n\t\n\telse if ($m341_toggleCustomChecker == 0)\n\t{\n\t\t//Kill the script job so it doesn't activate multiple times on save\n\t\tglobal int $m341_checkerJobNum;\n\t\tscriptJob -kill $m341_checkerJobNum -force;\n\t\t\n\t\t//Kill auto save script job so it doesn't activate multiple times on save\n\t\tstring $mayaPatch = `about -installedVersion`;\n\t\tstring $array[];\n\t\t$array = stringToStringArray($mayaPatch, \" \");\n\t\tfloat $mayaPatchNumber = $array[2];\n\t\t\n\t\tif($mayaPatchNumber < 2019.2)\n\t\t{\n\t\t\t//Do nothing\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Turn on script job incase autosave happens with checker map still applied\n\t\t\tglobal int $m341_checkerJobNumAutoSaveFix;\n\t\t\tscriptJob -kill $m341_checkerJobNumAutoSaveFix -force;\n\t\t}\n\n\t\n\t\t//Set checker map switch to off\n\t\tglobal int $checkIfCheckerMapExists;\n\t\t$checkIfCheckerMapExists = 0;\n\t\t\n\t\t//Turn off base colour mode to fix viewport bug, change toggle to off to prevent toggle bug\n\t\tsoloMaterial -unsolo;\n\t\tglobal int $maToggleCheckerBaseColour;\n\t\t$maToggleCheckerBaseColour = 0;\n\t\t\n\t\t//Clear the selection\n\t\tselect -cl;\n\t\n\t\t//Turn colour management back on\n\t\tcolorManagementPrefs -edit -cmEnabled 1;\t\t\t\n\t\n\t\t\n\t\n\t\t//Paste back materials from stored names into original shading groups\n\t\tglobal int $maCheckerCounter;\n\t\tfor ($maCheckerItem in $shadingEngineRemoveDupes)\n\t\t{\n\t\t\tglobal int $maCheckerCounter;\n\t\t\tconnectAttr -f ($maMaterialsToPasteBack[$maCheckerCounter] + \".outColor \") ($shadingEngineRemoveDupes[$maCheckerCounter] + \".surfaceShader\");\n\t\t\t$maCheckerCounter = $maCheckerCounter += 1;\n\t\t}\n\t\t\n\t\tstring $searchSceneForCheckerMat[] = `ls -mat`;\n\t\tfor ($Item in $searchSceneForCheckerMat)\n\t\t{\n\t\t\tif (`gmatch $Item \"ma_checker_*\"`)\n\t\t\t{\n\t\t\t\tselect \"ma_checker*\";\n\t\t\t\tdelete;\n\t\t\t}\n\t\t}\n\t\t\n\t\t//Turn off UV editor image options so you don't see checker\n\t\tstring $maCurrentMayaYearUVFix2 = `about -product`;\n\t\tif(`gmatch $maCurrentMayaYearUVFix2 \"*2018*\"`)\n\t\t{\n\t\t\t//TURN OFF CHECKERS 2018\n\t\t\ttextureWindow -edit -displayCheckered 0 -checkerColorMode 0 polyTexturePlacementPanel1;\n\t\t\t//TURN OFF SHADED 2018\n\t\t\tDisplayUVWireframe;\n\t\t\t//TURN OFF DIM IMAGE 2018\n\t\t\t//textureWindow -e -imageDim 0 polyTexturePlacementPanel1; performTextureViewDimImageOptions 0;\n\t\t\t//textureWindow -edit -ibc 0.5 0.5 0.5 polyTexturePlacementPanel1;\t\n\t\t}\n\t\tif(`gmatch $maCurrentMayaYearUVFix2 \"*2017*\"`)\n\t\t{\n\t\t\t//TURN OFF CHECKERS 2017\n\t\t\ttextureWindow -edit -displayCheckered 0 polyTexturePlacementPanel1;\n\t\t\t//TURN OFF SHADED 2017\n\t\t\ttextureWindow -edit -solidMapPerShell 0 -displaySolidMap 0 polyTexturePlacementPanel1;\n\t\t\tDisplayUVWireframe;\n\t\t\t//TURN OFF DIM IMAGE 2017\n\t\t\t//textureWindow -e -imageDim 0 polyTexturePlacementPanel1; performTextureViewDimImageOptions 0;\n\t\t\t//textureWindow -edit -ibc 0.5 0.5 0.5 polyTexturePlacementPanel1;\n\t\t}\n\t\telse\n\t\t{\n\t\t\tif ((size(`textureWindow -query -parent polyTexturePlacementPanel1`)) == 0)\n\t\t\t{\n\t\t\t//Do nothing\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t//TURN OFF CHECKERS 2019\n\t\t\tif(`getModifiers`%2) performTextureViewCheckerMapOptions 1; else{ textureWindowDisplayCheckered(1,0);} txtWndUpdateEditor(\"polyTexturePlacementPanel1\", \"textureWindow\", \"null\", 101);\n\t\t\t}\n\t\t\t//TURN OFF SHADED 2019\n\t\t\ttextureWindow -edit -displayCheckered 0 -checkerColorMode 0 polyTexturePlacementPanel1;\n\t\t\tDisplayUVWireframe;\n\t\t\t//TURN OFF DIM IMAGE 2019\n\t\t\t//textureWindow -e -imageDim 0 polyTexturePlacementPanel1; performTextureViewDimImageOptions 0;\n\t\t\t//textureWindow -edit -ibc 0.5 0.5 0.5 polyTexturePlacementPanel1;\t\n\t\t}\n\t\t\n\t\tprint (\"Custom checker map OFF \" + $maCheckerCounter + \" materials\\n\");    \n\t}\n\tselect $maCheckerOriginalSelection;\n}\n\n\n//***********************************************************************************************************************************************************\n//checker map image toggle 1\nglobal proc m341_checkerMap_toggleChecker1()\n{\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 1;\n\t$m341_clickButton2 = 0;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker1.png\";\n\t}\n\tif ($m341_clickButton2 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker2.png\";\n\t}\n\tm341_checkerMap_toggleOnOff();\n\t\n\t\n\t//Render checker map if nothing exists first time to prevent no checker map showing up\n\tstring $mayaVersionMac = `about -mac`;\n\tif ($mayaVersionMac == 1)\n\t{\n\t\tsysFile -makeDir \"/Users/Shared/m341_temp\";\n\t\tstring $checkerMapFound[] = `getFileList -folder \"/Users/Shared/m341_temp\" -filespec \"checker1.png\"`;\n\t\t//Create checker map if it doesn't exist Mac\n\t\tint $sizeCheckerMapFound = `size $checkerMapFound`;\n\t\tif ($sizeCheckerMapFound == 0)\n\t\t{\n\t\t\tm341_checkerMap_renderCheckerStyle1();\n\t\t}\n\t}\n\telse\n\t{\n\t\tsysFile -makeDir \"C:/m341_temp\";\n\t\tstring $checkerMapFound[] = `getFileList -folder \"C:/m341_temp\" -filespec \"checker1.png\"`;\n\t\t//Create checker map if it doesn't exist PC\n\t\tint $sizeCheckerMapFound = `size $checkerMapFound`;\n\t\tif ($sizeCheckerMapFound == 0)\n\t\t{\n\t\t\tm341_checkerMap_renderCheckerStyle1();\n\t\t}\t\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Checker map image toggle 2\nglobal proc m341_checkerMap_toggleChecker2()\n{\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 0;\n\t$m341_clickButton2 = 1;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker1.png\";\n\t}\n\tif ($m341_clickButton2 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker2.png\";\n\t}\n\tm341_checkerMap_toggleOnOff();\n\t\n\t\n\t//Render checker map if nothing exists first time to prevent no checker map showing up\n\tstring $mayaVersionMac = `about -mac`;\n\tif ($mayaVersionMac == 1)\n\t{\n\t\tsysFile -makeDir \"/Users/Shared/m341_temp\";\n\t\tstring $checkerMapFound[] = `getFileList -folder \"/Users/Shared/m341_temp\" -filespec \"checker2.png\"`;\n\t\t//Create checker map if it doesn't exist Mac\n\t\tint $sizeCheckerMapFound = `size $checkerMapFound`;\n\t\tif ($sizeCheckerMapFound == 0)\n\t\t{\n\t\t\tm341_checkerMap_renderCheckerStyle2Map2();\n\t\t}\n\t}\n\telse\n\t{\n\t\tsysFile -makeDir \"C:/m341_temp\";\n\t\tstring $checkerMapFound[] = `getFileList -folder \"C:/m341_temp\" -filespec \"checker2.png\"`;\n\t\t//Create checker map if it doesn't exist PC\n\t\tint $sizeCheckerMapFound = `size $checkerMapFound`;\n\t\tif ($sizeCheckerMapFound == 0)\n\t\t{\n\t\t\tm341_checkerMap_renderCheckerStyle2Map2();\n\t\t}\t\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Custom checker density up\nglobal proc m341_checkerMap_plus()\n{\n\t$texelUpSelect = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\t//Find materials assigned to mesh\n\t\thyperShade -smn \"\";\n\t\tstring $materials[] = `ls -sl -fl`;\n\t\t\n\t\tfor ($item in $materials)\n\t\t{\n\t\t\tselect $item;\n\t\t\n\t\t\t//Find file node\n\t\t\tstring $fileNode[] = `listConnections -type \"file\"`;\n\t\t\t//Remove dupe names\n\t\t\tstring $fileNode_removeDupes[] = stringArrayRemoveDuplicates($fileNode);\n\t\t\tselect $fileNode_removeDupes;\n\t\t\t\n\t\t\t//If file node exists\n\t\t\tstring $fileNodeFound[] = `ls -sl`;\n\t\t\tint $sizeFileNodeFound = `size $fileNodeFound`;\n\t\t\tif ($sizeFileNodeFound > 0)\n\t\t\t{\n\t\t\t\t//Find place 2d node\n\t\t\t\tstring $p2dNode[] = `listConnections -type \"place2dTexture\"`;\n\t\t\t\t//Remove dupe names\n\t\t\t\tstring $p2dNode_removeDupes[] = stringArrayRemoveDuplicates($p2dNode);\n\t\t\t\tselect $p2dNode_removeDupes;\n\t\t\t\t\n\t\t\t\t//If p2d node exists\n\t\t\t\tstring $p2dNodeFound[] = `ls -sl`;\n\t\t\t\tint $sizeP2dNodeFound = `size $p2dNodeFound`;\n\t\t\t\tif ($sizeP2dNodeFound > 0)\n\t\t\t\t{\n\t\t\t\t\t//Set current p2d node to tile\n\t\t\t\t\tstring $place2DNode = $p2dNode_removeDupes[0];\n\t\t\t\t\t\n\t\t\t\t\t//Tile current found material down\n\t\t\t\t\tfloat $getValueRepeatU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\t\t\t\tfloat $incrementP2DU = $getValueRepeatU += 0.5;\n\t\t\t\t\tsetAttr ($place2DNode + \".repeatU \") $incrementP2DU;\n\t\t\t\t\t//global float $m341_checkerMap_incrementP2DU;\n\t\t\t\t\t//$m341_checkerMap_incrementP2DU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\t\n\t\t\t\t\tfloat $getValueRepeatV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\t\t\t\tfloat $incrementP2DV = $getValueRepeatV += 0.5;\n\t\t\t\t\tsetAttr ($place2DNode + \".repeatV \") $incrementP2DV;\n\t\t\t\t\t//global float $m341_checkerMap_incrementP2DV;\n\t\t\t\t\t//$m341_checkerMap_incrementP2DV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\t\t\t\t\n\t\t\t\t\tprint (\"Textures tiled \" + $incrementP2DU + \"\\n\");\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\telse\n\t{\n\t\t$place2DNode = \"ma_checker_map_p2d\";\n\t\n\t\t//tile UV checker material up\n\t\tfloat $getValueRepeatU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\tfloat $incrementP2DU = $getValueRepeatU += 0.5;\n\t\tsetAttr ($place2DNode + \".repeatU \") $incrementP2DU;\n\t\tglobal float $m341_checkerMap_incrementP2DU;\n\t\t$m341_checkerMap_incrementP2DU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\t\n\t\tfloat $getValueRepeatV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\tfloat $incrementP2DV = $getValueRepeatV += 0.5;\n\t\tsetAttr ($place2DNode + \".repeatV \") $incrementP2DV;\n\t\tglobal float $m341_checkerMap_incrementP2DV;\n\t\t$m341_checkerMap_incrementP2DV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\t\n\t\tprint (\"Custom checker map tiled \" + $incrementP2DU + \"\\n\");\n\t}\n\tselect $texelUpSelect;\n}\n\n\n//***********************************************************************************************************************************************************\n//Spin Left\nglobal proc m341_checkerMap_spinLeft()\n{\n\tstring $obj[] = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\t//Find materials assigned to mesh\n\t\thyperShade -smn \"\";\n\t\tstring $materials[] = `ls -sl -fl`;\n\t\n\t\tfor ($item in $materials)\n\t\t{\n\t\t\tselect $item;\n\t\t\n\t\t\t//Find file node\n\t\t\tstring $fileNode[] = `listConnections -type \"file\"`;\n\t\t\t//Remove dupe names\n\t\t\tstring $fileNode_removeDupes[] = stringArrayRemoveDuplicates($fileNode);\n\t\t\tselect $fileNode_removeDupes;\n\t\t\t\n\t\t\t//If file node exists\n\t\t\tstring $fileNodeFound[] = `ls -sl`;\n\t\t\tint $sizeFileNodeFound = `size $fileNodeFound`;\n\t\t\tif ($sizeFileNodeFound > 0)\n\t\t\t{\n\t\t\t\t//Find place 2d node\n\t\t\t\tstring $p2dNode[] = `listConnections -type \"place2dTexture\"`;\n\t\t\t\t//Remove dupe names\n\t\t\t\tstring $p2dNode_removeDupes[] = stringArrayRemoveDuplicates($p2dNode);\n\t\t\t\tselect $p2dNode_removeDupes;\n\t\t\t\t\n\t\t\t\t//If p2d node exists\n\t\t\t\tstring $p2dNodeFound[] = `ls -sl`;\n\t\t\t\tint $sizeP2dNodeFound = `size $p2dNodeFound`;\n\t\t\t\tif ($sizeP2dNodeFound > 0)\n\t\t\t\t{\n\t\t\t\t\t//Set current p2d node\n\t\t\t\t\tstring $place2DNode = $p2dNode_removeDupes[0];\n\t\t\t\t\t\n\t\t\t\t\t//Rotate current material left 45\n\t\t\t\t\tfloat $getValueRotateUV = `getAttr ($place2DNode + \".rotateUV\")`;\n\t\t\t\t\tfloat $incrementP2DR = $getValueRotateUV -= 45;\n\t\t\t\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t\t\t\t\n\t\t\t\t\t//Reset at 360 degrees\n\t\t\t\t\tif ($incrementP2DR == -360)\n\t\t\t\t\t{\n\t\t\t\t\t\t$incrementP2DR = 0;\n\t\t\t\t\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\tprint (\"Textures rotated \" + $incrementP2DR + \"\\n\");\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\t\n\telse\n\t{\n\t\t$place2DNode = \"ma_checker_map_p2d\";\n\t\t\n\t\t//Rotate UV checker material left\n\t\tfloat $getValueRotateUV = `getAttr ($place2DNode + \".rotateUV\")`;\n\t\tfloat $incrementP2DR = $getValueRotateUV -= 45;\n\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t\n\t\t//Reset at 360 degrees\n\t\tif ($incrementP2DR == -360)\n\t\t{\n\t\t\t$incrementP2DR = 0;\n\t\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t}\n\t\t\n\t\tglobal float $m341_checkerMap_incrementP2DR;\n\t\t$m341_checkerMap_incrementP2DR = `getAttr ($place2DNode + \".rotateUV\")`;\n\t\t\n\t\tprint (\"Custom checker map rotated \" + $incrementP2DR + \"\\n\");\n\t}\n\tselect $obj;\n}\n\n\n//***********************************************************************************************************************************************************\n//Spin Right\nglobal proc m341_checkerMap_spinRight()\n{\n\tstring $obj[] = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\t//Find materials assigned to mesh\n\t\thyperShade -smn \"\";\n\t\tstring $materials[] = `ls -sl -fl`;\n\t\t\n\t\tfor ($item in $materials)\n\t\t{\n\t\t\tselect $item;\n\t\t\n\t\t\t//Find file node\n\t\t\tstring $fileNode[] = `listConnections -type \"file\"`;\n\t\t\t//Remove dupe names\n\t\t\tstring $fileNode_removeDupes[] = stringArrayRemoveDuplicates($fileNode);\n\t\t\tselect $fileNode_removeDupes;\n\t\t\t\n\t\t\t//If file node exists\n\t\t\tstring $fileNodeFound[] = `ls -sl`;\n\t\t\tint $sizeFileNodeFound = `size $fileNodeFound`;\n\t\t\tif ($sizeFileNodeFound > 0)\n\t\t\t{\n\t\t\t\t//Find place 2d node\n\t\t\t\tstring $p2dNode[] = `listConnections -type \"place2dTexture\"`;\n\t\t\t\t//Remove dupe names\n\t\t\t\tstring $p2dNode_removeDupes[] = stringArrayRemoveDuplicates($p2dNode);\n\t\t\t\tselect $p2dNode_removeDupes;\n\t\t\t\t\n\t\t\t\t//If p2d node exists\n\t\t\t\tstring $p2dNodeFound[] = `ls -sl`;\n\t\t\t\tint $sizeP2dNodeFound = `size $p2dNodeFound`;\n\t\t\t\tif ($sizeP2dNodeFound > 0)\n\t\t\t\t{\n\t\t\t\t\t//Set current p2d node\n\t\t\t\t\tstring $place2DNode = $p2dNode_removeDupes[0];\n\t\t\t\t\t\n\t\t\t\t\t//Rotate current material left 45\n\t\t\t\t\tfloat $getValueRotateUV = `getAttr ($place2DNode + \".rotateUV\")`;\n\t\t\t\t\tfloat $incrementP2DR = $getValueRotateUV += 45;\n\t\t\t\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t\t\t\t\n\t\t\t\t\t//Reset at 360 degrees\n\t\t\t\t\tif ($incrementP2DR == 360)\n\t\t\t\t\t{\n\t\t\t\t\t\t$incrementP2DR = 0;\n\t\t\t\t\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\tprint (\"Textures rotated \" + $incrementP2DR + \"\\n\");\n\t\t\t\t}\n\t\t\t}\n\t\t}\t\n\t}\n\t\n\telse\n\t{\n\t\t$place2DNode = \"ma_checker_map_p2d\";\n\t\t\n\t\t//Rotate UV checker material right\n\t\tfloat $getValueRotateUV = `getAttr ($place2DNode + \".rotateUV\")`;\n\t\tfloat $incrementP2DR = $getValueRotateUV += 45;\n\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t\n\t\t//Reset at 360 degrees\n\t\tif ($incrementP2DR == 360)\n\t\t{\n\t\t\t$incrementP2DR = 0;\n\t\t\tsetAttr ($place2DNode + \".rotateUV \") $incrementP2DR;\n\t\t}\n\t\t\n\t\tglobal float $m341_checkerMap_incrementP2DR;\n\t\t$m341_checkerMap_incrementP2DR = `getAttr ($place2DNode + \".rotateUV\")`;\n\t\t\n\t\tprint (\"Custom checker map rotated \" + $incrementP2DR + \"\\n\");\n\t}\n\n\tselect $obj;\n}\n\n\n//***********************************************************************************************************************************************************\n//Custom checker density down\nglobal proc m341_checkerMap_minus()\n{\n\t$texelDownSelect = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\t//Find materials assigned to mesh\n\t\thyperShade -smn \"\";\n\t\tstring $materials[] = `ls -sl -fl`;\n\t\t\n\t\tfor ($item in $materials)\n\t\t{\n\t\t\tselect $item;\n\t\t\n\t\t\t//Find file node\n\t\t\tstring $fileNode[] = `listConnections -type \"file\"`;\n\t\t\t//Remove dupe names\n\t\t\tstring $fileNode_removeDupes[] = stringArrayRemoveDuplicates($fileNode);\n\t\t\tselect $fileNode_removeDupes;\n\t\t\t\n\t\t\t//If file node exists\n\t\t\tstring $fileNodeFound[] = `ls -sl`;\n\t\t\tint $sizeFileNodeFound = `size $fileNodeFound`;\n\t\t\tif ($sizeFileNodeFound > 0)\n\t\t\t{\n\t\t\t\t//Find place 2d node\n\t\t\t\tstring $p2dNode[] = `listConnections -type \"place2dTexture\"`;\n\t\t\t\t//Remove dupe names\n\t\t\t\tstring $p2dNode_removeDupes[] = stringArrayRemoveDuplicates($p2dNode);\n\t\t\t\tselect $p2dNode_removeDupes;\n\t\t\t\t\n\t\t\t\t//If p2d node exists\n\t\t\t\tstring $p2dNodeFound[] = `ls -sl`;\n\t\t\t\tint $sizeP2dNodeFound = `size $p2dNodeFound`;\n\t\t\t\tif ($sizeP2dNodeFound > 0)\n\t\t\t\t{\n\t\t\t\t\t//Set current p2d node to tile\n\t\t\t\t\tstring $place2DNode = $p2dNode_removeDupes[0];\n\t\t\t\t\t\n\t\t\t\t\t//Tile current found material down\n\t\t\t\t\tfloat $getValueRepeatU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\t\t\t\tfloat $incrementP2DU = $getValueRepeatU -= 0.5;\n\t\t\t\t\tsetAttr ($place2DNode + \".repeatU \") $incrementP2DU;\n\t\t\t\t\t//global float $m341_checkerMap_incrementP2DU;\n\t\t\t\t\t//$m341_checkerMap_incrementP2DU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\t\n\t\t\t\t\tfloat $getValueRepeatV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\t\t\t\tfloat $incrementP2DV = $getValueRepeatV -= 0.5;\n\t\t\t\t\tsetAttr ($place2DNode + \".repeatV \") $incrementP2DV;\n\t\t\t\t\t//global float $m341_checkerMap_incrementP2DV;\n\t\t\t\t\t//$m341_checkerMap_incrementP2DV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\t\t\t\t\n\t\t\t\t\tprint (\"Textures tiled \" + $incrementP2DU + \"\\n\");\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\telse\n\t{\n\t\t$place2DNode = \"ma_checker_map_p2d\";\n\t\t\n\t\t//tile UV checker material down\n\t\tfloat $getValueRepeatU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\tfloat $incrementP2DU = $getValueRepeatU -= 0.5;\n\t\tsetAttr ($place2DNode + \".repeatU \") $incrementP2DU;\n\t\tglobal float $m341_checkerMap_incrementP2DU;\n\t\t$m341_checkerMap_incrementP2DU = `getAttr ($place2DNode + \".repeatU\")`;\n\t\t\n\t\tfloat $getValueRepeatV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\tfloat $incrementP2DV = $getValueRepeatV -= 0.5;\n\t\tsetAttr ($place2DNode + \".repeatV \") $incrementP2DV;\n\t\tglobal float $m341_checkerMap_incrementP2DV;\n\t\t$m341_checkerMap_incrementP2DV = `getAttr ($place2DNode + \".repeatV\")`;\n\t\t\n\t\tprint (\"Custom checker map tiled \" + $incrementP2DU + \"\\n\");\n\t}\n\tselect $texelDownSelect;\n}\n\n\n//***********************************************************************************************************************************************************\n//Base colour mode\nglobal proc m341_checkerMap_baseColour()\n{\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\terror \"Turn on checker map first\";\n\t}\n\n\telse\n\t{\n\tglobal int $maToggleCheckerBaseColour;\n\t$maToggleCheckerBaseColour = !$maToggleCheckerBaseColour;\n\t$baseColourSelect = `ls -sl`;\n\n\t\tif ($maToggleCheckerBaseColour == 1)\n\t\t{\n\t\t\tsoloMaterial -node \"ma_checker_map_f*\";\n\t\t\t//colorManagementPrefs -edit -cmEnabled 0;\n\t\t\tselect -cl;\n\t\t\tglobal int $maRememberBaseColour;\n\t\t\t$maRememberBaseColour = 1;\n\t\t\tprint \"Checker map base color On\\n\";\t\n\t\t}\n\t\t\n\t\telse if ($maToggleCheckerBaseColour == 0)\n\t\t{\n\t\t\tsoloMaterial -unsolo;\n\t\t\t//colorManagementPrefs -edit -cmEnabled 1;\n\t\t\tselect -cl;\n\t\t\tglobal int $maRememberBaseColour;\n\t\t\t$maRememberBaseColour = 0;\n\t\t\tprint \"Checker map base color Off\\n\";\t\n\t\t}\n\tselect \t$baseColourSelect;\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Render checker map style 1\nglobal proc m341_checkerMap_renderCheckerStyle1()\n{\n\t//Check if Maya LT show window explaining button won't work in LT\n\tstring $maCurrentMayaVersion = `about -product`;\n\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t{\n\t\t$warningLTWindow = `confirmDialog -title \"ERROR\" -message \"Unfortunately Maya LT doesn't come with the required nodes to create the checker maps. Using your own custom checker map will work fine, or you can download the checker maps seen in the Youtube video here \\n\\nhttps://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing\" -button \"OK\"`;\n\t\terror \"Maya LT doesn't come with the required nodes to create the checker maps\\n\";\n\t}\n\t\n\t//Force checker map one image flag so correct texture is displayed after render is complete\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 1;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker1.png\";\n\t}\n\t\n\t\n\t//Switch to Maya software render\n\tsetCurrentRenderer \"mayaSoftware\";\n\tsetAttr hardwareRenderingGlobals.renderMode 1;\n\t\n\t\n\t//Remember user selection\n\t$maCreateCheckRememberUserSelection = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 1)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\t\n\t\n\t//Create checker material style 1\n\tstring $searchSceneForCheckerMatStyle_1[] = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_1)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Create plane\n\tpolyPlane -name \"maCheckerMapPlaneRenderTemp_1001\" -w 2048 -h 2048 -sx 1 -sy 1 -ax 0 1 0 -cuv 2 -ch 1; objectMoveCommand;\n\tmove -rpr -1024 0 -1024 maCheckerMapPlaneRenderTemp_1001.scalePivot maCheckerMapPlaneRenderTemp_1001.rotatePivot;\n\tmove -rpr 0 0 0;\n\t$maRenderTexturePlane = `ls -sl`;\n\t\n\t//Create material\n\tshadingNode -asShader surfaceShader -name ma_create_checker_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_SG;\n\tconnectAttr -f ma_create_checker_m.outColor ma_create_checker_SG.surfaceShader;\n\t\n\t//Create layer texture\n\tshadingNode -asTexture layeredTexture;\n\trename \"ma_create_checker_f\";\n\t$maCreateCheck_File = `ls -sl`;\n\tconnectAttr -f ma_create_checker_f.outColor ma_create_checker_m.outColor;\n\t\n\t//Apply material to plane\n\tselect $maRenderTexturePlane;\n\tsets -e -forceElement ma_create_checker_SG;\n\t\n\t//Create black grid node\n\tshadingNode -asTexture grid -name ma_create_checker_GRID;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_grid_P2D;\n\tconnectAttr ma_create_checker_grid_P2D.outUV ma_create_checker_GRID.uv;\n\tsetAttr \"ma_create_checker_grid_P2D.repeatU\" 64;\n\tsetAttr \"ma_create_checker_grid_P2D.repeatV\" 64;\n\tsetAttr \"ma_create_checker_GRID.lineColor\" -type double3 0 0 0 ;\n\tsetAttr \"ma_create_checker_GRID.fillerColor\" -type double3 1 1 1 ;\n\tconnectAttr -force ma_create_checker_GRID.outColor ma_create_checker_f.inputs[0].color;\n\tsetAttr \"ma_create_checker_f.inputs[0].blendMode\" 6;\n\t\n\t//Create white grid node\n\tshadingNode -asTexture grid -name ma_create_checker_GRID2;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_grid_P2D2;\n\tconnectAttr ma_create_checker_grid_P2D2.outUV ma_create_checker_GRID2.uv;\n\tsetAttr \"ma_create_checker_grid_P2D2.repeatV\" 128;\n\tsetAttr \"ma_create_checker_grid_P2D2.repeatU\" 128;\n\tsetAttr \"ma_create_checker_GRID2.uWidth\" 0.06;\n\tsetAttr \"ma_create_checker_GRID2.vWidth\" 0.06;\n\tsetAttr \"ma_create_checker_f.inputs[1].alpha\" 0.2;\n\tconnectAttr -force ma_create_checker_GRID2.outColor ma_create_checker_f.inputs[1].color;\n\tsetAttr \"ma_create_checker_f.inputs[1].blendMode\" 4;\n\t\n\t//Create ramp node\n\tshadingNode -asTexture ramp -name ma_create_checker_RAMP;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_ramp_P2D;\n\tconnectAttr ma_create_checker_ramp_P2D.outUV ma_create_checker_RAMP.uv;\n\tsetAttr \"ma_create_checker_ramp_P2D.repeatV\" 8;\n\tsetAttr \"ma_create_checker_ramp_P2D.repeatU\" 8;\n\tsetAttr \"ma_create_checker_ramp_P2D.rotateFrame\" 90;\n\tsetAttr \"ma_create_checker_RAMP.type\" 2;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[0].color\" -type double3 0.235294 0.278431 0.686275 ;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[1].color\" -type double3 0.803922 0.423529 0.423529 ;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[1].position\" 1;\n\tconnectAttr -force ma_create_checker_RAMP.outColor ma_create_checker_f.inputs[2].color;\n\t\n\t//Create material for numbers 1\n\tshadingNode -asShader surfaceShader -name ma_create_checker_numbers1_m;\n\t$maCreateCheckNumb1_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_numbers1_SG;\n\tconnectAttr -f ma_create_checker_numbers1_m.outColor ma_create_checker_numbers1_SG.surfaceShader;\n\t//Create ramp node\n\tshadingNode -asTexture ramp -name ma_create_checker_numbers1_RAMP;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_numbers1_ramp_P2D;\n\tconnectAttr ma_create_checker_numbers1_ramp_P2D.outUV ma_create_checker_numbers1_RAMP.uv;\n\tconnectAttr -f ma_create_checker_numbers1_RAMP.outColor ma_create_checker_numbers1_m.outColor;\n\tsetAttr \"ma_create_checker_numbers1_RAMP.colorEntryList[0].color\" -type double3 0.972549 1 0.229999;\n\tsetAttr \"ma_create_checker_numbers1_RAMP.colorEntryList[1].color\" -type double3 1 1 0.984329; \n\tsetAttr \"ma_create_checker_numbers1_RAMP.colorEntryList[1].position\" 1;\n\t\n\t//Create material for numbers 2\n\tshadingNode -asShader surfaceShader -name ma_create_checker_numbers2_m;\n\t$maCreateCheckNumb2_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_numbers2_SG;\n\tconnectAttr -f ma_create_checker_numbers2_m.outColor ma_create_checker_numbers2_SG.surfaceShader;\n\t//Create ramp node\n\tshadingNode -asTexture ramp -name ma_create_checker_numbers2_RAMP;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_numbers2_ramp_P2D;\n\tconnectAttr ma_create_checker_numbers2_ramp_P2D.outUV ma_create_checker_numbers2_RAMP.uv;\n\tconnectAttr -f ma_create_checker_numbers2_RAMP.outColor ma_create_checker_numbers2_m.outColor;\n\tsetAttr \"ma_create_checker_numbers2_RAMP.colorEntryList[0].color\" -type double3 0.0 0.0 0.0;\n\tsetAttr \"