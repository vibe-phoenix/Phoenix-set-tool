75841 -p 248.492859 2.5 20.550846 -p 248.536621 2.5 19.80072 -p 248.485916 2.5 19.027622 -p 248.333817 2.5 18.289196 -p 248.080307 2.5 17.585436 -p 247.725388 2.5 16.916344 -p 247.267349 2.5 16.296654 -p 246.704422 2.5 15.7411 -p 246.036636 2.5 15.249681 -p 245.263962 2.5 14.822399 -p 246.345612 2.5 13.976501 -p 247.094437 2.5 13.102867 -p 247.434189 2.5 12.495312 -p 247.676865 2.5 11.865221 -p 247.822464 2.5 11.212597 -p 247.871002 2.5 10.537437 -p 247.840561 2.5 9.960649 -p 247.749222 2.5 9.408995 -p 247.597015 2.5 8.882475 -p 247.383911 2.5 8.38109 -p 246.775055 2.5 7.453722 -p 245.922653 2.5 6.62689 -p 245.402313 2.5 6.262877 -p 244.815445 2.5 5.947399 -p 244.162064 2.5 5.680456 -p 243.442169 2.5 5.462048 -p 242.655746 2.5 5.292173 -p 241.802811 2.5 5.170835 -p 239.897369 2.5 5.073767;\n\t\n\t//Select all numbers and combine them\n\tselect \"maCreateCheckNumb*\";\n\tpolyUnite -name \"maCreateCheckCombinedNumb\";\n\tDeleteHistory;\n\t\n\t//Apply material\n\t//sets -e -forceElement ma_create_checker_numbers2_SG;\n\t\n\t//Duplicate and move assets around\n\tduplicate -rr;\n\tmove -rpr -x 256;\n\tduplicate -rr;\n\tmove -rpr -x 512;\n\tduplicate -rr;\n\tmove -rpr -x 768 ;\n\tduplicate -rr;\n\tmove -rpr -x 1024;\n\tduplicate -rr;\n\tmove -rpr -x 1280;\n\tduplicate -rr;\n\tmove -rpr -x 1536;\n\tduplicate -rr;\n\tmove -rpr -x 1792;\n\tselect \"maCreateCheckCombinedNumb*\";\n\tpolyUnite -name \"maCreateCheckCombinedNumb\";\n\tDeleteHistory;\n\t\n\t//Apply material, for some reason it has to be here for Maya 2024 to work\n\tsets -e -forceElement ma_create_checker_numbers2_SG;\n\t\n\t//Duplicate and apply correct material to each row\n\tduplicate -rr;\n\tmove -rpr -z 32;\n\tsets -e -forceElement ma_create_checker_numbers1_SG;\n\tduplicate -rr;\n\tmove -rpr -z 64;\n\tsets -e -forceElement ma_create_checker_numbers2_SG;\n\tduplicate -rr;\n\tmove -rpr -z 96;\n\tsets -e -forceElement ma_create_checker_numbers1_SG;\n\tduplicate -rr;\n\tmove -rpr -z 128;\n\tsets -e -forceElement ma_create_checker_numbers2_SG;\n\tduplicate -rr;\n\tmove -rpr -z 160;\n\tsets -e -forceElement ma_create_checker_numbers1_SG;\n\tduplicate -rr;\n\tmove -rpr -z 192;\n\tsets -e -forceElement ma_create_checker_numbers2_SG;\n\tduplicate -rr;\n\tmove -rpr -z 224;\n\tsets -e -forceElement ma_create_checker_numbers1_SG;\n\tselect \"maCreateCheckCombinedNumb*\";\n\tpolyUnite -name \"maCreateCheckCombinedNumb\";\n\tDeleteHistory;\n\t\n\t//Planar map horizontal section\n\tselect \"maCreateCheckCombinedNumb*\";\n\tConvertSelectionToFaces;\n\tpolyProjection -ch 1 -type Planar -ibd on -md y;\n\tselect \"maCreateCheckCombinedNumb*\";\n\tDeleteHistory;\n\t\n\t//Duplicate the rest of it\n\tduplicate -rr;\n\tmove -rpr -z 256;\n\tduplicate -rr;\n\tmove -rpr -z 512;\n\tduplicate -rr;\n\tmove -rpr -z 768;\n\tduplicate -rr;\n\tmove -rpr -z 1024;\n\tduplicate -rr;\n\tmove -rpr -z 1280;\n\tduplicate -rr;\n\tmove -rpr -z 1536;\n\tduplicate -rr;\n\tmove -rpr -z 1792;\n\tselect \"maCreateCheckCombinedNumb*\";\n\tpolyUnite -name \"maCreateCheckCombinedNumb\";\n\tDeleteHistory;\n\t$maRenderTexturePlane2 = `ls -sl`;\n\t\n\t\n\t//Position the camera and adjust settings\n\tcamera -e -lockTransform 1 perspShape; \n\tselect $maRenderTexturePlane; \n\tsetFocus modelPanel1;\n\n\t//Only works when this code is in a button won't work from script editor\n\t//evalDeferred \"viewFit topShape\";\n\tsetAttr \"top.translateZ\" 1024;\n\tsetAttr \"top.translateX\" 1024;\n\t\n\t//FrameSelectedWithoutChildren;\n\t//fitPanel -selectedNoChildren;\n\tsetAttr \"topShape.orthographicWidth\" 2048;\n\tcamera -e -lockTransform 0 perspShape; \n\t\n\t//Set the render globals settings\n\t//select -r defaultRenderGlobals;\n\tsetAttr \"defaultRenderGlobals.imageFormat\" 32;\n\tsetAttr \"topShape.mask\" 0;\n\tsetAttr \"defaultResolution.width\" 2048;\n\tsetAttr \"defaultResolution.height\" 2048;\n\tsetAttr \"defaultResolution.deviceAspectRatio\" 1;\n\tsetAttr \"defaultRenderQuality.edgeAntiAliasing\" 1;\n\tsetAttr \"defaultRenderQuality.shadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.maxShadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.useMultiPixelFilter\" 0;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthX\" 2.2;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthY\" 2.2;\n\tsetAttr \"defaultRenderQuality.enableRaytracing\" 0;\n\tsetAttr \"defaultRenderGlobals.motionBlur\" 0;\n\t\n\t\n\t//Render the top down camera to a texture file\n\tselect $maRenderTexturePlane;\n\tselect -add $maRenderTexturePlane2;\n\tInvertSelection;\n\t$maRenderSelected = `ls -sl`;\n\tHideSelectedObjects;\n\tselect $maRenderTexturePlane;\n\tselect -add $maRenderTexturePlane2;\n\trenderWindowRenderCamera render renderView top;\n\t\t//Check if Mac and save file to correct location if so\n\t\tstring $maCurrentMayaVersionMac3 = `about -mac`;\n\t\tif($maCurrentMayaVersionMac3 == 1)\n\t\t{\n\t\t\trenderWindowSaveImageCallback \"renderView\" \"/Users/Shared/m341_temp/checker1\" \".png\";\n\t\t}\t\n\t\telse\n\t\t{\n\t\t\trenderWindowSaveImageCallback \"renderView\" \"c:/m341_temp/checker1\" \".png\";\n\t\t}\n\tselect $maRenderSelected;\n\tShowSelectedObjects;\n\tselect -clear;\n\t\n\t//Delete the render rig at the end\n\tdelete $maRenderTexturePlane;\n\tdelete $maRenderTexturePlane2;\n\t$searchSceneForCheckerMatStyle_1 = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_1)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Select user selection and print\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\tselect $maCreateCheckRememberUserSelection;\n\t//Set renderer to Arnold\n\tsetCurrentRenderer \"arnold\";\n\tsetAttr hardwareRenderingGlobals.renderMode 4;\n\t\n\tprint \"Created checker1.png Style 1\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Render checker map style 2\nglobal proc m341_checkerMap_renderCheckerStyle2()\n{\n\t//Check if Maya LT show window explaining button won't work in LT\n\tstring $maCurrentMayaVersion = `about -product`;\n\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t{\n\t\t$warningLTWindow = `confirmDialog -title \"ERROR\" -message \"Unfortunately Maya LT doesn't come with the required nodes to create the checker maps. Using your own custom checker map will work fine, or you can download the checker maps seen in the Youtube video here\\n\\nhttps://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing\" -button \"OK\"`;\n\t\terror \"Maya LT doesn't come with the required nodes to create the checker maps\\n\";\n\t}\n\t\n\t//Force checker map one image flag so correct texture is displayed after render is complete\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 1;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker1.png\";\n\t}\n\t\n\t//Switch to Maya software render\n\tsetCurrentRenderer \"mayaSoftware\";\n\tsetAttr hardwareRenderingGlobals.renderMode 1;\n\t\n\t//Remember user selection\n\t$maCreateCheckRememberUserSelection = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 1)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\t\n\t//Create checker material style 2\n\tstring $searchSceneForCheckerMatStyle_2[] = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_2)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Create plane\n\tpolyPlane -name \"maCheckerMapPlaneRenderTemp_1001\" -w 512 -h 512 -sx 1 -sy 1 -ax 0 1 0 -cuv 2 -ch 1; objectMoveCommand;\n\tmove -rpr -256 0 -256 maCheckerMapPlaneRenderTemp_1001.scalePivot maCheckerMapPlaneRenderTemp_1001.rotatePivot ;\n\tmove -rpr 0 0 0;\n\t$maRenderTexturePlane = `ls -sl`;\n\t\n\t//Create material\n\tshadingNode -asShader surfaceShader -name ma_create_checker_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_SG;\n\tconnectAttr -f ma_create_checker_m.outColor ma_create_checker_SG.surfaceShader;\n\t\n\t//Create layer texture\n\tshadingNode -asTexture layeredTexture;\n\trename \"ma_create_checker_f\";\n\t$maCreateCheck_File = `ls -sl`;\n\tconnectAttr -f ma_create_checker_f.outColor ma_create_checker_m.outColor;\n\t\n\t//Apply material to plane\n\tselect $maRenderTexturePlane;\n\tsets -e -forceElement ma_create_checker_SG;\n\t\n\t//Create black grid thin\n\tshadingNode -asTexture grid -name ma_create_checker_GRID;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_grid_P2D;\n\tconnectAttr ma_create_checker_grid_P2D.outUV ma_create_checker_GRID.uv;\n\tsetAttr \"ma_create_checker_grid_P2D.repeatU\" 32;\n\tsetAttr \"ma_create_checker_grid_P2D.repeatV\" 32;\n\tsetAttr \"ma_create_checker_GRID.uWidth\" 0.04;\n\tsetAttr \"ma_create_checker_GRID.vWidth\" 0.04;\n\tsetAttr \"ma_create_checker_GRID.lineColor\" -type double3 0.5 0.5 0.5 ;\n\tsetAttr \"ma_create_checker_GRID.fillerColor\" -type double3 1 1 1 ;\n\tconnectAttr -force ma_create_checker_GRID.outColor ma_create_checker_f.inputs[0].color;\n\tsetAttr \"ma_create_checker_f.inputs[0].blendMode\" 6;\n\t\n\t//Create black grid thick\n\tshadingNode -asTexture grid -name ma_create_checker_GRID2;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_grid_P2D2;\n\tconnectAttr ma_create_checker_grid_P2D2.outUV ma_create_checker_GRID2.uv;\n\tsetAttr \"ma_create_checker_grid_P2D2.repeatV\" 8;\n\tsetAttr \"ma_create_checker_grid_P2D2.repeatU\" 8;\n\tsetAttr \"ma_create_checker_GRID2.uWidth\" 0.02;\n\tsetAttr \"ma_create_checker_GRID2.vWidth\" 0.02;\n\tsetAttr \"ma_create_checker_GRID2.lineColor\" -type double3 0 0 0 ;\n\tsetAttr \"ma_create_checker_GRID2.fillerColor\" -type double3 1 1 1 ;\n\tconnectAttr -force ma_create_checker_GRID2.outColor ma_create_checker_f.inputs[1].color;\n\tsetAttr \"ma_create_checker_f.inputs[1].blendMode\" 6;\n\t\n\t//Create ramp node diagonal\n\tshadingNode -asTexture ramp -name ma_create_checker_RAMP;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_ramp_P2D;\n\tconnectAttr ma_create_checker_ramp_P2D.outUV ma_create_checker_RAMP.uv;\n\tsetAttr \"ma_create_checker_RAMP.type\" 3;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[0].color\" -type double3 1 0.298 0.267;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[0].position\" 0.635;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[1].color\" -type double3 0.2 1 0.2;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[1].position\" 1;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[2].color\" -type double3 0.2 1 0.2;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[2].position\" 0;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[3].color\" -type double3 0.2 0.6 1;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[3].position\" 0.2;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[4].color\" -type double3 0.517647 0.454902 1;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[4].position\" 0.4;\n\t\n\tconnectAttr -force ma_create_checker_RAMP.outColor ma_create_checker_f.inputs[2].color;\n\tsetAttr \"ma_create_checker_f.inputs[2].blendMode\" 6;\n\t\n\t//Create checker node\n\tshadingNode -asTexture checker -name ma_create_checker2_CHECKER;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker2_P2D;\n\tconnectAttr ma_create_checker2_P2D.outUV ma_create_checker2_CHECKER.uv;\n\tsetAttr \"ma_create_checker2_P2D.repeatU\" 4;\n\tsetAttr \"ma_create_checker2_P2D.repeatV\" 4;\n\tsetAttr \"ma_create_checker2_CHECKER.color2\" -type double3 0.7 0.7 0.7;\n\tconnectAttr -force ma_create_checker2_CHECKER.outColor ma_create_checker_f.inputs[3].color;\n\t\n\t//Create material for numbers 1\n\tshadingNode -asShader surfaceShader -name ma_create_checker_numbersS2_m;\n\t$maCreateCheckNumb1_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_numbersS2_SG;\n\tconnectAttr -f ma_create_checker_numbersS2_m.outColor ma_create_checker_numbersS2_SG.surfaceShader;\n\tsetAttr \"ma_create_checker_numbersS2_m.outColor\" -type double3 1 1 1 ;\n\t\n\t//Create font polygon numbers\n\t//1\n\tpolyCreateFacet -name \"maCreateCheckNumbOne\" -ch on -tx 1 -s 1 -p 40.230625 2.5 25.693203 -p 37.426682 2.5 25.693203 -p 37.130272 2.5 26.244423 -p 36.781857 2.5 26.749882 -p 36.381443 2.5 27.209579 -p 35.929024 2.5 27.623514 -p 35.402245 2.5 28.000528 -p 34.778744 2.5 28.349463 -p 34.058517 2.5 28.670315 -p 33.241562 2.5 28.963085 -p 33.241562 2.5 31.742071 -p 34.315926 2.5 31.375977 -p 35.192677 2.5 30.993242 -p 35.98415 2.5 30.541864 -p 36.802658 2.5 29.969843 -p 36.802658 2.5 38.098789 -p 40.230625 2.5 38.098789;\n\t//2\n\tpolyCreateFacet -name \"maCreateCheckNumbTwo\" -ch on -tx 1 -s 1 -p 96.61113 2.5 29.587109 -p 100.005821 2.5 29.861679 -p 100.093437 2.5 29.384821 -p 100.214867 2.5 28.985968 -p 100.370094 2.5 28.665113 -p 100.55912 2.5 28.422266 -p 100.779861 2.5 28.243898 -p 101.030258 2.5 28.116493 -p 101.31028 2.5 28.040051 -p 101.619957 2.5 28.01457 -p 101.918709 2.5 28.03927 -p 102.190941 2.5 28.113373 -p 102.436646 2.5 28.236877 -p 102.65583 2.5 28.409784 -p 102.836029 2.5 28.617531 -p 102.964729 2.5 28.845562 -p 103.041946 2.5 29.093872 -p 103.067696 2.5 29.362459 -p 103.041695 2.5 29.624031 -p 102.963692 2.5 29.892879 -p 102.833687 2.5 30.169012 -p 102.65168 2.5 30.452423 -p 102.376587 2.5 30.772755 -p 101.967331 2.5 31.159649 -p 100.74633 2.5 32.133125 -p 99.624382 2.5 33.005978 -p 98.696404 2.5 33.819023 -p 97.962402 2.5 34.572273 -p 97.422356 2.5 35.265724 -p 97.023766 2.5 35.940449 -p 96.714096 2.5 36.637535 -p 96.493347 2.5 37.356979 -p 96.361519 2.5 38.098789 -p 106.528946 2.5 38.098789 -p 106.528946 2.5 35.336