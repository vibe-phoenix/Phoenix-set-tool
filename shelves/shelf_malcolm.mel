        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Increase Shelf Height Toolbox\n//***********************************************************************************************************************************************************\nglobal string $m341_shelfHeightVersion;\n$m341_shelfHeightVersion = \"shelfSizer v1.8\";\n\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_shelfSizer_help()\n{\n\tglobal string $m341_shelfHeightVersion;\n\tglobal string $m341_shelfSizer_HelpWindow;\n\n\tif (`window -exists $m341_shelfSizer_HelpWindow`)\n\t{\n\t\tglobal string $m341_shelfSizer_HelpWindow;\n\t\tdeleteUI $m341_shelfSizer_HelpWindow;\n\t}\n\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n\t$helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\t$m341_shelfSizer_HelpWindow = `window -title (\"Help \" + $m341_shelfHeightVersion) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 315`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SHOW SHELF TABS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Toggles shelf tabs visability on/off.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"FIT HEIGHT TO ICONS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Fits the vertical height of the shelf to the number of rows of icons in it.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"RESET HEIGHT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Resets the shelf height to default.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"INCREASE HEIGHT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Increases shelf height by 32, 10, or 1.\\n\\n\";\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"DECREASE HEIGHT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Decreases shelf height by 32, 10, or 1.\\n\\n\";\n\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/v_HKnCfBO-I?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/v_HKnCfBO-I?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_shelfSizer_HelpWindow;\n}\n\n//***********************************************************************************************************************************************************\n//Reset\nglobal proc m341_shelfSizer_Reset()\n{\n\t//Turn shelf tabs on to prevent tool from not working\n\tint $tabsVisible = `shelfTabLayout -q -tabsVisible ShelfLayout`;\n\tif ($tabsVisible == 0)\n\t{\n\t\tevalDeferred \"toggleShelfTabs\";\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\t\n\t\n\t//New reset\n\tlayout -e -height 32 MainShelfLayout;\n\tupdateShelfInitialSize(\"Shelf\" );\n\t\n\t\n\t//Create search text specific to this checkbox to use with global add/remove proc above\n\tglobal string $m341_shelfSizer_searchFor[];\n\t$m341_shelfSizer_searchFor = {\"/*m341_shelfSizer_shelfHeight*/\"};\n\t\n\t//Remove shelf height text from userSetup.mel using global variable at top of proc\n\tm341_shelfSizer_userSetupRemove();\n\t\n\t\n\tif ($tabsVisible == 0)\n\t{\n\t\tevalDeferred \"toggleShelfTabs\";\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\tprint \"Shelf height reset to default\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Shelf Tabs\nglobal proc m341_shelfSizer_shelfTabs()\n{\n\tevalDeferred \"toggleShelfTabs\";\n\tupdateShelfInitialSize(\"Shelf\" );\n\n\t//Print\n\tint $tabsVisible = `shelfTabLayout -q -tabsVisible ShelfLayout`;\n\tif ($tabsVisible == 0)\n\t{\n\t\tprint \"Shelf tabs on\\n\";\n\t}\n\telse\n\t{\n\t\tprint \"Shelf tabs off\\n\";\n\t}\n}\n\n\n\n\n//***********************************************************************************************************************************************************\n//Fit Shelf to Icons\nglobal proc m341_shelfSizer_fitHeight()\n{\n\t//Turn shelf tabs on to prevent tool from not working\n\tint $tabsVisible = `shelfTabLayout -q -tabsVisible ShelfLayout`;\n\tif ($tabsVisible == 0)\n\t{\n\t\tevalDeferred \"toggleShelfTabs\";\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\n\t//Create search text specific to this checkbox to use with global add/remove proc above\n\tglobal string $m341_shelfSizer_searchFor[];\n\t$m341_shelfSizer_searchFor = {\"/*m341_shelfSizer_shelfHeight*/\"};\n\n\n\t//Edit height\n\tglobal int $m341_shelfSizer_currentHeight;\n\t$m341_shelfSizer_currentHeight = `layout -q -height MainShelfLayout`;\n\t\n\t\n\t//Reset shelf to fix bug where it won't get smaller\n\tlayout -e -height 32 MainShelfLayout;\n\tupdateShelfInitialSize(\"Shelf\" );\n\n\t\n\t\n\t//Store height up here so script works below because of some annoying execution timing\n\tfloat $shelfHeight = `layout -q -height MainShelfLayout`;\n\t\n\t\n\t//Get current shelf name\n\tglobal string $gShelfTopLevel;\n\tstring $activeShelf = `tabLayout -q -st $gShelfTopLevel`;\n\n\t//Get shelf info\n\tfloat $iconWidth = `shelfLayout -q -cellWidth $activeShelf`;\n\tfloat $iconHeight = `shelfLayout -q -cellHeight $activeShelf`;\n\tfloat $iconCount = `shelfLayout -q -numberOfChildren $activeShelf`;\n\tfloat $shelfWidth = `shelfLayout -q -width $activeShelf`;\n\t//Hack to make it work for some reason?\t\n\t$shelfWidth = $shelfWidth + 2;\n\t\n\t//Check if the integer is odd\n\tif ($shelfWidth % 2 == 1)\n\t{\n\t    //print(\"The integer is odd\\n\");\n    \t//$shelfWidth = $shelfWidth + 3;\n\t\t//polySphere -r 1 -sx 20 -sy 20 -ax 0 1 0 -cuv 2 -ch 1; objectMoveCommand;\n\t}\n\t\n\t\n\t//Calculate total width\n\tfloat $totalWidth = $iconWidth * $iconCount;\n\t\n\t//Calculate height to expand by\n\tfloat $newShelfHeight = $totalWidth / $shelfWidth;\n\n\t//Get decimals only\n\tfloat $decimals = $newShelfHeight - floor($newShelfHeight);\n\n\t//Get row height\n\tfloat $rowHeight = ceil($newShelfHeight);\n\t$rowPercentage = $newShelfHeight / $rowHeight;\n\tif ($rowPercentage >= 0.97)\n\t{\n\t\t$newShelfHeight = ceil($newShelfHeight);\n\t\t$newShelfHeight = $newShelfHeight + 1;\n\t}\n\telse\n\t{\n\t\t$newShelfHeight = ceil($newShelfHeight);\n\t\t//print \"Original\";\n\t}\n\t\n\t\n\t//Calculate final height\n\tfloat $finalShelfHeight = $iconHeight * $newShelfHeight;\n\t\n\t\n\t//Fit shelf to icons\n\tfloat $applyHeight = $shelfHeight + $finalShelfHeight - $iconHeight;\n\t\n\t//Pass to variable to avoid rewriting old code\n\t$m341_shelfSizer_currentHeight = $applyHeight;\n\t\n\t//Adjust shelf\n\t//layout -edit -height $applyHeight MainShelfLayout;\n\t\n\n\tstring $mayaMac = `about -mac`;\n\tif($mayaMac == 1)\n\t{\n\t\t//Mac version\n\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t}\n\n\telse\n\t{\n\t\t//PC version\n\t\t//Find current custom interface scaling and DPI\n\t\tfloat $interfaceScaling = `mayaDpiSetting -q -scaleValue`;\n\t\tint $interfaceDPI = `mayaDpiSetting -q -systemDpi`;\n\t\t\n\t\tif ($interfaceScaling == 1.25)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.25;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 1.50 || $interfaceDPI == 144)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.50;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 2.0 || $interfaceDPI == 192)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 2.0;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\t\t\n\t}\n\t\n\t//Create a string array with text in it to add or remove from userSetup.mel\n\tglobal string $m341_shelfSizer_print_textArray[];\n\t$m341_shelfSizer_print_textArray = {\"/*m341_shelfSizer_shelfHeight*/\" + \" layout -e -height \" + $m341_shelfSizer_currentHeight + \" MainShelfLayout\\;\"};\n\t\n\t//Add/Remove shelf height text from userSetup.mel using global variable at top of proc\n\tm341_shelfSizer_userSetup();\n\t\n\t\n\t//Bring back tabs user setting\n\tif ($tabsVisible == 0)\n\t{\n\t\ttoggleShelfTabs;\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\tprint \"Shelf height fit to icons\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Increase 32\nglobal proc m341_shelfSizer_increase_32()\n{\n\t//Turn shelf tabs on to prevent tool from not working\n\tint $tabsVisible = `shelfTabLayout -q -tabsVisible ShelfLayout`;\n\tif ($tabsVisible == 0)\n\t{\n\t\tevalDeferred \"toggleShelfTabs\";\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\t\n\t//Create search text specific to this checkbox to use with global add/remove proc above\n\tglobal string $m341_shelfSizer_searchFor[];\n\t$m341_shelfSizer_searchFor = {\"/*m341_shelfSizer_shelfHeight*/\"};\n\n\n\t//Edit height\n\tglobal int $m341_shelfSizer_currentHeight;\n\t$m341_shelfSizer_currentHeight = `layout -q -height MainShelfLayout`;\n\t\n\t//Reset shelf to fix bug where it won't get smaller\n\tm341_shelfSizer_Reset();\n\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\n\tint $thirtyTwo = 32;\n\tstring $mayaMac = `about -mac`;\n\tif($mayaMac == 1)\n\t{\n\t\t//Mac version\n\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight + $thirtyTwo;\n\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t}\n\n\telse\n\t{\n\t\t//PC version\n\t\t//Find current custom interface scaling and DPI\n\t\tfloat $interfaceScaling = `mayaDpiSetting -q -scaleValue`;\n\t\tint $interfaceDPI = `mayaDpiSetting -q -systemDpi`;\t\n\t\n\t\tif ($interfaceScaling == 1.25)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.25;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight + $thirtyTwo;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;    \n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 1.50 || $interfaceDPI == 144)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.50;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight + $thirtyTwo;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 2.0 || $interfaceDPI == 192)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 2.0;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight + $thirtyTwo;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\t\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight + $thirtyTwo;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\t\t\t\n\t}\n\t\n\t//Create a string ar