1.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tduplicate -rr;\n\tmove -r -z 51.200005 ;\n\tselect \"maCreateCheckCombinedNumb*\";\n\tpolyUnite -name \"maCreateCheckCombinedNumb\";\n\tDeleteHistory;\n\t$maCreateCheckNumbCombined = `ls -sl`;\n\t\n\t//Position the camera and adjust settings, only works when this code is in a button\n\tcamera -e -lockTransform 1 perspShape; \n\tselect $maRenderTexturePlane;\n\tsetFocus modelPanel1;\n\t//viewFit;\n\tsetAttr \"top.translateZ\" 1024;\n\tsetAttr \"top.translateX\" 1024;\n\tselect -add $maCreateCheckNumbCombined;\n\tsetAttr \"topShape.orthographicWidth\" 2048;\n\tcamera -e -lockTransform 0 perspShape; \n\t\n\t//Set the render globals settings\n\t//select -r defaultRenderGlobals;\n\tsetAttr \"defaultRenderGlobals.imageFormat\" 32;\n\tsetAttr \"topShape.mask\" 0;\n\tsetAttr \"defaultResolution.width\" 2048;\n\tsetAttr \"defaultResolution.height\" 2048;\n\tsetAttr \"defaultResolution.deviceAspectRatio\" 1;\n\tsetAttr \"defaultRenderQuality.edgeAntiAliasing\" 1;\n\tsetAttr \"defaultRenderQuality.shadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.maxShadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.useMultiPixelFilter\" 0;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthX\" 2.2;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthY\" 2.2;\n\tsetAttr \"defaultRenderQuality.enableRaytracing\" 0;\n\tsetAttr \"defaultRenderGlobals.motionBlur\" 0;\n\t\n\t//Render the top down camera to a texture file\n\tselect $maRenderTexturePlane;\n\tselect -add $maCreateCheckNumbCombined;\n\tInvertSelection;\n\t$maRenderSelected = `ls -sl`;\n\tHideSelectedObjects;\n\tselect $maRenderTexturePlane;\n\tselect -add $maCreateCheckNumbCombined;\n\trenderWindowRenderCamera render renderView top;\n\t//Check if Mac and save file to correct location if so\n\tstring $maCurrentMayaVersionMac3 = `about -mac`;\n\tif($maCurrentMayaVersionMac3 == 1)\n\t{\n\t\trenderWindowSaveImageCallback \"renderView\" \"/Users/Shared/m341_temp/checker1\" \".png\";\n\t}\t\n\telse\n\t{\n\t\trenderWindowSaveImageCallback \"renderView\" \"c:/m341_temp/checker1\" \".png\";\n\t}\n\tselect $maRenderSelected;\n\tShowSelectedObjects;\n\tselect -clear;\n\t\n\t//Delete the render rig at the end\n\tdelete $maRenderTexturePlane;\n\tdelete $maCreateCheckNumbCombined;\n\t$searchSceneForCheckerMatStyle_3 = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_3)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Select user selection and print\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\tselect $maCreateCheckRememberUserSelection;\n\t//Set renderer to Arnold\n\tsetCurrentRenderer \"arnold\";\n\tsetAttr hardwareRenderingGlobals.renderMode 4;\n\t\n\tprint \"Created checker1.png Style 3\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Render checker map style 4\nglobal proc m341_checkerMap_renderCheckerStyle4()\n{\n\t//Check if Maya LT show window explaining button won't work in LT\n\tstring $maCurrentMayaVersion = `about -product`;\n\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t{\n\t\t$warningLTWindow = `confirmDialog -title \"ERROR\" -message \"Unfortunately Maya LT doesn't have the required nodes to create the checker maps. Using your own custom checker map will work fine, or you can download the checker maps seen in the Youtube video from here\\n\\nhttps://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing\" -button \"OK\"`;\n\t\terror \"Maya LT doesn't have the required nodes to create the checker maps\\n\";\n\t}\n\t\n\t//Force checker map one image flag so correct texture is displayed after render is complete\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 1;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker1.png\";\n\t}\n\t\n\t//Switch to Maya software render\n\tsetCurrentRenderer \"mayaSoftware\";\n\tsetAttr hardwareRenderingGlobals.renderMode 1;\n\t\n\t//Remember user selection\n\t$maCreateCheckRememberUserSelection = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 1)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\t\n\t//Create checker material style 4\n\tstring $searchSceneForCheckerMatStyle_4[] = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_4)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Create plane\n\tpolyPlane -name \"maCheckerMapPlaneRenderTemp_1001\" -w 256 -h 256 -sx 1 -sy 1 -ax 0 1 0 -cuv 2 -ch 1; objectMoveCommand;\n\tmove -rpr -128 0 -128 maCheckerMapPlaneRenderTemp_1001.scalePivot maCheckerMapPlaneRenderTemp_1001.rotatePivot ;\n\tmove -rpr 0 0 0;\n\t$maRenderTexturePlane = `ls -sl`;\n\t\n\t//Create material\n\tshadingNode -asShader surfaceShader -name ma_create_checker_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_SG;\n\tconnectAttr -f ma_create_checker_m.outColor ma_create_checker_SG.surfaceShader;\n\t\n\t//Create layer texture\n\tshadingNode -asTexture layeredTexture;\n\trename \"ma_create_checker_f\";\n\t$maCreateCheck_File = `ls -sl`;\n\tconnectAttr -f ma_create_checker_f.outColor ma_create_checker_m.outColor;\n\t\n\t//Apply material to plane\n\tselect $maRenderTexturePlane;\n\tsets -e -forceElement ma_create_checker_SG;\n\t\n\t//Create white grid thick\n\tshadingNode -asTexture grid -name ma_create_checker_GRID2;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_grid_P2D2;\n\tconnectAttr ma_create_checker_grid_P2D2.outUV ma_create_checker_GRID2.uv;\n\tsetAttr \"ma_create_checker_grid_P2D2.repeatV\" 5;\n\tsetAttr \"ma_create_checker_grid_P2D2.repeatU\" 5;\n\tsetAttr \"ma_create_checker_GRID2.uWidth\" 0.03;\n\tsetAttr \"ma_create_checker_GRID2.vWidth\" 0.03;\n\tsetAttr \"ma_create_checker_GRID2.lineColor\" -type double3 1 1 1 ;\n\tsetAttr \"ma_create_checker_GRID2.fillerColor\" -type double3 0 0 0 ;\n\tconnectAttr -force ma_create_checker_GRID2.outColor ma_create_checker_f.inputs[0].color;\n\tsetAttr \"ma_create_checker_f.inputs[0].blendMode\" 4;\n\t\n\t//Create black grid thin\n\tshadingNode -asTexture grid -name ma_create_checker_GRID;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_grid_P2D;\n\tconnectAttr ma_create_checker_grid_P2D.outUV ma_create_checker_GRID.uv;\n\tsetAttr \"ma_create_checker_grid_P2D.repeatU\" 10;\n\tsetAttr \"ma_create_checker_grid_P2D.repeatV\" 10;\n\tsetAttr \"ma_create_checker_GRID.uWidth\" 0.02;\n\tsetAttr \"ma_create_checker_GRID.vWidth\" 0.02;\n\tsetAttr \"ma_create_checker_GRID.lineColor\" -type double3 0.0 0.0 0.0 ;\n\tsetAttr \"ma_create_checker_GRID.fillerColor\" -type double3 1 1 1 ;\n\tconnectAttr -force ma_create_checker_GRID.outColor ma_create_checker_f.inputs[1].color;\n\tsetAttr \"ma_create_checker_f.inputs[1].blendMode\" 6;\n\t\n\t//Create ramp node 4 way 1\n\tshadingNode -asTexture ramp -name ma_create_checker_RAMP;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_ramp_P2D;\n\tconnectAttr ma_create_checker_ramp_P2D.outUV ma_create_checker_RAMP.uv;\n\tsetAttr \"ma_create_checker_RAMP.type\" 7;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[0].color\" -type double3 0 0.478213 0.831;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[0].position\" 0;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[1].color\" -type double3 1 1 1;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[1].position\" 0.721;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[2].color\" -type double3 0 0.439 0.141109;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[2].position\" 0.365;\n\t\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[3].color\" -type double3 0.992 0.858692 0;\n\tsetAttr \"ma_create_checker_RAMP.colorEntryList[3].position\" 1;\n\t\n\tconnectAttr -force ma_create_checker_RAMP.outColor ma_create_checker_f.inputs[2].color;\n\tsetAttr \"ma_create_checker_f.inputs[2].blendMode\" 0;\n\t\n\t//Dupe plane and move\n\tselect $maRenderTexturePlane;\n\tduplicate -rr;\n\tmove -rpr -x 256 ;\n\t$maRenderTexturePlane = `ls -sl`;\n\t\n\t\n\t//Create ramp node 4 way 2\n\tshadingNode -asShader surfaceShader -name ma_create_checker2_m;\n\t$maCreateCheck2_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker2_SG;\n\tconnectAttr -f ma_create_checker2_m.outColor ma_create_checker2_SG.surfaceShader;\n\t\n\t//Create layer texture\n\tshadingNode -asTexture layeredTexture;\n\trename \"ma_create_checker2_f\";\n\t$maCreateCheck_File = `ls -sl`;\n\tconnectAttr -f ma_create_checker2_f.outColor ma_create_checker2_m.outColor;\n\t\n\t//Plug in existing grids from above material\n\tconnectAttr -force ma_create_checker_GRID2.outColor ma_create_checker2_f.inputs[0].color;\n\tsetAttr \"ma_create_checker2_f.inputs[0].blendMode\" 4;\n\tconnectAttr -force ma_create_checker_GRID.outColor ma_create_checker2_f.inputs[1].color;\n\tsetAttr \"ma_create_checker2_f.inputs[1].blendMode\" 6;\n\t\n\t//4 way ramp with new colours\n\tshadingNode -asTexture ramp -name ma_create_checker2_RAMP;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_ramp2_P2D;\n\tconnectAttr ma_create_checker_ramp2_P2D.outUV ma_create_checker2_RAMP.uv;\n\tsetAttr \"ma_create_checker2_RAMP.type\" 7;\n\tsetAttr \"ma_create_checker2_RAMP.colorEntryList[0].color\" -type double3 1 1 1;\n\tsetAttr \"ma_create_checker2_RAMP.colorE