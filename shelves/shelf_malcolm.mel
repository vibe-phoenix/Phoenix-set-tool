s window\n\tprogressWindow -edit -endProgress;\n\t\n\t\n\t//Remove center from left and right lists\n\tstring $diff[] = stringArrayRemove($m341_udimPacker_objCenter, $m341_udimPacker_objRight);\n\t$m341_udimPacker_objRight = $diff;\n\n\t$diff = stringArrayRemove($m341_udimPacker_objCenter, $m341_udimPacker_objLeft);\n\t$m341_udimPacker_objLeft = $diff;\n\t\n\t//LEFT\n\tint $sizeObjLeft = `size $m341_udimPacker_objLeft`;\n\tif ($sizeObjLeft > 0)\n\t{\n\t\t//Select left objects and send to tiles\n\t\tselect $m341_udimPacker_objLeft;\n\t\t\n\t\t//initialize the progress bar\n\t\tint $sizeProgressBar = `size $m341_udimPacker_objLeft`;\n\t\tif ($sizeProgressBar > 0)\n\t\t{\n\t\t\tprogressWindow -title \"Progress Bar\" -isInterruptable true -status \"Finding Shells Left Y...\" -maxValue $sizeProgressBar;\n\t\t\t\n\t\t\t//Sort left list algorithm NEW\n\t\t\tglobal string $m341_udimPacker_temp[];\n\t\t\t$m341_udimPacker_temp = `ls -sl`;\n\t\t\tglobal string $m341_udimPacker_distArray[];\n\t\t\t$m341_udimPacker_distArray = {};\n\t\t\tint $counter = 0;\n\t\t\tint $counter2 = 0;\n\t\t\tint $sizeTemp = `size $m341_udimPacker_temp`;\n\t\t\n\t\t\tfor ($i = 0; $i < $sizeTemp; ++$i)\n\t\t\t{\n\t\t\n\t\t\t\t//Find highest number in $m341_udimPacker_temp array\n\t\t\t\tfloat $distCompare = 0;\n\t\t\t\tfor ($item in $m341_udimPacker_temp)\n\t\t\t\t{\n\t\t\t\t\tselect $m341_udimPacker_temp[$counter];\n\t\t\t\t\tfloat $dist[] = `objectCenter -global`;\n\t\t\t\t\tif ($dist[1] >= $distCompare)\n\t\t\t\t\t{\n\t\t\t\t\t\t$distCompare = $dist[1];\n\t\t\t\t\t\tstring $mesh[] = `ls -sl`;\n\t\t\t\t\t\tglobal string $m341_udimPacker_distArray[];\n\t\t\t\t\t\t$m341_udimPacker_distArray[$counter2] = $mesh[0];\n\t\t\t\t\t}\n\t\t\t\t\t$counter = $counter + 1;\n\t\t\t\t\tselect $m341_udimPacker_distArray[$counter2];\n\t\t\t\t\t\n\t\t\t\t\t//Cancel progress bar\n\t\t\t\t\t//Cancel progress bar\n\t\t\t\t\tif(`progressWindow -query -isCancelled`)\n\t\t\t\t\t{\n\t\t\t\t\t\tprogressWindow -edit -endProgre