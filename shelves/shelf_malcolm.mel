setAttr \"top.translateX\" 1024;\n\t//viewFit;\n\t//FrameSelectedWithoutChildren;\n\t//fitPanel -selectedNoChildren;\n\tsetAttr \"topShape.orthographicWidth\" 2048;\n\tcamera -e -lockTransform 0 perspShape; \n\t\n\t//Set the render globals settings\n\t//select -r defaultRenderGlobals;\n\tsetAttr \"defaultRenderGlobals.imageFormat\" 32;\n\tsetAttr \"topShape.mask\" 0;\n\tsetAttr \"defaultResolution.width\" 2048;\n\tsetAttr \"defaultResolution.height\" 2048;\n\tsetAttr \"defaultResolution.deviceAspectRatio\" 1;\n\tsetAttr \"defaultRenderQuality.edgeAntiAliasing\" 1;\n\tsetAttr \"defaultRenderQuality.shadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.maxShadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.useMultiPixelFilter\" 0;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthX\" 2.2;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthY\" 2.2;\n\tsetAttr \"defaultRenderQuality.enableRaytracing\" 0;\n\tsetAttr \"defaultRenderGlobals.motionBlur\" 0;\n\t\n\t//Render the top down camera to a texture file\n\tselect $maRenderTexturePlaneCombined;\n\tscale 2 2 2;\n\tInvertSelection;\n\t$maRenderSelected = `ls -sl`;\n\tHideSelectedObjects;\n\tselect $maRenderTexturePlaneCombined;\n\trenderWindowRenderCamera render renderView top;\n\t//Check if Mac and save file to correct location if so\n\tstring $maCurrentMayaVersionMac3 = `about -mac`;\n\tif($maCurrentMayaVersionMac3 == 1)\n\t{\n\t\trenderWindowSaveImageCallback \"renderView\" \"/Users/Shared/m341_temp/checker1\" \".png\";\n\t}\t\n\telse\n\t{\n\t\trenderWindowSaveImageCallback \"renderView\" \"c:/m341_temp/checker1\" \".png\";\n\t}\n\tselect $maRenderSelected;\n\tShowSelectedObjects;\n\tselect -clear;\n\t\n\t//Delete the render rig at the end\n\tdelete $maRenderTexturePlaneCombined;\n\t$searchSceneForCheckerMatStyle_2 = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_2)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Select user selection and print\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\tselect $maCreateCheckRememberUserSelection;\n\t//Set renderer to Arnold\n\tsetCurrentRenderer \"arnold\";\n\tsetAttr hardwareRenderingGlobals.renderMode 4;\n\t\n\tprint \"Created checker1.png Style 2\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Render checker map style 2 Map 2 slot\nglobal proc m341_checkerMap_renderCheckerStyle2Map2()\n{\n\t//Check if Maya LT show window explaining button won't work in LT\n\tstring $maCurrentMayaVersion = `about -product`;\n\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t{\n\t\t$warningLTWindow = `confirmDialog -title \"ERROR\" -message \"Unfortunately Maya LT doesn't come with the required nodes to create the checker maps. Using your own custom checker map will work fine, or you can download the checker maps seen in the Youtube video here \\n\\nhttps://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing\" -button \"OK\"`;\n\t\terror \"Maya LT doesn't come with the required nodes to create the checker maps\\n\";\n\t}\n\t\n\t//Force checker map one image flag so correct texture is displayed after render is complete\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 1;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker2.png\";\n\t}\n\t\n\t\n\t//Switch to Maya software render\n\tsetCurrentRenderer \"mayaSoftware\";\n\tsetAttr hardwareRenderingGlobals.renderMode 1;\n\t\n\t\n\t//Remember user selection\n\t$maCreateCheckRememberUserSelection = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 1)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\t\n\t//Create direction material style 5\n\tstring $searchSceneForCheckerMatStyle_1[] = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_1)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Create plane\n\tpolyPlane -name \"maCheckerMapPlaneRenderTemp_1001\" -w 2048 -h 2048 -sx 1 -sy 1 -ax 0 1 0 -cuv 2 -ch 1;\n\tmove -rpr -1024 0 -1024 maCheckerMapPlaneRenderTemp_1001.scalePivot maCheckerMapPlaneRenderTemp_1001.rotatePivot;\n\tmove -rpr 0 0 0;\n\tstring $maRenderTexturePlane[] = `ls -sl`;\n\t\n\t//Create material\n\tshadingNode -asShader surfaceShader -name ma_create_checker_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_SG;\n\tconnectAttr -f ma_create_checker_m.outColor ma_create_checker_SG.surfaceShader;\n\t\n\t//Create layer texture\n\tshadingNode -asTexture layeredTexture;\n\trename \"ma_create_checker_f\";\n\t$maCreateCheck_File = `ls -sl`;\n\tconnectAttr -f ma_create_checker_f.outColor ma_create_checker_m.outColor;\n\t\n\t//Apply material to plane\n\tselect $maRenderTexturePlane;\n\tsets -e -forceElement ma_create_checker_SG;\n\n\t\n\t//Create checker node\n\tshadingNode -asTexture checker -name ma_create_checker_CHECKBOARD;\n\tshadingNode -asUtility place2dTexture -name ma_create_checker_CHECKBOARD_P2D;\n\tconnectAttr ma_create_checker_CHECKBOARD_P2D.outUV ma_create_checker_CHECKBOARD.uv;\n\tsetAttr \"ma_create_checker_CHECKBOARD_P2D.repeatU\" 16;\n\tsetAttr \"ma_create_checker_CHECKBOARD_P2D.repeatV\" 16;\n\tsetAttr \"ma_create_checker_CHECKBOARD.color1\" -type double3 0.501961 0.501961 0.501961;\n\tsetAttr \"ma_create_checker_CHECKBOARD.color2\" -type double3 0.25098 0.25098 0.25098;\n\tconnectAttr -force ma_create_checker_CHECKBOARD.outColor ma_create_checker_f.inputs[2].color;\n\t\n\t\n\t//Create material for arrows\n\tstring $arrowMat = `shadingNode -asShader surfaceShader -name ma_create_checker_arrow_M`;\n\tstring $arrowSG = `sets -renderable true -noSurfaceShader true -empty -name ma_create_checker_arrow_SG`;\n\tconnectAttr -f {$arrowMat + \".outColor\"} {$arrowSG + \".surfaceShader\"};\n\tsetAttr {$arrowMat + \".outColor\"} -type double3 1 0.949017 0;\n\n\t\n    //Create arrows\t\n    string $arrowMesh[] = `polyCreateFacet -ch off -tx 1 -s 1 -p 32 6.090086 4.977776 -p 15.826574 6.090086 29.584209 -p 26.550024 6.090086 29.584209 -p 26.550024 6.090086 59.022217 -p 37.449974 6.090086 59.022217 -p 37.449974 6.090086 29.584209 -p 48.173424 6.090086 29.584209`;\n    CenterPivot;\n   \t//Apply material\n\tsets -e -forceElement $arrowSG;\n\n    string $tempList[] = {};\n    stringArrayInsertAtIndex(0, $tempList, $arrowMesh[0]);\n    for ($i = 0; $i < 31; ++$i)\n    {\n        string $tempMesh[] = `duplicate -rr`;\n        move -relative -x 64;\n        stringArrayInsertAtIndex( 0, $tempList, $tempMesh[0] );\n        int $sizeTempList = `size $tempList`;\n        if ($sizeTempList == 32)\n        {\n            select $tempList;\n        }\n    }\n\t\n\t//Select all arrows and combine them\n\tpolyUnite -name \"maCreateCheckCombinedArrow\";\n\tDeleteHistory;\n\t\n\t//Duplicate and move assets around\n    $arrowMesh = `ls -sl`;\n    CenterPivot;\n    \n    $tempList = {};\n    stringArrayInsertAtIndex(0, $tempList, $arrowMesh[0]);\n    for ($i = 0; $i < 31; ++$i)\n    {\n        string $tempMesh[] = `duplicate -rr`;\n        move -relative -z 64;\n        stringArrayInsertAtIndex( 0, $tempList, $tempMesh[0] );\n        int $sizeTempList = `size $tempList`;\n        if ($sizeTempList == 32)\n        {\n            select $tempList;\n        }\n    }\n    \n    //Combine and store for delete\n   \tpolyUnite -name \"maCreateCheckCombinedArrow\";\n\tDeleteHistory;\n\t$maRenderTexturePlane2 = `ls -sl`;\n\t\n\t\n\t//Position the camera and adjust settings\n\tcamera -e -lockTransform 1 perspShape; \n\tselect $maRenderTexturePlane; \n\tsetFocus modelPanel1;\n\n\t//Only works when this code is in a button won't work from script editor\n\t//evalDeferred \"viewFit topShape\";\n\tsetAttr \"top.translateZ\" 1024;\n\tsetAttr \"top.translateX\" 1024;\n\t\n\t//FrameSelectedWithoutChildren;\n\t//fitPanel -selectedNoChildren;\n\tsetAttr \"topShape.orthographicWidth\" 2048;\n\tcamera -e -lockTransform 0 perspShape; \n\t\n\t//Set the render globals settings\n\t//select -r defaultRenderGlobals;\n\tsetAttr \"defaultRenderGlobals.imageFormat\" 32;\n\tsetAttr \"topShape.mask\" 0;\n\tsetAttr \"defaultResolution.width\" 2048;\n\tsetAttr \"defaultResolution.height\" 2048;\n\tsetAttr \"defaultResolution.deviceAspectRatio\" 1;\n\tsetAttr \"defaultRenderQuality.edgeAntiAliasing\" 1;\n\tsetAttr \"defaultRenderQuality.shadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.maxShadingSamples\" 1;\n\tsetAttr \"defaultRenderQuality.useMultiPixelFilter\" 0;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthX\" 2.2;\n\t//setAttr \"defaultRenderQuality.pixelFilterWidthY\" 2.2;\n\tsetAttr \"defaultRenderQuality.enableRaytracing\" 0;\n\tsetAttr \"defaultRenderGlobals.motionBlur\" 0;\n\t\n\t//Render the top down camera to a texture file\n\tselect $maRenderTexturePlane;\n\tselect -add $maRenderTexturePlane2;\n\tInvertSelection;\n\t$maRenderSelected = `ls -sl`;\n\tHideSelectedObjects;\n\tselect $maRenderTexturePlane;\n\tselect -add $maRenderTexturePlane2;\n\trenderWindowRenderCamera render renderView top;\n\t//Check if Mac and save file to correct location if so\n\tstring $maCurrentMayaVersionMac3 = `about -mac`;\n\tif($maCurrentMayaVersionMac3 == 1)\n\t{\n\t\trenderWindowSaveImageCallback \"renderView\" \"/Users/Shared/m341_temp/checker2\" \".png\";\n\t}\t\n\telse\n\t{\n\t\trenderWindowSaveImageCallback \"renderView\" \"c:/m341_temp/checker2\" \".png\";\n\t}\n\tselect $maRenderSelected;\n\tShowSelectedObjects;\n\tselect -clear;\n\t\n\t//Delete the render rig at the end\n\tdelete $maRenderTexturePlane;\n\tdelete $maRenderTexturePlane2;\n\t$searchSceneForCheckerMatStyle_1 = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_1)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Select user selection and print\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 0)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\tselect $maCreateCheckRememberUserSelection;\n\t//Set renderer to Arnold\n\tsetCurrentRenderer \"arnold\";\n\tsetAttr hardwareRenderingGlobals.renderMode 4;\n\t\n\tprint \"Created checker2.png Style 5\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Render checker map style 3\nglobal proc m341_checkerMap_renderCheckerStyle3()\n{\n\t//Check if Maya LT show window explaining button won't work in LT\n\tstring $maCurrentMayaVersion = `about -product`;\n\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t{\n\t\t$warningLTWindow = `confirmDialog -title \"ERROR\" -message \"Unfortunately Maya LT doesn't come with the required nodes to create the checker maps. Using your own custom checker map will work fine, or you can download the checker maps seen in the Youtube video here\\n\\nhttps://drive.google.com/file/d/13rscA2rRCqRsXi_uAfJmMsFSLxAwK7hO/view?usp=sharing\" -button \"OK\"`;\n\t\terror \"Maya LT doesn't come with the required nodes to create the checker maps\\n\";\n\t}\n\t\n\t//Force checker map one image flag so correct texture is displayed after render is complete\n\tglobal int $m341_clickButton1;\n\tglobal int $m341_clickButton2;\n\t$m341_clickButton1 = 1;\n\tif ($m341_clickButton1 == 1)\n\t{\n\t\tglobal string $m341_checkerImage;\n\t\t$m341_checkerImage = \"checker1.png\";\n\t}\n\t\n\t//Switch to Maya software render\n\tsetCurrentRenderer \"mayaSoftware\";\n\tsetAttr hardwareRenderingGlobals.renderMode 1;\n\t\n\t//Remember user selection\n\t$maCreateCheckRememberUserSelection = `ls -sl`;\n\tglobal int $checkIfCheckerMapExists;\n\tif ($checkIfCheckerMapExists == 1)\n\t{\n\t\tm341_checkerMap_toggleOnOff();\n\t} \n\t\n\t//Create checker material style 3\n\tstring $searchSceneForCheckerMatStyle_3[] = `ls -mat`;\n\tfor ($Item in $searchSceneForCheckerMatStyle_3)\n\t{\n\t\tif (`gmatch $Item \"ma_create_checker*\"`)\n\t\t{\n\t\t\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\t}\n\t}\n\t\n\t//Create plane\n\tpolyPlane -name \"maCheckerMapPlaneRenderChecksTemp_1001\" -w 12.8 -h 12.8 -sx 1 -sy 1 -ax 0 1 0 -cuv 2 -ch 1; objectMoveCommand;\n\tmove -rpr -6.4 0 -6.4 maCheckerMapPlaneRenderChecksTemp_1001.scalePivot maCheckerMapPlaneRenderChecksTemp_1001.rotatePivot ;\n\tmove -rpr 0 0 0;\n\t$maCurrentCheckPlane = `ls -sl`;\n\t\n\t//Create material Green\n\tshadingNode -asShader surfaceShader -name ma_create_checker1_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker1_SG;\n\tconnectAttr -f ma_create_checker1_m.outColor ma_create_checker1_SG.surfaceShader;\n\tsetAttr \"ma_create_checker1_m.outColor\" -type double3 0.145 0.373 0.463;\n\t\n\t//Create material Green Light\n\tshadingNode -asShader surfaceShader -name ma_create_checker2_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker2_SG;\n\tconnectAttr -f ma_create_checker2_m.outColor ma_create_checker2_SG.surfaceShader;\n\tsetAttr \"ma_create_checker2_m.outColor\" -type double3 0.369 0.820 0.733;\n\t\n\t//Create material Yellow\n\tshadingNode -asShader surfaceShader -name ma_create_checker3_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker3_SG;\n\tconnectAttr -f ma_create_checker3_m.outColor ma_create_checker3_SG.surfaceShader;\n\tsetAttr \"ma_create_checker3_m.outColor\" -type double3 0.984 0.922 0.635;\n\t\n\t//Create material Orange\n\tshadingNode -asShader surfaceShader -name ma_create_checker4_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker4_SG;\n\tconnectAttr -f ma_create_checker4_m.outColor ma_create_checker4_SG.surfaceShader;\n\tsetAttr \"ma_create_checker4_m.outColor\" -type double3 0.984 0.541 0.447;\n\t\n\t//Create material Red\n\tshadingNode -asShader surfaceShader -name ma_create_checker5_m;\n\t$maCreateCheck_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker5_SG;\n\tconnectAttr -f ma_create_checker5_m.outColor ma_create_checker5_SG.surfaceShader;\n\tsetAttr \"ma_create_checker5_m.outColor\" -type double3 0.792 0.224 0.388;\n\t\n\t//Create material for numbers\n\tshadingNode -asShader surfaceShader -name ma_create_checker_numbersS2_m;\n\t$maCreateCheckNumb1_Mat = `ls -sl`;\n\tsets -renderable true -noSurfaceShader true -empty -name ma_create_checker_numbersS2_SG;\n\tconnectAttr -f ma_create_checker_numbersS2_m.outColor ma_create_checker_numbersS2_SG.surfaceShader;\n\tsetAttr \"ma_create_checker_numbersS2_m.outTransparency\" -type double3 0.4 0.4 0.4 ;\n\t\n\t\n\t//Apply material to check square\n\tselect $maCurrentCheckPlane;\n\tsets -e -forceElement ma_create_checker1_SG;\n\t\n\t//Dupelicate and move diagonally\n\tselect $maCurrentCheckPlane;\n\tduplicate -rr;\n\tmove -rpr 12.8 0 12.8 ;\n\tduplicate -rr;\n\tmove -rpr 25.6 0 25.6 ;\n\tduplicate -rr;\n\tmove -rpr 38.400002 0 38.400002 ;\n\tduplicate -rr;\n\tmove -rpr 51.200005 0 51.200005 ;\n\t\n\tselect $maCurrentCheckPlane;\n\tduplicate -rr;\n\tmove -rpr -x 12.799999 ;\n\t//Apply material to check square\n\tsets -e -forceElement ma_create_checker2_SG;\n\tduplicate -rr;\n\tmove -rpr 25.599998 0 12.8 ;\n\tduplicate -rr;\n\tmove -rpr 38.399998 0 25.6 ;\n\tduplicate -rr;\n\tmove -rpr 51.200005 0 38.400002 ;\n\tduplicate -rr;\n\tmove -rpr 0 -1.2611e-008 51.200001 ;\n\t\n\tduplicate -rr;\n\tmove -rpr -z 38.400002 ;\n\t//Apply material to check square\n\tsets -e -f