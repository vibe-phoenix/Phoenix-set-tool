global proc shelf_malcolm () {
    global string $gBuffStr;
    global string $gBuffStr0;
    global string $gBuffStr1;


    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Help" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Help" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "render.png" 
        -image1 "render.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_helpGlobal()\n{\n\tglobal string $m341_global_helpWindow;\n\n\tif (`window -exists $m341_global_helpWindow`)\n\t{\n\t\tglobal string $m341_global_helpWindow;\n\t\tdeleteUI $m341_global_helpWindow;\n\t}\n\t\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n    $helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\t\n\t$m341_global_helpWindow = `window -title \"Help Malcolm341\" -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 220`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"QUICK START GUIDE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-To get started have a look at the online quick start guide.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://drive.google.com/file/d/1NMM3yHTmNzb8K1mmi6MmL8PRJGxSyexq/view?usp=share_link\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://drive.google.com/file/d/1NMM3yHTmNzb8K1mmi6MmL8PRJGxSyexq/view</a><br><br>\";\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"ADVANCED HELP AND VIDEOS\";\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Hover the mouse over the shelf button you want help with. A tool tip should appear telling you to right click or left click the button depending on which type of tool the button loads.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If you can't see the tool tip it's also displayed in the bottom left corner of Maya as you hover the mouse over the shelf buttons.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Some buttons run a script and use a right click help menu, and other buttons open a toolbox and need to be left clicked to access their help menu.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Help menus contain a detailed explanation of all features for that specific tool with Youtube video links at the bottom.\\n\";\n\n\tshowWindow $m341_global_helpWindow;\n}\nm341_helpGlobal();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "tbExp" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "tbExp" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "polyCube.png" 
        -image1 "polyCube.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps create new tools, features, and bug fixes\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Marmoset Export Toolbox\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\nglobal string $m341_tbExporterVersion;\n$m341_tbExporterVersion = \"tbExporter v2.1\";\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Help\nglobal proc m341_tbExporter_help()\n{\n\tglobal string $m341_tbExporter_helpWindow;\n\n\tif (`window -exists $m341_tbExporter_helpWindow`)\n\t{\n\t\tglobal string $m341_tbExporter_helpWindow;\n\t\tdeleteUI $m341_tbExporter_helpWindow;\n\t}\n\t\n\t//Left justify help window to center of Maya window\n    int $helpLeftEdge = `window -q -width MayaWindow`;\n    $helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\t\n\tglobal string $m341_tbExporterVersion;\n\t$m341_tbExporter_helpWindow = `window -title (\"Help \" + $m341_tbExporterVersion) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 800`;\n\t\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TOOLBAG EXPORT TUTORIAL\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Create a group named high and a group named low. Put your high poly and low poly meshes into the correct groups.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Select the high group, not the meshes inside it, and click the export high button. Name the file and choose where to export it to. Do the same for the low group so you have a high and a low .fbx file on your hard drive somewhere.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-The low file will be triangulated behind the scene and export options will be set automatically without affecting your current meshes in Maya. Additional options can be turned on using the checkboxes below. Smooth mesh preview will be exported correctly if active for meshes that get exported using the export high button. Smooth mesh preview is disabled for meshes exported using the export low button.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-In Toolbag import the high and low .fbx files you just created and bake them.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"RESET\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Resets the toolbox back to defualt settings.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EASY NORMALS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Softens all normals and then hardens UV border edges based on the tolerence angle you set in the easy normals input field. Lowing the tolerance will create more hard UV border edges and raising the tolerence will create more soft UV border edges. A good value to start with is 45.1, from there you can raise or lower the value incrementally and run the tool again tool until you get the desired result.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Easy normals can be handy for automatically assigning hard edges for baking without hardening edges that should be left as soft, for example two halves of a sphere or a cylinder.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SOFT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Softens the normals on the currently selected edges.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"HARD\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Hardens the normals on the currently selected edges.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"HARD BORDER\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Hardens the normals on all UV border edges of the selected mesh.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CUT HARD\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Cuts UVs on all hard edges of the selected mesh.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CUT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Cuts UVs on selected edges.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SEW\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Moves and sews UVs on selected edges.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"MAKE SHELL\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Creates a new UV shell from selected faces.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"VIS EDGES\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Toggles polygon edge display on/off in the viewport.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TB NAME MATCH\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Renames meshes and inserts the word _high or _low if the mesh is inside a group named high or low. This is extremely helpful for renaming multiple meshes in one click if you're going to use the name matching feature of Marmoset Toolbag or another baking program.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Create a group named high and a group named low. Put some meshes in the groups. Select the meshes in the groups, but not the groups themselves and click the TB name match button. Make sure to select meshes in the numeric order you want them named so the number increment works correctly.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Meshes will be renamed\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"name_high_01, name_high_02, name_high_03, etc.\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"name_low_01, name_low_02, name_low_03, etc.\\n\\n\";\n\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CREATE MAT IDS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Applies a randomly coloured material to each element/shell of your selected mesh. Works on combined meshes with multiple elements, or multiple meshes with a single element, or a combination of both. If faces are selected instead of a mesh, a single randomly coloured material will be applied to the selected faces.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"C P R\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Copy, paste, replace. C copies the current material id from a single selected face to the clipboard. P pastes the material from the clipboard to selected faces or objects. R replaces all faces that share the same material id on the mesh with the material id from the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EXPORT ANIMATION CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to export animation with the .fbx file that gets created when using the export high or export low buttons.\\n\\n\";\n\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EXPORT TANGENTS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if want to export tangents with the .fbx file that gets created when using the export low button. If you want tangents included in the .fbx that gets created when using the export high button you must turn on export tangents, turn on export high UVs, and turn off triangulate high. Tangents will not appear in the high file unless these exact checkboxes are set, this is due to a design flaw in Maya.\\n\\n\";\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EXPORT HIGH UVS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to export UVs with the .fbx file that gets created when using the export high button. Exporting UVs for the high poly will slow down the export process, so only turn this on if you need it for something specific.\\n\\n\";\t\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TRIANGULATE HIGH CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to triangulate the .fbx file that gets created when using the export high button.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TRIANGULATE LOW CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to triangulate the .fbx file that gets created when using the export low button. This is highly recommended if you're baking high to low normal maps to avoid triangle flip errors between the game engine and the baking software.\\n\\n\";\t\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SOFT + HARD BORDER CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to soften all normals and harden all UV border edges each time the export low button is used.\\n\\n\";\t\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EXPORT HIGH\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Exports the contents of a selected group as .fbx using the various checkboxes from above. Multiple meshes in the group is okay and smooth mesh preview will be exported correctly if active.\\n\\n\";\t\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EXPORT LOW\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Exports the contents of a selected group as .fbx using the various checkboxes from above. Multiple meshes in the group is okay and smooth mesh preview will be disabled if active.\\n\\n\";\t\n\t\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/r_zs0A6sWEY?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/r_zs0A6sWEY?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br><br>\";\n\t\n\tshowWindow $m341_tbExporter_helpWindow;\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Reset \nglobal proc m341_tbExporter_reset()\n{\n\t//text field\n\ttextField -e -text \"\" tbRename_TextFieldName;\n\tm341_tbExporter_TextValueChanged();\n\t\n\t//easy normals float\n\tfloatField -e -value 45.1 easyNormals_FloatFieldName;\n\tm341_tbExporter_EasyNormals_ValueChanged();\n\n\t//export animation\n\tcheckBox -e -value 0 tbExporter_ExportAnimation_CheckBoxName;\n\tglobal int $m341_tbExporter_ExportAnimation_userInput;\n\t$m341_tbExporter_ExportAnimation_userInput = `checkBox -q -value tbExporter_ExportAnimation_CheckBoxName`;\n\toptionVar -intValue \"m341_tbExporter_ExportAnimationCheckBox_VarName\" $m341_tbExporter_ExportAnimation_userInput;\t\n\t\n\t//export tangents\n\tcheckBox -e -value 0 tbExporter_ExportTangents_CheckBoxName;\n\tglobal int $m341_tbExporter_ExportTangents_userInput;\n\t$m341_tbExporter_ExportTangents_userInput = `checkBox -q -value tbExporter_ExportTangents_CheckBoxName`;\n\toptionVar -intValue \"m341_tbExporter_ExportsTangents_VarName\" $m341_tbExporter_ExportTangents_userInput;\t\n\n\t//export high UVs\n\tcheckBox -e -value 0 tbExporter_ExportHighUVs_CheckBoxName;\n\tglobal int $m341_tbExporter_ExportHighUVs_userInput;\n\t$m341_tbExporter_ExportHighUVs_userInput = `checkBox -q -value tbExporter_ExportHighUVs_CheckBoxName`;\n\toptionVar -intValue \"m341_tbExporter_ExportHighUVsCheckBox_VarName\" $m341_tbExporter_ExportHighUVs_userInput;\n\t\n\t//triangulate high\n\tcheckBox -e -value 0 tbExporter_TriangulateHigh_CheckBoxName;\n\tglobal int $m341_tbExporter_TriangulateHigh_userInput;\n\t$m341_tbExporter_TriangulateHigh_userInput = `checkBox -q -value tbExporter_TriangulateHigh_CheckBoxName`;\n\toptionVar -intValue \"m341_tbExporter_TriangulateHighCheckBox_VarName\" $m341_tbExporter_TriangulateHigh_userInput;\n\t\n\t//triangulate low\n\tcheckBox -e -value 1 tbExporter_TriangulateLow_CheckBoxName;\n\tglobal int $m341_tbExporter_TriangulateLow_UserInput;\n\t$m341_tbExporter_TriangulateLow_UserInput = `checkBox -q -value tbExporter_TriangulateLow_CheckBoxName`;\n\toptionVar -intValue \"m341_tbExporter_TriangulateLow_CheckBoxVarName\" $m341_tbExporter_TriangulateLow_UserInput;\t\n\t\n\t//soft + hard UV border\n\tcheckBox -e -value 0 tbExporter_HardenUVBorders_CheckBoxName;\n\tglobal int $m341_tbExporter_HardenUVBorders_userInput;\n\t$m341_tbExporter_HardenUVBorders_userInput = `checkBox -q -value tbExporter_HardenUVBorders_CheckBoxName`;\n\toptionVar -intValue \"m341_tbExporter_hardenUVBordersCheckBox_VarName\" $m341_tbExporter_HardenUVBorders_userInput;\t\n\t\n\tprint \"tbExporter reset to default\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Easy Normals\nglobal proc m341_tbExporter_EasyNormals()\n{\n\tm341_tbExporter_EasyNormals_ValueChanged();\n\tglobal float $m341_tbExporter_EasyNormals_userInput;\n\t\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\t//Soften all\n\tpolyPerformAction \"polySoftEdge -a 180\" e 0;\n\t//Harden border edges\n\tConvertSelectionToEdges;\n\tSelectEdgeMask;\n\tSelectUVBorderComponents;\n\tpolyPerformAction \"polySoftEdge -a 0\" e 0;\n\t\n\t//Harden edges that fall within tolerance\n\tpolySelectConstraint -mode 2 -type 0x0008 -smoothness 1 -angle true -anglebound 0 54;\n\tpolyPerformAction \"polySoftEdge -a $m341_tbExporter_EasyNormals_userInput\" e 0;\n\tresetPolySelectConstraint;\n\t\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\tDeleteHistory;\n\t\n\tprint(\"Normals softened, UV border edges below tolerance \" + $m341_tbExporter_EasyNormals_userInput + \" hardened\\n\");\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Soften Edges\nglobal proc m341_tbExporter_SoftenEdges()\n{\n\tPolygonSoftenEdge;\n\tprint \"Soften normals complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Harden Edges\nglobal proc m341_tbExporter_HardenEdges()\n{\n\tPolygonHardenEdge;\n\tprint \"Harden normals complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Harden UV Border Edges\nglobal proc m341_tbExporter_HardenBorderEdges()\n{\n\t//Select UV border edges\n\tSelectEdgeMask;\n\tSelectUVBorderComponents;\n\tpolyPerformAction \"polySoftEdge -a 0\" e 0;\n\n\tprint \"Harden UV border edges complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Cut Hard Edges\nglobal proc m341_tbExporter_CutHardEdges()\n{\n\t//Select UV border edges\n\tSelectEdgeMask;\n\tpolySelectConstraint -m 3 -t 0x8000 -sm 1;\n\tresetPolySelectConstraint; \n\tpolyMapCut -ch 0;\n\t\n\tprint \"Cut hard edges complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Cut Edges\nglobal proc m341_tbExporter_cutEdges()\n{\n\tpolyMapCut -ch 0;\n\t\n\tprint \"Cut edges complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Move and Sew Edges\nglobal proc m341_tbExporter_moveSewEdges()\n{\n\tpolyMapSewMove -nf 10 -lps 0 -ch 0;\n\t\n\tprint \"Move and sew edges complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Make Shell\nglobal proc m341_tbExporter_makeShell()\n{\n\tConvertSelectionToFaces;\n\tstring $faces[] = `ls -sl`;\n\t\n\tConvertSelectionToContainedEdges;\n\tstring $edges[] = `ls -sl`;\n\t\n\tSelectEdgeMask;\n\tSelectUVBorderComponents;\n\tstring $borderEdges[] = `ls -sl`;\n\t\n\tselect $faces;\n\tpolyMapCut -ch 0;\n\tselect $edges;\n\t\n\tselect -deselect $borderEdges;\n\t\n\tpolyMapSew -ch 0;\n\tConvertSelectionToFaces;\n\tselect $faces;\n\t\n\tprint \"Create shell complete\\n\";\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Show Edges\nglobal proc m341_tbExporter_ShowEdges()\n{\n\tstring $maDisplayMode = `displayPref -q -wsa`;\n\n\tif ($maDisplayMode == \"full\")\n\t{\n\t\tdisplayPref -wsa \"none\";\n\t\tprint \"Edge display set to None\\n\";\n\t}\n\n\telse if ($maDisplayMode == \"none\\n\")\n\t{\n\t\tdisplayPref -wsa \"full\";\n\t\tprint \"Edge display set to Full\\n\";\n\t}\n\n\telse\n\t{\n\t\tdisplayPref -wsa \"full\";\n\t\tprint \"Edge display set to Full\\n\";\n\t}\n}\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Group Match NEW\nglobal proc m341_tbExporter_GroupMatch()\n{\n\t//Filter list of objects by name\n\tm341_tbExporter_TextValueChanged();\n\tint $tbExporterDropDownIndex = 3;\n\tstring $tbExporterDropDownArray[] = {\"\", \"_\", \"_0\", \"_00\", \"_000\"};\n\tglobal string $m341_tbExporter_RenameField_UserInput;\t\t\t\n\tstring $searchForHigh[] = `ls -sl -long`;\n\tselect -cl;\n\t\n\tglobal string $m341_tbExporter_finalSelectHigh[];\n\t$m341_tbExporter_finalSelectHigh = `ls -sl`;\n\tglobal string $m341_tbExporter_finalSelectLow[];\n\t$m341_tbExporter_finalSelectLow = `ls -sl`;\n\tstring $tempItem[] = {};\n\t\n\tfor ($Item in $searchForHigh)\n\t{\n\t\tif (`gmatch $Item \"*|high|*\"`)   \n\t\t{\n\t\t\t$highObjs = $Item;\n\t\t\tselect -add $highObjs;\n\t\t}\n\t\t\n\t\tif (`gmatch $Item \"*|low|*\"`)   \n\t\t{\n\t\t\t$lowObjs = $Item;\n\t\t\tselect -d $lowObjs;\n\t\t}\n\t}    \n\t$found_High = `ls -sl -long`;\n\t\n\tselect -cl;\n\tfor ($Item in $searchForHigh)\n\t{\n\t\tif (`gmatch $Item \"*|low|*\"`)   \n\t\t{\n\t\t\t$lowObjs = $Item;\n\t\t\tselect -add $lowObjs;\n\t\t}\n\t\t\n\t\tif (`gmatch $Item \"*|high|*\"`)   \n\t\t{\n\t\t\t$highObjs = $Item;\n\t\t\tselect -d $highObjs;\n\t\t}\n\t}    \n\t$found_Low = `ls -sl -long`;\n\t\n\t//Select high list and add high name matching\n\tselect $found_High;\n\tfor ($Item in $found_High)\n\t{   \n\t\trenameSelectionList(\"namingFailed_matemp_1001\");\n\t}\n\t\n\t{\n\t\tstring $listHigh[] = `ls -sl`;\n\t\tint $listHighSize = `size $listHigh`;\n\t\tint $increment = 1;\n\t\tint $counter = 0;\n\t\t\n\t\tfor ($listHighItem = 0; $listHighItem < $listHighSize; ++$listHighItem)\n\t\t{\n\t\t\tselect $listHigh[$counter];\n\t\t\trename ($m341_tbExporter_RenameField_UserInput + \"_high\" + $tbExporterDropDownArray[$tbExporterDropDownIndex -1] + $increment);\n\t\t\t\n\t\t\t//Remove extra zero so names actually look good\n\t\t\tstring $REZ_Items[];\n\t\t\t$REZ_Items = `ls -sl`;\n\t\t\n\t\t\t//Check _01 name for extra zero\n\t\t\tif ($tbExporterDropDownIndex == 2)\n\t\t\t{\n\t\t\t\tif(`gmatch $REZ_Items[0] \"*_01\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_02\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_03\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_04\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_05\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_06\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_07\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_08\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_09\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t//Remove extra zero\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tsearchReplaceNames \"_0\" \"_\" \"selected\";\n\t\t\t\t}\n\t\t\t}\n\t\t\t\n\t\t\t//Check _001 name for extra zero\n\t\t\tif ($tbExporterDropDownIndex == 3)\n\t\t\t{\n\t\t\t\tif(`gmatch $REZ_Items[0] \"*_001\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_002\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_003\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_004\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_005\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_006\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_007\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_008\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_009\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t//Remove extra zero\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tsearchReplaceNames \"_00\" \"_0\" \"selected\";\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t//Remove extra zero 99-999\n\t\t\t\t$finalZeroTest = `ls -sl`;\n\t\t\t\t//Convert string array to string\n\t\t\t\t$objName = $finalZeroTest[0];\n\t\t\t\t//Strip off all but last 4 characters\n\t\t\t\tstring $endStr = endString($objName, 4);\n\t\t\t\t\n\t\t\t\tif(`gmatch $endStr \"0[1-9]*\"`)\n\t\t\t\t{\n\t\t\t\t\tsearchReplaceNames \"_0\" \"_\" \"selected\";\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\t//Remove extra zero 999-9999\n\t\t\t\t$finalZeroTest = `ls -sl`;\n\t\t\t\t//Convert string array to string\n\t\t\t\t$objName = $finalZeroTest[0];\n\t\t\t\t//Strip off all but last 4 characters\n\t\t\t\t$endStr = endString($objName, 5);\n\t\t\t\t\n\t\t\t\tif(`gmatch $endStr \"0[1-9]*\"`)\n\t\t\t\t{\n\t\t\t\t\tsearchReplaceNames \"_0\" \"_\" \"selected\";\n\t\t\t\t}\n\t\t\t}\n\t\t\t\n\t\t\t//Check _0001 name for extra zero\n\t\t\tif ($tbExporterDropDownIndex == 4)\n\t\t\t{\n\t\t\t\tif(`gmatch $REZ_Items[0] \"*_0001\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_0002\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_0003\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_0004\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_0005\"`)\n\t\t\t\t{\n\t\t\t\t\t\n\t\