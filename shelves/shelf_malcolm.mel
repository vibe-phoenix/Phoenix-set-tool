        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Paste Material from Clipboard v1.2\n\nglobal proc m341_pasteMatFromClipboard()\n{\n    //Change mode to one if you want the pasted material to be a duplicate of the copied material\n    int $mode = 0;\n\n\tglobal string $m341_copyShadingGroup[];\n\tif ($mode == 1)\n    {\n        string $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t    sets -e -forceElement $newMat;\t\n\t   \tprint \"Pasted duplicate material from clipboard\\n\";\n    }\n    \n    else\n    {\n    \tsets -e -forceElement $m341_copyShadingGroup;\t\n\t    print \"Pasted material from clipboard\\n\";\n    }\n}\nm341_pasteMatFromClipboard();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Paste Duplicate" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Paste Material from Clipboard v1.2\nglobal proc m341_pasteMatFromClipboard()\n{\n    //Change mode to one if you want the pasted material to be a duplicate of the copied material\n    int $mode = 1;\n\n\tglobal string $m341_copyShadingGroup[];\n\tif ($mode == 1)\n    {\n        string $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t    sets -e -forceElement $newMat;\t\n\t   \tprint \"Pasted duplicate material from clipboard\\n\";\n    }\n    \n    else\n    {\n    \tsets -e -forceElement $m341_copyShadingGroup;\t\n\t    print \"Pasted material from clipboard\\n\";\n    }\n}\nm341_pasteMatFromClipboard();" )
        -mi "Help paste" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Help\n\nglobal proc m341_HelpCopyPaste()\n{\n\tglobal string $m341_CopyPaste_HelpWindow;\n\n\tif (`window -exists $m341_CopyPaste_HelpWindow`)\n\t{\n\t\tglobal string $m341_CopyPaste_HelpWindow;\n\t\tdeleteUI $m341_CopyPaste_HelpWindow;\n\t}\n\t\n\t$m341_CopyPaste_HelpWindow = `window -title \"Copy Paste Help\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 260`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"COPY\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Copies the material from a single polygon face to the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PASTE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Pastes the material from the clipboard to selected faces or objects.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"REPLACE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Replaces all faces that share the same material on the current mesh with the material from the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PASTE DUPLICATE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If you right click the paste or replace shelf buttons you can paste/replace as a duplicate material from what's currently stored in the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/BvSg2T2L5Do?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/BvSg2T2L5Do?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_CopyPaste_HelpWindow;\n}\nm341_HelpCopyPaste();" )
