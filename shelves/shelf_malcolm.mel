UD_startTime;\\\n\t$m341_extraHUD_startTime = `timerX`;\\\n\t\\\n\tglobal int $m341_extraHUD_lastSave_ScriptJobName;\\\n\t$m341_extraHUD_lastSave_ScriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \\\"SceneSaved\\\" \\\"m341_extraHUD_lastSave_ScriptJobProc\\\"`;\\\n\t\\\n\theadsUpDisplay -attachToRefresh -section $lastSave_SectionVar -block $lastSave_NextFreeBlock -blockSize \\\"small\\\" -label \\\"Last Save:\\\" -labelFontSize \\\"small\\\" -command \\\"m341_extraHUD_lastSave_Display()\\\" extraHUD_lastSave_HUDName;\"};\n\n\t//Query the value of the checkbox and store in variable\n\tglobal int $m341_extraHUD_lastSave_userInput;\n\t$m341_extraHUD_lastSave_userInput = `checkBox -q -value extraHUD_lastSave_CheckBoxName`;\n\toptionVar -intValue \"m341_extraHUD_lastSaveCheckBox_VarName\" $m341_extraHUD_lastSave_userInput;\n\t//Print value\n\tif ($m341_extraHUD_lastSave_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem extraHUD_lastSave_HUDName;\n\n\t\t//Kill the script job on HUD exit\n\t\t//global int $m341_extraHUD_lastSave_ScriptJobName;\n\t\t//scriptJob -kill $m341_extraHUD_lastSave_ScriptJobName -force;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_lastSave*/\"};\n\t\t\n\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\n\t\tprint \"Last save checkbox off\\n\";\n\t}\n\telse\n\t{\n\t\t//Turn on refresh script job to keep GPU from getting hammered\n\t\tglobal int $m341_extraHUD_refreshTimer_scriptJobName;\n\t\t$m341_extraHUD_refreshTimer_scriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \"idleVeryLow\" \"m341_extraHUD_refreshTimer\"`;\n\n\t\t\n\t    //Timer\n\t\tglobal float $m341_extraHUD_startTime;\n\t\t$m341_extraHUD_startTime = `timerX`;\n\t\t\n\t\t//Reset timer script job\n\t\tglobal int $m341_extraHUD_lastSave_ScriptJobName;\n\t\t$m341_extraHUD_lastSave_ScriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \"SceneSaved\" \"m341_extraHUD_lastSave_ScriptJobProc\"`;\n\t\t\n\t\theadsUpDisplay -attachToRefresh -section $lastSave_SectionVar -block $lastSave_NextFreeBlock -blockSize \"small\" -label \"Last Save:\" -labelFontSize \"small\" -command \"m341_extraHUD_lastSave_Display()\" extraHUD_lastSave_HUDName;\n\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_lastSave*/\"};\n\t\t\n\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\n\n\t\t//Suppress spam prints\n\t\tm341_extraHUD_SuppressPrint();\n\t\tprint \"Last save checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Supress Script Editor Prints\nglobal proc m341_extraHUD_SuppressPrint()\n{\n\tcommandEcho -af {\"m341_extraHUD_refreshTimer\", \"m341_extraHUD_lastSave_Display()\", \"m341_extraHUD_lastSaveBroken\", \"m341_extraHUD_lastAutoSave_Display()\", \"m341_extraHUD_lastAutoSaveBroken\", \"m341_extraHUD_upAxis_Display()\", \"m341_extraHUD_camSelection_Display()\", \"m341_extraHUD_toolAxis_Display()\", \"m341_extraHUD_selectedItems_Display()\", \"m341_extraHUD_assignedMaterials_Display()\", \"m341_extraHUD_uvSet_Display()\", \"m341_extraHUD_preserveUVs_Display()\"};\n}\t\t\n\n\n//***********************************************************************************************************************************************************\n//Update lastAutoSave Checkbox Value\nglobal proc string m341_extraHUD_lastAutoSave_Display()\n{\n\t//Start timer\n\tglobal float $m341_extraHUD_autoSave_startTime;\n    float $currentTime = `timerX -startTime $m341_extraHUD_autoSave_startTime`;\n  \n  \tint $minutes = $currentTime / 60;\n  \tint $seconds = $currentTime % 60;\n  \tint $hours = $minutes / 60;\n  \t$minutes %= 60;\n\n\tint $autoSaveStatus = `autoSave -q -enable`;  \n\tstring $currentMayaYear = `about -product`;\n\t\n\tif(`gmatch $currentMayaYear \"*2017*\"`)\n\t{\n\t\tstring $autoSavePrint = \"requires Maya 2019 or later\";\n\t\treturn $autoSavePrint;\n\t}\n\t\n\telse if(`gmatch $currentMayaYear \"*2018*\"`)\n\t{\n\t\tstring $autoSavePrint = \"requires Maya 2019 or later\";\n\t\treturn $autoSavePrint;\n\t}\n\t\n\telse if ($autoSaveStatus == 1)\n\t{\n\t\treturn ($hours + \":\" + $minutes + \":\" + $seconds);\n\t}\n\t\n\telse if ($autoSaveStatus == 0)\n\t{\n\t\t//print \"Auto save disabled\";\n\t\tstring $autoSavePrint = \"auto save disabled\";\n\t\treturn $autoSavePrint;\n\t}\n}\n\n//Reset Timer proc\nglobal proc m341_extraHUD_lastAutoSave_ScriptJobProc()\n{\n\tglobal float $m341_extraHUD_autoSave_startTime;\n    float $currentTime = `timerX -startTime $m341_extraHUD_autoSave_startTime`;\n\t\n\tint $minutes = $currentTime / 60;\n  \tint $seconds = $currentTime % 60;\n  \tint $hours = $minutes / 60;\n  \t$minutes %= 60;\n\t\n\t$m341_extraHUD_autoSave_startTime = `timerX`;\n}\n\nglobal proc m341_extraHUD_lastAutoSave_ValueChanged()\n{\n\t//Section and block variables\n\tint $lastAutoSave_SectionVar = 6;\n\tint $lastAutoSave_NextFreeBlock = `headsUpDisplay -nextFreeBlock $lastAutoSave_SectionVar`;\n\n\t//Create a string array with text in it to add or remove from userSet.mel\n\tglobal string $m341_extraHUD_print_textArray[];\n\t$m341_extraHUD_print_textArray = {\"/*m341_extraHUD_lastAutoSave*/ evalDeferred \\\"commandEcho -af {\\\\\\\"m341_extraHUD_refreshTimer\\\\\\\", \\\\\\\"m341_extraHUD_lastAutoSave_Display()\\\\\\\"}\\\";\\\n\t\\\n\tglobal float $m341_extraHUD_refresh_counter1;\\\n\t$m341_extraHUD_refresh_counter1 = 0.45;\\\n\tglobal float $m341_extraHUD_refresh_counter2;\\\n\t$m341_extraHUD_refresh_counter2 = 0.55;\\\n\tglobal float $