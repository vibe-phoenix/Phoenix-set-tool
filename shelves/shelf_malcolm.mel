        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "stSurf" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "stSurf" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconModify.png" 
        -image1 "menuIconModify.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Snap Transform to Surface v1.2\n\nglobal proc m341_snapTransformsToSurface()\n{\n\t//Get list of objects\n\tstring $selected_Objs[] = `ls -sl -long`;\n\n\t//Get last selected object\n\tstring $surfaceToSnapTo = $selected_Objs[size($selected_Objs)-1];\n\t$surfaceToSnapToArray = stringToStringArray($surfaceToSnapTo, \" \");\n\n    //Create list of objects that will be snapped\n    string $Objs[] = stringArrayRemove($surfaceToSnapToArray, $selected_Objs);\n    \n    int $counter = 0;\n\tfor ($item in $Objs)\n\t{\n    \tdelete `geometryConstraint $surfaceToSnapToArray $Objs[$counter]`;\n   \t\tdelete `normalConstraint -aimVector 0 1 0 $surfaceToSnapToArray $Objs[$counter]`;\n   \t\t$counter = $counter + 1;\n\t}\n}\nm341_snapTransformsToSurface();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help stSurf" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Help\n\nglobal proc m341_HelpTransformTools()\n{\n\tglobal string $m341_TransformTools_HelpWindow;\n\n\tif (`window -exists $m341_TransformTools_HelpWindow`)\n\t{\n\t\tglobal string $m341_TransformTools_HelpWindow;\n\t\tdeleteUI $m341_TransformTools_HelpWindow;\n\t}\n\t\n\t$m341_TransformTools_HelpWindow = `window -title \"Transform Tools Help\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 140`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"ST SURF\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Select the objects you want to snap first and then shift select the surface to snap to last. The object's local Y up axis and pivot point are used as the direction the snapping will occur on.\\n\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEOS HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_TransformTools_HelpWindow;\n}\nm341_HelpTransformTools();" )
    ;
