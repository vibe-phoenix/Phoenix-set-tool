        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Replace Material from Clipboard v1.1\n\nglobal proc m341_replaceMatFromClipboard()\n{\n    //Change mode to one if you want the pasted material to be a duplicate of the copied material\n    int $mode = 0;\n    global string $m341_copyShadingGroup[];\n\t\n\tstring $faces[] = `ls -sl`;\n\tstring $isObjSelected[] = `filterExpand -sm 12`;\n\tint $sizeIsObjSelected = `size $isObjSelected`;\n\n\t//Replace if object mode selected\n\tif ($sizeIsObjSelected == 1)\n\t{\n\t\tif ($mode == 1)\n\t\t{\n\t\t\tstring $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t\t\tsets -e -forceElement $newMat;\t\n\t\t\tprint \"Pasted duplicate material from clipboard\\n\";\t\t\n\t\t}\n\t\telse\n\t\t{\n\t\t\tsets -e -forceElement $m341_copyShadingGroup;\t\n\t\t\tprint \"Pasted material from clipboard\\n\";\n\t\t}\n\t}\n\t\n\telse\n\t{\n\t\t//Error if more than one face selected\n\t\tstring $errorFaces[] = `filterExpand -sm 34`;\n\t\tint $sizeErrorFaces = `size $errorFaces`;\n\t\tif(size($errorFaces)!= 1)\n\t\t{\n    \t\terror \"Please select exactly one face or one object\";    \n\t\t}\n\t\t\n\t\tglobal string $smid_SelectedFace[];\n\t\tConvertSelectionToFaces;\n\t\t$smid_SelectedFace = `ls -fl -sl`;\n\n\t\ttoggleSelMode;\n\t\ttoggleSelMode;\n\t\tselectMode -object;\n\t\tglobal string $smid_ObjectName[];\n\t\t$smid_ObjectName = `ls -sl`;\n\t\t\n\t\t//If only one material for whole object replace\n\t\thyperShade -smn;\n\t\tstring $numbMats[] = `ls -sl`;\n\t\tint $sizeNumbMats = `size $numbMats`;\n\t\tif ($sizeNumbMats == 1)\n\t\t{\n\t\t\tselect $smid_ObjectName;\n\t\t\tif ($mode == 1)\n\t\t\t{\n\t\t\t\tstring $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t\t\t\tsets -e -forceElement $newMat;\t\n\t\t\t\tprint \"Pasted duplicate material from clipboard\\n\";\t\t\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tsets -e -forceElement $m341_copyShadingGroup;\n\t\t\t\tprint \"Replaced material from clipboard\\n\";\n\t\t\t}\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\tConvertSelectionToFaces;\n\t\t\tselect $smid_SelectedFace;\n   \t\t\thyperShade -smn \"\";\n\t\t\t$smid_Mat_Name = `ls -sl`;\n    \t\t$smid_SG_Name = `listSets -type 1 -object $smid_SelectedFace[0]`;\n\t\t\tselect -clear;\n\t    \tselect -add $smid_SG_Name;\n\t\t\tstring $smid_AllSelectedFaces[] = `ls -fl -sl`;\n\t\t\tstring $smid_FilteredList[];\n   \n\t\t\tfor ($smid_Item in $smid_AllSelectedFaces)\n\t\t\t{\n\t\t\t\tstring $smid_NameMatch = `match $smid_ObjectName[0] $smid_Item`;\n\t        \tif ($smid_NameMatch == $smid_ObjectName[0])    \n\t\t    \t{        \n    \t\t\t\tint $smid_Index = (size($smid_FilteredList));\n        \t\t\t$smid_FilteredList[$smid_Index] = $smid_Item;\n\t\t    \t}\n\t\t\t}\n\n\t\t\tselect -replace $smid_FilteredList;\n\t\t\t//Set component mode to faces\n\t\t\tSelectFacetMask;\n\n\t\t\t//Paste material\n\t\t\t{\n\t\t\t\tif ($mode == 1)\n\t\t\t\t{\n\t\t\t\t\tstring $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t\t\t\t\tsets -e -forceElement $m341_copyShadingGroup;\t\n\t\t\t\t\t$faces = `ls -sl -fl`;\n\t\t\t\t\tselect $smid_ObjectName;\n\t\t\t\t\t//Set component mode to faces\n\t\t\t\t\tSelectFacetMask;\n\t\t\t\t\tselect $faces;\n\t\t\t\t\tprint \"Replaced material from clipboard\\n\";\t\t\t\t\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tsets -e -forceElement $m341_copyShadingGroup;\t\n\t\t\t\t\t$faces = `ls -sl -fl`;\n\t\t\t\t\tselect $smid_ObjectName;\n\t\t\t\t\t//Set component mode to faces\n\t\t\t\t\tSelectFacetMask;\n\t\t\t\t\tselect $faces;\n\t\t\t\t\tprint \"Replaced material from clipboard\\n\";\t\t\t\t\t\t\t\t\n\t\t\t\t}\n\n\t\t\t}\n\t\t}\t\t\t\n\t}\n}\nm341_replaceMatFromClipboard();\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Replace Duplicate" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Replace Material from Clipboard v1.1\nglobal proc m341_replaceMatFromClipboard()\n{\n    //Change mode to one if you want the pasted material to be a duplicate of the copied material\n    int $mode = 1;\n    global string $m341_copyShadingGroup[];\n\t\n\tstring $faces[] = `ls -sl`;\n\tstring $isObjSelected[] = `filterExpand -sm 12`;\n\tint $sizeIsObjSelected = `size $isObjSelected`;\n\n\t//Replace if object mode selected\n\tif ($sizeIsObjSelected == 1)\n\t{\n\t\tif ($mode == 1)\n\t\t{\n\t\t\tstring $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t\t\tsets -e -forceElement $newMat;\t\n\t\t\tprint \"Pasted duplicate material from clipboard\\n\";\t\t\n\t\t}\n\t\telse\n\t\t{\n\t\t\tsets -e -forceElement $m341_copyShadingGroup;\t\n\t\t\tprint \"Pasted material from clipboard\\n\";\n\t\t}\n\t}\n\t\n\telse\n\t{\n\t\t//Error if more than one face selected\n\t\tstring $errorFaces[] = `filterExpand -sm 34`;\n\t\tint $sizeErrorFaces = `size $errorFaces`;\n\t\tif(size($errorFaces)!= 1)\n\t\t{\n    \t\terror \"Please select exactly one face or one object\";    \n\t\t}\n\t\t\n\t\tglobal string $smid_SelectedFace[];\n\t\tConvertSelectionToFaces;\n\t\t$smid_SelectedFace = `ls -fl -sl`;\n\n\t\ttoggleSelMode;\n\t\ttoggleSelMode;\n\t\tselectMode -object;\n\t\tglobal string $smid_ObjectName[];\n\t\t$smid_ObjectName = `ls -sl`;\n\t\t\n\t\t//If only one material for whole object replace\n\t\thyperShade -smn;\n\t\tstring $numbMats[] = `ls -sl`;\n\t\tint $sizeNumbMats = `size $numbMats`;\n\t\tif ($sizeNumbMats == 1)\n\t\t{\n\t\t\tselect $smid_ObjectName;\n\t\t\tif ($mode == 1)\n\t\t\t{\n\t\t\t\tstring $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t\t\t\tsets -e -forceElement $newMat;\t\n\t\t\t\tprint \"Pasted duplicate material from clipboard\\n\";\t\t\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\tsets -e -forceElement $m341_copyShadingGroup;\n\t\t\t\tprint \"Replaced material from clipboard\\n\";\n\t\t\t}\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\tConvertSelectionToFaces;\n\t\t\tselect $smid_SelectedFace;\n   \t\t\thyperShade -smn \"\";\n\t\t\t$smid_Mat_Name = `ls -sl`;\n    \t\t$smid_SG_Name = `listSets -type 1 -object $smid_SelectedFace[0]`;\n\t\t\tselect -clear;\n\t    \tselect -add $smid_SG_Name;\n\t\t\tstring $smid_AllSelectedFaces[] = `ls -fl -sl`;\n\t\t\tstring $smid_FilteredList[];\n   \n\t\t\tfor ($smid_Item in $smid_AllSelectedFaces)\n\t\t\t{\n\t\t\t\tstring $smid_NameMatch = `match $smid_ObjectName[0] $smid_Item`;\n\t        \tif ($smid_NameMatch == $smid_ObjectName[0])    \n\t\t    \t{        \n    \t\t\t\tint $smid_Index = (size($smid_FilteredList));\n        \t\t\t$smid_FilteredList[$smid_Index] = $smid_Item;\n\t\t    \t}\n\t\t\t}\n\n\t\t\tselect -replace $smid_FilteredList;\n\t\t\t//Set component mode to faces\n\t\t\tSelectFacetMask;\n\n\t\t\t//Paste material\n\t\t\t{\n\t\t\t\tif ($mode == 1)\n\t\t\t\t{\n\t\t\t\t\tstring $newMat[] = `duplicate -upstreamNodes ($m341_copyShadingGroup[0] + \".surfaceShader\")`;\n\t\t\t\t\tsets -e -forceElement $m341_copyShadingGroup;\t\n\t\t\t\t\t$faces = `ls -sl -fl`;\n\t\t\t\t\tselect $smid_ObjectName;\n\t\t\t\t\t//Set component mode to faces\n\t\t\t\t\tSelectFacetMask;\n\t\t\t\t\tselect $faces;\n\t\t\t\t\tprint \"Replaced material from clipboard\\n\";\t\t\t\t\n\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t{\n\t\t\t\t\tsets -e -forceElement $m341_copyShadingGroup;\t\n\t\t\t\t\t$faces = `ls -sl -fl`;\n\t\t\t\t\tselect $smid_ObjectName;\n\t\t\t\t\t//Set component mode to faces\n\t\t\t\t\tSelectFacetMask;\n\t\t\t\t\tselect $faces;\n\t\t\t\t\tprint \"Replaced material from clipboard\\n\";\t\t\t\t\t\t\t\t\n\t\t\t\t}\n\n\t\t\t}\n\t\t}\t\t\t\n\t}\n}\nm341_replaceMatFromClipboard();\n\n" )
        -mi "Help replace" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Help\n\nglobal proc m341_HelpCopyPaste()\n{\n\tglobal string $m341_CopyPaste_HelpWindow;\n\n\tif (`window -exists $m341_CopyPaste_HelpWindow`)\n\t{\n\t\tglobal string $m341_CopyPaste_HelpWindow;\n\t\tdeleteUI $m341_CopyPaste_HelpWindow;\n\t}\n\t\n\t$m341_CopyPaste_HelpWindow = `window -title \"Copy Paste Help\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 260`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"COPY\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Copies the material from a single polygon face to the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PASTE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Pastes the material from the clipboard to selected faces or objects.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"REPLACE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Replaces all faces that share the same material on the current mesh with the material from the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PASTE DUPLICATE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If you right click the paste or replace shelf buttons you can paste/replace as a duplicate material from what's currently stored in the clipboard.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/BvSg2T2L5Do?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/BvSg2T2L5Do?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_CopyPaste_HelpWindow;\n}\nm341_HelpCopyPaste();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "default" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "default" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "render_lambert.png" 
        -image1 "render_lambert.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Change Default Material Toolbox\nglobal string $m341_dmatRemapperVersion;\n$m341_dmatRemapperVersion = \"defaultMat v1.6\";\n\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_dmatRemapper_help()\n{\n\tglobal string $m341_dmatRemapper_helpWindow;\n\n\tif (`window -exists $m341_dmatRemapper_helpWindow`)\n\t{\n\t\tglobal string $m341_dmatRemapper_helpWindow;\n\t\tdeleteUI $m341_dmatRemapper_helpWindow;\n\t}\n\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n\t$helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\tglobal string $m341_dmatRemapperVersion;\n\t$m341_dmatRemapper_helpWindow = `window -title (\"Help \" + $m341_dmatRemapperVersion) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 580`;\n\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"LAMBERT1\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Sets the default material to lambert1.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"STANDARD SURFACE1\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Sets the default material to standardSurface1 if it's available in your version of Maya.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"BLINN, PHONG\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Sets the default material to blinn or phong.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"AI STANDARD SURFACE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Sets the default material to aiStandardSurface if it's available in your version of Maya.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SELECTED MATERIAL\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Sets the default material to the currently selected material in the Hypershade.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"EXPORT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Exports the currently selected material in the Hypershade to a temp file.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"IMPORT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Imports the material from the temp file and sets it as the default material, this allows you to create a custom default material that can be imported into any scene.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"FIND\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Opens the folder where the temp file is stored. The temp file is named m341_default_material\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CLEAN UNUSED\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Deletes unused nodes in the Hypershade, the Hypershade doesn't need to be open to delete unused.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"HS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Toggles the Hypershade open/closed.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/cmyKGl_IUi4?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/cmyKGl_IUi4?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\t\n\n\t\n\tshowWindow $m341_dmatRemapper_helpWindow;\n}\n\n//***********************************************************************************************************************************************************\n//Reset \nglobal proc m341_dmatRemapper_reset()\n{\n\t//scale float field\n\tfloatField -e -value 100 planeScale_FloatFieldName;\n\tm341_dmatRemapper_planeScale_ValueChanged();\n\n\t//X\n\tcheckBox -e -value 0 createRefPlanesOnX_CheckBoxName;\n\tglobal int $m341_dmatRemapper_createRefPlanesOnX_userInput;\n\t$m341_dmatRemapper_createRefPlanesOnX_userInput = `checkBox -q -value createRefPlanesOnX_CheckBoxName`;\n\toptionVar -intValue \"m341_dmatRemapper_createRefPlanesOnXCheckBox_VarName\" $m341_dmatRemapper_createRefPlanesOnX_userInput;\t\n\t\n\t//Y\n\tcheckBox -e -value 0 createRefPlanesOnY_CheckBoxName;\n\tglobal int $m341_dmatRemapper_createRefPlanesOnY_userInput;\n\t$m341_dmatRemapper_createRefPlanesOnY_userInput = `checkBox -q -value createRefPlanesOnY_CheckBoxName`;\n\toptionVar -intValue \"m341_dmatRemapper_createRefPlanesOnY_VarName\" $m341_dmatRemapper_createRefPlanesOnY_userInput;\t\n\n\t//Z\n\tcheckBox -e -value 1 createRefPlanesOnZ_CheckBoxName;\n\tglobal int $m341_dmatRemapper_createRefPlanesOnZ_userInput;\n\t$m341_dmatRemapper_createRefPlanesOnZ_userInput = `checkBox -q -value createRefPlanesOnZ_CheckBoxName`;\n\toptionVar -intValue \"m341_dmatRemapper_createRefPlanesOnZCheckBox_VarName\" $m341_dmatRemapper_createRefPlanesOnZ_userInput;\n\t\n\t//2 sided geometry\n\tcheckBox -e -value 0 twoSidedGeometry_CheckBoxName;\n\tglobal int $m341_dmatRemapper_twoSidedGeometry_userInput;\n\t$m341_dmatRemapper_twoSidedGeometry_userInput = `checkBox -q -value twoSidedGeometry_CheckBoxName`;\n\toptionVar -intValue \"m341_dmatRemapper_twoSidedGeometryCheckBox_VarName\" $m341_dmatRemapper_twoSidedGeometry_userInput;\t\n\t\n\t\n\t//offset ref planes\n\tcheckBox -e -value 0 offsetPOSX_CheckBoxName;\n\tglobal int $m341_dmatRemapper_offsetPOSX_userInput;\n\t$m341_dmatRemapper_offsetPOSX_userInput = `checkBox -q -value offsetPOSX_CheckBoxName`;\n\toptionVar -intValue \"m341_dmatRemapper_offsetPOSXCheckBox_VarName\" $m341_dmatRemapper_offsetPOSX_userInput;\t\n\t\n\tglobal string $m341_dmatRemapperVersion;\n\tprint ($m341_dmatRemapperVersion + \" reset to default\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Lambert1\nglobal proc m341_dmatRemapper_lambert()\n{\n\tconnectAttr -f lambert1.outColor initialShadingGroup.surfaceShader;\n\tprint \"Default material set to lambert1\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Standard Surface\nglobal proc m341_dmatRemapper_standardSurface()\n{\n\n\n\tconnectAttr -f standardSurface1.outColor initialShadingGroup.surfaceShader;\n\tprint \"Default material set to standardSurface1\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Blinn\nglobal proc m341_dmatRemapper_blinn()\n{\n\tstring $selection[] = `ls -sl -fl`;\n\n\tstring $blinnName_M = `shadingNode -asShader blinn -name blinn`;\n\tstring $blinnName_SG = `sets -renderable true -noSurfaceShader true -empty -name blinn_SG`;\n\tconnectAttr -f ($blinnName_M + \".outColor\") ($blinnName_SG + \".surfaceShader\");\n\n\t//Connect to default\n\tconnectAttr -f ($blinnName_M + \".outColor\") initialShadingGroup.surfaceShader;\n\t\n\tselect $selection;\n\tprint (\"Default material set to \" + $blinnName_M + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Phong\nglobal proc m341_dmatRemapper_phong()\n{\n\tstring $selection[] = `ls -sl -fl`;\n\t\n\tstring $phongName_M = `shadingNode -asShader phong -name phong`;\n\tstring $phongName_SG = `sets -renderable true -noSurfaceShader true -empty -name phong_SG`;\n\tconnectAttr -f ($phongName_M + \".outColor\") ($phongName_SG + \".surfaceShader\");\n\n\t//Connect to default\n\tconnectAttr -f ($phongName_M + \".outColor\") initialShadingGroup.surfaceShader;\n\t\n\tselect $selection;\n\tprint (\"Default material set to \" + $phongName_M + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//aiStandardSurface\nglobal proc m341_dmatRemapper_aiStandard()\n{\n\tstring $selection[] = `ls -sl -fl`;\n\n\tstring $aiStandardName_M = `shadingNode -asShader aiStandardSurface -name aiStandardSurface`;\n\tstring $aiStandardName_SG = `sets -renderable true -noSurfaceShader true -empty -name aiStandard_SG`;\n\tconnectAttr -f ($aiStandardName_M + \".outColor\") ($aiStandardName_SG + \".surfaceShader\");\n\n\t//Connect to default\n\tconnectAttr -f ($aiStandardName_M + \".outColor\") initialShadingGroup.surfaceShader;\n\t\n\tselect $selection;\n\tprint (\"Default material set to \" + $aiStandardName_M + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Selected Material\nglobal proc m341_dmatRemapper_selectedMaterial()\n{\n\tstring $selection[] = `ls -sl -fl`;\n    //Check if material selected\n    string $mat[] = `ls -mat $selection[0]`;\n    int $sizeMat = `size $mat`;\n    if ($sizeMat == 0)\n    {\n    \thyperShade -smn \"\";        \n    }\n   \tstring $selectedMaterialName_M[] = `ls -sl -fl`;\n\t\n\t//Connect to default\n\tconnectAttr -f ($selectedMaterialName_M[0] + \".outColor\") initialShadingGroup.surfaceShader;\n\t\n\tselect $selection;\n\tprint (\"Default material set to \" + $selectedMaterialName_M[0] + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Export\nglobal proc m341_dmatRemapper_saveMaterial()\n{\n\t\n\t//Error\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeSelection = `size $selection`;\n\tif ($sizeSelection != 1)\n\t{\n\t\terror \"Please select exactly one material in the Hypershade\\n\";\n\t}\n\t\n\tif (`gmatch $selection[0] \"lambert1\"`)\n\t{\n\t\terror \"lambert1 can't be exported\\n\";\n\t}\t\n\t\n\tif (`gmatch $selection[0] \"standardSurface1\"`)\n\t{\n\t\terror \"standardSurface1 can't be exported\\n\";\n\t}\t\n\t\n\t\n\t//Store selection node type\n\tstring $type = `nodeType $selection[0]`;\n\t\n\t//Create array with valid material types\n\tstring $array[] = {\"ShaderfxGameHair\", \"ShaderfxShader\", \"StingrayPBS\", \"anisotropic\", \"blinn\", \"hairPhysicalShader\", \"hairTubeShader\", \"lambert\", \"layeredShader\", \"oceanShader\", \"phong\", \"phongE\", \"rampShader\", \"shadingMap\", \"standardSurface\", \"surfaceShader\", \"usdPreviewSurface\", \"useBackground\", \"aiAmbientOcclusion\", \"aiAxfShader\", \"aiCarPaint\", \"aiClipGeo\", \"aiFlat\", \"aiLambert\", \"aiLayerShader\", \"aiMaterialXShader\", \"aiMatte\", \"aiMixShader\", \"aiPassthrough\", \"aiRaySwitch\", \"aiShadowMatte\", \"aiStandardHair\", \"aiStandardSurface\", \"aiSwitch\", \"aiToon\", \"aiTwoSided\", \"aiUtility\", \"aiWireframe\", \"VRayAlSurface\", \"VRayBlendMtl\", \"VRayBumpMtl\", \"VRayCarPaint2Mtl\", \"VRayCarPaintMtl\", \"VRayFastSSS2Mtl\", \"VRayFlakes2Mtl\", \"VRayFlakesMtl\", \"VRayHairNextMtl\", \"VRayLightMtl\", \"VRayMtl\", \"VRayMtl2Sided\", \"VRayMtlGLSL\", \"VRayMtlMDL\", \"VRayMtlOSL\", \"VRayMtlRenderStats\", \"VRayMtlWrapper\", \"VRayPointParticleMtl\", \"VRayScannedMtl\", \"VRayStochasticFlakesMtl\", \"VRaySwitchMtl\", \"VRayToonMtl\", \"VRayVRmatMtl\"};\n\n\t//Check if selection is a valid material type\n\tglobal int $m341_dmatRemapper_validType;\n\t$m341_dmatRemapper_validType = 0;\n\tfor ($item in $array)\n\t{\n\t\tif (`gmatch $item $type`)\n\t\t{\n\t\t\tglobal int $m341_dmatRemapper_validType;\n\t\t\t$m341_dmatRemapper_validType = 1;\n\t\t}\t\n\t}\n\t\n\t//If valid export\n\tif ($m341_dmatRemapper_validType == 1)\n\t{\n\t\tstring $mayaVersionMac = `about -mac`;\n\t\tif ($mayaVersionMac == 1)\n\t\t{\n\t\t\tsysFile -makeDir \"/Users/Shared/m341_temp\";\n\t\t\tstring $currentMayaVersion = `about -product`;\n\t\t\tif(`gmatch $currentMayaVersion \"*LT*\"`)\n\t\t\t{\n\t\t\t\tfile -options \"v=0;\" -typ \"mayaLT\" -pr -es \"/Users/Shared/m341_temp/m341_default_material.mlt\";\n\t\t\t\tprint \"Result: Users\\\\Shared\\\\m341_temp\\\\m341_default_material.mlt\\n\";\n\t\t\t}\n\t\t\t\n\t\t\telse\n\t\t\t{\n\t\t\t\tfile -options \"v=0;\" -typ \"mayaAscii\" -pr -es \"/Users/Shared/m341_temp/m341_default_material.ma\";\n\t\t\t\tprint \"Result: Users\\\\Shared\\\\m341_temp\\\\m341_default_material.ma\\n\";\n\t\t\t}\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\tsysFile -makeDir \"C:/m341_temp\";\n\t\t\tstring $currentMayaVersion = `about -product`;\n\t\t\tif(`gmatch $currentMayaVersion \"*LT*\"`)\n\t\t\t{\n\t\t\t\tfile -options \"v=0;\" -typ \"mayaLT\" -pr -es \"C:/m341_temp/m341_default_material.mlt\";\n\t\t\t\tprint \"Result C:\\\\m341_temp\\\\m341_default_material.mlt\\n\";\n\t\t\t}\n\t\t\t\t\n\t\t\telse\n\t\t\t{\n\t\t\t\tfile -options \"v=0;\" -typ \"mayaAscii\" -pr -es \"C:/m341_temp/m341_default_material.ma\";\n\t\t\t\tprint \"Result: C:\\\\m341_temp\\\\m341_default_material.ma\\n\";\n\t\t\t}\n\t\t}\t\n\t}\n\t\n\telse\n\t{\n\t\terror \"Please select exactly one material in the Hypershade\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Import\nglobal proc m341_dmatRemapper_loadMaterial()\n{\n\tstring $selection[] = `ls -sl -fl`;\n\t\n\t//List all materials\n\tstring $before[] = `ls -mat`;\n\t\n\tstring $mayaVersionMac = `about -mac`;\n\tif ($mayaVersionMac == 1)\n\t{    \n\t\tstring $maCurrentMayaVersion = `about -product`;\n\t\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t\t{\n\t\t\tfile -import \"/Users/Shared/m341_temp/m341_default_material.mlt\";\n\t\t\t//print \"Imported temp.mlt into current scene\";\n\t\t}\n\t\t\t\n\t\telse\n\t\t{\n\t\t\tfile -import \"/Users/Shared/m341_temp/m341_default_material.ma\";\n\t\t\t//print \"Imported temp.ma into current scene\";\n\t\t}\n\t}\n\t\n\telse\n\t{\n\t\tstring $maCurrentMayaVersion = `about -product`;\n\t\tif(`gmatch $maCurrentMayaVersion \"*LT*\"`)\n\t\t{\n\t\t\tfile -import \"C:/m341_temp/m341_default_material.mlt\";\n\t\t\t//print \"Imported temp.mlt into current scene\";\n\t\t}\n\t\t\t\n\t\telse\n\t\t{\n\t\t\tfile -import \"C:/m341_temp/m341_default_material.ma\";\n\t\t\t//print \"Imported temp.ma into current scene\";\n\t\t}\n\t}\n\t\n\t//Find imported material\n\tstring $after[] = `ls -mat`;\n\tstring $importedMat[] = stringArrayRemove($before, $after);\n\t\n\t//Connect to default\n\tconnectAttr -f ($importedMat[0] + \".outColor\") initialShadingGroup.surfaceShader;\n\t\n\tselect $selection;\n\tprint (\"Default material set to \" + $importedMat[0] + \"\\n\");\n}\n\n\n\n//***********************************************************************************************************************************************************\n//Find\nglobal proc m341_dmatRemapper_findFolder()\n{\n\tstring $mayaVersionMac = `about -mac`;\n\tif($mayaVersionMac == 1)\n\t{\n\t\tsysFile -makeDir \"/Users/Shared/m341_temp\";\n\t\tlaunch -directory \"/Users/Shared/m341_temp\";\n \t}\t\n\telse\n\t{\n\t\tsysFile -makeDir \"C:/m341_temp\";\n\t\tlaunch -directory \"C:/m341_temp\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Clean Unused\nglobal proc m341_dmatRemapper_cleanUnused()\n{\n\thyperShadePanelMenuCommand(\"hyperShadePanel1\", \"deleteUnusedNodes\");\n\t\n\tprint \"Unused nodes deleted\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Hypershade\nglobal proc m341_dmatRemapper_hypershade()\n{\n\tif (`window -exists hyperShadePanel1Window`)\n\t{\n\t\tdeleteUI hyperShadePanel1Window;\n\t\tprint \"Hypershade closed\\n\";\n\t}\n\telse\n\t{\n\t\tHypershadeWindow;\n\t\tprint \"Hypershade opened\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Toggle All On/Off\nglobal proc m341_dmatRemapper_setAllOn()\n{\n\tglobal int $m341_dmatRemapper_toggle;\n\t$m341_dmatRemapper_toggle = !$m341_dmatRemapper_toggle;\n\t\n\tif ($m341_dmatRemapper_toggle == 1)\n\t{\n\t\tstring $selection[] = `ls -sl -fl`;\n\t\t\n\t\t//Disconnect initialParticleSe so it doesn't mess up paste back count\n\t\tconnectAttr -f lambert1.outColor initialParticleSE.surfaceShader;\n\t\tdisconnectAttr lambert1.outColor initialParticleSE.surfaceShader;\n\t\t\n\t\tselect `ls -type mesh`;\n\t\thyperShade -smn \"\";\n\t\tglobal string $m341_dmatRemapper_materialsToPasteBack[];\n\t\t$m341_dmatRemapper_materialsToPasteBack = `ls -sl -fl`;\n\t\tselect $m341_dmatRemapper_materialsToPasteBack;\n\t\tselect -cl;\n\t\t\n\t\t//Get the list of shading groups and store the number of shading groups\n\t\tstring $shadingEngines[] = listConnections(\"-type\",\"shadingEngine\", $m341_dmatRemapper_materialsToPasteBack);\n\t\tglobal string $m341_dmatRemapper_shadingEngineRemoveDupes[];\n\t\t$m341_dmatRemapper_shadingEngineRemoveDupes = stringArrayRemoveDuplicates($shadingEngines);\n\t\n\t\t//Get current default material name\n\t\tstring $defaultMat[] = `defaultNavigation -defaultTraversal -destination initialShadingGroup.surfaceShader`;\n\t\t\n\t\n\t\t//Plug current default material into all shading groups\n\t\tint $counter = 0;\n\t\tfor ($item in $m341_dmatRemapper_shadingEngineRemoveDupes)\n\t\t{\n\t\t\tconnectAttr -f ($defaultMat[0] + \".outColor \") ($m341_dmatRemapper_shadingEngineRemoveDupes[$counter] + \".surfaceShader\");\n\t\t\t$counter = $counter + 1;\n\t\t\t//print ($item + \"\\n\");\n\t\t}\n\t\t\n\t\tselect $selection;\n\t\tprint (\"All materials set to \" + $defaultMat[0] + \"\\n\");\n\t}\n\t\n\telse\n\t{\n\t\tstring $selection[] = `ls -sl -fl`;\n\t\n\t\t//Remove initial shading group from list so it doesn't mess up paste back count\n\t\tstring $remove[] = {\"initialShadingGroup\"};\n\t\tglobal string $m341_dmatRemapper_shadingEngineRemoveDupes[];\n\t\tstring $originalShadingGroups[] = stringArrayRemove($remove, $m341_dmatRemapper_shadingEngineRemoveDupes);\n\t\t\n\t\t//Paste back materials from stored names into original shading groups\n\t\tint $counter = 0;\n\t\tglobal string $m341_dmatRemapper_materialsToPasteBack[];\n\t\n\t\tfor ($item in $m341_dmatRemapper_materialsToPasteBack)\n\t\t{\n\t\t\tconnectAttr -f ($m341_dmatRemapper_materialsToPasteBack[$counter] + \".outColor \") ($originalShadingGroups[$counter] + \".surfaceShader\");\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\n\t\tselect $selection;\n\t\tprint (\"All materials reset\\n\");\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Toggle All Off\nglobal proc m341_dmatRemapper_setAllOff()\n{\n\tstring $selection[] = `ls -sl -fl`;\n\t\n\t//Remove initial shading group from list so it doesn't mess up paste back count\n\tstring $remove[] = {\"initialShadingGroup\"};\n\tglobal string $m341_dmatRemapper_shadingEngineRemoveDupes[];\n\tstring $originalShadingGroups[] = stringArrayRemove($remove, $m341_dmatRemapper_shadingEngineRemoveDupes);\n\t\n\t//Paste back materials from stored names into original shading groups\n\tint $counter = 0;\n\tglobal string $m341_dmatRemapper_materialsToPasteBack[];\n\n\tfor ($item in $m341_dmatRemapper_materialsToPasteBack)\n\t{\n\t\tconnectAttr -f ($m341_dmatRemapper_materialsToPasteBack[$counter] + \".outColor \") ($originalShadingGroups[$counter] + \".surfaceShader\");\n\t\t$counter = $counter + 1;\n\t}\n\n\tselect $selection;\n\tprint (\"All materials reset\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Window and Buttons\nglobal proc m341_dmatRemapper_launchWindow()\n{\n\tif (`window -exists m341_dmatRemapper_windowName`)\n\t{\n\t\tdeleteUI m341_dmatRemapper_windowName;\n\t};\n\t\n\tglobal string $m341_dmatRemapperVersion;\n\twindow -title $m341_dmatRemapperVersion -toolbox true -sizeable true -resizeToFitChildren true m341_dmatRemapper_windowName;\n\tcolumnLayout -adjustableColumn true;\n\ttext -label \"by Malcolm341\";\n\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-labelOffset 30\n\t\t\t-label \"click for help\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 108\n\t\t\t-height 15\n\t\t\t-command \"m341_dmatRemapper_help;\";\n\t\t\t\n\t\tsetParent ..;\n\t\ttext \"Set Default Mat To\";\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.772 0.521 0.302\n\t\t\t-width 108\n\t\t\t-label \"lambert1\"\n\t\t\t-command \"m341_dmatRemapper_lambert;\";\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.596 0.529 0.769\n\t\t\t-width 108\n\t\t\t-label \"standardSurface1\"\n\t\t\t-command \"m341_dmatRemapper_standardSurface;\";\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.50 0.67 0.37\n\t\t\t-width 53\n\t\t\t-label \"blinn\"\n\t\t\t-command \"m341_dmatRemapper_blinn;\";\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.34 0.59 0.47\n\t\t\t-width 54\n\t\t\t-label \"phong\"\n\t\t\t-command \"m341_dmatRemapper_phong;\";\n\t\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.451 0.529 0.78\n\t\t\t-width 108\n\t\t\t-label \"aiStandardSurface\"\n\t\t\t-command \"m341_dmatRemapper_aiStandard;\";\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.427 0.643 0.643\n\t\t\t-width 108\n\t\t\t-label \"selected material\"\n\t\t\t-command \"m341_dmatRemapper_selectedMaterial;\";\n\n\t\t//setParent ..;\n\t\t//rowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\t//iconTextButton -style \"textOnly\"\n\t\t\t//-backgroundColor 0.51 0.51 0.51\n\t\t\t//-width 108\n\t\t\t//-label \"set default to all\"\n\t\t\t//-command \"m341_dmatRemapper_setAllOn;\";\n\t\t\t\n\t\t\t\n\t\t//iconTextButton -style \"textOnly\"\n\t\t\t//-backgroundColor 0.51 0.51 0.51\n\t\t\t//-width 53\n\t\t\t//-label \"revert all\"\n\t\t\t//-command \"m341_dmatRemapper_setAllOff;\";\n\n\t\tsetParent ..;\n\t\ttext -label \"Hypershade Mat\";\n\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.72 0.68 0.39\n\t\t\t-width 39\n\t\t\t-height 19\n\t\t\t-label \"export\"\n\t\t\t-command \"m341_dmatRemapper_saveMaterial;\";\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.72 0.68 0.39\n\t\t\t-width 39\n\t\t\t-height 19\n\t\t\t-label \"import\"\n\t\t\t-command \"m341_dmatRemapper_loadMaterial;\";\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 28\n\t\t\t-height 19\n\t\t\t-label \"find\"\n\t\t\t-command \"m341_dmatRemapper_findFolder;\";\n\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.70 0.39 0.34\n\t\t\t-width 75\n\t\t\t-label \"clean unused\"\n\t\t\t-command \"m341_dmatRemapper_cleanUnused;\";\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 32\n\t\t\t-label \"HS\"\n\t\t\t-command \"m341_dmatRemapper_hypershade;\";\n\t\t\t\n\t\t\t\n\tshowWindow;\n\twindow -edit -width 100 -height 100 m341_dmatRemapper_windowName;\n\t\n\tprint (\"Toolbox loaded \" + $m341_dmatRemapperVersion + \"\\n\");\n}\n\nm341_dmatRemapper_launchWindow();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "matID" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "matID" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "UVEditorFace.png" 
        -image1 "UVEditorFace.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n\nglobal string $smid_SelectedFace[];\nConvertSelectionToFaces;\n$smid_SelectedFace = `ls -fl -sl`;\n\ntoggleSelMode;\ntoggleSelMode;\nselectMode -object;\nglobal string $smid_ObjectName[];\n$smid_ObjectName = `ls -sl`;\n\n\nConvertSelectionToFaces;\nselect $smid_SelectedFace;\n\nif(size($smid_SelectedFace)!= 1)\n{\n    error \"Please select only one face\";    \n}\n\nelse\n{\n    hyperShade -smn \"\";\n    $smid_Mat_Name = `ls -sl`;\n    $smid_SG_Name = `listSets -type 1 -object $smid_SelectedFace[0]`;\n    select -clear;\n    select -add $smid_SG_Name;\nstring $smid_AllSelectedFaces[] = `ls -fl -sl`;\n    string $smid_FilteredList[];\n   \nfor ($smid_Item in $smid_AllSelectedFaces)\n    {\n        string $smid_NameMatch = `match $smid_ObjectName[0] $smid_Item`;\n        if ($smid_NameMatch == $smid_ObjectName[0])    \n        {        \n            int $smid_Index = (size($smid_FilteredList));\n            $smid_FilteredList[$smid_Index] = $smid_Item;\n        }\n    }\n\nselect -replace $smid_FilteredList;\nprint (\"Selected faces with Material ID \" + $smid_Mat_Name[0]);\n}\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help matID" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_HelpMatId()\n{\n\tglobal string $m341_MatID_HelpWindow;\n\n\tif (`window -exists $m341_MatID_HelpWindow`)\n\t{\n\t\tglobal string $m341_MatID_HelpWindow;\n\t\tdeleteUI $m341_MatID_HelpWindow;\n\t}\n\t\n\t$m341_MatID_HelpWindow = `window -title \"Help Mat id\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 125`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"MATID\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Selects all faces that share the same material id on the current mesh.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Select a single face before using the tool.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/6iv728I313s?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/6iv728I313s?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_MatID_HelpWindow;\n}\nm341_HelpMatId();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "graph" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "graph" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "hypergraph.png" 
        -image1 "hypergraph.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n\nstring $maGraphSelectedFaces[] = `ls -sl`;\nHypershadeWindow;\nhyperShade -smn;\nhyperShadePanelGraphCommand (\"hyperShadePanel1\", \"showUpstream\");\nhyperShadePanelGraphCommand (\"hyperShadePanel1\", \"rearrangeGraph\");\nselect -r $maGraphSelectedFaces;" 
