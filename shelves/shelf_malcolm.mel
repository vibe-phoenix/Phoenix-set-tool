.4;\\\n\t\t}\\\n\t\tif ($m341_extraHUD_refresh_elapsedTime > $m341_extraHUD_refresh_counter2)\\\n\t\t{\\\n\t\t\tglobal float $m341_extraHUD_refresh_elapsedTime;\\\n\t\t\tglobal float $m341_extraHUD_refresh_counter1;\\\n\t\t\tglobal float $m341_extraHUD_refresh_counter2;\\\n\t\t\t$m341_extraHUD_refresh_elapsedTime = $m341_extraHUD_refresh_counter1 + 0.3;\\\n\t\t\trefresh;\\\n\t\t\t$m341_extraHUD_refresh_counter1 = $m341_extraHUD_refresh_counter1 + 0.4;\\\n\t\t\t$m341_extraHUD_refresh_counter2 = $m341_extraHUD_refresh_counter2 + 0.4;\\\n\t\t}\\\n\t}\\\n\tglobal proc m341_extraHUD_lastAutoSave_ScriptJobProc()\\\n\t{\\\n\t\tglobal float $m341_extraHUD_autoSave_startTime;\\\n\t\tfloat $currentTime = `timerX -startTime $m341_extraHUD_autoSave_startTime`;\\\n\t\tint $minutes = $currentTime / 60;\\\n\t\tint $seconds = $currentTime % 60;\\\n\t\tint $hours = $minutes / 60;\\\n\t\t$minutes %= 60;\\\n\t\t$m341_extraHUD_autoSave_startTime = `timerX`;\\\n\t}\\\n\t\\\n\tint $lastAutoSave_SectionVar = 6;\\\n\tint $lastAutoSave_NextFreeBlock = `headsUpDisplay -nextFreeBlock $lastAutoSave_SectionVar`;\\\n\t\\\n\tglobal int $m341_extraHUD_refreshTimer_scriptJobName;\\\n\t$m341_extraHUD_refreshTimer_scriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \\\"idleVeryLow\\\" \\\"m341_extraHUD_refreshTimer\\\"`;\\\n\t\\\n\tglobal float $m341_extraHUD_autoSave_startTime;\\\n\t$m341_extraHUD_autoSave_startTime = `timerX`;\\\n\t\\\n\tglobal int $m341_extraHUD_lastAutoSave_ScriptJobName;\\\n\t$m341_extraHUD_lastAutoSave_ScriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \\\"renderSetupAutoSave\\\" \\\"m341_extraHUD_lastAutoSave_ScriptJobProc\\\"`;\\\n\t\\\n\theadsUpDisplay -attachToRefresh -section $lastAutoSave_SectionVar -block $lastAutoSave_NextFreeBlock -blockSize \\\"small\\\" -label \\\"Last Auto Save:\\\" -labelFontSize \\\"small\\\" -command \\\"m341_extraHUD_lastAutoSave_Display()\\\" extraHUD_lastAutoSave_HUDName;\"};\n\n\n\t//Query the value of the checkbox and store in variable\n\tglobal int $m341_extraHUD_lastAutoSave_userInput;\n\t$m341_extraHUD_lastAutoSave_userInput = `checkBox -q -value extraHUD_lastAutoSave_CheckBoxName`;\n\toptionVar -intValue \"m341_extraHUD_lastAutoSaveCheckBox_VarName\" $m341_extraHUD_lastAutoSave_userInput;\n\t//Print value\n\tif ($m341_extraHUD_lastAutoSave_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem extraHUD_lastAutoSave_HUDName;\n\t\t\n\t\tstring $currentMayaYear = `about -product`;\n\t\tif(`gmatch $currentMayaYear \"*2017*\"`)\n\t\t{\n\t\t\t//Do nothing\n\t\t}\n\t\t\n\t\telse if(`gmatch $currentMayaYear \"*2018*\"`)\n\t\t{\n\t\t\t//Do nothing\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\t//Kill the script job on HUD exit\n\t\t\t//global int $m341_extraHUD_lastAutoSave_ScriptJobName;\n\t\t\t//scriptJob -kill $m341_extraHUD_lastAutoSave_ScriptJobName -force;\n\n\t\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_lastAutoSave*/\"};\n\t\t\n\t\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\t}\n\t\t\n\t\tprint \"Last auto save checkbox off\\n\";\n\t}\n\t\n\telse\n\t{\n\t\tstring $currentMayaYear = `about -product`;\n\t\tif(`gmatch $currentMayaYear \"*2017*\"`)\n\t\t{\n\t\t\t//Do nothing\n\t\t}\n\t\t\n\t\telse if(`gmatch $currentMayaYear \"*2018*\"`)\n\t\t{\n\t\t\t//Do nothing\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\t//Turn on refresh script job to keep GPU from getting hammered\n\t\t\tglobal int $m341_extraHUD_refreshTimer_scriptJobName;\n\t\t\t$m341_extraHUD_refreshTimer_scriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \"idleVeryLow\" \"m341_extraHUD_refreshTimer\"`;\n\t\t\t\n\t\t\t//Timer\n\t\t\tglobal float $m341_extraHUD_autoSave_startTime;\n\t\t\t$m341_extraHUD_autoSave_startTime = `timerX`;\n\t\t\n\t\t\t//Reset timer script job\n\t\t\tglobal int $m341_extraHUD_lastAutoSave_ScriptJobName;\n\t\t\n\t\t\tglobal int $m341_extraHUD_lastAutoSave_ScriptJobName;\n\t\t\t$m341_extraHUD_lastAutoSave_ScriptJobName = `scriptJob -runOnce 0 -compressUndo 1 -event \"renderSetupAutoSave\" \"m341_extraHUD_lastAutoSave_ScriptJobProc\"`;\n\t\t\t\n\t\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_lastAutoSave*/\"};\n\t\t\n\t\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\t}\n\t\t\n\t\theadsUpDisplay -attachToRefresh -section $lastAutoSave_SectionVar -block $lastAutoSave_NextFreeBlock -blockSize \"small\" -label \"Last Auto Save:\" -labelFontSize \"small\" -command \"m341_extraHUD_lastAutoSave_Display()\" extraHUD_lastAutoSave_HUDName;\n\t\t\n\t\t//Suppress spam prints\n\t\tm341_extraHUD_SuppressPrint();\n\t\tprint \"Last auto save checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Window and Buttons\nglobal proc m341_extraHUD_LaunchWindow()\n{\n\tif (`window -exists m341_extraHUD_ToolboxName`)\n\t{\n\t\tdeleteUI m341_extraHUD_ToolboxName;\n\t}\n\n\tglobal string $m341_extraHUD_Version;\n\n\twindow -title $m341_extraHUD_Version -toolbox true -sizeable true -resizeToFitChildren true m341_extraHUD_ToolboxName;\n\tcolumnLayout -adjustableColumn true;\n\ttext -label \"by Malcolm341\";\n\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-labelOffset 30\n\t\t\t-label \"click for help\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 78\n\t\t\t-height 15\n\t\t\t-command \"m341_extraHUD_help;\";\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-labelOffset 30\n\t\t\t-label \"reset\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 38\n\t\t\t-height 15\n\t\t\t-command \"m341_extraHUD_reset;\";\n\t\n\t\n\t\t//Save preferences Working units checkbox\n\t\tint $extraHUD_workingUnits_checkBoxValue;\n\t\tglobal int $m341_extraHUD_workingUnits_userInput;\n\t\tstring $extraHUD_workingUnits_OptionVar = `optionVar -exists \"m341_extraHUD_workingUnitsCheckBox_VarName\"`;\n\t\tif ($extraHUD_workingUnits_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_workingUnitsCheckBox_VarName\" 0;\n\t\t\t$extraHUD_workingUnits_checkBoxValue = `optionVar -q \"m341_extraHUD_workingUnitsCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_workingUnits_checkBoxValue = `optionVar -q \"m341_extraHUD_workingUnitsCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"working units\" -width 103 -height 15 -value $extraHUD_workingUnits_checkBoxValue -changeCommand \"m341_extraHUD_workingUnits_ValueChanged();\" extraHUD_workingUnits_CheckBoxName;\n\t\t\n\t\t\n\t\t//Save preferences scene time warp checkbox\n\t\tint $extraHUD_enableSceneTimeWarp_checkBoxValue;\n\t\tglobal int $m341_extraHUD_enableSceneTimeWarp_userInput;\n\t\tstring $extraHUD_enableSceneTimeWarp_OptionVar = `optionVar -exists \"m341_extraHUD_enableSceneTimeWarpCheckBox_VarName\"`;\n\t\tif ($extraHUD_enableSceneTimeWarp_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_enableSceneTimeWarpCheckBox_VarName\" 0;\n\t\t\t$extraHUD_enableSceneTimeWarp_checkBoxValue = `optionVar -q \"m341_extraHUD_enableSceneTimeWarpCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_enableSceneTimeWarp_checkBoxValue = `optionVar -q \"m341_extraHUD_enableSceneTimeWarpCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"scene time warp\" -width 103 -height 15 -value $extraHUD_enableSceneTimeWarp_checkBoxValue -changeCommand \"m341_extraHUD_enableSceneTimeWarp_ValueChanged();\" extraHUD_enableSceneTimeWarp_CheckBoxName;\n\t\n\t\n\t\t//Save preferences up axis checkbox\n\t\tint $extraHUD_upAxis_checkBoxValue;\n\t\tglobal int $m341_extraHUD_upAxis_userInput;\n\t\tstring $extraHUD_upAxis_OptionVar = `optionVar -exists \"m341_extraHUD_upAxisCheckBox_VarName\"`;\n\t\tif ($extraHUD_upAxis_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_upAxisCheckBox_VarName\" 0;\n\t\t\t$extraHUD_upAxis_checkBoxValue = `optionVar -q \"m341_extraHUD_upAxisCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_upAxis_checkBoxValue = `optionVar -q \"m341_extraHUD_upAxisCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"up axis\" -width 103 -height 15 -value $extraHUD_upAxis_checkBoxValue -changeCommand \"m341_extraHUD_upAxis_ValueChanged();\" extraHUD_upAxis_CheckBoxName;\t\n\t\n\t\n\t\t//Save preferences selectedItems export checkbox\n\t\tint $extraHUD_selectedItems_checkBoxValue;\n\t\tglobal int $m341_extraHUD_selectedItems_userInput;\n\t\tstring $extraHUD_selectedItems_OptionVar = `optionVar -exists \"m341_extraHUD_selectedItemsCheckBox_VarName\"`;\n\t\tif ($extraHUD_selectedItems_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_selectedItemsCheckBox_VarName\" 0;\n\t\t\t$extraHUD_selectedItems_checkBoxValue = `optionVar -q \"m341_extraHUD_selectedItemsCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_selectedItems_checkBoxValue = `optionVar -q \"m341_extraHUD_selectedItemsCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"selected items\" -width 103 -height 15 -value $extraHUD_selectedItems_checkBoxValue -changeCommand \"m341_extraHUD_selectedItems_ValueChanged();\" extraHUD_selectedItems_CheckBoxName;\n\t\t\n\t\t\n\t\t//Save preferences applied materials checkbox\n\t\tint $extraHUD_assignedMaterials_checkBoxValue;\n\t\tglobal int $m341_extraHUD_assignedMaterials_userInput;\n\t\tstring $extraHUD_assignedMaterials_OptionVar = `optionVar -exists \"m341_extraHUD_assignedMaterialsCheckBox_VarName\"`;\n\t\tif ($extraHUD_assignedMaterials_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_assignedMaterialsCheckBox_VarName\" 0;\n\t\t\t$extraHUD_assignedMaterials_checkBoxValue = `optionVar -q \"m341_extraHUD_assignedMaterialsCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_assignedMaterials_checkBoxValue = `optionVar -q \"m341_extraHUD_assignedMaterialsCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"assigned materials\" -width 103 -height 15 -value $extraHUD_assignedMaterials_checkBoxValue -changeCommand \"m341_extraHUD_assignedMaterials_ValueChanged();\" extraHUD_assignedMaterials_CheckBoxName;\t\n\t\t\n\t\t\n\t\t\n\t\t//Save preferences uv set checkbox\n\t\tint $extraHUD_uvSet_checkBoxValue;\n\t\tglobal int $m341_extraHUD_uvSet_userInput;\n\t\tstring $extraHUD_uvSet_OptionVar = `optionVar -exists \"m341_extraHUD_uvSetCheckBox_VarName\"`;\n\t\tif ($extraHUD_uvSet_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_uvSetCheckBox_VarName\" 0;\n\t\t\t$extraHUD_uvSet_checkBoxValue = `optionVar -q \"m341_extraHUD_uvSetCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_uvSet_checkBoxValue = `optionVar -q \"m341_extraHUD_uvSetCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"uv set\" -width 103 -height 15 -value $extraHUD_uvSet_checkBoxValue -changeCommand \"m341_extraHUD_uvSet_ValueChanged();\" extraHUD_uvSet_CheckBoxName;\t\n\t\t\n\t\t\n\t\t\n\t\t//Save preferences preserve UVs checkbox\n\t\tint $extraHUD_preserveUVs_checkBoxValue;\n\t\tglobal int $m341_extraHUD_preserveUVs_userInput;\n\t\tstring $extraHUD_preserveUVs_OptionVar = `optionVar -exists \"m341_extraHUD_preserveUVsCheckBox_VarName\"`;\n\t\tif ($extraHUD_preserveUVs_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_preserveUVsCheckBox_VarName\" 0;\n\t\t\t$extraHUD_preserveUVs_checkBoxValue = `optionVar -q \"m341_extraHUD_preserveUVsCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_preserveUVs_checkBoxValue = `optionVar -q \"m341_extraHUD_preserveUVsCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"preserve UVs\" -width 103 -height 15 -value $extraHUD_preserveUVs_checkBoxValue -changeCommand \"m341_extraHUD_preserveUVs_ValueChanged();\" extraHUD_preserveUVs_CheckBoxName;\n\t\t\n\t\t\n\t\t\n\t\t//Save preferences project checkbox\n\t\tint $extraHUD_project_checkBoxValue;\n\t\tglobal int $m341_extraHUD_project_userInput;\n\t\tstring $extraHUD_project_OptionVar = `optionVar -exists \"m341_extraHUD_projectCheckBox_VarName\"`;\n\t\tif ($extraHUD_project_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_projectCheckBox_VarName\" 0;\n\t\t\t$extraHUD_project_checkBoxValue = `optionVar -q \"m341_extraHUD_projectCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_project_checkBoxValue = `optionVar -q \"m341_extraHUD_projectCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"project\" -width 103 -height 15 -value $extraHUD_project_checkBoxValue -changeCommand \"m341_extraHUD_project_ValueChanged();\" extraHUD_project_CheckBoxName;\t\n\t\n\t\n\t\n\t\t//Save preferences lastSave checkbox\n\t\tint $extraHUD_lastSave_checkBoxValue;\n\t\tglobal int $m341_extraHUD_lastSave_userInput;\n\t\tstring $extraHUD_lastSave_OptionVar = `optionVar -exists \"m341_extraHUD_lastSaveCheckBox_VarName\"`;\n\t\tif ($extraHUD_lastSave_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_lastSaveCheckBox_VarName\" 0;\n\t\t\t$extraHUD_lastSave_checkBoxValue = `optionVar -q \"m341_extraHUD_lastSaveCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_lastSave_checkBoxValue = `optionVar -q \"m341_extraHUD_lastSaveCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"last save\" -width 103 -height 15 -value $extraHUD_lastSave_checkBoxValue -changeCommand \"m341_extraHUD_lastSave_ValueChanged();\" extraHUD_lastSave_CheckBoxName;\n\n\n\n\t\t//Save preferences lastAutoSave checkbox\n\t\tint $extraHUD_lastAutoSave_checkBoxValue;\n\t\tglobal int $m341_extraHUD_lastAutoSave_userInput;\n\t\tstring $extraHUD_lastAutoSave_OptionVar = `optionVar -exists \"m341_extraHUD_lastAutoSaveCheckBox_VarName\"`;\n\t\tif ($extraHUD_lastAutoSave_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_lastAutoSaveCheckBox_VarName\" 0;\n\t\t\t$extraHUD_lastAutoSave_checkBoxValue = `optionVar -q \"m341_extraHUD_lastAutoSaveCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_lastAutoSave_checkBoxValue = `optionVar -q \"m341_extraHUD_lastAutoSaveCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"last auto save\" -width 103 -height 15 -value $extraHUD_lastAutoSave_checkBoxValue -changeCommand \"m341_extraHUD_lastAutoSave_ValueChanged();\" extraHUD_lastAutoSave_CheckBoxName;\n\n\t\t\n\t\t\n\t\t//Save preferences tool axis checkbox\n\t\tint $extraHUD_toolAxis_checkBoxValue;\n\t\tglobal int $m341_extraHUD_toolAxis_userInput;\n\t\tstring $extraHUD_toolAxis_OptionVar = `optionVar -exists \"m341_extraHUD_toolAxisCheckBox_VarName\"`;\n\t\tif ($extraHUD_toolAxis_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_toolAxisCheckBox_VarName\" 0;\n\t\t\t$extraHUD_toolAxis_checkBoxValue = `optionVar -q \"m341_extraHUD_toolAxisCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_toolAxis_checkBoxValue = `optionVar -q \"m341_extraHUD_toolAxisCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"tool axis\" -width 103 -height 15 -value $extraHUD_toolAxis_checkBoxValue -changeCommand \"m341_extraHUD_toolAxis_ValueChanged();\" extraHUD_toolAxis_CheckBoxName;\t\n\n\n\t\t//Save preferences cam distance checkbox\n\t\tint $extraHUD_camDistance_checkBoxValue;\n\t\tglobal int $m341_extraHUD_camDistance_userInput;\n\t\tstring $extraHUD_camDistance_OptionVar = `optionVar -exists \"m341_extraHUD_camDistanceCheckBox_VarName\"`;\n\t\tif ($extraHUD_camDistance_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_camDistanceCheckBox_VarName\" 0;\n\t\t\t$extraHUD_camDistance_checkBoxValue = `optionVar -q \"m341_extraHUD_camDistanceCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_camDistance_checkBoxValue = `optionVar -q \"m341_extraHUD_camDistanceCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"cam distance\" -width 103 -height 15 -value $extraHUD_camDistance_checkBoxValue -changeCommand \"m341_extraHUD_camDistance_ValueChanged();\" extraHUD_camDistance_CheckBoxName;\t\t\t\n\t\t\n\t\t\n\t\t//Save preferences cam selection checkbox\n\t\tint $extraHUD_camSelection_checkBoxValue;\n\t\tglobal int $m341_extraHUD_camSelection_userInput;\n\t\tstring $extraHUD_camSelection_OptionVar = `optionVar -exists \"m341_extraHUD_camSelectionCheckBox_VarName\"`;\n\t\tif ($extraHUD_camSelection_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_extraHUD_camSelectionCheckBox_VarName\" 0;\n\t\t\t$extraHUD_camSelection_checkBoxValue = `optionVar -q \"m341_extraHUD_camSelectionCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$extraHUD_camSelection_checkBoxValue = `optionVar -q \"m341_extraHUD_camSelectionCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"cam selection\" -width 103 -height 15 -value $extraHUD_camSelection_checkBoxValue -changeCommand \"m341_extraHUD_camSelection_ValueChanged();\" extraHUD_camSelection_CheckBoxName;\n\t\t\n\t\t\n\tshowWindow;\n\twindow -edit -width 100 -height 100 m341_extraHUD_ToolboxName;\n\t\n\tprint (\"Toolbox loaded \" + $m341_extraHUD_Version + \"\\n\");\n}\nm341_extraHUD_LaunchWindow();\n\n\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "DM" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "DM" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "distanceDim.png" 
        -image1 "distanceDim.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Dynamic Measuring Toolbox\nglobal string $m341_measureErVersion;\n$m341_measureErVersion = \"measureEr v1.6\";\n\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_measureEr_help()\n{\n\tglobal string $m341_measureEr_helpWindow;\n\tglobal string $m341_measureErVersion;\n\n\tif (`window -exists $m341_measureEr_helpWindow`)\n\t{\n\t\tglobal string $m341_measureEr_helpWindow;\n\t\tdeleteUI $m341_measureEr_helpWindow;\n\t}\n\t\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n    $helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\t$m341_measureEr_helpWindow = `window -title (\"Help \" + $m341_measureErVersion) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 340`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"WORKING UNITS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the current working units Maya is set to. For example, meters, centimeters, feet, etc.\\n\\n\";\n\n\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"FT IN M CM MM\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Sets the Maya working units to feet ft, inches in, meters m, centimeters cm, millimeters mm.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"DYNAMIC MEASURE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Creates a dynamic measure curve between two or more selected vertices.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-After the curve's been created you can move the objects or the vertices the curve is attached to and see the measure distance update in real time.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-The measure distance is displayed in whatever working unit Maya is currently set to. If you change the working unit after the measure curve's been created the distance will update to the new working unit.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"UNDO MEASURE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Removes the last created measure node. Maya's default undo function doesn't work correctly for measure nodes, it produces unexpected results which can lead to a messy scene so I've created a special undo button that removes the measure nodes correctly.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/bC1lhtDG0no?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/bC1lhtDG0no?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\t\t\n\n\t\n\tshowWindow $m341_measureEr_helpWindow;\n}\n\n\n//***********************************************************************************************************************************************************\n//Switch to Feet\nglobal proc m341_measureEr_switchToFeet()\n{\n\tstring $selection[] = `ls -sl`;\n\tcurrentUnit -linear \"ft\";\n\t\n\t//Update arc length nodes\n\tstring $arcLength[] = `ls -exactType (\"arcLengthDimension\")`;\n\tint $sizeArcLength = `size $arcLength`;\n\n\tif ($sizeArcLength > 0)\n\t{\n\t\tfor ($item in $arcLength)\n\t\t{\n\t\t\tselect $item;\n\t\t\tdgdirty;\n\t\t}\n\t}\n\t\n\tselect $selection;\n\tprint \"Working units set to feet\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Switch to Inch\nglobal proc m341_measureEr_switchToInch()\n{\n\tstring $selection[] = `ls -sl`;\n\tcurrentUnit -linear \"in\";\n\t\n\t//Update arc length nodes\n\tstring $arcLength[] = `ls -exactType (\"arcLengthDimension\")`;\n\tint $sizeArcLength = `size $arcLength`;\n\n\tif ($sizeArcLength > 0)\n\t{\n\t\tfor ($item in $arcLength)\n\t\t{\n\t\t\tselect $item;\n\t\t\tdgdirty;\n\t\t}\n\t}\n\t\n\tselect $selection;\n\tprint \"Working units set to inches\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Switch to Meters\nglobal proc m341_measureEr_switchToMeter()\n{\n\tstring $selection[] = `ls -sl`;\n\tcurrentUnit -linear \"m\";\n\t\n\t//Update arc length nodes\n\tstring $arcLength[] = `ls -exactType (\"arcLengthDimension\")`;\n\tint $sizeArcLength = `size $arcLength`;\n\n\tif ($sizeArcLength > 0)\n\t{\n\t\tfor ($item in $arcLength)\n\t\t{\n\t\t\tselect $item;\n\t\t\tdgdirty;\n\t\t}\n\t}\t\n\t\n\tselect $selection;\n\tprint \"Working units set to meters\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Switch to Centimeters\nglobal proc m341_measureEr_switchToCentimeter()\n{\n\tstring $selection[] = `ls -sl`;\n\tcurrentUnit -linear \"cm\";\n\t\n\t//Update arc length nodes\n\tstring $arcLength[] = `ls -exactType (\"arcLengthDimension\")`;\n\tint $sizeArcLength = `size $arcLength`;\n\n\tif ($sizeArcLength > 0)\n\t{\n\t\tfor ($item in $arcLength)\n\t\t{\n\t\t\tselect $item;\n\t\t\tdgdirty;\n\t\t}\n\t}\n\t\n\tselect $selection;\n\tprint \"Working units set to centimeters\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Switch to Millimeters\nglobal proc m341_measureEr_switchToMillimeter()\n{\n\tstring $selection[] = `ls -sl`;\n\tcurrentUnit -linear \"mm\";\n\t\n\t//Update arc length nodes\n\tstring $arcLength[] = `ls -exactType (\"arcLengthDimension\")`;\n\tint $sizeArcLength = `size $arcLength`;\n\n\tif ($sizeArcLength > 0)\n\t{\n\t\tfor ($item in $arcLength)\n\t\t{\n\t\t\tselect $item;\n\t\t\tdgdirty;\n\t\t}\n\t}\n\t\n\tselect $selection;\n\tprint \"Working units set to millimeters\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Dynamic Measure v1.1\nglobal proc m341_measureEr_measureDistance()\n{\n\t//Error\n\tstring $verts[] = `filterExpand -ex 1 -sm 31`;\n\tint $sizeVerts = `size $verts`;\n\tif ($sizeVerts < 2)\n\t{\n\t\terror \"Please select two or more vertices\";\n\t}\n\t\n\t\n\t//Store current tool\n\tstring $currentToolActive = `currentCtx`;\n\t\n\t//Query what component mode the user is in\n\tint $component_Vert = `selectType -q -vertex`;\n\tint $component_Multi = `selectType -q -meshComponents`;\n\t\n\n\t//Fix other unit measurements\n\tstring $workingUnit = `currentUnit -q`;\n\tcurrentUnit -linear \"cm\";\t\n\n\t//Get ordered verts\t\n    string $vertsOrdered[] = `ls -os -fl`;\n    int $sizeVertsOrdered = `size $vertsOrdered`;\n    $sizeVertsOrdered = $sizeVertsOrdered - 1;\n\t\n    toggleSelMode;\n    toggleSelMode;\n    selectMode -object;\n    string $objs[] = `ls -sl`;\n\n    //Create cube\n    string $tempCube[]= `polyCube -w 1 -h 1 -d 1 -sx 1 -sy 1 -sz 1 -ax 0 1 0 -cuv 4 -ch 0`;\n    scale 100 100 100;\n    select ($tempCube[0] + \".e[1]\");\n    //Extract curve\n    polyToCurve -form 0 -degree 1 -name \"length_01\";\n    DeleteHistory;\n    string $curve[] = `ls -sl`;\n    //ToggleCVs;\n    //rebuildCurve -ch 1 -rpo 1 -rt 0 -end 1 -kr 0 -kcp 0 -kep 1 -kt 0 -fr 0 -s 2 -d 1 -tol 0.1 \"length_01\";\n    rebuildCurve -ch 0 -rpo 1 -rt 0 -end 1 -kr 0 -kcp 0 -kep 1 -kt 0 -fr 0 -s $sizeVertsOrdered -d 1 -tol 0.1 $curve;\n    select $curve;\n    DeleteHistory;\n    CenterPivot;\n    move -rpr 0 0 0;\n    makeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1;\n    delete $tempCube;\n    //Get curve name because it changed\n    $curve = `ls -sl`;\n    //Get CVs of curve\n    select ($curve[0] + \".cv[*]\");\n    string $CVs[] = `ls -sl -fl`;\n\n    //Create measure group\n    select -clear;\n    doGroup 0 1 1;\n    rename \"dynamic_measure_01\";\n\tstring $groupName[] = `ls -sl`;\n\t\n\t//Store each measure node into an array so you can undo them\n\tglobal string $m341_measureEr_undoList[];\n\tappendStringArray($m341_measureEr_undoList, $groupName, 1);\n\n\n    //Move CVs to verts and cluster each CV\n    MoveTool;\n    string $cluster[];\n    float $moveToolPOS[];\n    float $vertPOS[];\n    float $locatorPOS[];\n    float $distance1;\n    float $distance2;\n    int $counter = 0;\n    \n    for ($item in $vertsOrdered)\n    {\n        //Get position of vert\n        select $vertsOrdered[$counter];\n        $vertPOS = `manipMoveContext -q -position \"Move\"`;\n        \n        //Move CV to vert\n        select $CVs[$counter];\n        move -a -os -wd $vertPOS[0] $vertPOS[1] $vertPOS[2];\n        CreateCluster;\n        $cluster = `ls -sl`;\n        HideSelectedObjects;\n\t    \n        //Create attach curve and locator\n        //Convert to edges\n        select $vertsOrdered[$counter];\n        ConvertSelectionToEdges;\n        string $edges[] = `ls -sl -fl`;\n        select $edges[0];\n        //Check if edge has correct vert attached to it\n        /////////////////////////////////////////////////////////////////////////////////\n\n        string $curveAttach[] = `polyToCurve -form 0 -degree 1`;\n        HideSelectedObjects;\n        CreateLocator;\n        string $locator[] = `ls -sl`;\n        scale 20 20 20;\n        select $curveAttach;\n        select -add $locator;\n        pathAnimation -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 0 -endTimeU 1;\n        select $locator;\n        HideSelectedObjects;\n        select $locator;\n\n        //Find motion path name\n        string $motionPath[] = `listConnections -type motionPath`;\n        //print ($motionPath[0] + \"_uValue\");\n        selectKey -k -t 0 -t 1 ($motionPath[0] + \"_uValue\");\n        cutKey -clear;\n\n        //Store locator position\n        $locatorPOS = `manipMoveContext -q -position \"Move\"`;\n\t\t//Measure locator distance from vert\n\t\tselect $vertsOrdered[$counter];\n        $vertPOS = `manipMoveContext -q -position \"Move\"`;\n\t\t$distance1 = sqrt( pow(($locatorPOS[0] - $vertPOS[0]) , 2) + pow(($locatorPOS[1] - $vertPOS[1]) , 2) + pow(($locatorPOS[2] - $vertPOS[2]) , 2));\n\n        //Move locator to other end of curve\n        float $uValue = `getAttr ($motionPath[0] + \".uValue\")`;\n        if ($uValue == 0)\n        {\n            setAttr ($motionPath[0] + \".uValue\") 1;\n        }\n        if ($uValue == 1)\n        {\n            setAttr ($motionPath[0] + \".uValue\") 0;\n        }\n        \n        //Store locator position\n        select $locator;\n        $locatorPOS = `manipMoveContext -q -position \"Move\"`;\n\t\t//Measure locator distance from vert\n\t\t$distance2 = sqrt( pow(($locatorPOS[0] - $vertPOS[0]) , 2) + pow(($locatorPOS[1] - $vertPOS[1]) , 2) + pow(($locatorPOS[2] - $vertPOS[2]) , 2));\n\t\t\n\t\tprint ($distance1 + \"\\n\");\n\t\tprint ($distance2 + \"\\n\");\n\t\t\n        //If locator at wrong end of curve move it back\n        if ($distance2 > $distance1)\n        {\n            $uValue = `getAttr ($motionPath[0] + \".uValue\")`;\n            if ($uValue == 0)\n            {\n                setAttr ($motionPath[0] + \".uValue\") 1;        \n            }\n    \n            if ($uValue == 1)\n            {\n                setAttr ($motionPath[0] + \".uValue\") 0;   \n            }\n        }\n        \n       \n        //Parent cluster under locator and then put cluster and attach curve in group\n        parent $cluster $locator;\n        parent $locator $groupName;\n        parent $curveAttach $groupName;\n        \n        $counter = $counter + 1;    \t\n    }\n\n\t//Attach measurment\n\tarcLengthDimension ($curve[0] + \".u[100.0]\");\n\n    \n    //Put length curve in group and hide group\n    parent $curve $groupName;\n\n\n\t//Set colour\n\tstring $curveRenamed[] = `ls -sl -fl`;\n\tstring $curveShapeName[] = `listRelatives -fullPath -s $curveRenamed`;\n\tsetAttr ($curveShapeName[0] + \".overrideEnabled\") 1;\n\tsetAttr ($curveShapeName[0] + \".overrideColor\") 17;\n\n\t//Set visible on top for 2022\n\tstring $mayaYear = `about -product`;\n\tstring $array[];\n\t$array = stringToStringArray($mayaYear, \" \");\n\tint $mayaVersionNumber = $array[1];\n\n\tif($mayaVersionNumber >= 2022)\n\t{\n\t\tsetAttr ($curveShapeName[0] + \".alwaysDrawOnTop\") 1;\n\t}\n\n\t\n\t//Set display of group to reference\n\t//string $groupShapeName[] = `listRelatives -fullPath -s $groupName`;\n\t//setAttr ($groupName[0] + \".overrideEnabled\") 1;\n\t//setAttr ($groupName[0] + \".overrideDisplayType\") 2;\n\t\n\t\n\t//SelectTool;\n    //select -clear;\n    float $distance = `arclen $curveRenamed`;\n\n\t//Switch back to user choosen measure unit\n\tcurrentUnit -linear $workingUnit;\n\t\n\t//Set selection back to vert mode and deselect all verts\n\tselect $objs;\n\tif ($component_Multi > 0)\n\t{\n\t\tSelectMultiComponentMask;\n\t}\n\telse\n\t{\n\t\tSelectVertexMask;\n\t}\n\tselect -deselect $vertsOrdered;\n\t\n\t\n\t//Bring back user tool\n\tsetToolTo $currentToolActive;\n\t\n    print (\"Distance = \" + $distance + \" \" + $workingUnit + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Undo Measure\nglobal proc m341_measureEr_undoMeasure()\n{\n\tglobal string $m341_measureEr_undoList[];\n\tselect $m341_measureEr_undoList[size($m341_measureEr_undoList)-1];\n\tdelete;\n\t\n\t//Remove last item from array so selection works each time run undo\n\tint $sizeUndoList = `size $m341_measureEr_undoList`;\n\t$sizeUndoList = $sizeUndoList - 1;\n\tstringArrayRemoveAtIndex($sizeUndoList, $m341_measureEr_undoList);\n\t\n\tprint \"Measure node removed\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Ordered select user pref\n//***********************************************************************************************************************************************************\nglobal proc m341_measureEr_orderedSelectUserPrefRevert()\n{\n\tglobal int $m341_measureEr_selectSwitch;\n\tif ($m341_measureEr_selectSwitch == 0)\n\t{\n\t\tselectPref -trackSelectionOrder false;\n\t\t//polyCube -w 1 -h 1 -d 1 -sx 1 -sy 1 -sz 1 -ax 0 1 0 -cuv 4 -ch 0;\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update userSetup regular checkbox\nglobal proc m341_measureEr_userSetup_regularCheckbox()\n{\n\tglobal string $m341_measureEr_print_textArray[];\n\t\n\t//Turn off notify if userSetup.mel changes\n\tint $securityUserSetup = `optionVar -exists \"SafeModeUserSetupHashOption\"`;\n\tif($securityUserSetup == 1)\n\t{\n\t\tint $notifyUserSetup = `optionVar -q \"SafeModeUserSetupHashOption\"`;\n\t\toptionVar -iv SafeModeUserSetupHashOption false;\n\t}\n\t\n\t//Find Maya current version script folder\n\tstring $mayaScriptDir = `internalVar -userScriptDir`;\n\t\n\t//Create file path\n\tstring $filePath = ($mayaScriptDir + \"userSetup.mel\");\n\t\n\t//See if userSetup.mel exists\n\tint $userSetupExists = `file -q -exists $filePath`;\n\t\n\t//Define file id\n\tint $fileId;\n\t\n\t//Create file if it doesn't exist and write text into it\n\tif ($userSetupExists == 0)\n\t{\n\t\t//Open file\n\t\t$fileId = `fopen ($mayaScriptDir + \"userSetup.mel\") \"a\"`;\n\t\t//Write text into file\n\t\tfprint $fileId (\"\\n\" + $m341_measureEr_print_textArray[0]);\n\t\t//Close file\n\t\tfclose $fileId;\n\t}\n\t\n\t\n\t//If file exists\n\tif ($userSetupExists == 1)\n\t{\n\t\t//Strip white space and add carriage return to append works correctly\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\t\n\t\t//Get The First Line\n\t\tstring $nextLine = `fgetline $fileId`;\n\t\t\n\t\t//Define string array\n\t\tstring $dataArray[];\n\t\t$dataArray = {\"\"};\n\t\t\n\t\twhile (size($nextLine) > 0)\n\t\t{\n\t\t\t//Strip whitespace from the beginning and end of line\n\t\t\tstring $cleanLine = strip($nextLine);\n\t\t\t\n\t\t\t//Add to array\n\t\t\t$dataArray[size($dataArray)] = $cleanLine;\n\t\t\n\t\t\t//Get next line and continue\n\t\t\t$nextLine = `fgetline $fileId`;\n\t\t}\n\t\t\n\t\t//Remove first line from array to fix line counting\n\t\tstringArrayRemoveAtIndex(0,$dataArray);\n\t\tfclose $fileId;\n\t\t\n\t\t//Add carriage return to end of file so append works consistently\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\n\t\t//Print array to file\n\t\tint $counter = 0;\n\t\tfor ($item in $dataArray)\n\t\t{\n\t\t\tfprint $fileId ($dataArray[$counter] + \"\\n\");\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t//Close File\n\t\tfclose $fileId;\n\t\n\t\t\n\t\t//Add or remove code from file if it exists\n\t\tglobal int $m341_measureEr_removeSwitch1;\n\t\t$m341_measureEr_removeSwitch1 = 0;\n\t\t//Search for existing string in file and remove it\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\tstring $nextLine2 = `fgetline $fileId`;\n\t\tstring $contents_1 = \"\";\n\t\tstring $contents_2 = \"\";\n\t\n\t\twhile(size ($nextLine2) > 0)\n\t\t{\n\t\t\t//Store line in array\n\t\t\t$lineArray = stringToStringArray($nextLine2, \"\");\n\t\t\t$contents_1 = $lineArray[0];\n\t\t\t\n\t\t\t//Get current line to search for set by each checkbox\n\t\t\tglobal string $m341_measureEr_searchFor[];\n\t\t\tif(`gmatch $lineArray[0] (\"*\" + $m341_measureEr_searchFor[0] + \"*\")`)\n\t\t\t{\n\t\t\t\t//Turn on remove text switch\n\t\t\t\tglobal int $m341_measureEr_removeSwitch1;\n\t\t\t\t$m341_measureEr_removeSwitch1 = 1;\n\t\t\t\t//polySphere -r 1 -sx 32 -sy 32 -ax 0 1 0 -cuv 2 -ch 1;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//Store text from each line to remove in $contents_2\n\t\t\t\t$contents_2 = ($contents_2 + $contents_1);\n\t\t\t}\n\t\t\t$nextLine2 = `fgetline $fileId`;\n\t\t}\n\t\tfclose $fileId;\n\t\n\t\t//Remove code from text file by pasting back the original file text\n\t\tif ($m341_measureEr_removeSwitch1 == 1)\n\t\t{\n\t\t\tstring $measureEr_removeStringArray[] = {$contents_2}; \n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\t//Print array to file  \n\t\t\tfprint $fileId $measureEr_removeStringArray[0];\n\t\t\n\t\t\t//Close file  \n\t\t\tfclose $fileId;\n\t\t}\n\t\n\t\t//Add code to text file\n\t\tif ($m341_measureEr_removeSwitch1 == 0)\n\t\t{\n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"a\"`;\n\t\n\t\t\t//Print text array to file\n\t\t\tfor ($item in $m341_measureEr_print_textArray)\n\t\t\t{\n\t\t\t\tfprint $fileId ($item);\n\t\t\t}\n\t\t\t//Close File\n\t\t\tfclose $fileId;\n\t\t}\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update Working units Checkbox Value\nglobal proc string m341_measureEr_workingUnits_Display()\n{\n\tstring $currentUnits = `currentUnit -q`;\n\treturn $currentUnits;\n}\n\nglobal proc m341_measureEr_workingUnits_ValueChanged()\n{\n\t//Section and block variables\n\tint $workingUnits_SectionVar = 1;\n\tint $workingUnits_NextFreeBlock = `headsUpDisplay -nextFreeBlock $workingUnits_SectionVar`;\n\t\n\t//Create a string array with text in it to add or remove from userSetup.mel\n\tglobal string $m341_measureEr_print_textArray[];\n\t$m341_measureEr_print_textArray = {\"/*m341_measureEr_workingUnits*/ global proc string m341_measureEr_workingUnits_Display(){string $currentUnits = `currentUnit -q`;return $currentUnits;}int $workingUnits_SectionVar = 1;int $workingUnits_NextFreeBlock = `headsUpDisplay -nextFreeBlock $workingUnits_SectionVar`;headsUpDisplay -section $workingUnits_SectionVar -block $workingUnits_NextFreeBlock -blockSize \\\"small\\\" -label \\\"Working Units:\\\" -labelFontSize \\\"small\\\" -command \\\"m341_measureEr_workingUnits_Display()\\\" -event \\\"linearUnitChanged\\\" measureEr_workingUnits_HUDName;\"};\n\t\n\t//Query the value of the checkbox and store in variable\n\tglobal int $m341_measureEr_workingUnits_userInput;\n\t$m341_measureEr_workingUnits_userInput = `checkBox -q -value measureEr_workingUnits_CheckBoxName`;\n\toptionVar -intValue \"m341_measureEr_workingUnitsCheckBox_VarName\" $m341_measureEr_workingUnits_userInput;\n\t//Print value\n\tif ($m341_measureEr_workingUnits_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem measureEr_workingUnits_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_measureEr_searchFor[];\n\t\t$m341_measureEr_searchFor = {\"/*m341_measureEr_workingUnits*/\"};\n\t\t\n\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\tm341_measureEr_userSetup_regularCheckbox();\n\t\tprint \"Working units checkbox off\\n\";\n\t}\n\telse\n\t{\n\t\t//-section is horizontal position of HUD element\n\t\t//-block is vertical position of HUD element\n\t\t//-blockSize is height\n\t\theadsUpDisplay -section $workingUnits_SectionVar -block $workingUnits_NextFreeBlock -blockSize \"small\" -label \"Working Units:\" -labelFontSize \"small\" -command \"m341_measureEr_workingUnits_Display()\" -event \"linearUnitChanged\" measureEr_workingUnits_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_measureEr_searchFor[];\n\t\t$m341_measureEr_searchFor = {\"/*m341_measureEr_workingUnits*/\"};\n\t\t\n\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\tm341_measureEr_userSetup_regularCheckbox();\n\t\t\n\t\t//Suppress spam prints\n\t\tm341_measureEr_SuppressPrint();\n\t\tprint \"Working units checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Supress Script Editor Prints\nglobal proc m341_measureEr_SuppressPrint()\n{\n\tcommandEcho -af {\"m341_measureEr_refreshTimer\", \"m341_measureEr_lastSave_Display()\", \"m341_measureEr_lastSaveBroken\", \"m341_measureEr_lastAutoSave_Display()\", \"m341_measureEr_lastAutoSaveBroken\", \"m341_measureEr_upAxis_Display()\", \"m341_measureEr_camSelection_Display()\", \"m341_measureEr_toolAxis_Display()\", \"m341_measureEr_selectedItems_Display()\", \"m341_measureEr_assignedMaterials_Display()\", \"m341_measureEr_uvSet_Display()\"};\n}\t\t\n\n\n\n//***********************************************************************************************************************************************************\n//Window and Buttons\nglobal proc m341_measureEr_launchWindow()\n{\n\tif (`window -exists m341_measureEr_windowName`)\n\t{\n\t\tdeleteUI m341_measureEr_windowName;\n\t}\n\n\t\n\t//Colours\n\tfloat $r[] = {0.698, 0.259, 0.263};\n\tfloat $g[] = {0.282, 0.675, 0.282};\n\tfloat $b[] = {0.145, 0.463, 0.737};\n\tfloat $grey[] = {0.51, 0.51, 0.51};\n\tfloat $red[] = {0.70, 0.39, 0.34};\n\tfloat $orange[] = {0.761, 0.522, 0.314};\n\tfloat $yellow[] = {0.72, 0.68, 0.39};\n\tfloat $green[] = {0.34, 0.59, 0.47};\n\tfloat $greenYellow[] = {0.50, 0.67, 0.37};\n\tfloat $blue[] = {0.32, 0.59, 0.72};\n\tfloat $seafoam[] = {0.427, 0.643, 0.643};\n\tfloat $purple[] = {0.596, 0.529, 0.769};\n\tfloat $purpleDrank[] = {0.451, 0.529, 0.78};\n\t\n\t\n\t//Turn on ordered selection\n\tglobal int $m341_measureEr_selectSwitch;\n\t$m341_measureEr_selectSwitch = 0;\n\t$m341_measureEr_selectSwitch = `selectPref -q -trackSelectionOrder`;\n\tselectPref -trackSelectionOrder true;\t\n\t\n\tglobal string $m341_measureErVersion;\n\twindow -title $m341_measureErVersion -toolbox true -sizeable true -resizeToFitChildren true -closeCommand \"m341_measureEr_orderedSelectUserPrefRevert();\" m341_measureEr_windowName;\n\tcolumnLayout -adjustableColumn true;\n\ttext -label \"by Malcolm341\";\n\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-labelOffset 30\n\t\t\t-label \"click for help\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 97\n\t\t\t-height 15\n\t\t\t-command \"m341_measureEr_help;\";\n\n\n\t\t//Save preferences Working units checkbox\n\t\tint $measureEr_workingUnits_checkBoxValue;\n\t\tglobal int $m341_measureEr_workingUnits_userInput;\n\t\tstring $measureEr_workingUnits_OptionVar = `optionVar -exists \"m341_measureEr_workingUnitsCheckBox_VarName\"`;\n\t\tif ($measureEr_workingUnits_OptionVar == 0)\n\t\t{\n\t\t\t//Set default value\n\t\t\toptionVar -intValue \"m341_measureEr_workingUnitsCheckBox_VarName\" 0;\n\t\t\t$measureEr_workingUnits_checkBoxValue = `optionVar -q \"m341_measureEr_workingUnitsCheckBox_VarName\"`;\n\t\t}\n\t\telse\n\t\t{\n\t\t\t//Query from prefs file\n\t\t\t$measureEr_workingUnits_checkBoxValue = `optionVar -q \"m341_measureEr_workingUnitsCheckBox_VarName\"`;\n\t\t}\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\tcheckBox -label \"Working Units\" -value $measureEr_workingUnits_checkBoxValue -changeCommand \"m341_measureEr_workingUnits_ValueChanged();\" measureEr_workingUnits_CheckBoxName;\n\n\n\n\t\t//setParent ..;\n\t\t//rowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\t//text -label \"Working Units\";\n\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 18\n\t\t\t-height 18\n\t\t\t-label \"ft\"\n\t\t\t-command \"m341_measureEr_switchToFeet;\"\n\t\t\t-commandRepeatable 0;\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 18\n\t\t\t-height 18\n\t\t\t-label \"in\"\n\t\t\t-command \"m341_measureEr_switchToInch;\"\n\t\t\t-commandRepeatable 0;\n\t\t\tseparator -width 1 -style \"none\";\n\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 18\n\t\t\t-height 18\n\t\t\t-label \"m\"\n\t\t\t-command \"m341_measureEr_switchToMeter;\"\n\t\t\t-commandRepeatable 0;\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 19\n\t\t\t-height 18\n\t\t\t-label \"cm\"\n\t\t\t-command \"m341_measureEr_switchToCentimeter;\"\n\t\t\t-commandRepeatable 0;\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 20\n\t\t\t-height 18\n\t\t\t-label \"mm\"\n\t\t\t-command \"m341_measureEr_switchToMillimeter;\"\n\t\t\t-commandRepeatable 0;\n\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.72 0.68 0.39\n\t\t\t-width 97\n\t\t\t-label \"dynamic measure\"\n\t\t\t-command \"m341_measureEr_measureDistance;\"\n\t\t\t-commandRepeatable 1;\n\t\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor $red[0] $red[1] $red[2]\n\t\t\t-width 97\n\t\t\t-label \"undo measure\"\n\t\t\t-command \"m341_measureEr_undoMeasure;\"\n\t\t\t-commandRepeatable 1;\n\t\t\n\n\t\t\t\n\tshowWindow;\n\twindow -edit -width 90 -height 90 m341_measureEr_windowName;\n\t\n\tprint (\"Toolbox loaded \" + $m341_measureErVersion + \"\\n\");\n}\n\nm341_measureEr_launchWindow();\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "pivot" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "pivot" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconModify.png" 
        -image1 "menuIconModify.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Move Pivot to Selection Center v1.6\n\nglobal proc m341_movePivotToSelectionCenter()\n{\n\t//Change mode to 1 or 2 for different scripts\n\t//1 Move pivot to selection center\n\t//2 Move pivot to selection center on each mesh\n\tint $mode = 1;\n\n\t//Move pivot to selection center\n\tif ($mode == 1)\n\t{\n\t\tint $MPTS_Item;\n\t\tfloat $vert_location[3];\n\t\tfloat $center_location[3];\n\t\tstring $selected[];\n\t\t$selected = `ls -sl`;\n\t\t\n\t\t//Check for verts\n\t\tConvertSelectionToVertices;\n\t\tstring $selected_Verts[] = `filterExpand -ex 1 -sm 31`;\n\t\tint $sizeSelect_Verts = `size $selected_Verts`;\n\t\n\t\t//Check for CVs\n\t\tstring $selected_CVs[] = `filterExpand -ex 1 -sm 28`;\n\t\tint $sizeSelect_CVs = `size $selected_CVs`;\n\t\t\n\t\t\n\t\tstring $nodeType[] = `ls -sl -exactType transform`;\n\t\tint $sizeNodeType = `size $nodeType`;\n\t\t\n\t\t//Convert selection to CVs if NURBS found\n\t\tif ($sizeNodeType > 0 && $sizeSelect_Verts == 0 && $sizeSelect_CVs == 0)\n\t\t{\n\t\t\tSelectCVsMask;\n\t\t\tSelectAll;\n\t\t\t//eval \"select ($selected[0] + \\\".cv[\"\"*\"\"]\\\");\";\n\t\t\t//select nurbsPlane1.cv[\"*\"];\n\t\t\t//select nurbsPlane1.cv[1];\n\t\t}\n\t\t\n\t\t$selected_Verts = `ls -sl -fl`;\n\t\tint $selected_Verts_size = `size $selected_Verts`;\n\t\tstring $find_ShapeNode[] = `ls -sl -o`;\n\t\tselect $find_ShapeNode[0];\n\t\tstring $find_Transform[] = `pickWalk -d up`;\n\t\n\t\tfor ($MPTS_Item = 0; $MPTS_Item < $selected_Verts_size; $MPTS_Item++)\n\t\t{\n\t\t\t$vert_location = `pointPosition -world $selected_Verts[$MPTS_Item]`;\n\t\t\t$center_location[0] += $vert_location[0];\n\t\t\t$center_location[1] += $vert_location[1];\n\t\t\t$center_location[2] += $vert_location[2];\n\t\t}\n\t\n\t\t$center_location[0] /= $selected_Verts_size;\n\t\t$center_location[1] /= $selected_Verts_size;\n\t\t$center_location[2] /= $selected_Verts_size;\n\t\n\t\txform -worldSpace -pivots $center_location[0] $center_location[1] $center_location[2];\n\t\t\n\t\t\n\t\t//Select object and print\n\t\ttoggleSelMode;\n\t\ttoggleSelMode;\n\t\tselectMode -object;\n\t\t\n\t\tprint \"Pivot moved to selection center\\n\";\n\t}\n\t\n\t\n\t//Move pivot to selection center on each mesh\n\tif ($mode == 2)\n\t{\n\t\t//Store current tool\n\t\tstring $currentToolActive = `currentCtx`;\n\t\tMoveTool;\n\t\t\n\t\t//Store meshes and verts\n\t\tint $counter = 0;\n\t\tstring $meshArray[] = `ls -sl -o`;\n\t\tint $sizeMeshArray = `size $meshArray`;\n\t\tConvertSelectionToVertices;\n\t\tstring $verts[] = `filterExpand -ex 1 -sm 31`;\n   \t\t\n\t\t//Select vert on mesh and move pivot for each mesh to vert\n\t\tfor($i=0; $i<$sizeMeshArray; ++$i)\n\t\t{\n            select $meshArray[$counter];\n            pickWalk -d up;\n            string $name[] = `ls -sl`;\n            select -clear;\n\n            //Get move tool position for selected components on each mesh\n            for ($item in $verts)\n            {\n            \tif (`gmatch $item ($name[0] + \"*\")`)\n            \t{\n\t\t\t\t\t//print \"Found it\\n\";\n\t\t\t\t\tselect -add $item;\n            \t}\n            }\n\t\t\t\n\t\t\t\n\t\t\t//Get the selected vertices\n            string $selectedVerts[] = `ls -sl -fl`;\n\n            //Initialize variables for summing vertex positions\n            float $sumX = 0.0;\n            float $sumY = 0.0;\n            float $sumZ = 0.0;\n\n            //Loop through each selected vertex\n            for ($vert in $selectedVerts)\n            {\n                //Get the world space position of the vertex\n                float $pos[] = `pointPosition -w $vert`;\n\n                //Accumulate the X, Y, and Z coordinates\n                $sumX += $pos[0];\n                $sumY += $pos[1];\n                $sumZ += $pos[2];\n            }\n\n            //Calculate the average position\n            int $numVerts = size($selectedVerts);\n            float $centerX = $sumX / $numVerts;\n            float $centerY = $sumY / $numVerts;\n            float $centerZ = $sumZ / $numVerts;\n\n            //Move pivot to selection center\n            manipPivot -p $centerX $centerY $centerZ;\n\t\t\t\n\t\t\t\n\t\t\t//Move pivot to move tool\n            float $moveToolPOS[] = `manipMoveContext -q -position \"Move\"`;\n            select $name;\n            xform -worldSpace -pivots $moveToolPOS[0] $moveToolPOS[1] $moveToolPOS[2];\n\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t\n\t\tselect $meshArray;\n\t\tpickWalk -d up;\n\t\t\n\t\t//Bring back user tool\n\t\tsetToolTo $currentToolActive;\n\t\t\n\t\tprint \"Pivot moved to selection center on each mesh\\n\";\n\t}\n}\nm341_movePivotToSelectionCenter();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Move Pivot to Selection Center Multiple" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Move Pivot to Selection Center v1.7\n\nglobal proc m341_movePivotToSelectionCenter()\n{\n\t//Change mode to 1 or 2 for different scripts\n\t//1 Move pivot to selection center\n\t//2 Move pivot to selection center on each mesh\n\tint $mode = 2;\n\n\n    int $sizeSelection = size(`ls -sl -fl`);\n    if ($sizeSelection == 0)\n    {\n        error \"Nothing selected\\n\";\n    }\n\n\n\t//Move pivot to selection center\n\tif ($mode == 1)\n\t{\n\t\tint $MPTS_Item;\n\t\tfloat $vert_location[3];\n\t\tfloat $center_location[3];\n\t\tstring $selected[];\n\t\t$selected = `ls -sl`;\n\t\t\n\t\t//Check for verts\n\t\tConvertSelectionToVertices;\n\t\tstring $selected_Verts[] = `filterExpand -ex 1 -sm 31`;\n\t\tint $sizeSelect_Verts = `size $selected_Verts`;\n\t\n\t\t//Check for CVs\n\t\tstring $selected_CVs[] = `filterExpand -ex 1 -sm 28`;\n\t\tint $sizeSelect_CVs = `size $selected_CVs`;\n\t\t\n\t\t\n\t\tstring $nodeType[] = `ls -sl -exactType transform`;\n\t\tint $sizeNodeType = `size $nodeType`;\n\t\t\n\t\t//Convert selection to CVs if NURBS found\n\t\tif ($sizeNodeType > 0 && $sizeSelect_Verts == 0 && $sizeSelect_CVs == 0)\n\t\t{\n\t\t\tSelectCVsMask;\n\t\t\tSelectAll;\n\t\t\t//eval \"select ($selected[0] + \\\".cv[\"\"*\"\"]\\\");\";\n\t\t\t//select nurbsPlane1.cv[\"*\"];\n\t\t\t//select nurbsPlane1.cv[1];\n\t\t}\n\t\t\n\t\t$selected_Verts = `ls -sl -fl`;\n\t\tint $selected_Verts_size = `size $selected_Verts`;\n\t\tstring $find_ShapeNode[] = `ls -sl -o`;\n\t\tselect $find_ShapeNode[0];\n\t\tstring $find_Transform[] = `pickWalk -d up`;\n\t\n\t\tfor ($MPTS_Item = 0; $MPTS_Item < $selected_Verts_size; $MPTS_Item++)\n\t\t{\n\t\t\t$vert_location = `pointPosition -world $selected_Verts[$MPTS_Item]`;\n\t\t\t$center_location[0] += $vert_location[0];\n\t\t\t$center_location[1] += $vert_location[1];\n\t\t\t$center_location[2] += $vert_location[2];\n\t\t}\n\t\n\t\t$center_location[0] /= $selected_Verts_size;\n\t\t$center_location[1] /= $selected_Verts_size;\n\t\t$center_location[2] /= $selected_Verts_size;\n\t\n\t\txform -worldSpace -pivots $center_location[0] $center_location[1] $center_location[2];\n\t\t\n\t\t\n\t\t//Select object and print\n\t\ttoggleSelMode;\n\t\ttoggleSelMode;\n\t\tselectMode -object;\n\t\t\n\t\tprint \"Pivot moved to selection center\\n\";\n\t}\n\t\n\t\n\t//Move pivot to selection center on each mesh\n\tif ($mode == 2)\n\t{\n\t\t//Store current tool\n\t\tstring $currentToolActive = `currentCtx`;\n\t\tMoveTool;\n\t\t\n\t\t//Store meshes and verts\n\t\tint $counter = 0;\n\t\tstring $meshArray[] = `ls -sl -o`;\n\t\tint $sizeMeshArray = `size $meshArray`;\n\t\tConvertSelectionToVertices;\n\t\tstring $verts[] = `filterExpand -ex 1 -sm 31`;\n   \t\t\n\t\t//Select vert on mesh and move pivot for each mesh to vert\n\t\tfor($i=0; $i<$sizeMeshArray; ++$i)\n\t\t{\n            select $meshArray[$counter];\n            pickWalk -d up;\n            string $name[] = `ls -sl`;\n            select -clear;\n\n            //Get move tool position for selected components on each mesh\n            for ($item in $verts)\n            {\n            \tif (`gmatch $item ($name[0] + \".vtx*\")`)\n            \t{\n\t\t\t\t\t//print \"Found it\\n\";\n\t\t\t\t\tselect -add $item;\n            \t}\n            }\n\n            //Reset pivot\n            manipPivot -rp;\n\t\t\t\n\t\t\t//Move pivot to move tool\n            float $moveToolPOS[] = `manipMoveContext -q -position \"Move\"`;\n            select $name;\n            xform -worldSpace -pivots $moveToolPOS[0] $moveToolPOS[1] $moveToolPOS[2];\n\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t\n\t\tselect $meshArray;\n\t\tpickWalk -d up;\n\t\t\n\t\t//Bring back user tool\n\t\tsetToolTo $currentToolActive;\n\t\t\n\t\tprint \"Pivot moved to selection center on each mesh\\n\";\n\t}\n}\nm341_movePivotToSelectionCenter();" )
        -mi "Help pivot" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_HelpTransformTools()\n{\n\tglobal string $m341_TransformTools_HelpWindow;\n\n\tif (`window -exists $m341_TransformTools_HelpWindow`)\n\t{\n\t\tglobal string $m341_TransformTools_HelpWindow;\n\t\tdeleteUI $m341_TransformTools_HelpWindow;\n\t}\n\t\n\t//Left justify help window to center of Maya window\n    int $helpLeftEdge = `window -q -width MayaWindow`;\n    $helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\t$m341_TransformTools_HelpWindow = `window -title \"Help Transform Tools\" -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 165`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PIVOT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Moves the pivot to the center of selected components, also works on a single object or multipe objects.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-If you right click the shelf button you can move the pivots of individual meshes at the same time by selecting components on multiple meshes. Each mesh will have its pivot moved to the center of selected components on itself.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEOS HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_TransformTools_HelpWindow;\n}\nm341_HelpTransformTools();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "reBuild" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "reBuild" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconModify.png" 
        -image1 "menuIconModify.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Rebuild transform v1.4\n\nglobal proc m341_rebuildTransform()\n{\n\t//Store current tool\n\tstring $currentToolActive = `currentCtx`;\n\n\tint $keepPivot = 0;\n\n\t//Store as one undo\n\tundoInfo -openChunk;\n\n\t//Fix other unit measurements\n\tstring $mayaUnits = `currentUnit -q`;\n\tcurrentUnit -linear \"cm\";\t\n\t\n\tstring $component[] = `ls -fl -sl`;\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\tstring $object[] = `ls -sl`;\n\tselect $component;\n\t\n\t//Switch to move tool component mode\n\tstring $maCurrentMayaYear = `about -product`;\n\tif(`gmatch $maCurrentMayaYear \"*2017*\"`)\n\t{\n\t\tMoveTool;\n\t\tmanipMoveContext -edit -mode 9 Move;\n\t}\n\telse\n\t{\n\t\tMoveTool;\n\t\tmanipMoveContext -edit -mode 10 Move;\n\t}\n\t\n\t//Get move tool pivot position\n\tfloat $componentPivot[] = `manipMoveContext -q -position \"Move\"`;\n\t//Get move tool angle and convert radius to degrees\n\tfloat $componentAngle[] = `manipMoveContext -q -orientAxes \"Move\"`;\n\t$componentAngle[0] = rad_to_deg ($componentAngle[0]);\n\t$componentAngle[1] = rad_to_deg ($componentAngle[1]);\n\t$componentAngle[2] = rad_to_deg ($componentAngle[2]);\n\n\tselect $object;\n\t\n\tif ($keepPivot == 0)\n\t{\n\t\t//Move pivot to component\n\t\txform -worldSpace -pivots $componentPivot[0] $componentPivot[1] $componentPivot[2];\t\n\t}\n\n\t//Duplicate faces and delete all except one to avoid slow bake pivot bug\n\tduplicate;\n\tConvertSelectionToFaces;\n\tstring $componentsTooMany[] = `ls -sl -fl`;\n\tselect $componentsTooMany[0];\n\tInvertSelection;\n\tDelete;\n\tselect $componentsTooMany[0];\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\t//Adjust rotate pivot so it aligns with average component selection from above\n\tmanipPivot -o $componentAngle[0] $componentAngle[1] $componentAngle[2];\n\tbakeCustomToolPivot 1 1;\n\t\n\tDeleteHistory;\t\n\tstring $rotatorObj[] = `ls -sl`;\n\t\n\t//Parent object under face with rebuilt transform\n\tparent $object $rotatorObj;\n\n\t//Unrotate parent face so child gets rotated back to zero correctly\n\tselect $rotatorObj;\n\trotate -os -fo 0 0 0;\n\n\t//Freeze transform of object and unparent\n\tselect $object;\n\tmakeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1;\n\tparent -w;\n\t\n\t\n\t//Apply lattice and group all object and lattice\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\n\t//Rotate group back to original angle and clean up\n\trotate -r -os -fo $componentAngle[0] $componentAngle[1] $componentAngle[2];\n\tdelete $rotatorObj;\n\t\n\t//Switch back to user choosen measure unit\n\tcurrentUnit -linear $mayaUnits;\n\t\n\t//Undo above chunk\n    undoInfo -closeChunk;\n\t\n\t//Bring back user tool\n\tsetToolTo $currentToolActive;\n    \n    print \"Rebuild transform complete\";\n}\nm341_rebuildTransform();\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help reBuild" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_HelpTransformTools()\n{\n\tglobal string $m341_TransformTools_HelpWindow;\n\n\tif (`window -exists $m341_TransformTools_HelpWindow`)\n\t{\n\t\tglobal string $m341_TransformTools_HelpWindow;\n\t\tdeleteUI $m341_TransformTools_HelpWindow;\n\t}\n\t\n\t$m341_TransformTools_HelpWindow = `window -title \"Transform Tools Help\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 165`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"REBUILD\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Select a single component and run the tool to rebuild the translate and rotate values to align with the world correctly.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-For best results select a single planar face, also works with multiple components selected, but will produce an averaged alignment of the selected components which may or may not be useful.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEOS HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_TransformTools_HelpWindow;\n}\nm341_HelpTransformTools();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "faceY" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "faceY" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconModify.png" 
        -image1 "menuIconModify.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Face Y Axis v1.4\n\n//Unfreeze transform v1.2\nglobal proc m341_unfreezeTransform()\n{\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\t\n\tstring $unfreeze_Selection[] = `ls -sl`;\n\tfor ($unfreeze_Item in $unfreeze_Selection)\n\t{\n    \t//Get rotate pivot info from object\n\t\tfloat $worldRotatePivot[];\n    \tmakeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1 $unfreeze_Item;\n\t\tfloat $worldTranslatePivot[] = `getAttr ($unfreeze_Item + \".rotatePivot\")`;\n\t\tsetAttr ($unfreeze_Item + \".t\") (-1 * $worldTranslatePivot[0]) (-1 *$worldTranslatePivot[1]) (-1 *$worldTranslatePivot[2]);\n\n\t    //Paste back transform so it has correct transform from zero\n\t\tmakeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1 $unfreeze_Item;\n\t\tsetAttr ($unfreeze_Item +\".t\") $worldTranslatePivot[0] $worldTranslatePivot[1] $worldTranslatePivot[2];\n\t\tsetAttr ($unfreeze_Item +\".r\") $worldRotatePivot[0] $worldRotatePivot[1] $worldRotatePivot[2];\n\t}\n}\n\n\nglobal proc m341_faceYup()\n{\n\t//Store as one undo\n\tundoInfo -openChunk;\n\t\n\t\n\t//Fix other unit measurements\n\tstring $mayaUnits = `currentUnit -q`;\n\tcurrentUnit -linear \"cm\";\t\n\n\tstring $component[] = `ls -fl -sl`;\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\tstring $object[] = `ls -sl`;\n\tselect $component;\n\t\t\n\t//Store rebuilt rotation and translation in variable for later\n\t//Switch to move tool component mode\n\tstring $maCurrentMayaYear = `about -product`;\n\tif(`gmatch $maCurrentMayaYear \"*2017*\"`)\n\t{\n\t\tMoveTool;\n\t\tmanipMoveContext -edit -mode 9 Move;\n\t}\n\telse\n\t{\n\t\tMoveTool;\n\t\tmanipMoveContext -edit -mode 10 Move;\n\t}\n\t\n\t//Get move tool pivot position\n\tfloat $locatorTargetPOS[] = `manipMoveContext -q -position \"Move\"`;\n\t//Get move tool angle and convert radius to degrees\n\tfloat $locatorTargetAngle[] = `manipMoveContext -q -orientAxes \"Move\"`;\n\t$locatorTargetAngle[0] = rad_to_deg ($locatorTargetAngle[0]);\n\t$locatorTargetAngle[1] = rad_to_deg ($locatorTargetAngle[1]);\n\t$locatorTargetAngle[2] = rad_to_deg ($locatorTargetAngle[2]);\n\n    //Center pivot\n\tselect $object;\n\tCenterPivot;\n\n\t//Duplicate faces and delete all except one to avoid slow bake pivot bug\n\tduplicate;\n\tConvertSelectionToFaces;\n\tstring $componentsTooMany[] = `ls -sl -fl`;\n\tselect $componentsTooMany[0];\n\tInvertSelection;\n\tDelete;\n\tselect $componentsTooMany[0];\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\t//Adjust rotate pivot so it aligns with average component selection from above\n\tmanipPivot -o $locatorTargetAngle[0] $locatorTargetAngle[1] $locatorTargetAngle[2];\n\tbakeCustomToolPivot 1 1;\n\tDeleteHistory;\t\n\tstring $rotatorObj[] = `ls -sl`;\n\t\t\n\t//Parent object under face with rebuilt transform\n\tparent $object $rotatorObj;\n\n\t//Unrotate parent face so child gets rotated back to zero correctly\n\tselect $rotatorObj;\n\trotate -os -fo 0 0 0;\n\n\t//Freeze transform of object and unparent\n\tselect $object;\n\tmakeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1;\n\tparent -w;\n\n\t//Rotate group back to original angle and clean up\n\tdelete $rotatorObj;\n\t//Check if scene Z-Up and fix it with extra rotation\n\tstring $m341_upAxis = `upAxis -q -axis`;\n\tif(`gmatch $m341_upAxis \"*z*\"`)\n\t{\n\t\trotate -r -os -fo 0 -90 0; \n\t}\n\telse\n\t{\n\t\trotate -r -os -fo 0 0 90;\t\t\n\t}\n\tmakeIdentity -apply true -translate true -rotate true;\n\tm341_unfreezeTransform();\n\t\t\t\n   \tif(`gmatch $m341_upAxis \"*z*\"`)\n\t{\n\t    print \"Aligned to Z up\";\n\t}\n\telse\n\t{\n\t    print \"Aligned to Y up\";\n\t}\n\t\n\t//Switch back to user choosen measure unit\n\tcurrentUnit -linear $mayaUnits;\n\t\n\t//Undo above chunk\n    undoInfo -closeChunk;\n}\nm341_faceYup();\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help faceY" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_HelpTransformTools()\n{\n\tglobal string $m341_TransformTools_HelpWindow;\n\n\tif (`window -exists $m341_TransformTools_HelpWindow`)\n\t{\n\t\tglobal string $m341_TransformTools_HelpWindow;\n\t\tdeleteUI $m341_TransformTools_HelpWindow;\n\t}\n\t\n\t$m341_TransformTools_HelpWindow = `window -title \"Transform Tools Help\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 165`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"FACE Y\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Select a single component and run the tool to rotate the object so that component faces Y up. This is handy for unrotating a model so you can work on it aligned with the world axis.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-For best results select a single planar face.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEOS HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/GT5xDtaWNxk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/k0rCzRIHsEs?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_TransformTools_HelpWindow;\n}\nm341_HelpTransformTools();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
