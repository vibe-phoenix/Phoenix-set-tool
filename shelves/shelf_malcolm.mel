50 || $interfaceDPI == 144)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.50;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $ten;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 2.0 || $interfaceDPI == 192)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 2.0;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $ten;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $ten;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\t\t\t\n\t}\n\t\t\n\t//Create a string array with text in it to add or remove from userSetup.mel\n\tglobal string $m341_shelfSizer_print_textArray[];\n\t$m341_shelfSizer_print_textArray = {\"/*m341_shelfSizer_shelfHeight*/layout -e -height \" + $m341_shelfSizer_currentHeight + \" MainShelfLayout\\;\"};\n\t\n\t//Add/Remove shelf height text from userSetup.mel using global variable at top of proc\n\tm341_shelfSizer_userSetup();\n\t\n\t//Bring back tabs user setting\n\tif ($tabsVisible == 0)\n\t{\n\t\ttoggleShelfTabs;\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\tprint (\"Shelf height decreased to \" + $m341_shelfSizer_currentHeight + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Decrease 1\nglobal proc m341_shelfSizer_decrease_1()\n{\n\t//Turn shelf tabs on to prevent tool from not working\n\tint $tabsVisible = `shelfTabLayout -q -tabsVisible ShelfLayout`;\n\tif ($tabsVisible == 0)\n\t{\n\t\tevalDeferred \"toggleShelfTabs\";\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\t\n\t\n\t//Create search text specific to this checkbox to use with global add/remove proc above\n\tglobal string $m341_shelfSizer_searchFor[];\n\t$m341_shelfSizer_searchFor = {\"/*m341_shelfSizer_shelfHeight*/\"};\n\t\n\t\n\t//Edit height\n\tglobal int $m341_shelfSizer_currentHeight;\n\t$m341_shelfSizer_currentHeight = `layout -q -height MainShelfLayout`;\n\t\n\t//Reset shelf to fix bug where it won't get smaller\n\tm341_shelfSizer_Reset();\n\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\n\tint $one = 1;\n\tstring $mayaMac = `about -mac`;\n\tif($mayaMac == 1)\n\t{\n\t\t//Mac version\n\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $one;\n\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t}\n\n\telse\n\t{\n\t\t//PC version\n\t\t//Find current custom interface scaling and DPI\n\t\tfloat $interfaceScaling = `mayaDpiSetting -q -scaleValue`;\n\t\tint $interfaceDPI = `mayaDpiSetting -q -systemDpi`;\t\n\t\n\t\tif ($interfaceScaling == 1.25)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.25;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $one;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;    \n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 1.50 || $interfaceDPI == 144)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 1.50;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $one;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse if ($interfaceScaling == 2.0 || $interfaceDPI == 192)\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight / 2.0;\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $one;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\n\t\t\n\t\telse\n\t\t{\n\t\t\t$m341_shelfSizer_currentHeight = $m341_shelfSizer_currentHeight - $one;\n\t\t\tlayout -e -height $m341_shelfSizer_currentHeight MainShelfLayout;\n\t\t}\t\t\t\n\t}\n\n\t//Create a string array with text in it to add or remove from userSetup.mel\n\tglobal string $m341_shelfSizer_print_textArray[];\n\t$m341_shelfSizer_print_textArray = {\"/*m341_shelfSizer_shelfHeight*/layout -e -height \" + $m341_shelfSizer_currentHeight + \" MainShelfLayout\\;\"};\n\t\n\t//Add/Remove shelf height text from userSetup.mel using global variable at top of proc\n\tm341_shelfSizer_userSetup();\n\t\n\t//Bring back tabs user setting\n\tif ($tabsVisible == 0)\n\t{\n\t\ttoggleShelfTabs;\n\t\tupdateShelfInitialSize(\"Shelf\" );\n\t}\n\tprint (\"Shelf height decreased to \" + $m341_shelfSizer_currentHeight + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Update userSetup file\nglobal proc m341_shelfSizer_userSetup()\n{\n\tglobal string $m341_shelfSizer_print_textArray[];\n\t\n\t//Turn off notify if userSetup.mel changes\n\tint $securityUserSetup = `optionVar -exists \"SafeModeUserSetupHashOption\"`;\n\tif($securityUserSetup == 1)\n\t{\n\t\tint $notifyUserSetup = `optionVar -q \"SafeModeUserSetupHashOption\"`;\n\t\toptionVar -iv SafeModeUserSetupHashOption false;\n\t}\n\t\n\t//Find Maya current version script folder\n\tstring $mayaScriptDir = `internalVar -userScriptDir`;\n\t\n\t//Create file path\n\tstring $filePath = ($mayaScriptDir + \"userSetup.mel\");\n\t\n\t//See if userSetup.mel exists\n\tint $userSetupExists = `file -q -exists $filePath`;\n\t\n\t//Define file id\n\tint $fileId;\n\t\n\t//Create file if it doesn't exist and write text into it\n\tif ($userSetupExists == 0)\n\t{\n\t\t//Open file\n\t\t$fileId = `fopen ($mayaScriptDir + \"userSetup.mel\") \"a\"`;\n\t\t//Write text into file\n\t\tfprint $fileId (\"\\n\" + $m341_shelfSizer_print_textArray[0]);\n\t\t//Close file\n\t\tfclose $fileId;\n\t}\n\t\n\t\n\t//If file exists\n\tif ($userSetupExists == 1)\n\t{\n\t\t//Strip white space and add carriage return to append works correctly\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\t\n\t\t//Get The First Line\n\t\tstring $nextLine = `fgetline $fileId`;\n\t\t\n\t\t//Define string array\n\t\tstring $dataArray[];\n\t\t$dataArray = {\"\"};\n\t\t\n\t\twhile (size($nextLine) > 0)\n\t\t{\n\t\t\t//Strip whitespace from the beginning and end of line\n\t\t\tstring $cleanLine = strip($nextLine);\n\t\t\t\n\t\t\t//Add to array\n\t\t\t$dataArray[size($dataArray)] = $cleanLine;\n\t\t\n\t\t\t//Get next line and continue\n\t\t\t$nextLine = `fgetline $fileId`;\n\t\t}\n\t\t\n\t\t//Remove first line from array to fix line counting\n\t\tstringArrayRemoveAtIndex(0,$dataArray);\n\t\tfclose $fileId;\n\t\t\n\t\t//Add carriage return to end of file so append works consistently\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\n\t\t//Print array to file\n\t\tint $counter = 0;\n\t\tfor ($item in $dataArray)\n\t\t{\n\t\t\tfprint $fileId ($dataArray[$counter] + \"\\n\");\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t//Close File\n\t\tfclose $fileId;\n\t\n\t\t\n\t\t//Add or remove code from file if it exists\n\t\tglobal int $m341_shelfSizer_removeSwitch1;\n\t\t$m341_shelfSizer_removeSwitch1 = 0;\n\t\t//Search for existing string in file and remove it\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\tstring $nextLine2 = `fgetline $fileId`;\n\t\tstring $contents_1 = \"\";\n\t\tstring $contents_2 = \"\";\n\t\n\t\twhile(size ($nextLine2) > 0)\n\t\t{\n\t\t\t//Store line in array\n\t\t\t$lineArray = stringToStringArray($nextLine2, \"\");\n\t\t\t$contents_1 = $lineArray[0];\n\t\t\t\n\t\t\t//Get current line to search for set by each checkbox\n\t\t\tglobal string $m341_shelfSizer_searchFor[];\n\t\t\tif(`gmatch $lineArray[0] (\"*\" + $m341_shelfSizer_searchFor[0] + \"*\")`)\n\t\t\t{\n\t\t\t\t//Turn on remove text switch\n\t\t\t\tglobal int $m341_shelfSizer_removeSwitch1;\n\t\t\t\t$m341_shelfSizer_removeSwitch1 = 1;\n\t\t\t\t//polySphere -r 1 -sx 32 -sy 32 -ax 0 1 0 -cuv 2 -ch 1;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//Store text from each line to remove in $contents_2\n\t\t\t\t$contents_2 = ($contents_2 + $contents_1);\n\t\t\t}\n\t\t\t$nextLine2 = `fgetline $fileId`;\n\t\t}\n\t\tfclose $fileId;\n\t\n\t\t//Update code from text file if it's there\n\t\tif ($m341_shelfSizer_removeSwitch1 == 1)\n\t\t{\n\t\t\tstring $shelfSizer_removeStringArray[] = {$contents_2}; \n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\t//Print array to file  \n\t\t\tfprint $fileId $shelfSizer_removeStringArray[0];\n\t\t\n\t\t\t//Close file  \n\t\t\tfclose $fileId;\n\t\t\t\n\t\t\t{\n\t\t\t\t//Open file\n\t\t\t\t$fileId = `fopen $filePath \"a\"`;\n\t\n\t\t\t\t//Print text array to file\n\t\t\t\tfor ($item in $m341_shelfSizer_print_textArray)\n\t\t\t\t{\n\t\t\t\t\tfprint $fileId ($item);\n\t\t\t\t}\n\t\t\t\t//Close File\n\t\t\t\tfclose $fileId;\n\t\t\t}\n\t\t}\n\t\n\t\t//Add code to text file if it's not there\n\t\tif ($m341_shelfSizer_removeSwitch1 == 0)\n\t\t{\n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"a\"`;\n\t\n\t\t\t//Print text array to file\n\t\t\tfor ($item in $m341_shelfSizer_print_textArray)\n\t\t\t{\n\t\t\t\tfprint $fileId ($item);\n\t\t\t}\n\t\t\t//Close File\n\t\t\tfclose $fileId;\n\t\t}\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Remove data from userSetup file\nglobal proc m341_shelfSizer_userSetupRemove()\n{\n\tglobal string $m341_shelfSizer_print_textArray[];\n\t\n\t//Turn off notify if userSetup.mel changes\n\tint $securityUserSetup = `optionVar -exists \"SafeModeUserSetupHashOption\"`;\n\tif($securityUserSetup == 1)\n\t{\n\t\tint $notifyUserSetup = `optionVar -q \"SafeModeUserSetupHashOption\"`;\n\t\toptionVar -iv SafeModeUserSetupHashOption false;\n\t}\n\t\n\t//Find Maya current version script folder\n\tstring $mayaScriptDir = `internalVar -userScriptDir`;\n\t\n\t//Create file path\n\tstring $filePath = ($mayaScriptDir + \"userSetup.mel\");\n\t\n\t//See if userSetup.mel exists\n\tint $userSetupExists = `file -q -exists $filePath`;\n\t\n\t//Define file id\n\tint $fileId;\n\t\n\n\t//If file exists\n\tif ($userSetupExists == 1)\n\t{\n\t\t//Strip white space and add carriage return to append works correctly\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\t\n\t\t//Get The First Line\n\t\tstring $nextLine = `fgetline $fileId`;\n\t\t\n\t\t//Define string array\n\t\tstring $dataArray[];\n\t\t$dataArray = {\"\"};\n\t\t\n\t\twhile (size($nextLine) > 0)\n\t\t{\n\t\t\t//Strip whitespace from the beginning and end of line\n\t\t\tstring $cleanLine = strip($nextLine);\n\t\t\t\n\t\t\t//Add to array\n\t\t\t$dataArray[size($dataArray)] = $cleanLine;\n\t\t\n\t\t\t//Get next line and continue\n\t\t\t$nextLine = `fgetline $fileId`;\n\t\t}\n\t\t\n\t\t//Remove first line from array to fix line counting\n\t\tstringArrayRemoveAtIndex(0,$dataArray);\n\t\tfclose $fileId;\n\t\t\n\t\t//Add carriage return to end of file so append works consistently\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\n\t\t//Print array to file\n\t\tint $counter = 0;\n\t\tfor ($item in $dataArray)\n\t\t{\n\t\t\tfprint $fileId ($dataArray[$counter] + \"\\n\");\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t//Close File\n\t\tfclose $fileId;\n\t\n\t\t\n\t\t//Add or remove code from file if it exists\n\t\tglobal int $m341_shelfSizer_removeSwitch1;\n\t\t$m341_shelfSizer_removeSwitch1 = 0;\n\t\t//Search for existing string in file and remove it\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\tstring $nextLine2 = `fgetline $fileId`;\n\t\tstring $contents_1 = \"\";\n\t\tstring $contents_2 = \"\";\n\t\n\t\twhile(size ($nextLine2) > 0)\n\t\t{\n\t\t\t//Store line in array\n\t\t\t$lineArray = stringToStringArray($nextLine2, \"\");\n\t\t\t$contents_1 = $lineArray[0];\n\t\t\t\n\t\t\t//Get current line to search for set by each checkbox\n\t\t\tglobal string $m341_shelfSizer_searchFor[];\n\t\t\tif(`gmatch $lineArray[0] (\"*\" + $m341_shelfSizer_searchFor[0] + \"*\")`)\n\t\t\t{\n\t\t\t\t//Turn on remove text switch\n\t\t\t\tglobal int $m341_shelfSizer_removeSwitch1;\n\t\t\t\t$m341_shelfSizer_removeSwitch1 = 1;\n\t\t\t\t//polySphere -r 1 -sx 32 -sy 32 -ax 0 1 0 -cuv 2 -ch 1;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//Store text from each line to remove in $contents_2\n\t\t\t\t$contents_2 = ($contents_2 + $contents_1);\n\t\t\t}\n\t\t\t$nextLine2 = `fgetline $fileId`;\n\t\t}\n\t\tfclose $fileId;\n\t\n\t\t//Remove code from text file if it's there\n\t\t{\n\t\t\tstring $shelfSizer_removeStringArray[] = {$contents_2}; \n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\t//Print array to file  \n\t\t\tfprint $fileId $shelfSizer_removeStringArray[0];\n\t\t\n\t\t\t//Close file  \n\t\t\tfclose $fileId;\n\t\t}\n\t}\n}\n\n\n\n//***********************************************************************************************************************************************************\n//Window and Buttons\nglobal proc m341_shelfSizer_LaunchWindow()\n{\n\tif (`window -exists m341_shelfSizer_WindowName`)\n\t{\n\t\tdeleteUI m341_shelfSizer_WindowName;\n\t}\n\n\t//Colours\n\tfloat $r[] = {0.698, 0.259, 0.263};\n\tfloat $g[] = {0.282, 0.675, 0.282};\n\tfloat $b[] = {0.145, 0.463, 0.737};\n\tfloat $grey[] = {0.51, 0.51, 0.51};\n\tfloat $red[] = {0.70, 0.39, 0.34};\n\tfloat $orange[] = {0.761, 0.522, 0.314};\n\tfloat $yellow[] = {0.72, 0.68, 0.39};\n\tfloat $green[] = {0.34, 0.59, 0.47};\n\tfloat $greenYellow[] = {0.50, 0.67, 0.37};\n\tfloat $blue[] = {0.32, 0.59, 0.72};\n\tfloat $seafoam[] = {0.427, 0.643, 0.643};\n\tfloat $purple[] = {0.596, 0.529, 0.769};\n\tfloat $purpleDrank[] = {0.451, 0.529, 0.78};\n\n\n\tglobal string $m341_shelfHeightVersion;\n\t\n\twindow -title $m341_shelfHeightVersion -toolbox true -sizeable true -resizeToFitChildren true m341_shelfSizer_WindowName;\n\tcolumnLayout -adjustableColumn true;\n\ttext -label \"by Malcolm341\";\n\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"click for help\"\n\t\t-backgroundColor 0.51 0.51 0.51\n\t\t-width 100\n\t\t-height 15\n\t\t-command \"m341_shelfSizer_help;\";\n\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"show shelf tabs\"\n\t\t-backgroundColor $seafoam[0] $seafoam[1] $seafoam[2]\n\t\t-width 100\n\t\t-command \"m341_shelfSizer_shelfTabs();\";\n\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"fit height to icons\"\n\t\t-backgroundColor $yellow[0] $yellow[1] $yellow[2]\n\t\t-width 100\n\t\t-command \"m341_shelfSizer_fitHeight();\";\n\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"reset height\"\n\t\t-backgroundColor $red[0] $red[1] $red[2]\n\t\t-width 100\n\t\t-command \"m341_shelfSizer_Reset();\";\n\t\n\tsetParent ..;\n\ttext -label \"Increase Height\";\n\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"32\"\n\t\t-backgroundColor 0.772 0.521 0.322\n\t\t-width 40\n\t\t-height 17\n\t\t-command \"m341_shelfSizer_increase_32;\";\n\t\tseparator -width 1 -style \"none\";\n\t\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"10\"\n\t\t-backgroundColor 0.772 0.521 0.322\n\t\t-width 31\n\t\t-height 17\n\t\t-command \"m341_shelfSizer_increase_10;\";\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"1\"\n\t\t-backgroundColor 0.772 0.521 0.322\n\t\t-width 27\n\t\t-height 17\n\t\t-command \"m341_shelfSizer_increase_1;\";\n\n\tsetParent ..;\n\ttext -label \"Decrease Height\";\n\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"32\"\n\t\t-backgroundColor 0.34 0.59 0.47\n\t\t-width 40\n\t\t-height 17\n\t\t-command \"m341_shelfSizer_decrease_32;\";\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"10\"\n\t\t-backgroundColor 0.34 0.59 0.47\n\t\t-width 31\n\t\t-height 17\n\t\t-command \"m341_shelfSizer_decrease_10;\";\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\ticonTextButton -style \"textOnly\"\n\t\t-labelOffset 32\n\t\t-label \"1\"\n\t\t-backgroundColor 0.34 0.59 0.47\n\t\t-width 27\n\t\t-height 17\n\t\t-command \"m341_shelfSizer_decrease_1;\";\n\t\t\n\n\t\t\n\tshowWindow;\n\twindow -edit -width 100 -height 100 m341_shelfSizer_WindowName;\n\n\n\tprint (\"Toolbox loaded \" + $m341_shelfHeightVersion + \"\\n\");\n}\n\nm341_shelfSizer_LaunchWindow();\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "HUD" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "HUD" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconDisplay.png" 
        -image1 "menuIconDisplay.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Extra HUD Toolbox\nglobal string $m341_extraHUD_Version;\n$m341_extraHUD_Version = \"extraHUD v2.4\";\n\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_extraHUD_help()\n{\n\tglobal string $m341_extraHUD_Version;\n\tglobal string $m341_extraHUD_helpWindow;\n\n\tif (`window -exists $m341_extraHUD_helpWindow`)\n\t{\n\t\tglobal string $m341_extraHUD_helpWindow;\n\t\tdeleteUI $m341_extraHUD_helpWindow;\n\t}\n\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n\t$helpLeftEdge = 0.5 * $helpLeftEdge;\n\t\n\t$m341_extraHUD_helpWindow = `window -title (\"Help \" + $m341_extraHUD_Version) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 755`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"RESET\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Resets the toolbox back to defualt settings. If Maya crashes and some of the checkboxes become inverted, use the reset button to fix this issue.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"WORKING UNITS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the current working units Maya is set to. For example, meters, centimeters, feet, etc.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SCENE TIME WARP\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see if the enable scene time warp feature is on or off for the current scene.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"UP AXIS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the current up axis Maya is set to. For example, y or z.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"SELECTED ITEMS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the number of currently selected items, anything you select will be automatically counted and the number displayed.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"ASSIGNED MATERIALS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the names of the materials that are assigned to the currently selected objects or faces. The material names displayed will update as your selection changes.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"UV SET CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see what UV set is currently active for the selected mesh.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PRESERVE UVS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see if the preserve UVs feature is on or off.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PROJECT CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the current project path Maya is set to.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"LAST SAVE CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see how long it's been since you last saved the scene. The timer will reset if you save, save as, or increment save.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"LAST AUTO SAVE CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see how long it's been since Maya last auto saved the scene. If auto save is disabled in the preferences the timer will display auto save disabled. If you're using a Maya version older than Maya 2019 this feature won't work and the timer will display requires Maya 2019 or later.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TOOL AXIS CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the axis orientation mode for the current tool. For example move tool world, object, component, etc.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CAM DISTANCE CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see the distance the camera is from the currently selected object.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"CAM SELECTION CHECKBOX\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Turn on if you want to see if camera based selection is active. For example, on or off.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/4laRTHUJPlE?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/4laRTHUJPlE?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_extraHUD_helpWindow;\n}\n\n\n//***********************************************************************************************************************************************************\n//Reset \nglobal proc m341_extraHUD_reset()\n{\n\tglobal string $m341_extraHUD_searchFor[];\n\tint $hudExists = 0;\n\n\t//workingUnits\n\tglobal int $m341_extraHUD_workingUnits_userInput;\n\t$m341_extraHUD_workingUnits_userInput = `checkBox -q -value extraHUD_workingUnits_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_workingUnits_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_workingUnitsCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_workingUnits_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_workingUnits_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_workingUnits_HUDName;\t\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_workingUnits*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t\tglobal string $m341_extraHUD_searchFor[];\n\tint $hudExists = 0;\n\n\n\t//enableSceneTimeWarp\n\tglobal int $m341_extraHUD_enableSceneTimeWarp_userInput;\n\t$m341_extraHUD_enableSceneTimeWarp_userInput = `checkBox -q -value extraHUD_enableSceneTimeWarp_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_enableSceneTimeWarp_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_enableSceneTimeWarpCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_enableSceneTimeWarp_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_enableSceneTimeWarp_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_enableSceneTimeWarp_HUDName;\t\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_enableSceneTimeWarp*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\n\n\t//upAxis\n\tglobal int $m341_extraHUD_upAxis_userInput;\n\t$m341_extraHUD_upAxis_userInput = `checkBox -q -value extraHUD_upAxis_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_upAxis_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_upAxisCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_upAxis_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_upAxis_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_upAxis_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_upAxis*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//toolAxis\n\tglobal int $m341_extraHUD_toolAxis_userInput;\n\t$m341_extraHUD_toolAxis_userInput = `checkBox -q -value extraHUD_toolAxis_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_toolAxis_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_toolAxisCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_toolAxis_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_toolAxis_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_toolAxis_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_toolAxis*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\n\t\n\t//selectedItems\n\tglobal int $m341_extraHUD_selectedItems_userInput;\n\t$m341_extraHUD_selectedItems_userInput = `checkBox -q -value extraHUD_selectedItems_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_selectedItems_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_selectedItemsCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_selectedItems_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_selectedItems_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_selectedItems_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_selectedItems*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//assignedMaterials\n\tglobal int $m341_extraHUD_assignedMaterials_userInput;\n\t$m341_extraHUD_assignedMaterials_userInput = `checkBox -q -value extraHUD_assignedMaterials_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_assignedMaterials_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_assignedMaterialsCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_assignedMaterials_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_assignedMaterials_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_assignedMaterials_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_assignedMaterials*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//uvSet\n\tglobal int $m341_extraHUD_uvSet_userInput;\n\t$m341_extraHUD_uvSet_userInput = `checkBox -q -value extraHUD_uvSet_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_uvSet_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_uvSetCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_uvSet_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_uvSet_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_uvSet_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_uvSet*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//project\n\tglobal int $m341_extraHUD_project_userInput;\n\t$m341_extraHUD_project_userInput = `checkBox -q -value extraHUD_project_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_project_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_projectCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_project_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_project_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_project_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_project*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//lastSave\n\tglobal int $m341_extraHUD_lastSave_userInput;\n\t$m341_extraHUD_lastSave_userInput = `checkBox -q -value extraHUD_lastSave_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_lastSave_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_lastSaveCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_lastSave_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_lastSave_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_lastSave_HUDName;\n\t\t//Kill script job\n\t\t//global int $m341_extraHUD_lastSave_ScriptJobName;\n\t\t//scriptJob -kill $m341_extraHUD_lastSave_ScriptJobName -force;\n\t\n\t\t//global int $m341_extraHUD_refreshTimer_scriptJobName;\n\t\t//scriptJob -kill $m341_extraHUD_refreshTimer_scriptJobName -force;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_lastSave*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//autoSave status\n\t//checkBox -e -value 0 extraHUD_autoSave_CheckBoxName;\n\t//global int $m341_extraHUD_autoSave_userInput;\n\t//$m341_extraHUD_autoSave_userInput = `checkBox -q -value extraHUD_autoSave_CheckBoxName`;\n\t//optionVar -intValue \"m341_extraHUD_autoSaveCheckBox_VarName\" $m341_extraHUD_autoSave_userInput;\t\n\t//headsUpDisplay -rem extraHUD_autoSave_HUDName;\n\t\n\t//lastAutoSave\n\tglobal int $m341_extraHUD_lastAutoSave_userInput;\n\t$m341_extraHUD_lastAutoSave_userInput = `checkBox -q -value extraHUD_lastAutoSave_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_lastAutoSave_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_lastAutoSaveCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_lastAutoSave_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_lastAutoSave_CheckBoxName;\n\t\tstring $currentMayaYear = `about -product`;\n\t\tif(`gmatch $currentMayaYear \"*2017*\"`)\n\t\t{\n\t\t\theadsUpDisplay -rem extraHUD_lastAutoSave_HUDName;\n\t\t}\n\t\t\t\n\t\telse if(`gmatch $currentMayaYear \"*2018*\"`)\n\t\t{\n\t\t\theadsUpDisplay -rem extraHUD_lastAutoSave_HUDName;\t\n\t\t}\n\t\t\t\n\t\telse\n\t\t{\n\t\t\t//Kill lastAutoSave script job\n\t\t\t//global int $m341_extraHUD_lastAutoSave_ScriptJobName;\n\t\t\t//scriptJob -kill $m341_extraHUD_lastAutoSave_ScriptJobName -force;\n\t\t\theadsUpDisplay -rem extraHUD_lastAutoSave_HUDName;\t\n\t\t}\t\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_lastAutoSave*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\n\n\t//preserve UVs\n\tglobal int $m341_extraHUD_preserveUVs_userInput;\n\t$m341_extraHUD_preserveUVs_userInput = `checkBox -q -value extraHUD_preserveUVs_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_preserveUVs_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_preserveUVsCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_preserveUVs_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_preserveUVs_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_preserveUVs_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_preserveUVs*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\n\n\n\t//cam selection\n\tglobal int $m341_extraHUD_camSelection_userInput;\n\t$m341_extraHUD_camSelection_userInput = `checkBox -q -value extraHUD_camSelection_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_camSelection_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_camSelectionCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_camSelection_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_camSelection_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_camSelection_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_camSelection*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\t\n\t\n\t//cam distance\n\tglobal int $m341_extraHUD_camDistance_userInput;\n\t$m341_extraHUD_camDistance_userInput = `checkBox -q -value extraHUD_camDistance_CheckBoxName`;\n\t$hudExists = `headsUpDisplay -exists \"extraHUD_camDistance_HUDName\"`;\n\toptionVar -intValue \"m341_extraHUD_camDistanceCheckBox_VarName\" 0;\n\tif ($m341_extraHUD_camDistance_userInput == 1 || $hudExists == 1)\n\t{\n\t\tcheckBox -e -value 0 extraHUD_camDistance_CheckBoxName;\n\t\theadsUpDisplay -rem extraHUD_camDistance_HUDName;\n\t}\n\t//Clean the file\n\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_camDistance*/\"};\n\tm341_extraHUD_userSetup_resetUserSetup();\n\n\n\tglobal string $m341_extraHUD_Version;\n\tprint ($m341_extraHUD_Version + \" reset to default\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Reset userSetup.mel\nglobal proc m341_extraHUD_userSetup_resetUserSetup()\n{\n\tglobal string $m341_extraHUD_print_textArray[];\n\t\n\t//Turn off notify if userSetup.mel changes\n\tint $securityUserSetup = `optionVar -exists \"SafeModeUserSetupHashOption\"`;\n\tif($securityUserSetup == 1)\n\t{\n\t\tint $notifyUserSetup = `optionVar -q \"SafeModeUserSetupHashOption\"`;\n\t\toptionVar -iv SafeModeUserSetupHashOption false;\n\t}\n\t\n\t//Find Maya current version script folder\n\tstring $mayaScriptDir = `internalVar -userScriptDir`;\n\t\n\t//Create file path\n\tstring $filePath = ($mayaScriptDir + \"userSetup.mel\");\n\t\n\t//See if userSetup.mel exists\n\tint $userSetupExists = `file -q -exists $filePath`;\n\t\n\t//Define file id\n\tint $fileId;\n\t\n\t//Create file if it doesn't exist and write text into it\n\tif ($userSetupExists == 0)\n\t{\n\t\t//Open file\n\t\t$fileId = `fopen ($mayaScriptDir + \"userSetup.mel\") \"a\"`;\n\t\t//Write text into file\n\t\tfprint $fileId (\"\\n\" + $m341_extraHUD_print_textArray[0]);\n\t\t//Close file\n\t\tfclose $fileId;\n\t}\n\t\n\t\n\t//If file exists\n\tif ($userSetupExists == 1)\n\t{\n\t\t//Strip white space and add carriage return to append works correctly\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\t\n\t\t//Get The First Line\n\t\tstring $nextLine = `fgetline $fileId`;\n\t\t\n\t\t//Define string array\n\t\tstring $dataArray[];\n\t\t$dataArray = {\"\"};\n\t\t\n\t\twhile (size($nextLine) > 0)\n\t\t{\n\t\t\t//Strip whitespace from the beginning and end of line\n\t\t\tstring $cleanLine = strip($nextLine);\n\t\t\t\n\t\t\t//Add to array\n\t\t\t$dataArray[size($dataArray)] = $cleanLine;\n\t\t\n\t\t\t//Get next line and continue\n\t\t\t$nextLine = `fgetline $fileId`;\n\t\t}\n\t\t\n\t\t//Remove first line from array to fix line counting\n\t\tstringArrayRemoveAtIndex(0,$dataArray);\n\t\tfclose $fileId;\n\t\t\n\t\t//Add carriage return to end of file so append works consistently\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\n\t\t//Print array to file\n\t\tint $counter = 0;\n\t\tfor ($item in $dataArray)\n\t\t{\n\t\t\tfprint $fileId ($dataArray[$counter] + \"\\n\");\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t//Close File\n\t\tfclose $fileId;\n\t\n\t\t\n\t\t//Add or remove code from file if it exists\n\t\tglobal int $m341_extraHUD_removeSwitch1;\n\t\t$m341_extraHUD_removeSwitch1 = 0;\n\t\t//Search for existing string in file and remove it\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\tstring $nextLine2 = `fgetline $fileId`;\n\t\tstring $contents_1 = \"\";\n\t\tstring $contents_2 = \"\";\n\t\n\t\twhile(size ($nextLine2) > 0)\n\t\t{\n\t\t\t//Store line in array\n\t\t\t$lineArray = stringToStringArray($nextLine2, \"\");\n\t\t\t$contents_1 = $lineArray[0];\n\t\t\t\n\t\t\t//Get current line to search for set by each checkbox\n\t\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t\tif(`gmatch $lineArray[0] (\"*\" + $m341_extraHUD_searchFor[0] + \"*\")`)\n\t\t\t{\n\t\t\t\t//Turn on remove text switch\n\t\t\t\tglobal int $m341_extraHUD_removeSwitch1;\n\t\t\t\t$m341_extraHUD_removeSwitch1 = 1;\n\t\t\t\t//polySphere -r 1 -sx 32 -sy 32 -ax 0 1 0 -cuv 2 -ch 1;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//Store text from each line to remove in $contents_2\n\t\t\t\t$contents_2 = ($contents_2 + $contents_1);\n\t\t\t}\n\t\t\t$nextLine2 = `fgetline $fileId`;\n\t\t}\n\t\tfclose $fileId;\n\t\n\t\t//Remove code from text file by pasting back the original file text\n\t\tif ($m341_extraHUD_removeSwitch1 == 1)\n\t\t{\n\t\t\tstring $extraHUD_removeStringArray[] = {$contents_2}; \n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\t//Print array to file  \n\t\t\tfprint $fileId $extraHUD_removeStringArray[0];\n\t\t\n\t\t\t//Close file\n\t\t\tfclose $fileId;\n\t\t}\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update userSetup regular checkbox\nglobal proc m341_extraHUD_userSetup_regularCheckbox()\n{\n\tglobal string $m341_extraHUD_print_textArray[];\n\t\n\t//Turn off notify if userSetup.mel changes\n\tint $securityUserSetup = `optionVar -exists \"SafeModeUserSetupHashOption\"`;\n\tif($securityUserSetup == 1)\n\t{\n\t\tint $notifyUserSetup = `optionVar -q \"SafeModeUserSetupHashOption\"`;\n\t\toptionVar -iv SafeModeUserSetupHashOption false;\n\t}\n\t\n\t//Find Maya current version script folder\n\tstring $mayaScriptDir = `internalVar -userScriptDir`;\n\t\n\t//Create file path\n\tstring $filePath = ($mayaScriptDir + \"userSetup.mel\");\n\t\n\t//See if userSetup.mel exists\n\tint $userSetupExists = `file -q -exists $filePath`;\n\t\n\t//Define file id\n\tint $fileId;\n\t\n\t//Create file if it doesn't exist and write text into it\n\tif ($userSetupExists == 0)\n\t{\n\t\t//Open file\n\t\t$fileId = `fopen ($mayaScriptDir + \"userSetup.mel\") \"a\"`;\n\t\t//Write text into file\n\t\tfprint $fileId (\"\\n\" + $m341_extraHUD_print_textArray[0]);\n\t\t//Close file\n\t\tfclose $fileId;\n\t}\n\t\n\t\n\t//If file exists\n\tif ($userSetupExists == 1)\n\t{\n\t\t//Strip white space and add carriage return to append works correctly\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\t\n\t\t//Get The First Line\n\t\tstring $nextLine = `fgetline $fileId`;\n\t\t\n\t\t//Define string array\n\t\tstring $dataArray[];\n\t\t$dataArray = {\"\"};\n\t\t\n\t\twhile (size($nextLine) > 0)\n\t\t{\n\t\t\t//Strip whitespace from the beginning and end of line\n\t\t\tstring $cleanLine = strip($nextLine);\n\t\t\t\n\t\t\t//Add to array\n\t\t\t$dataArray[size($dataArray)] = $cleanLine;\n\t\t\n\t\t\t//Get next line and continue\n\t\t\t$nextLine = `fgetline $fileId`;\n\t\t}\n\t\t\n\t\t//Remove first line from array to fix line counting\n\t\tstringArrayRemoveAtIndex(0,$dataArray);\n\t\tfclose $fileId;\n\t\t\n\t\t//Add carriage return to end of file so append works consistently\n\t\t//Open file\n\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\n\t\t//Print array to file\n\t\tint $counter = 0;\n\t\tfor ($item in $dataArray)\n\t\t{\n\t\t\tfprint $fileId ($dataArray[$counter] + \"\\n\");\n\t\t\t$counter = $counter + 1;\n\t\t}\n\t\t//Close File\n\t\tfclose $fileId;\n\t\n\t\t\n\t\t//Add or remove code from file if it exists\n\t\tglobal int $m341_extraHUD_removeSwitch1;\n\t\t$m341_extraHUD_removeSwitch1 = 0;\n\t\t//Search for existing string in file and remove it\n\t\t$fileId = `fopen $filePath \"r\"`;\n\t\tstring $nextLine2 = `fgetline $fileId`;\n\t\tstring $contents_1 = \"\";\n\t\tstring $contents_2 = \"\";\n\t\n\t\twhile(size ($nextLine2) > 0)\n\t\t{\n\t\t\t//Store line in array\n\t\t\t$lineArray = stringToStringArray($nextLine2, \"\");\n\t\t\t$contents_1 = $lineArray[0];\n\t\t\t\n\t\t\t//Get current line to search for set by each checkbox\n\t\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t\tif(`gmatch $lineArray[0] (\"*\" + $m341_extraHUD_searchFor[0] + \"*\")`)\n\t\t\t{\n\t\t\t\t//Turn on remove text switch\n\t\t\t\tglobal int $m341_extraHUD_removeSwitch1;\n\t\t\t\t$m341_extraHUD_removeSwitch1 = 1;\n\t\t\t\t//polySphere -r 1 -sx 32 -sy 32 -ax 0 1 0 -cuv 2 -ch 1;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\t//Store text from each line to remove in $contents_2\n\t\t\t\t$contents_2 = ($contents_2 + $contents_1);\n\t\t\t}\n\t\t\t$nextLine2 = `fgetline $fileId`;\n\t\t}\n\t\tfclose $fileId;\n\t\n\t\t//Remove code from text file by pasting back the original file text\n\t\tif ($m341_extraHUD_removeSwitch1 == 1)\n\t\t{\n\t\t\tstring $extraHUD_removeStringArray[] = {$contents_2}; \n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"w\"`;\n\t\t\t//Print array to file  \n\t\t\tfprint $fileId $extraHUD_removeStringArray[0];\n\t\t\n\t\t\t//Close file  \n\t\t\tfclose $fileId;\n\t\t}\n\t\n\t\t//Add code to text file\n\t\tif ($m341_extraHUD_removeSwitch1 == 0)\n\t\t{\n\t\t\t//Open file\n\t\t\t$fileId = `fopen $filePath \"a\"`;\n\t\n\t\t\t//Print text array to file\n\t\t\tfor ($item in $m341_extraHUD_print_textArray)\n\t\t\t{\n\t\t\t\tfprint $fileId ($item);\n\t\t\t}\n\t\t\t//Close File\n\t\t\tfclose $fileId;\n\t\t}\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update Working units Checkbox Value\nglobal proc string m341_extraHUD_workingUnits_Display()\n{\n\tstring $currentUnits = `currentUnit -q`;\n\treturn $currentUnits;\n}\n\nglobal proc m341_extraHUD_workingUnits_ValueChanged()\n{\n\t//Section and block variables\n\tint $workingUnits_SectionVar = 1;\n\tint $workingUnits_NextFreeBlock = `headsUpDisplay -nextFreeBlock $workingUnits_SectionVar`;\n\t\n\t//Create a string array with text in it to add or remove from userSetup.mel\n\tglobal string $m341_extraHUD_print_textArray[];\n\t$m341_extraHUD_print_textArray = {\"/*m341_extraHUD_workingUnits*/ global proc string m341_extraHUD_workingUnits_Display(){string $currentUnits = `currentUnit -q`;return $currentUnits;}int $workingUnits_SectionVar = 1;int $workingUnits_NextFreeBlock = `headsUpDisplay -nextFreeBlock $workingUnits_SectionVar`;headsUpDisplay -section $workingUnits_SectionVar -block $workingUnits_NextFreeBlock -blockSize \\\"small\\\" -label \\\"Working Units:\\\" -labelFontSize \\\"small\\\" -command \\\"m341_extraHUD_workingUnits_Display()\\\" -event \\\"linearUnitChanged\\\" extraHUD_workingUnits_HUDName;\"};\n\t\n\t//Query the value of the checkbox and store in variable\n\tglobal int $m341_extraHUD_workingUnits_userInput;\n\t$m341_extraHUD_workingUnits_userInput = `checkBox -q -value extraHUD_workingUnits_CheckBoxName`;\n\toptionVar -intValue \"m341_extraHUD_workingUnitsCheckBox_VarName\" $m341_extraHUD_workingUnits_userInput;\n\t//Print value\n\tif ($m341_extraHUD_workingUnits_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem extraHUD_workingUnits_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_workingUnits*/\"};\n\t\t\n\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\tprint \"Working units checkbox off\\n\";\n\t}\n\telse\n\t{\n\t\t//-section is horizontal position of HUD element\n\t\t//-block is vertical position of HUD element\n\t\t//-blockSize is height\n\t\theadsUpDisplay -section $workingUnits_SectionVar -block $workingUnits_NextFreeBlock -blockSize \"small\" -label \"Working Units:\" -labelFontSize \"small\" -command \"m341_extraHUD_workingUnits_Display()\" -event \"linearUnitChanged\" extraHUD_workingUnits_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_workingUnits*/\"};\n\t\t\n\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\t\n\t\t//Suppress spam prints\n\t\tm341_extraHUD_SuppressPrint();\n\t\tprint \"Working units checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update Scene time warp Checkbox Value\nglobal proc string m341_extraHUD_enableSceneTimeWarp_Display()\n{\n\n\t\n\tstring $enableSceneTimeWarp = `getAttr time1.enableTimewarp`;\n\t//return $enableSceneTimeWarp;\n\tif ($enableSceneTimeWarp == 0)\n\t{\n\t\tstring $enableSceneTimeWarpOff = \"off\";\n\t\treturn $enableSceneTimeWarpOff;\n\t}\n\t\n\tif ($enableSceneTimeWarp == 1)\n\t{\n\t\tstring $enableSceneTimeWarpOn = \"on\";\n\t\treturn $enableSceneTimeWarpOn;\n\t}\n}\n\nglobal proc m341_extraHUD_enableSceneTimeWarp_ValueChanged()\n{\n\t//Section and block variables\n\tint $enableSceneTimeWarp_SectionVar = 1;\n\tint $enableSceneTimeWarp_NextFreeBlock = `headsUpDisplay -nextFreeBlock $enableSceneTimeWarp_SectionVar`;\n\t\n\t//Create a string array with text in it to add or remove from userSetup.mel\n\tglobal string $m341_extraHUD_print_textArray[];\n\t$m341_extraHUD_print_textArray = {\"/*m341_extraHUD_enableSceneTimeWarp*/ \\\n\tint $enableSceneTimeWarp_SectionVar = 1;\\\n\tint $enableSceneTimeWarp_NextFreeBlock = `headsUpDisplay -nextFreeBlock $enableSceneTimeWarp_SectionVar`;\\\n\t\\\n\tglobal proc string m341_extraHUD_enableSceneTimeWarp_Display()\\\n\t{\\\n\t\tstring $enableSceneTimeWarp = `getAttr time1.enableTimewarp`;\\\n\t\tif ($enableSceneTimeWarp == 0)\\\n\t\t{\\\n\t\t\tstring $enableSceneTimeWarpOff = \\\"off\\\";\\\n\t\t\treturn $enableSceneTimeWarpOff;\\\n\t\t}\\\n\t\tif ($enableSceneTimeWarp == 1)\\\n\t\t{\\\n\t\t\tstring $enableSceneTimeWarpOn = \\\"on\\\";\\\n\t\t\treturn $enableSceneTimeWarpOn;\\\n\t\t}\\\n\t}\\\n\theadsUpDisplay -section $enableSceneTimeWarp_SectionVar -block $enableSceneTimeWarp_NextFreeBlock -blockSize \\\"small\\\" -label \\\"Enable Scene Time Warp:\\\" -labelFontSize \\\"small\\\" -command \\\"m341_extraHUD_enableSceneTimeWarp_Display()\\\" -event \\\"timeChanged\\\" extraHUD_enableSceneTimeWarp_HUDName;\"};\n\t\n\t\n\t//Query the value of the checkbox and store in variable\n\tglobal int $m341_extraHUD_enableSceneTimeWarp_userInput;\n\t$m341_extraHUD_enableSceneTimeWarp_userInput = `checkBox -q -value extraHUD_enableSceneTimeWarp_CheckBoxName`;\n\toptionVar -intValue \"m341_extraHUD_enableSceneTimeWarpCheckBox_VarName\" $m341_extraHUD_enableSceneTimeWarp_userInput;\n\t//Print value\n\tif ($m341_extraHUD_enableSceneTimeWarp_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem extraHUD_enableSceneTimeWarp_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_enableSceneTimeWarp*/\"};\n\t\t\n\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\tprint \"Enable time warp checkbox off\\n\";\n\t}\n\telse\n\t{\n\t\t//-section is horizontal position of HUD element\n\t\t//-block is vertical position of HUD element\n\t\t//-blockSize is height\n\t\theadsUpDisplay -section $enableSceneTimeWarp_SectionVar -block $enableSceneTimeWarp_NextFreeBlock -blockSize \"small\" -label \"Enable Scene Time Warp:\" -labelFontSize \"small\" -command \"m341_extraHUD_enableSceneTimeWarp_Display()\" -event \"timeChanged\" extraHUD_enableSceneTimeWarp_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_enableSceneTimeWarp*/\"};\n\t\t\n\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\t\n\t\t//Suppress spam prints\n\t\tm341_extraHUD_SuppressPrint();\n\t\tprint \"Enable time warp checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update up axis Checkbox Value\nglobal proc string m341_extraHUD_upAxis_Display()\n{\n\tstring $upAxis = `upAxis -q -ax`;\n\treturn $upAxis;\t\t\t\n}\n\nglobal proc m341_extraHUD_upAxis_ValueChanged()\n{\n\t//Section and block variables\n\tint $upAxis_SectionVar = 2;\n\tint $upAxis_NextFreeBlock = `headsUpDisplay -nextFreeBlock $upAxis_SectionVar`;\n\n\t//Create a string array with text in it to add or remove from userSet.mel\n\tglobal string $m341_extraHUD_print_textArray[];\n\t$m341_extraHUD_print_textArray = {\"/*m341_extraHUD_upAxis*/ evalDeferred \\\"commandEcho -af {\\\\\\\"m341_extraHUD_upAxis_Display()\\\\\\\"}\\\";global proc string m341_extraHUD_upAxis_Display(){string $upAxis = `upAxis -q -ax`;return $upAxis;}int $upAxis_SectionVar = 2;int $upAxis_NextFreeBlock = `headsUpDisplay -nextFreeBlock $upAxis_SectionVar`;headsUpDisplay -attachToRefresh -section $upAxis_SectionVar -block $upAxis_NextFreeBlock -blockSize \\\"small\\\" -label \\\"Up Axis:\\\" -labelFontSize \\\"small\\\" -command \\\"m341_extraHUD_upAxis_Display()\\\" extraHUD_upAxis_HUDName;\"};\n\n\n\t//Query the value of the checkbox and store in variable\n\tglobal int $m341_extraHUD_upAxis_userInput;\n\t$m341_extraHUD_upAxis_userInput = `checkBox -q -value extraHUD_upAxis_CheckBoxName`;\n\toptionVar -intValue \"m341_extraHUD_upAxisCheckBox_VarName\" $m341_extraHUD_upAxis_userInput;\n\t//Print value\n\tif ($m341_extraHUD_upAxis_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem extraHUD_upAxis_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_upAxis*/\"};\n\t\n\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\tprint \"Up axis checkbox off\\n\";\n\t}\n\n\telse\n\t{\n\t\theadsUpDisplay -attachToRefresh -section $upAxis_SectionVar -block $upAxis_NextFreeBlock -blockSize \"small\" -label \"Up Axis:\" -labelFontSize \"small\" -command \"m341_extraHUD_upAxis_Display()\" extraHUD_upAxis_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_upAxis*/\"};\n\t\t\t\t\n\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\t\n\t\t//Suppress spam prints\n\t\tm341_extraHUD_SuppressPrint();\n\t\tprint \"Up axis checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update tool axis Checkbox Value\nglobal proc string m341_extraHUD_toolAxis_Display()\n{\n\t//3\n    string $currentCtx = `currentCtx`;\n\t\n\t//4\n\tif ($currentCtx == \"moveSuperContext\" || $currentCtx == \"manipMoveContext\")\n    {\n\t    int $axisMode = `manipMoveContext -q -mode Move`;\n    \tif ($axisMode == 0)\n\t    {\n\t\t\tstring $axisOrient = \"object\";\n\t\t\treturn $axisOrient;\n\t    }\n    \tif ($axisMode == 2)\n\t    {\n\t\t\tstring $axisOrient = \"world\";\n\t\t\treturn $axisOrient;\n\t    }\n\t   \tif ($axisMode == 10)\n\t    {\n\t\t\tstring $axisOrient = \"component\";\n\t\t\treturn $axisOrient;\n\t    }\n   \t   \tif ($axisMode == 1)\n\t    {\n\t\t\tstring $axisOrient = \"parent\";\n\t\t\treturn $axisOrient;\n\t    }\n   \t   \tif ($axisMode == 3)\n\t    {\n\t\t\tstring $axisOrient = \"normal\";\n\t\t\treturn $axisOrient;\n\t    }\n   \t   \tif ($axisMode == 4)\n\t    {\n\t\t\tstring $axisOrient = \"rotate axis\";\n\t\t\treturn $axisOrient;\n\t    }\n  \t   \tif ($axisMode == 5)\n\t    {\n\t\t\tstring $axisOrient = \"live axis\";\n\t\t\treturn $axisOrient;\n\t    }\n   \t   \tif ($axisMode == 6)\n\t    {\n\t\t\tstring $axisOrient = \"custom\";\n\t\t\treturn $axisOrient;\n\t    }\t    \n    }\n\t\n\t//5\n\tif ($currentCtx == \"RotateSuperContext\" || $currentCtx == \"manipRotateContext\")\n    {\n\t    int $axisMode = `manipRotateContext -q -mode Rotate`;\n\t\tif ($axisMode == 0)\n\t    {\n\t\t\tstring $axisOrient = \"object\";\n\t\t\treturn $axisOrient;\n\t    }\n\t\tif ($axisMode == 1)\n\t    {\n\t\t\tstring $axisOrient = \"world\";\n\t\t\treturn $axisOrient;\n\t    }\n\t\tif ($axisMode == 10)\n