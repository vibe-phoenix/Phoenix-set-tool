 $REZ_Items[0] \"*_0008\"`)\n\t\t\t\t\t{\n\t\t\t\t\t\t\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\telse if(`gmatch $REZ_Items[0] \"*_0009\"`)\n\t\t\t\t\t{\n\t\t\t\t\t\t\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\t//Remove extra zero\n\t\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\t\tsearchReplaceNames \"_000\" \"_00\" \"selected\";\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\t//Remove extra zero 99-999\n\t\t\t\t\t$finalZeroTest = `ls -sl`;\n\t\t\t\t\t//Convert string array to string\n\t\t\t\t\t$objName = $finalZeroTest[0];\n\t\t\t\t\t//Strip off all but last 4 characters\n\t\t\t\t\tstring $endStr = endString($objName, 4);\n\t\t\t\t\t\n\t\t\t\t\tif(`gmatch $endStr \"0[1-9]*\"`)\n\t\t\t\t\t{\n\t\t\t\t\t\tsearchReplaceNames \"_0\" \"_\" \"selected\";\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\t//Remove extra zero 999-9999\n\t\t\t\t\t$finalZeroTest = `ls -sl`;\n\t\t\t\t\t//Convert string array to string\n\t\t\t\t\t$objName = $finalZeroTest[0];\n\t\t\t\t\t//Strip off all but last 5 characters\n\t\t\t\t\t$endStr = endString($objName, 5);\n\t\t\t\t\t\n\t\t\t\t\tif(`gmatch $endStr \"0[1-9]*\"`)\n\t\t\t\t\t{\n\t\t\t\t\t\tsearchReplaceNames \"_00\" \"_\" \"selected\";\n\t\t\t\t\t}\n\t\t\t\t}\t\t\t\n\t\t\t\t\n\t\t\t\t//Store each newly named object so you can select it at the end\n\t\t\t\t$tempItem = `ls -sl -fl`;\n\t\t\t\tglobal string $m341_reNamer_finalSelectLow[];\n\t\t\t\tselect $m341_reNamer_finalSelectLow;\n\t\t\t\tselect -add $tempItem;\n\t\t\t\t$m341_reNamer_finalSelectLow = `ls -sl -fl`;\n\t\t\t\t\n\t\t\t\t$increment = $increment + 1;\n\t\t\t\t$counter = $counter + 1;\n\t\t\t}\n\t\t}\n\t}\n\t\n\tselect -clear;\n\t\n\t//Select newly named objects\n\tglobal string $m341_reNamer_finalSelectHigh[];\n\tselect $m341_reNamer_finalSelectHigh;\n\tglobal string $m341_reNamer_finalSelectLow[];\n\tselect -add $m341_reNamer_finalSelectLow;\n\t\n\tprint (\"Name matching complete: \" + $m341_UserInput_Renamer + \" high/low\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Trim Amount Int Value Changed\nglobal proc m341_reNamer_TrimAmount_IntValueChanged()\n{\n\tglobal int $m341_reNamer_TrimAmount_IntInput;\n\t//Query the value from the int field and store it in a variable.\n\t$m341_reNamer_TrimAmount_IntInput = `intField -query -value m341_reNamer_TrimAmount_IntFieldName`;\n\toptionVar -floatValue \"m341_reNamer_TrimAmount_IntField_VarName\" $m341_reNamer_TrimAmount_IntInput;\n\t\n\tprint(\"Trim amount set to \" + $m341_reNamer_TrimAmount_IntInput + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Trim Prefix\nglobal proc m341_reNamer_TrimPrefix()\n{\n\t//Trim amount comes from int field\n\tint $trimAmount = `intField -query -value m341_reNamer_TrimAmount_IntFieldName`;\n\t\n\t//Final select variables\n\tglobal string $m341_reNamer_finalSelect[];\n\t$m341_reNamer_finalSelect = {};\n\tstring $tempItem[] = {};\n\t\n\tstring $Objs[] = `ls -sl`;\n\tint $ObjsSize = `size $Objs`;\n\tint $counter = 0;\n\tint $increment = 0;\n\t\n\tfor ($item = 0; $item < $ObjsSize; ++$item)\n\t{\n\t\tselect -ne $Objs[$counter];\n        string $currentName = $Objs[$counter];\n        string $currentPrefix = startString($Objs[$counter], $trimAmount);\n        searchReplaceNames $currentPrefix \"\" \"selected\";\n\t\n\t\t//Store each newly named object so you can select it at the end\n\t\t$tempItem = `ls -sl -fl`;\n\t\tselect -ne $m341_reNamer_finalSelect;\n\t\tselect -ne -add $tempItem;\n\t\t$m341_reNamer_finalSelect = `ls -sl -fl`;\n\t\t\n\t\t$increment = $increment + 1;\n\t\t$counter = $counter + 1;\n\t}\n\t\n\tselect -clear;\n\t\n\t//Select newly named objects\n\tselect -ne $m341_reNamer_finalSelect;\n\t\n\tprint (\"Prefix characters trimmed by \" + $trimAmount + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Trim Suffix\nglobal proc m341_reNamer_TrimSuffix()\n{\n\t//Trim amount comes from int field\n\tint $trimAmount = `intField -query -value m341_reNamer_TrimAmount_IntFieldName`;\n\t\n\t//Final select variables\n\tglobal string $m341_reNamer_finalSelect[];\n\t$m341_reNamer_finalSelect = {};\n\tstring $tempItem[] = {};\n\t\n\tstring $Objs[] = `ls -sl`;\n\tint $ObjsSize = `size $Objs`;\n\tint $counter = 0;\n\tint $increment = 0;\n\t\n\tfor ($item = 0; $item < $ObjsSize; ++$item)\n\t{\n\t\tselect -ne $Objs[$counter];\n        string $currentName = $Objs[$counter];\n        string $currentSuffix = endString($Objs[$counter], $trimAmount);\n        string $trimName = basename($currentName, $currentSuffix);\n\t\trename ($trimName);\n\t\t\n\t\t//Store each newly named object so you can select it at the end\n\t\t$tempItem = `ls -sl -fl`;\n\t\tselect -ne $m341_reNamer_finalSelect;\n\t\tselect -ne -add $tempItem;\n\t\t$m341_reNamer_finalSelect = `ls -sl -fl`;\n\t\t\n\t\t$increment = $increment + 1;\n\t\t$counter = $counter + 1;\n\t}\n\t\n\tselect -clear;\n\t\n\t//Select newly named objects\n\tselect -ne $m341_reNamer_finalSelect;\n\t\n\tprint (\"Suffix characters trimmed by \" + $trimAmount + \"\\n\");\n}\n\n\n//***********************************************************************************************************************************************************\n//Window and Buttons\nglobal proc m341_reNamer_launchWindow()\n{\n\tif (`window -exists m341_reNamer_windowName`)\n\t{\n\t\tdeleteUI m341_reNamer_windowName;\n\t}\n\n\n\t//Colours\n\tfloat $r[] = {0.698, 0.259, 0.263};\n\tfloat $g[] = {0.282, 0.675, 0.282};\n\tfloat $b[] = {0.145, 0.463, 0.737};\n\tfloat $grey[] = {0.51, 0.51, 0.51};\n\tfloat $red[] = {0.70, 0.39, 0.34};\n\tfloat $orange[] = {0.761, 0.522, 0.314};\n\tfloat $yellow[] = {0.72, 0.68, 0.39};\n\tfloat $green[] = {0.34, 0.59, 0.47};\n\tfloat $greenYellow[] = {0.50, 0.67, 0.37};\n\tfloat $blue[] = {0.32, 0.59, 0.72};\n\tfloat $seafoam[] = {0.427, 0.643, 0.643};\n\tfloat $purple[] = {0.596, 0.529, 0.769};\n\tfloat $purpleDrank[] = {0.451, 0.529, 0.78};\n\n\tglobal string $m341_TextFieldName_Renamer = \"\";\n\tglobal string $m341_UserInput_Renamer = \"\";\n\tglobal string $m341_TextFieldName_RenamerReplace = \"\";\n\tglobal string $m341_UserInput_RenamerReplace = \"\";\n\tglobal string $m341_reNamer_Version;\n\t\n\twindow -title $m341_reNamer_Version -toolbox true -sizeable true -resizeToFitChildren true m341_reNamer_windowName;\n\tcolumnLayout -adjustableColumn true;\n\ttext -label \"by Malcolm341\";\n\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t//Fix keyboard focus\n\t\n\tstring $mayaYear = `about -product`;\n\tstring $mayaYearAarray[];\n\t$mayaYearAarray = stringToStringArray($mayaYear, \" \");\n\tint $mayaVersionNumber = $mayaYearAarray[1];\n\t\n\tif ($mayaVersionNumber < 2019)\n\t{\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-labelOffset 30\n\t\t\t-label \"click for help\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 130\n\t\t\t-height 15\n\t\t\t-command \"m341_reNamer_help;\";\n\t}\n\telse\n\t{\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-enableKeyboardFocus 1\n\t\t\t-labelOffset 30\n\t\t\t-label \"click for help\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 130\n\t\t\t-height 15\n\t\t\t-command \"m341_reNamer_help;\";\n\t}\n\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t-label \"sort outliner by name\"\n\t\t-backgroundColor $yellow[0] $yellow[1] $yellow[2]\n\t\t-width 130\n\t\t//-height 18\n\t\t-command \"m341_reNamer_sortOutliner;\"\n\t\t-commandRepeatable 1;\n\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\t$m341_TextFieldName_Renamer = `textField -placeholderText \"rename/search for:\" -width 130 -changeCommand \"m341_textValueChanged_Renamer();\"`;\n\t\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 3;\n\ticonTextButton -style \"textOnly\"\n\t\t-label \"replace\"\n\t\t-labelOffset 30\n\t\t-backgroundColor 0.51 0.51 0.51\n\t\t-width 44\n\t\t-height 18\n\t\t-command \"m341_reNamer_replace;\"\n\t\t-commandRepeatable 0;\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\t$m341_TextFieldName_RenamerReplace = `textField -placeholderText \"replace with:\" -width 85 -changeCommand \"m341_textValueChanged_RenamerReplace();\"`;\t\n\t\t\n\tsetParent ..;\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t-label \"pre\"\n\t\t-labelOffset 40\n\t\t-backgroundColor 0.596 0.529 0.769\n\t\t-width 22\n\t\t-command \"m341_reNamer_prefix;\"\n\t\t-commandRepeatable 0;\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t-label \"suf\"\n\t\t-labelOffset 40\n\t\t-backgroundColor 0.32 0.59 0.72\n\t\t-width 22\n\t\t-command \"m341_reNamer_suffix;\"\n\t\t-commandRepeatable 0;\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t-label \"TB name match\"\n\t\t-labelOffset 0\n\t\t-backgroundColor 0.34 0.59 0.47\n\t\t-width 84\n\t\t-command \"m341_reNamer_groupMatch;\"\n\t\t-commandRepeatable 0;\n\t\n\tsetParent ..;\t\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\n\t\n\ticonTextButton -style \"textOnly\"\n\t\t-label \"trim pre\"\n\t\t-labelOffset 0\n\t\t-backgroundColor $grey[0] $grey[1] $grey[2]\n\t\t-width 47\n\t\t-height 18\n\t\t-command \"m341_reNamer_TrimPrefix;\"\n\t\t-commandRepeatable 0;\n\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\n\t//Save preferences trim amount int field\n\tint $reNamer_TrimAmount_IntFieldValue;\n\tglobal float $m341_reNamer_TrimAmount_IntFieldValue;\n\tstring $reNamer_TrimAmount_IntField_OptionVar = `optionVar -exists \"m341_reNamer_TrimAmount_IntField_VarName\"`;\n\t\n\tif ($reNamer_TrimAmount_IntField_OptionVar == 0)\n\t{\n\t\t//Set default value\n\t\toptionVar -floatValue \"m341_reNamer_TrimAmount_IntField_VarName\" 1;\n\t\t$reNamer_TrimAmount_IntFieldValue = `optionVar -q \"m341_reNamer_TrimAmount_IntField_VarName\"`;\n\t}\n\telse\n\t{\n\t\t//Query from prefs file\n\t\t$reNamer_TrimAmount_IntFieldValue = `optionVar -q \"m341_reNamer_TrimAmount_IntField_VarName\"`;\n\t}\n\t\n\tif($mayaVersionNumber < 2019)\n\t{\n\t\tintField -value 4 -minValue 1 -width 35 -changeCommand \"m341_reNamer_TrimAmount_IntValueChanged();\" m341_reNamer_TrimAmount_IntFieldName;\n\t}\n\telse\n\t{\n\t\tintField -enableKeyboardFocus 0 -value $reNamer_TrimAmount_IntFieldValue -minValue 1 -width 35 -changeCommand \"m341_reNamer_TrimAmount_IntValueChanged();\" m341_reNamer_TrimAmount_IntFieldName;\n\t}\n\t\n\tseparator -width 1 -style \"none\";\n\ticonTextButton -style \"textOnly\"\n\t\t-label \"trim suf\"\n\t\t-labelOffset 0\n\t\t-backgroundColor $grey[0] $grey[1] $grey[2]\n\t\t-width 46\n\t\t-height 18\n\t\t-command \"m341_reNamer_TrimSuffix;\"\n\t\t-commandRepeatable 0;\n\t\t\n\t\n\t\n\t\n\n\tsetParent ..;\t\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ttext \"  increment \";\n\t\toptionMenu -width 70 -height 19 reNamerDropDown;\n\t\tmenuItem -label \"_A\";\n\t\tmenuItem -label \"1\";\n\t\tmenuItem -label \"_1\";\n\t\tmenuItem -label \"_01\";\n\t\tmenuItem -label \"_001\";\n\t\tmenuItem -label \"_0001\";\n\t\tmenuItem -label \"_LOD_0\";\n\t\toptionMenu -edit -select 4 reNamerDropDown;\n\t\t\n\tsetParent ..;\t\n\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t-label \"rename\"\n\t\t//-backgroundColor 0.70 0.39 0.34\n\t\t-backgroundColor 0.772 0.521 0.302\n\t\t-width 130\n\t\t-command \"m341_reNamer_rename;\"\n\t\t-commandRepeatable 0;\n\t\t\n\tshowWindow;\n\twindow -edit -width 100 -height 100 m341_reNamer_windowName;\n\t\n\tprint (\"Toolbox loaded \" + $m341_reNamer_Version + \"\\n\");\n}\n\nm341_reNamer_launchWindow();" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Left click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "dotPat" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "dotPat" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "polyDuplicateEdgeLoop.png" 
        -image1 "polyDuplicateEdgeLoop.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here www.youtube.com/malcolm341\n\n\n//***********************************************************************************************************************************************************\n//Select Every Other Edge Vert Face Toolbox\nglobal string $m341_skipSelectorVersion;\n$m341_skipSelectorVersion = \"skipSelector v1.5\";\n\n\n//***********************************************************************************************************************************************************\n//Help\nglobal proc m341_skipSelector_help()\n{\n\tglobal string $m341_skipSelector_helpWindow;\n\n\tif (`window -exists $m341_skipSelector_helpWindow`)\n\t{\n\t\tglobal string $m341_skipSelector_helpWindow;\n\t\tdeleteUI $m341_skipSelector_helpWindow;\n\t}\n\n\t//Left justify help window to center of Maya window\n\tint $helpLeftEdge = `window -q -width MayaWindow`;\n\t$helpLeftEdge = 0.5 * $helpLeftEdge;\t\n\n\tglobal string $m341_skipSelectorVersion;\n\t$m341_skipSelector_helpWindow = `window -title (\"Help \" + $m341_skipSelectorVersion) -leftEdge $helpLeftEdge -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 580`;\n\t\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"N-GONS AND TRIS\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Triangles and n-gons are not supported in this tool, n-gons will be ignored as part of the pattern and triangles will make the selection come out wrong.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"INVERT DOT/PAT\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Inverts the last pattern that was selected by the tool.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"DOT LOOP\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Selects every other component on the current loop. The current loop is defined by selecting two adjacent components of the same type and running the tool.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PAT LOOP\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Selects a user defined pattern of loops on the current mesh. The loop pattern is defined by selecting two or more adjacent components of the same type and running the tool. For example, selecting 4 adjacent faces will produce a 4/on 4/off pattern. Non-symmetrical patterns are not supported, so 4/on 3/off is not possible in this tool.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TO LOOP\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Converts the current selection to a component loop of that type, this can be helpful to convert Non-symmetrical or partial selection patterns into component loops.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"TO RING\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Converts the current selection to a component ring of that type, this can be helpful to convert Non-symmetrical or partial selection patterns into component rings.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"DOT RING\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Selects every other component on the current ring. The current ring is defined by selecting two adjacent components of the same type and running the tool.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"PAT RING\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Selects a user defined pattern of rings on the current mesh. The ring pattern is defined by selecting two or more adjacent components of the same type and running the tool. For example, selecting 4 adjacent faces will produce a 4/on 4/off pattern. Non-symmetrical patterns are not supported, so 4/on 3/off is not possible in this tool.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/X7at0KhauWk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/X7at0KhauWk?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_skipSelector_helpWindow;\n}\n\n\n//***********************************************************************************************************************************************************\n//Invert Loop/Ring\nglobal proc m341_skipSelector_invertLoopRing()\n{\n\t//Query what component mode the user is in\n\tint $component_Face = `selectType -q -facet`;\n\tint $component_Shell = `selectType -q -meshUVShell`;\n\tint $component_Vert = `selectType -q -vertex`;\n\tint $component_Edge = `selectType -q -edge`;\n\tint $component_UV = `selectType -q -polymeshUV`;\n\tint $component_Multi = `selectType -q -meshComponents`;\n\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeCounter = `size $selection`;\n\t\n\ttoggleSelMode;\n    toggleSelMode;\n    selectMode -object;\n    string $obj[] = `ls -sl`;\n    \n\t//Find n-gons, run clean up twice to fix selection bug\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\t//Store n-gons in specific comoponent type\n\tif ($component_Vert > 0)\n\t{\n\t\tConvertSelectionToVertices;\n\t}\n\tif ($component_Edge > 0)\n\t{\n\t\tConvertSelectionToEdges;\n\t}\n\tstring $nGons[] = `ls -sl -fl`;\n\t\n\tselect $obj;\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tselect $selection;\n\n\t\t\n\t//Dot loop invert\n\tglobal int $m341_skipSelector_dotLoopSwitch;\n\tif ($m341_skipSelector_dotLoopSwitch == 1)\n\t{\n\t\tInvertSelection;\n\t\tglobal string $m341_skipSelector_invertComponents[];\n\t\tselect -deselect $m341_skipSelector_invertComponents;\n\t}\n\t\n\t//Pat loop invert\n\tglobal int $m341_skipSelector_patLoopSwitch;\n\tif ($m341_skipSelector_patLoopSwitch == 1)\n\t{\n\t\tInvertSelection;\n\t\tglobal string $m341_skipSelector_invertComponents[];\n\t\tselect -deselect $m341_skipSelector_invertComponents;\n\t}\n\t\n\t//Dot ring invert\n\tglobal int $m341_skipSelector_dotRingSwitch;\n\tif ($m341_skipSelector_dotRingSwitch == 1)\n\t{\n\t\tglobal string $m341_skipSelector_invertComponents[];\t\n\t\tselect $m341_skipSelector_invertComponents;\n\n        //Fix invert dot ring edges\n\t\tglobal int $m341_skipSelector_edgesFound;\n\t\tif ($m341_skipSelector_edgesFound == 1)\n\t\t{\n        \tselect $nGons;\n\t\t\tConvertSelectionToVertices;\n            $nGons = `ls -sl -fl`;\n\t\t\t\n\t    \tglobal string $m341_skipSelector_invertComponents[];\t\n    \t\tselect $m341_skipSelector_invertComponents;\n\t\t\tConvertSelectionToVertices;\n\t\t\tInvertSelection;\n\t\t\tselect -deselect $nGons;\n\t\t\tConvertSelectionToContainedEdges;\n\t\t\tSelectEdgeLoopSp;\n\t\t}\n\n        else\n        {\n    \t\tInvertSelection;            \n        }\n\n\t\tselect -deselect $m341_skipSelector_invertComponents;\n\t\t\n\t\tglobal string $m341_skipSelector_invertComponents[];\n\t\t$m341_skipSelector_invertComponents = `ls -sl -fl`;\n\t\tselect -deselect $nGons;\n\t}\n\t\n\t//Pat ring invert\n\tglobal int $m341_skipSelector_patRingSwitch;\n\tif ($m341_skipSelector_patRingSwitch == 1)\n\t{\n\t\tglobal string $m341_skipSelector_invertComponents[];\t\n\t\tselect $m341_skipSelector_invertComponents;\n\n        //Fix invert pat ring edges\n\t\tif ($component_Edge > 0)\n\t\t{\n\t\t\tstring $edgeRings[] = `ls -sl -fl`;\n\t\t\tglobal int $m341_skipSelector_countEdges;\n\t\t\tfor ($i = 0; $i < $m341_skipSelector_countEdges; ++$i)\n\t\t\t{\n\t\t\t\tselect `ls -sl`;PolySelectTraverse 5;select `ls -sl`;\n\t\t\t\tselect -deselect $edgeRings;\t\t\t\n\t\t\t}\n\t\t}\n\t\t\n\t\telse\n\t\t{\n    \t\tInvertSelection;\n\t    }\n\t\t\n\t\tselect -deselect $m341_skipSelector_invertComponents;\n\t\t\n\t    global string $m341_skipSelector_invertComponents[];\n\t\t$m341_skipSelector_invertComponents = `ls -sl -fl`;\n\t\tselect -deselect $nGons;\n\t}\n\t\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Shell > 0)\n\t{\n\t\tSelectMeshUVShell;\n\t}\n\t\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tif ($component_UV > 0)\n\t{\n\t\tSelectUVMask;\n\t}\n\t\n\tif ($component_Multi > 0)\n\t{\n\t\tSelectMultiComponentMask;\n\t}\n\n\tprint \"Loop/ring inverted\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Dot Loop\nglobal proc m341_skipSelector_dotLoop()\n{\n\t//Query what component mode the user is in\n\tint $component_Face = `selectType -q -facet`;\n\tint $component_Shell = `selectType -q -meshUVShell`;\n\tint $component_Vert = `selectType -q -vertex`;\n\tint $component_Edge = `selectType -q -edge`;\n\tint $component_UV = `selectType -q -polymeshUV`;\n\tint $component_Multi = `selectType -q -meshComponents`;\n\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeSelection = `size $selection`;\n\t\n\t//Error\n\tif ($sizeSelection != 2)\n\t{\n\t\terror \"Please select at least two adjacent components first\\n\";\n\t}\n\n    //Create loop number\n\tstring $edges[] = `filterExpand -ex 1 -sm 32`;\n\tint $sizeEdges = `size $edges`;\n\t\n\tif ($sizeEdges > 0)\n\t{\n\t\tSelectEdgeLoopSp;\n\t\tstring $temp[] = `ls -sl -fl`;\n\t\tselect $temp[0];\n\t\tpolySelectEdgesEveryN \"edgeLoopOrBorder\" 2;\n\t\t$temp = `ls -sl -fl`;\n\t\n\t    SelectEdgeLoopSp;\n    \tstring $ring[] = `ls -sl -fl`;\n\t\n    \tInvertSelection;\n\t    string $badFaces[] = `ls -sl -fl`;\n\n    \tglobal string $m341_skipSelector_invertComponents[];\n\t    $m341_skipSelector_invertComponents = `ls -sl -fl`;\n\t    \n\t    select $temp;\n\t}\n\t\n\telse\n\t{\n    \tSelectEdgeLoopSp;\n\t    SelectEdgeLoopSp;\n    \tstring $ring[] = `ls -sl -fl`;\n\t    int $sizeRing = `size $ring`;\n\t\t\n    \tInvertSelection;\n\t    string $badFaces[] = `ls -sl -fl`;\n\t\n    \tglobal string $m341_skipSelector_invertComponents[];\n\t    $m341_skipSelector_invertComponents = `ls -sl -fl`;\n\n    \tselect $ring[0];\n\t\t\n\t\tint $sizeProgressBar = $sizeRing;\n\t\tprogressWindow -title \"Progress Bar\" -isInterruptable true -status \"\" -maxValue $sizeProgressBar;\t\t\n\t\n\t    for ($i = 0; $i < $sizeRing; ++$i)\n    \t{\n\t    \t$selection = `ls -sl -fl`;\n\t\t    //select `ls -sl`;PolySelectTraverse 5;select `ls -sl`;\n    \t\tGrowPolygonSelectionRegion;\n\t    \tselect -deselect $badFaces;\n\t\t    select -deselect $selection;\n\t\t\t\n\t\t\t//Cancel progress bar\n\t\t\tif(`progressWindow -query -isCancelled`)\n\t\t\t{\n\t\t\t\tprogressWindow -edit -endProgress;\n\t\t\t\terror \"Process cancelled\\n\";\n\t\t\t}\t\t\t\n\n\t\t\t//update the progress bar\n\t\t\tprogressWindow -edit -step 1;\t\t\t\n    \t}\n\t\t//Kill the progress window\n\t\tprogressWindow -edit -endProgress;\t\n\t}\n\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Shell > 0)\n\t{\n\t\tSelectMeshUVShell;\n\t}\n\t\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tif ($component_UV > 0)\n\t{\n\t\tSelectUVMask;\n\t}\n\t\n\tif ($component_Multi > 0)\n\t{\n\t\tSelectMultiComponentMask;\n\t}\n\t\n\t//Invert switches\n\tglobal int $m341_skipSelector_dotLoopSwitch;\n\t$m341_skipSelector_dotLoopSwitch = 1;\n\t\n\tglobal int $m341_skipSelector_patLoopSwitch;\n\t$m341_skipSelector_patLoopSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_dotRingSwitch;\n\t$m341_skipSelector_dotRingSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_patRingSwitch;\n\t$m341_skipSelector_patRingSwitch = 0;\n\t\n\tprint \"Alternating loop selected\\n\";\n}\n\t\n\n//***********************************************************************************************************************************************************\n//Pat Loop\nglobal proc m341_skipSelector_patLoop()\n{\n\t//Query what component mode the user is in\n\tint $component_Face = `selectType -q -facet`;\n\tint $component_Shell = `selectType -q -meshUVShell`;\n\tint $component_Vert = `selectType -q -vertex`;\n\tint $component_Edge = `selectType -q -edge`;\n\tint $component_UV = `selectType -q -polymeshUV`;\n\tint $component_Multi = `selectType -q -meshComponents`;\n\t\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeSelection = `size $selection`;\n\t\n\t//Error\n\tif ($sizeSelection < 2)\n\t{\n\t\terror \"Please select at least two adjacent components first\\n\";\n\t}\n\t\n\t\n\ttoggleSelMode;\n    toggleSelMode;\n    selectMode -object;\n    string $obj[] = `ls -sl`;\n\t\n\t//Find n-gons, run clean up twice to fix selection bug\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\tstring $nGons[] = `ls -sl -fl`;\n\n\tselect $obj;\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\n\tselect $selection;\n\t\n\tstring $check[] = `ls -sl -fl`;\n    int $sizeCheck = `size $check`;\n\t\n\tSelectEdgeLoopSp;\n\t\n\tstring $ring[] = `ls -sl -fl`;\n\tint $sizeRing = `size $ring`;\n\t\n\t//For n-gons hack to get edge loop\n\tstring $counter[] = {};\n\tint $sizeCounter = 0;\n\tstring $expand[] = {};\n\tint $sizeExpand = 0;\n\t\n\tif ($sizeCheck == $sizeRing)\n\t{\n\t    $counter = `ls -sl -fl`;\n        $sizeCounter = `size $counter`;\n        $sizeExpand = $sizeCounter - 1;\n   \n        while ($sizeCounter != $sizeExpand)\n        {\n   \t\t\tselect `ls -sl`;PolySelectTraverse 5;\n\t\t\tselect `ls -sl`;\n            $counter = `ls -sl -fl`;\n            $sizeCounter = `size $counter`;\n            $sizeExpand = $sizeExpand + 1;\n        }\n\t}\n\t\n\t$ring = `ls -sl -fl`;\n\t$sizeRing = `size $ring`;\n\t\n\tselect -deselect $nGons;\n\t\n\tInvertSelection;\n\tstring $badFaces[] = `ls -sl -fl`;\n\t\n\tglobal string $m341_skipSelector_invertComponents[];\n\t$m341_skipSelector_invertComponents = `ls -sl -fl`;\n\n    //Fix for surfaces with subdivision in only one direction like a plane\n    int $tempSize = size(`ls -sl -fl`);\n    if ($tempSize == 0)\n    {\n\t\tselect $selection;\n    }\n\n\n    //Create loop number\n    string $faces[] = `filterExpand -ex 1 -sm 34`;\n   \tint $sizeFaces = `size $faces`;\n\tif ($sizeFaces > 0)\n\t{\n\t\tselect $selection[0];\n\t\tstring $temp[] = `ls -sl -fl`;\n\t\tselect $temp[0];\n\t}\n\t\n    //Create loop number\n   \tstring $edges[] = `filterExpand -ex 1 -sm 32`;\n\tint $sizeEdges = `size $edges`;\n\tif ($sizeEdges > 0)\n\t{\n\t\tselect $selection[0];\n        ConvertSelectionToFaces;\n\t\tstring $temp[] = `ls -sl -fl`;\n\t\tselect $temp[0];\n\t}\n\t\n    //Create loop number\n\tstring $verts[] = `filterExpand -ex 1 -sm 31`;\n\tint $sizeVerts = `size $verts`;\n\tif ($sizeVerts > 0)\n\t{\n\t\tselect $selection[0];\n        ConvertSelectionToFaces;\n\t\tstring $temp[] = `ls -sl -fl`;\n\t\tselect $temp[0];\n\t}\n\n\tSelectFacePath;\n\tstring $loopCount[] = `ls -sl -fl`;\n\t$sizeLoopCount = `size $loopCount`;\n\t$sizeLoopCount = $sizeLoopCount / 2;\n\n\tselect $selection;\n    $sizeSelection = `size $selection`;\n    int $skipAmount = 0;\n\n\n    //Fast edge selection using Maya built in command\n\tif ($sizeEdges > 0)\n\t{\n\n\t    $skipAmount = $sizeSelection * 2;\n       \tpolySelectEdgesEveryN \"edgeLoopOrBorder\" $skipAmount;\n\t}\n\t\n\telse\n\t{\n\t\tint $sizeProgressBar = $sizeLoopCount;\n\t\tprogressWindow -title \"Progress Bar\" -isInterruptable true -status \"\" -maxValue $sizeProgressBar;\t\t\n\t\t\n    \tfor ($i = 0; $i < $sizeLoopCount; ++$i)\n\t    {\n    \t\tfor ($grow = 0; $grow < $sizeSelection; ++$grow)\n\t    \t{\n    \t\t\t//select `ls -sl`;PolySelectTraverse 5;select `ls -sl`;\n\t\t    \tGrowPolygonSelectionRegion;\n\t    \t\tselect -deselect $badFaces;\n    \t\t}\n\t\t    select -deselect $selection;\n\t    \t$selection = `ls -sl -fl`;\n\t\t\t\n\t\t\t//Cancel progress bar\n\t\t\tif(`progressWindow -query -isCancelled`)\n\t\t\t{\n\t\t\t\tprogressWindow -edit -endProgress;\n\t\t\t\terror \"Process cancelled\\n\";\n\t\t\t}\t\t\t\n\n\t\t\t//update the progress bar\n\t\t\tprogressWindow -edit -step 1;\t\t\t\n    \t}\n\t\t\n\t\t//Kill the progress window\n\t\tprogressWindow -edit -endProgress;\t\n\t}\n\t\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t}\n\t\n\tif ($component_Shell > 0)\n\t{\n\t\tSelectMeshUVShell;\n\t}\n\t\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tif ($component_UV > 0)\n\t{\n\t\tSelectUVMask;\n\t}\n\t\n\tif ($component_Multi > 0)\n\t{\n\t\tSelectMultiComponentMask;\n\t}\n\t\n\t//Invert switches\n\tglobal int $m341_skipSelector_dotLoopSwitch;\n\t$m341_skipSelector_dotLoopSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_patLoopSwitch;\n\t$m341_skipSelector_patLoopSwitch = 1;\n\t\n\tglobal int $m341_skipSelector_dotRingSwitch;\n\t$m341_skipSelector_dotRingSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_patRingSwitch;\n\t$m341_skipSelector_patRingSwitch = 0;\n\t\n\tm341_skipSelector_invertLoopRing();\n\t\n\tprint \"Pattern loop selected\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//To Loop\nglobal proc m341_skipSelector_toLoop()\n{\n\t//Error\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeSelection = `size $selection`;\n\tif ($sizeSelection == 0)\n\t{\n\t\terror \"Nothing selected\\n\";\n\t}\n\n\tstring $edges[] = `filterExpand -ex 1 -sm 32`;\n\tint $sizeEdges = `size $edges`;\n\tif ($sizeEdges > 0)\n\t{\n\t\t//Error\n\t\tif ($sizeEdges < 1)\n\t\t{\n\t\t\terror \"Please select at least one edge first\\n\";\n\t\t}\t\t\n\t\tSelectEdgeLoopSp;\n\t\tprint \"Selection converted to loop\\n\";\n\t}\t\t\n\n\tstring $verts[] = `filterExpand -ex 1 -sm 31`;\n\tint $sizeVerts = `size $verts`;\n\tif ($sizeVerts > 0)\n\t{\n\t\t//Error\n\t\tif ($sizeVerts < 2)\n\t\t{\n\t\t\terror \"Please select at least two vertices first\\n\";\n\t\t}\n\t\tSelectEdgeLoopSp;\n\t\tprint \"Selection converted to loop\\n\";\n\t}\n\t\t\n\tstring $faces[] = `filterExpand -ex 1 -sm 34`;\n\tint $sizeFaces = `size $faces`;\n\tif ($sizeFaces > 0)\n\t{\n\t\t//Error\n\t\tif ($sizeFaces < 2)\n\t\t{\n\t\t\terror \"Please select at least two faces first\\n\";\n\t\t}\n\t\tSelectEdgeLoopSp;\n\t\tprint \"Selection converted to loop\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//To Ring\nglobal proc m341_skipSelector_toRing()\n{\n\t//Error\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeSelection = `size $selection`;\n\tif ($sizeSelection == 0)\n\t{\n\t\terror \"Nothing selected\\n\";\n\t}\n\n\tstring $edges[] = `filterExpand -ex 1 -sm 32`;\n\tint $sizeEdges = `size $edges`;\n\t\n\tif ($sizeEdges > 0)\n\t{\n\t\tSelectEdgeRingSp;\n\t\tprint \"Selection converted to ring\\n\";\n\t}\t\t\n\n\tstring $verts[] = `filterExpand -ex 1 -sm 31`;\n\tint $sizeVerts = `size $verts`;\n\n\tif ($sizeVerts > 0)\n\t{\n\t\t//Error\n\t\tif ($sizeVerts < 2)\n\t\t{\n\t\t\terror \"Please select at least two adjacent components first\\n\";\n\t\t}\n\t\t\n\t\tConvertSelectionToContainedEdges;\n\t\tSelectEdgeRingSp;\n\t\tConvertSelectionToVertices;\n\t\tprint \"Selection converted to ring\\n\";\n\t}\n\t\n\t\n\tstring $faces[] = `filterExpand -ex 1 -sm 34`;\n\tint $sizeFaces = `size $faces`;\n\n\tif ($sizeFaces > 0)\n\t{\n\t\t//Error\n\t\tif ($sizeFaces < 2)\n\t\t{\n\t\t\terror \"Please select at least two adjacent components first\\n\";\n\t\t}\n\t\t\n\t\tConvertSelectionToContainedEdges;\n\t\tSelectEdgeLoopSp;\n\t\tConvertSelectionToFaces;\n\t\tprint \"Selection converted to ring\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Dot Ring\nglobal proc m341_skipSelector_dotRing()\n{\n\t//Query what component mode the user is in\n\tint $component_Face = `selectType -q -facet`;\n\tint $component_Shell = `selectType -q -meshUVShell`;\n\tint $component_Vert = `selectType -q -vertex`;\n\tint $component_Edge = `selectType -q -edge`;\n\tint $component_UV = `selectType -q -polymeshUV`;\n\tint $component_Multi = `selectType -q -meshComponents`;\n\t\n\tstring $selection[] = `ls -sl -fl`;\n\tint $sizeSelection = `size $selection`;\n\t\n\ttoggleSelMode;\n    toggleSelMode;\n    selectMode -object;\n    string $obj[] = `ls -sl`;\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tselect $selection;\n\t\n\t\n\t\n\t//Error\n\tif ($sizeSelection < 2)\n\t{\n\t\terror \"Please select at least two adjacent components first\\n\";\n\t}\n\t\n\tif ($sizeSelection > 2)\n\t{\n\t\terror \"Please select at least two adjacent components first\\n\";\n\t}\n\t\n\t//If edges get vert ring\n\tif ($component_Edge > 0)\n\t{\n\t\tConvertSelectionToVertices;\n\t}\n\t\n\tSelectEdgeLoopSp;\n\tSelectEdgeLoopSp;\n\tstring $ring[] = `ls -sl -fl`;\n\tint $sizeRing = `size $ring`;\n\tselect $ring;\n\t\n\t//Find n-gons, run clean up twice to fix selection bug\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\t//Store n-gons in specific comoponent type\n\tif ($component_Vert > 0)\n\t{\n\t\tConvertSelectionToVertices;\n\t}\n\n\tif ($component_Edge > 0)\n\t{\n\t\tConvertSelectionToEdges;\n\t}\n\tstring $nGons[] = `ls -sl -fl`;\n\t\n\tselect $obj;\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\t//Build loop counter\n\tselect $ring[0];\n    SelectFacePath;\n\tstring $counter[] = `ls -sl -fl`;\n\tint $sizeCounter = `size $counter`;\n\t$sizeCounter = $sizeCounter / 2;\n\t\n\tselect $ring;\n\t\n\t//If verts run Maya built in command trick to save time\n\tif ($component_Vert > 0)\n\t{\n        select $selection;\n        ConvertSelectionToContainedEdges;\n        polySelectEdgesEveryN \"edgeRing\" 2;\n        SelectEdgeLoopSp;\n        ConvertSelectionToVertices;\n\t}\n\t\n\tif ($component_Edge > 0)\n    {\n        select $selection;\n        polySelectEdgesEveryN \"edgeRing\" 2;\n        SelectEdgeLoopSp;\n    }\n\n\t\n\t//Faces\n\tif ($component_Face > 0)\n    {\n\t\tint $sizeProgressBar = $sizeCounter;\n\t\tprogressWindow -title \"Progress Bar\" -isInterruptable true -status \"\" -maxValue $sizeProgressBar;\t\t\n\t\n    \tfor ($i = 0; $i < $sizeCounter; ++$i)\n    \t{\n\t\t    select -deselect $nGons;\n\t    \t//if ($component_Vert > 0 || $component_Edge > 0)\n    \t\t//{\n\t\t    //\tselect `ls -sl`;PolySelectTraverse 5;select `ls -sl`;\n\t    \t//}\n    \t\t$selection = `ls -sl -fl`;\n\t\t    GrowPolygonSelectionRegion;\n\t    \tselect -deselect $selection;\n\t\t\t\n\t\t\t//Cancel progress bar\n\t\t\tif(`progressWindow -query -isCancelled`)\n\t\t\t{\n\t\t\t\tprogressWindow -edit -endProgress;\n\t\t\t\terror \"Process cancelled\\n\";\n\t\t\t}\n\t\t\t\n\t\t\t//update the progress bar\n\t\t\tprogressWindow -edit -step 1;\t\t\t\n\t\t\t\n    \t}\n\t\t//Kill the progress window\n\t\tprogressWindow -edit -endProgress;\t\n\t}\n\t\n\n\n\tselect -deselect $nGons;\n\tstring $finalSelect[] = `ls -sl -fl`;\n\t\n\tglobal string $m341_skipSelector_invertComponents[];\n\tif ($component_Edge > 0)\n\t{\n\t\tglobal int $m341_skipSelector_edgesFound;\n\t\t$m341_skipSelector_edgesFound = 1;\n\t}\n\t\n\telse\n\t{\n\t\tglobal int $m341_skipSelector_edgesFound;\n\t\t$m341_skipSelector_edgesFound = 0;\n\t}\n\n\n\t$m341_skipSelector_invertComponents = `ls -sl -fl`;\n\tselect $finalSelect;\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Shell > 0)\n\t{\n\t\tSelectMeshUVShell;\n\t}\n\t\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tif ($component_UV > 0)\n\t{\n\t\tSelectUVMask;\n\t}\n\t\n\tif ($component_Multi > 0)\n\t{\n\t\tSelectMultiComponentMask;\n\t}\n\t\n\t\n\t//Invert switches\n\tglobal int $m341_skipSelector_dotLoopSwitch;\n\t$m341_skipSelector_dotLoopSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_patLoopSwitch;\n\t$m341_skipSelector_patLoopSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_dotRingSwitch;\n\t$m341_skipSelector_dotRingSwitch = 1;\n\t\n\tglobal int $m341_skipSelector_patRingSwitch;\n\t$m341_skipSelector_patRingSwitch = 0;\n\t\n\tprint \"Alternating ring selected\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Pat Ring\nglobal proc m341_skipSelector_patRing()\n{\n\t//Query what component mode the user is in\n\tint $component_Face = `selectType -q -facet`;\n\tint $component_Shell = `selectType -q -meshUVShell`;\n\tint $component_Vert = `selectType -q -vertex`;\n\tint $component_Edge = `selectType -q -edge`;\n\tint $component_UV = `selectType -q -polymeshUV`;\n\tint $component_Multi = `selectType -q -meshComponents`;\n\n\tstring $selection[] = `ls -sl -fl`;\n\t\n\ttoggleSelMode;\n    toggleSelMode;\n    selectMode -object;\n    string $obj[] = `ls -sl`;\n\t\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\n\t\n\tselect $selection;\n\t\n\n\tstring $edges[] = `ls -sl -fl`;\n\tglobal int $m341_skipSelector_countEdges;\n\t$m341_skipSelector_countEdges = `size $edges`;\n\t\n\t\n\t//Error\n\tif ($m341_skipSelector_countEdges < 2)\n\t{\n\t\terror \"Please select at least two adjacent components first\\n\";\n\t}\n\t\n\n\t//Find n-gons, run clean up twice to fix selection bug\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\tpolyCleanupArgList 4 { \"0\",\"2\",\"1\",\"0\",\"1\",\"0\",\"0\",\"0\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"1e-05\",\"0\",\"-1\",\"0\",\"0\" };\n\t//Store n-gons in specific comoponent type\n\tif ($component_Vert > 0)\n\t{\n\t\tConvertSelectionToVertices;\n\t}\n\tif ($component_Edge > 0)\n\t{\n\t\tConvertSelectionToEdges;\n\t}\n\tstring $nGons[] = `ls -sl -fl`;\n\t\n\tselect $obj;\n\tif ($component_Face > 0)\n\t{\n\t\tSelectFacetMask;\n\t\t\n\t}\n\t\n\tif ($component_Vert > 0)\n\t{\n\t\tSelectVertexMask;\n\t}\n\t\n\tif ($component_Edge > 0)\n\t{\n\t\tSelectEdgeMask;\n\t}\t\n\t\n\tselect $selection;\n\n\tm341_skipSelector_patLoop();\n\tm341_skipSelector_toRing();\n\t\n\tselect -deselect $nGons;\n\tglobal string $m341_skipSelector_invertComponents[];\n\t$m341_skipSelector_invertComponents = `ls -sl -fl`;\n\t\n\t//Invert switches\n\tglobal int $m341_skipSelector_dotLoopSwitch;\n\t$m341_skipSelector_dotLoopSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_patLoopSwitch;\n\t$m341_skipSelector_patLoopSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_dotRingSwitch;\n\t$m341_skipSelector_dotRingSwitch = 0;\n\t\n\tglobal int $m341_skipSelector_patRingSwitch;\n\t$m341_skipSelector_patRingSwitch = 1;\n\t\n\tprint \"Pattern ring selected\\n\";\n}\n\n\n//***********************************************************************************************************************************************************\n//Window and Buttons\nglobal proc m341_skipSelector_launchWindow()\n{\n\tif (`window -exists m341_skipSelector_windowName`)\n\t{\n\t\tdeleteUI m341_skipSelector_windowName;\n\t};\n\t\n\tglobal string $m341_skipSelectorVersion;\n\twindow -title $m341_skipSelectorVersion -toolbox true -sizeable true -resizeToFitChildren true m341_skipSelector_windowName;\n\tcolumnLayout -adjustableColumn true;\n\ttext -label \"by Malcolm341\";\n\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-labelOffset 30\n\t\t\t-label \"click for help\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 100\n\t\t\t-height 15\n\t\t\t-command \"m341_skipSelector_help;\";\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.596 0.529 0.769\n\t\t\t-width 100\n\t\t\t-label \"invert dot/pat\"\n\t\t\t-command \"m341_skipSelector_invertLoopRing;\";\n\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.50 0.67 0.37\n\t\t\t-width 50\n\t\t\t-label \"dot loop\"\n\t\t\t-command \"m341_skipSelector_dotLoop;\"\n\t\t\t-commandRepeatable 1;\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.32 0.59 0.72\n\t\t\t-width 49\n\t\t\t-label \"pat loop\"\n\t\t\t-command \"m341_skipSelector_patLoop;\"\n\t\t\t-commandRepeatable 1;\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 50\n\t\t\t-height 17\n\t\t\t-label \"to loop\"\n\t\t\t-command \"m341_skipSelector_toLoop;\"\n\t\t\t-commandRepeatable 1;\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.51 0.51 0.51\n\t\t\t-width 49\n\t\t\t-height 17\n\t\t\t-label \"to ring\"\n\t\t\t-command \"m341_skipSelector_toRing;\";\n\t\t\n\t\tsetParent ..;\n\t\trowColumnLayout -numberOfRows 1 -adjustableColumn 1;\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.50 0.67 0.37\n\t\t\t-width 50\n\t\t\t-label \"dot ring\"\n\t\t\t-command \"m341_skipSelector_dotRing;\";\n\t\t\tseparator -width 1 -style \"none\";\n\t\t\t\n\t\ticonTextButton -style \"textOnly\"\n\t\t\t-backgroundColor 0.32 0.59 0.72\n\t\t\t-width 49\n\t\t\t-label \"pat ring\"\n\t\t\t-command \"m341_skipSelector_patRing;\";\n\t\t\n\tshowWindow;\n\twindow -edit -width 100 -height 100 m341_skipSelector_windowName;\n\t\n\tprint (\"Toolbox loaded \" + $m341_skipSelectorVersion + \"\\n\");\n}\n\nm341_skipSelector_launchWindow();\n\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Half" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Half" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "polyConvertToEdgeLoop.png" 
        -image1 "polyConvertToEdgeLoop.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here www.gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps create new tools, features, and bug fixes\n\n\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\n//Select Half Your Mesh from Edge Loop v1.7\n//-----------------------------------------------------------------------------------------------------------------------------------------------------------\nglobal proc m341_loopToHalfFaces()\n{\n\tstring $edges[] = `ls -sl -fl`;\n\tint $sizeEdges = `size $edges`;\n\t\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\t//DeleteHistory;\n\tstring $mesh[] = `ls -sl`;\n\t\n\t//Create shells and store planar node to delete later\n\tConvertSelectionToFaces;\n\tpolyProjection -ch 1 -type Planar -ibd on -md x;\n\t//toggleSelMode;\n\t//toggleSelMode;\n\t//selectMode -object;\n\tstring $historyNode[] = `listHistory -fullNodeName 1 $mesh`;\n\n\t//Cut UV edges\n\tselect $edges;\n\tpolyMapCut -ch 0;\n\t\n\n\t//Error if edge loop won't create too halves\t\n\tint $numbUVShells[] = `polyEvaluate -uvShell $mesh[0]`;\n\tif ($numbUVShells[0] < 2)\n\t{\n\t\t//polyUVSet -delete -uvSet \"m341_tempUVsDelete\";\n\t\tSelectEdgeMask;\n \t\terror \"Current edge loop selection can't divide the mesh into two halves\\n\";\n\t}\n\n\t//Get faces\n\tConvertSelectionToUVs;\n\tInvertSelection;\n\tstring $UVs[] = `ls -sl -fl`;\n\tselect $UVs[0];\n\tConvertSelectionToUVShell;\n\tConvertSelectionToFaces;\n\tstring $faces[] = `ls -sl -fl`;\n\n\t//Clean up\n\tdelete $historyNode[1];\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\tDeleteHistory;\n\n\t//Select half\n\tselect $faces;\n\tselect -add $mesh;\n\tSelectMultiComponentMask;\n\t//So you don't get accidental components selected if the script errored out on the previous run\n\tselect $faces;\n\t\n\tprint \"Select half mesh complete\\n\";\n}\nm341_loopToHalfFaces();\n\n\n\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Help Half" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc m341_HelpLooptoHalfFaces()\n{\n\tglobal string $m341_LooptoHalfFaces_HelpWindow;\n\n\tif (`window -exists $m341_LooptoHalfFaces_HelpWindow`)\n\t{\n\t\tglobal string $m341_LooptoHalfFaces_HelpWindow;\n\t\tdeleteUI $m341_LooptoHalfFaces_HelpWindow;\n\t}\n\t\n\t$m341_LooptoHalfFaces_HelpWindow = `window -title \"Loop to Half Faces Help\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable false -resizeToFitChildren false -width 800 -height 190`;\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"HALF\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Converts the current edge loop selection into one half of the faces on the mesh, handy for selecting half your mesh quickly. If the wrong half of the mesh is selected immediately run the tool a second time to select the other half.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-The edge loop needs to be continuous without any gaps in it for the tool to work. For example, select a continuous horizontal edge loop on a sphere and run the tool.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-The edge loop selection can be any shape you want and doesn't need to be exactly half the mesh, any shape will work as long as the loop is continuous and creates two distict elements to select.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/WRGN1BSqnfI?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/WRGN1BSqnfI?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_LooptoHalfFaces_HelpWindow;\n}\nm341_HelpLooptoHalfFaces();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Right click for help" 
        -enableBackground 1
        -backgroundColor 0.168627 0.168627 0.168627 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "findGB" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "findGB" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.133333 0.133333 0.133333 0.7 
        -image "menuIconSubdivSurf.png" 
        -image1 "menuIconSubdivSurf.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Find Geometry Border Edges v1.0\n\n{\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\tDeleteHistory;\n\n\t//Switch to edge selection mask mode\n\tsetSelectMode components Components;\n\tselectType -smp 0 -sme 1 -smf 0 -smu 0 -pv 0 -pe 1 -pf 0 -puv 0;\n\tHideManipulators; \n\n\t//Select geometry border edges to check for seams\n\tpolySelectConstraint -mode 3 -type 0x8000 -where 1;\n\tresetPolySelectConstraint;\n\n\t//Store geometry border edges in variable\n\t$geoBorderEdges = `ls -sl -fl`;\n\t$geoBorderEdgesSize = `size $geoBorderEdges`;\n\n\tprint (\"Geometry border edges found \" + $geoBorderEdgesSize);\n}\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "" ( "" )
        -mi "Merge Selected findGB" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Merge Selected Verts and Find Geometry Border Edges v1.0\n\n{\n\t//Merge verts\n\tpolyMergeVertex  -d 0.01 -am 1 -ch 0;\n\n\ttoggleSelMode;\n\ttoggleSelMode;\n\tselectMode -object;\n\tDeleteHistory;\n\n\t//Switch to edge selection mask mode\n\tsetSelectMode components Components;\n\tselectType -smp 0 -sme 1 -smf 0 -smu 0 -pv 0 -pe 1 -pf 0 -puv 0;\n\tHideManipulators; \n\n\t//Select geometry border edges to check for seams\n\tpolySelectConstraint -mode 3 -type 0x8000 -where 1;\n\tresetPolySelectConstraint;\n\n\t//Store geometry border edges in variable\n\t$geoBorderEdges = `ls -sl -fl`;\n\t$geoBorderEdgesSize = `size $geoBorderEdges`;\n\n\tprint (\"Geometry border edges found \" + $geoBorderEdgesSize);\n}\n\n" )
        -mi "Help findGB" ( "//This is a paid script pack and is not free to use. Please purchase a copy and download the script pack here https://gumroad.com/malcolm341\n\n//Thanks very much for your support! Each purchase helps maintain the ad free Youtube channel found here https://www.youtube.com/malcolm341\n\n//Help\n\nglobal proc helpFindGB()\n{\n\tglobal string $m341_findGB_HelpWindow;\n\n\tif (`window -exists $m341_findGB_HelpWindow`)\n\t{\n\t\tglobal string $m341_findGB_HelpWindow;\n\t\tdeleteUI $m341_findGB_HelpWindow;\n\t}\n\t\n\t$m341_findGB_HelpWindow = `window -title \"Help Find Geometry Border Edges\" -leftEdge 900 -topEdge 115 -toolbox true -sizeable true -resizeToFitChildren false -width 800 -height 138`;\n\t\t\n\tpaneLayout -configuration \"horizontal2\";\n\tscrollLayout;\n\trowColumnLayout -numberOfColumns 1;\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"FIND GB\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Selects all geometry border edges on the current mesh. This is helpful for identifying unweled verts and open edges.\\n\";\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"-Right click the shelf button and choose Merge Selected findGB to merge selected vertices with a radius of 0.01 and select geometry border edges with a single click.\\n\\n\";\n\t\n\t\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -font \"boldLabelFont\" -label \"YOUTUBE VIDEO HERE\";\n\ttext -align \"left\" -wordWrap 1 -width 780 -hl 1 -label \"<a href=\\\"https://youtu.be/1qC5HS9FcXM?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6\\\"style=\\\"color:rgb(187,187,187)\\;\\\">https://youtu.be/1qC5HS9FcXM?list=PLAUgGUDpaMENfz8Nd7Zw-LxDK_v5ZflY6</a><br>\";\n\t\n\tshowWindow $m341_findGB_HelpWindow;\n}\nhelpFindGB();" )
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
