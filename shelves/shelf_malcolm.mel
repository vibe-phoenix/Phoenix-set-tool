 value\n\tif ($m341_extraHUD_camDistance_userInput == 0)\n\t{\n\t\theadsUpDisplay -rem extraHUD_camDistance_HUDName;\n\t\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_camDistance*/\"};\n\t\n\t\t//Remove HUD text from userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\tprint \"Cam distance checkbox off\\n\";\n\t}\n\n\telse\n\t{\n\t\theadsUpDisplay -section $camDistance_SectionVar -block $camDistance_NextFreeBlock -preset \"distanceFromCamera\" -label \"Cam Distance:\" extraHUD_camDistance_HUDName;\n\t\n\t\t//Create search text specific to this checkbox to use with global add/remove proc above\n\t\tglobal string $m341_extraHUD_searchFor[];\n\t\t$m341_extraHUD_searchFor = {\"/*m341_extraHUD_camDistance*/\"};\n\t\t\n\t\t//Add HUD text to userSetup.mel using global variable at top of proc\n\t\tm341_extraHUD_userSetup_regularCheckbox();\n\t\t\n\t\t//Suppress spam prints\n\t\tm341_extraHUD_SuppressPrint();\n\t\tprint \"Cam distance checkbox on\\n\";\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Save and auto save refresher script job\n\n//Global variables\nglobal float $m341_extraHUD_refresh_counter1;\n$m341_extraHUD_refresh_counter1 = 0.45;\nglobal float $m341_extraHUD_refresh_counter2;\n$m341_extraHUD_refresh_counter2 = 0.55;\nglobal float $m341_extraHUD_refresh_startTime1;\n$m341_extraHUD_refresh_startTime1 = `timerX`;\n\n//Refresh timer that runs in background\nglobal proc m341_extraHUD_refreshTimer()\n{\n\tglobal float $m341_extraHUD_refresh_startTime1;\n\tglobal float $m341_extraHUD_refresh_elapsedTime;\n\tglobal float $m341_extraHUD_refresh_counter1;\n\tglobal float $m341_extraHUD_refresh_counter2;\n\t\n\t$m341_extraHUD_refresh_elapsedTime = `timerX -startTime $m341_extraHUD_refresh_startTime1`;\n\t\n\tif ($m341_extraHUD_refresh_elapsedTime >= $m341_extraHUD_refresh_counter1 && $m341_extraHUD_refresh_elapsedTime <= $m341_extraHUD_refresh_counter2)\n\t{\n        //print ($m341_extraHUD_refresh_elapsedTime + \"\\n\");\n\t\trefresh;\n\t\tglobal float $m341_extraHUD_refresh_counter1;\n\t\tglobal float $m341_extraHUD_refresh_counter2;\n\t\t$m341_extraHUD_refresh_counter1 = $m341_extraHUD_refresh_counter1 + 0.4;\n\t\t$m341_extraHUD_refresh_counter2 = $m341_extraHUD_refresh_counter2 + 0.4;\n\t}\n\t\n\tif ($m341_extraHUD_refresh_elapsedTime > $m341_extraHUD_refresh_counter2)\n\t{\n\t\tglobal float $m341_extraHUD_refresh_elapsedTime;\n\t\tglobal float $m341_extraHUD_refresh_counter1;\n\t\tglobal float $m341_extraHUD_refresh_counter2;\n\t\n\t\t$m341_extraHUD_refresh_elapsedTime = $m341_extraHUD_refresh_counter1 + 0.3;\n\t\t\n        //print ($m341_extraHUD_refresh_elapsedTime + \"\\n\");\n    \trefresh;\n\t\t$m341_extraHUD_refresh_counter1 = $m341_extraHUD_refresh_counter1 + 0.4;\n\t\t$m341_extraHUD_refresh_counter2 = $m341_extraHUD_refresh_counter2 + 0.4;\n\t\t//polyCube -w 1 -h 1 -d 1 -sx 1 -sy 1 -sz 1 -ax 0 1 0 -cuv 4 -ch 1;\n\t}\n}\n\n\n//***********************************************************************************************************************************************************\n//Update lastSave Checkbox Value\nglobal proc string m341_extraHUD_lastSave_Display()\n{\n\t//Start timer\n\tglobal float $m341_extraHUD_startTime;\n    float $currentTime = `timerX -startTime $m341_extraHUD_startTime`;\n  \n  \tint $minutes = $currentTime / 60;\n  \tint $seconds = $currentTime % 60;\n  \tint $hours = $minutes / 60;\n  \t$minutes %= 60;\n  \n    return ($hours + \":\" + $minutes + \":\" + $seconds);\n}\n\n//***********************************************************************************************************************************************************\n//Update lastSave Checkbox Value After restart\nglobal proc string m341_extraHUD_lastSave_displayBroken()\n{\n\tstring $broken = \"Toggle Checkbox to Enable Timer\\n\";\n    return ($broken);\n}\n\n//Reset Timer proc\nglobal proc m341_extraHUD_lastSave_ScriptJobProc()\n{\n\tglobal float $m341_extraHUD_startTime;\n    float $currentTime = `timerX -startTime $m341_extraHUD_startTime`;\n\t\n\tint $minutes = $currentTime / 60;\n  \tint $seconds = $currentTime % 60;\n  \tint $hours = $minutes / 60;\n  \t$minutes %= 60;\n\t\n\t$m341_extraHUD_startTime = `timerX`;\n\t\n\t//Test if script job running\n\t//polySphere -r 1 -sx 32 -sy 32 -ax 0 1 0 -cuv 2 -ch 1;\n}\n\nglobal proc m341_extraHUD_lastSave_ValueChanged()\n{\n\t//Section and block variables\n\tint $lastSave_SectionVar = 6;\n\tint $lastSave_NextFreeBlock = `headsUpDisplay -nextFreeBlock $lastSave_SectionVar`;\n\n\t//Create a string array with text in it to add or remove from userSet.mel\n\tglobal string $m341_extraHUD_print_textArray[];\n\t$m341_extraHUD_print_textArray = {\"/*m341_extraHUD_lastSave*/ evalDeferred \\\"commandEcho -af {\\\\\\\"m341_extraHUD_refreshTimer\\\\\\\", \\\\\\\"m341_extraHUD_lastSave_Display()\\\\\\\"}\\\";\\\n\t\\\n\tglobal float $m341_extraHUD_refresh_counter1;\\\n\t$m341_extraHUD_refresh_counter1 = 0.45;\\\n\tglobal float $m341_extraHUD_refresh_counter2;\\\n\t$m341_extraHUD_refresh_counter2 = 0.55;\\\n\tglobal float $m341_extraHUD_refresh_startTime1;\\\n\t$m341_extraHUD_refresh_startTime1 = `timerX`;\\\n\t\\\n\tglobal proc string m341_extraHUD_lastSave_Display()\\\n\t{\\\n\t\tglobal float $m341_extraHUD_startTime;\\\n\t\tfloat $currentTime = `timerX -startTime $m341_extraHUD_startTime`;\\\n\t\tint $minutes = $currentTime / 60;\\\n\t\tint $seconds = $currentTime % 60;\\\n\t\tint $hours = $minutes / 60;\\\n\t\t$minutes %= 60;\\\n\t\treturn ($hours + \\\":\\\" + $minutes + \\\":\\\" + $seconds);\\\n\t}\\\n\t\\\n\tglobal proc m341_extraHUD_refreshTimer()\\\n\t{\\\n\t\tglobal float $m341_extraHUD_refresh_startTime1;\\\n\t\tglobal float $m3