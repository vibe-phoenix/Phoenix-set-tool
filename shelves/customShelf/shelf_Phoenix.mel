        -marginHeight 1
        -command "# Maya Units Popup (buttons for: millimeter, centimeter, meter, inch, foot, yard)\n# Paste into Script Editor (Python) and run. Bind `units_popup()` to a shelf button if you like.\n\nimport maya.cmds as cmds\n\n_UNIT_MAP = {\n    \"millimeter\": \"mm\",\n    \"centimeter\": \"cm\",\n    \"meter\": \"m\",\n    \"inch\": \"in\",\n    \"foot\": \"ft\",\n    \"yard\": \"yd\",\n}\n\ndef _set_working_units(full_word):\n    code = _UNIT_MAP.get(full_word)\n    if not code:\n        cmds.warning(\"Unknown unit: {}\".format(full_word))\n        return\n    try:\n        cmds.undoInfo(openChunk=True)\n        cmds.currentUnit(linear=code)\n        cmds.inViewMessage(amg='Linear units set to <hl>{}</hl>.'.format(full_word),\n                           pos='topCenter', fade=True, alpha=.9)\n        print(\"[Units] Linear units set to:\", full_word, \"({})\".format(code))\n    finally:\n        cmds.undoInfo(closeChunk=True)\n\ndef _get_current_unit_full():\n    code = cmds.currentUnit(q=True, linear=True)\n    for full, short in _UNIT_MAP.items():\n        if short == code:\n            return full\n    return code  # fallback\n\ndef units_popup():\n    current = _get_current_unit_full()\n    # Buttons use Title Case so they're clean in the UI; we'll map back to full-word lowercase.\n    buttons = [\"Millimeter\", \"Centimeter\", \"Meter\", \"Inch\", \"Foot\", \"Yard\", \"Cancel\"]\n\n    # Try to highlight the current unit button as default if present\n    default_btn = current.title() if current and current.title() in buttons else \"Cancel\"\n\n    choice = cmds.confirmDialog(\n        title=\"Set Working Units\",\n        message=\"Choose linear unit (current: {})\".format(current),\n        button=buttons,\n        defaultButton=default_btn,\n        cancelButton=\"Cancel\",\n        dismissString=\"Cancel\",\n        icon=\"question\"\n    )\n\n    if choice and choice != \"Cancel\":\n        _set_working_units(choice.lower())\n\n# Run this to open the popup\nunits_popup()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
