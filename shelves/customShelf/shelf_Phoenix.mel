        -image "alignMin.png" 
        -image1 "alignMin.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef align_lowest_point_to_world_y0(selection=None):\n    \"\"\"\n    Moves selected transforms (meshes/groups) in Y so their lowest world-space point\n    (bounding box minY) aligns to world Y=0. X/Z are unchanged.\n    \"\"\"\n    if selection is None:\n        selection = cmds.ls(sl=True, long=True) or []\n\n    if not selection:\n        cmds.warning(\"Nothing selected. Select meshes or groups (transforms).\")\n        return\n\n    # Filter to transforms (groups/mesh transforms)\n    transforms = []\n    for obj in selection:\n        if cmds.nodeType(obj) == \"transform\":\n            transforms.append(obj)\n        else:\n            parent = cmds.listRelatives(obj, parent=True, fullPath=True) or []\n            if parent and cmds.nodeType(parent[0]) == \"transform\":\n                transforms.append(parent[0])\n\n    transforms = list(dict.fromkeys(transforms))  # unique, keep order\n\n    for t in transforms:\n        # World-space bounding box: [minX, minY, minZ, maxX, maxY, maxZ]\n        bb = cmds.exactWorldBoundingBox(t)\n        minY = bb[1]\n\n        # If minY is already at 0, no move needed\n        if abs(minY) < 1e-8:\n            continue\n\n        # Move ONLY in Y by -minY so minY becomes 0\n        cmds.move(0, -minY, 0, t, relative=True, worldSpace=True)\n\n    cmds.inViewMessage(\n        amg=\"Aligned lowest point to <hl>World Y=0</hl> (Y only).\",\n        pos=\"topCenter\",\n        fade=True\n    )\n\n# Run it on current selection:\nalign_lowest_point_to_world_y0()\n" 
        -sourceType "python" 
        -doubleClickCommand "\"\"\"\nPhoenix Snap Panel\nSnaps the selected mesh/group to the nearest surface in any direction.\nRaycasts from the selection's bounding box face in that direction,\nfinds the closest other mesh, and aligns the object flush against it.\n\"\"\"\n\nimport maya.cmds as cmds\nimport maya.api.OpenMaya as om2\n\nWINDOW_NAME = \"phoenixSnapPanel\"\n\n\ndef get_all_mesh_shapes(node):\n    shapes = cmds.listRelatives(node, allDescendents=True, type=\"mesh\", fullPath=True) or []\n    direct = cmds.listRelatives(node, shapes=True, fullPath=True, type=\"mesh\") or []\n    return list(set(shapes + direct))\n\n\ndef snap_direction(direction):\n    sel = cmds.ls(selection=True, long=True)\n    if not sel:\n        cmds.warning(\"Nothing selected.\")\n        return\n\n    target = sel[0]\n\n    if cmds.nodeType(target) == \"mesh\":\n        transform = cmds.listRelatives(target, parent=True, fullPath=True)[0]\n    elif cmds.nodeType(target) == \"transform\":\n        transform = target\n    else:\n        cmds.warning(\"Select a mesh or group.\")\n        return\n\n    own_shapes = get_all_mesh_shapes(transform)\n    all_meshes = cmds.ls(type=\"mesh\", long=True) or []\n    surface_meshes = [m for m in all_meshes if m not in own_shapes]\n\n    if not surface_meshes:\n        cmds.warning(\"No other meshes to snap onto.\")\n        return\n\n    bbox = cmds.exactWorldBoundingBox(transform)\n    xmin, ymin, zmin, xmax, ymax, zmax = bbox\n\n    cx = (xmin + xmax) / 2.0\n    cy = (ymin + ymax) / 2.0\n    cz = (zmin + zmax) / 2.0\n\n    config = {\n        \"top\": {\n            \"origin\": (cx, ymax, cz),\n            \"dir\": (0, 1, 0),\n            \"bbox_face\": ymax,\n            \"axis\": 1,\n            \"sign\": 1,\n        },\n        \"bottom\": {\n            \"origin\": (cx, ymin, cz),\n            \"dir\": (0, -1, 0),\n            \"bbox_face\": ymin,\n            \"axis\": 1,\n            \"sign\": -1,\n        },\n        \"left\": {\n            \"origin\": (xmin, cy, cz),\n            \"dir\": (-1, 0, 0),\n            \"bbox_face\": xmin,\n            \"axis\": 0,\n            \"sign\": -1,\n        },\n        \"right\": {\n            \"origin\": (xmax, cy, cz),\n            \"dir\": (1, 0, 0),\n            \"bbox_face\": xmax,\n            \"axis\": 0,\n            \"sign\": 1,\n        },\n        \"front\": {\n            \"origin\": (cx, cy, zmax),\n            \"dir\": (0, 0, 1),\n            \"bbox_face\": zmax,\n            \"axis\": 2,\n            \"sign\": 1,\n        },\n        \"back\": {\n            \"origin\": (cx, cy, zmin),\n            \"dir\": (0, 0, -1),\n            \"bbox_face\": zmin,\n            \"axis\": 2,\n            \"sign\": -1,\n        },\n    }\n\n    cfg = config[direction]\n    ray_origin = om2.MFloatPoint(*cfg[\"origin\"])\n    ray_dir = om2.MFloatVector(*cfg[\"dir\"])\n    axis = cfg[\"axis\"]\n    bbox_face = cfg[\"bbox_face\"]\n\n    closest_hit = None\n    closest_dist = None\n\n    for mesh_path in surface_meshes:\n        sel_list = om2.MSelectionList()\n        try:\n            sel_list.add(mesh_path)\n        except RuntimeError:\n            continue\n        dag_path = sel_list.getDagPath(0)\n        try:\n            fn_mesh = om2.MFnMesh(dag_path)\n        except RuntimeError:\n            continue\n\n        result = fn_mesh.closestIntersection(\n            ray_origin, ray_dir, om2.MSpace.kWorld, 9999999.0, False,\n        )\n        if result is None:\n            continue\n        hit_point, hit_param, hit_face, hit_tri, b1, b2 = result\n        if hit_param <= 0.0001:\n            continue\n        if closest_dist is None or hit_param < closest_dist:\n            closest_dist = hit_param\n            closest_hit = [hit_point.x, hit_point.y, hit_point.z]\n\n    # Fallback: cast from far away to find surfaces the object is inside of\n    if closest_hit is None:\n        fb_origin_vals = list(cfg[\"origin\"])\n        fb_origin_vals[axis] -= cfg[\"sign\"] * 5000.0\n        fb_origin = om2.MFloatPoint(*fb_origin_vals)\n        fb_dir = om2.MFloatVector(*cfg[\"dir\"])\n\n        for mesh_path in surface_meshes:\n            sel_list = om2.MSelectionList()\n            try:\n                sel_list.add(mesh_path)\n            except RuntimeError:\n                continue\n            dag_path = sel_list.getDagPath(0)\n            try:\n                fn_mesh = om2.MFnMesh(dag_path)\n            except RuntimeError:\n                continue\n            result = fn_mesh.closestIntersection(\n                fb_origin, fb_dir, om2.MSpace.kWorld, 9999999.0, False,\n            )\n            if result is None:\n                continue\n            hit_point, hit_param, hf, ht, b1, b2 = result\n            if hit_param <= 0.0001:\n                continue\n            hp = [hit_point.x, hit_point.y, hit_point.z]\n            if closest_hit is None or hp[axis] * cfg[\"sign\"] > closest_hit[axis] * cfg[\"sign\"]:\n                closest_hit = hp\n\n    if closest_hit is None:\n        cmds.warning(\"No surface found in the '{}' direction.\".format(direction))\n        return\n\n    offset = closest_hit[axis] - bbox_face\n    current_pos = cmds.xform(transform, query=True, worldSpace=True, translation=True)\n    new_pos = list(current_pos)\n    new_pos[axis] += offset\n    cmds.xform(transform, worldSpace=True, translation=new_pos)\n\n    name = transform.split(\"|\")[-1]\n    axes = [\"X\", \"Y\", \"Z\"]\n    print(\"// Snapped '{}' {} by {:.4f} ({})\".format(name, direction, abs(offset), axes[axis]))\n\n\ndef build_ui():\n    if cmds.window(WINDOW_NAME, exists=True):\n        cmds.deleteUI(WINDOW_NAME)\n\n    bw = 68\n    bh = 26\n    bg = [0.36, 0.36, 0.36]\n\n    pad = 4\n    gap = 2\n    w = bw * 2 + pad * 2 + gap\n    h = bh * 4 + gap * 3 + pad * 2 + 10\n\n    win = cmds.window(\n        WINDOW_NAME,\n        title=\"Phoenix Snap\",\n        widthHeight=(w, h),\n        sizeable=False,\n    )\n\n    cmds.columnLayout(adjustableColumn=True, rowSpacing=gap, columnOffset=[\"both\", pad])\n    cmds.separator(height=pad, style=\"none\")\n\n    #      Top\n    cmds.rowLayout(numberOfColumns=3, adjustableColumn=2)\n    cmds.text(label=\"\", width=bw / 2)\n    cmds.button(label=\"Top\", h=bh, w=bw, bgc=bg, command=lambda *_: snap_direction(\"top\"))\n    cmds.text(label=\"\", width=bw / 2)\n    cmds.setParent(\"..\")\n\n    # Left  Right\n    cmds.rowLayout(numberOfColumns=2, adjustableColumn=2)\n    cmds.button(label=\"Left\", h=bh, w=bw, bgc=bg, command=lambda *_: snap_direction(\"left\"))\n    cmds.button(label=\"Right\", h=bh, w=bw, bgc=bg, command=lambda *_: snap_direction(\"right\"))\n    cmds.setParent(\"..\")\n\n    #    Bottom\n    cmds.rowLayout(numberOfColumns=3, adjustableColumn=2)\n    cmds.text(label=\"\", width=bw / 2)\n    cmds.button(label=\"Bottom\", h=bh, w=bw, bgc=bg, command=lambda *_: snap_direction(\"bottom\"))\n    cmds.text(label=\"\", width=bw / 2)\n    cmds.setParent(\"..\")\n\n    cmds.separator(height=8, style=\"none\")\n\n    # Front  Back\n    cmds.rowLayout(numberOfColumns=2, adjustableColumn=2)\n    cmds.button(label=\"Front\", h=bh, w=bw, bgc=bg, command=lambda *_: snap_direction(\"front\"))\n    cmds.button(label=\"Back\", h=bh, w=bw, bgc=bg, command=lambda *_: snap_direction(\"back\"))\n    cmds.setParent(\"..\")\n\n    cmds.separator(height=pad, style=\"none\")\n    cmds.setParent(\"..\")\n\n    cmds.showWindow(win)\n\n\nbuild_ui()" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Snap to bottom of the mesh" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Snap to bottom of the mesh" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "snap" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "alignVMin.png" 
        -image1 "alignVMin.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef pivot_to_bottom_center_of_bbox(selection=None):\n    \"\"\"\n    Sets the pivot of selected transforms (meshes/groups) to the bottom-center\n    of their WORLD bounding box:\n        X = (minX+maxX)/2\n        Y = minY\n        Z = (minZ+maxZ)/2\n    \"\"\"\n    if selection is None:\n        selection = cmds.ls(sl=True, long=True) or []\n\n    if not selection:\n        cmds.warning(\"Nothing selected. Select meshes or groups (transforms).\")\n        return\n\n    # Normalize selection to transforms\n    transforms = []\n    for obj in selection:\n        if cmds.nodeType(obj) == \"transform\":\n            transforms.append(obj)\n        else:\n            parent = cmds.listRelatives(obj, parent=True, fullPath=True) or []\n            if parent and cmds.nodeType(parent[0]) == \"transform\":\n                transforms.append(parent[0])\n\n    transforms = list(dict.fromkeys(transforms))  # unique, keep order\n\n    for t in transforms:\n        # World-space bounding box: [minX, minY, minZ, maxX, maxY, maxZ]\n        bb = cmds.exactWorldBoundingBox(t)\n        minX, minY, minZ, maxX, maxY, maxZ = bb\n\n        cx = (minX + maxX) * 0.5\n        cz = (minZ + maxZ) * 0.5\n\n        # Set both rotatePivot and scalePivot in world space\n        cmds.xform(t, ws=True, rp=(cx, minY, cz))\n        cmds.xform(t, ws=True, sp=(cx, minY, cz))\n\n    cmds.inViewMessage(\n        amg=\"Pivot set to <hl>bottom-center</hl> of world bounding box.\",\n        pos=\"topCenter\",\n        fade=True\n    )\n\n# Run it on current selection:\npivot_to_bottom_center_of_bbox()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Clean all HIstory, Center Piviot and Freeze Transform" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Clean all HIstory, Center Piviot and Freeze Transform" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "cln All" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.8 
        -image "trash.png" 
        -image1 "trash.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef process_node(node):\n    cmds.xform(node, centerPivots=True)\n    cmds.makeIdentity(node, apply=True, t=True, r=True, s=True, n=False, pn=True)\n    cmds.delete(node, constructionHistory=True)\n\ndef get_all_descendants(root):\n    descendants = cmds.listRelatives(root, allDescendents=True, fullPath=True) or []\n    return [root] + descendants\n\ndef is_group(node):\n    shapes = cmds.listRelatives(node, shapes=True, fullPath=True) or []\n    return len(shapes) == 0\n\ndef is_mesh(node):\n    shapes = cmds.listRelatives(node, shapes=True, fullPath=True) or []\n    return any(cmds.nodeType(s) == 'mesh' for s in shapes)\n\ndef is_position_ref(node):\n    short = node.split('|')[-1].lower()\n    return 'positionref' in short\n\ndef get_depth(node, root):\n    root_depth = root.count('|')\n    return node.count('|') - root_depth\n\ndef c(text, color):\n    return f'<span style=\"color:{color};\">{text}</span>'\n\ndef run_cleanup():\n    sel = cmds.ls(selection=True, long=True)\n\n    if not sel:\n        top_level = cmds.ls(assemblies=True, long=True)\n        candidates = [\n            n for n in top_level\n            if cmds.nodeType(n) == 'transform'\n            and not cmds.listRelatives(n, shapes=True, type='camera')\n            and not is_position_ref(n)\n        ]\n        if len(candidates) == 1:\n            sel = [candidates[0]]\n        else:\n            cmds.inViewMessage(\n                amg=f\"{c('Phoenix Cleanup:', '#E8A838')} No group selected.\",\n                pos=\"topCenter\", fade=True, fadeStayTime=2000\n            )\n            return\n\n    root = sel[0]\n\n    all_nodes = []\n    seen = set()\n    for r in sel:\n        for node in get_all_descendants(r):\n            if node not in seen:\n                seen.add(node)\n                all_nodes.append(node)\n\n    transforms = [n for n in all_nodes\n                  if cmds.nodeType(n) == 'transform' and not is_position_ref(n)]\n    transforms.sort(key=lambda n: n.count('|'), reverse=True)\n\n    root_groups = []\n    sub_groups  = []\n    mesh_nodes  = []\n\n    for node in transforms:\n        depth = get_depth(node, root)\n        if is_mesh(node):\n            mesh_nodes.append(node)\n        elif is_group(node):\n            if depth == 0:\n                root_groups.append(node)\n            else:\n                sub_groups.append(node)\n\n    errors = []\n    for node in transforms:\n        try:\n            process_node(node)\n        except Exception as e:\n            errors.append(node)\n            cmds.warning(f\"[Phoenix Cleanup] Skipped {node}: {e}\")\n\n    total   = len(transforms)\n    cleaned = total - len(errors)\n\n    rg = len(root_groups)\n    sg = len(sub_groups)\n    m  = len(mesh_nodes)\n\n    msg = (\n        f\"{c('Cleaned', '#A8D8A8')} {c(cleaned, '#57D957')}: \"\n        f\"{c(rg, '#7EC8E3')} root group{'s' if rg != 1 else ''}, \"\n        f\"{c(sg, '#7EC8E3')} subgroup{'s' if sg != 1 else ''}, \"\n        f\"{c(m, '#C8A8E8')} mesh{'es' if m != 1 else ''}\"\n    )\n\n    cmds.inViewMessage(amg=msg, pos=\"topCenter\", fade=True, fadeStayTime=2500)\n\nrun_cleanup()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Render Layers" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Render Layers" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Rndr" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/icons-phoenix/fileNode/RENDER.png" 
        -image1 "C:/icons-phoenix/fileNode/RENDER.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "\"\"\"\nRender Layer & AOV Batch Render Manager\nMaya Legacy Render Layers + Arnold/VRay/RenderMan AOV support\n\nUsage:\n    import renderLayerAOVManager\n    renderLayerAOVManager.show()\n\"\"\"\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport maya.app.renderSetup.model.renderSetup as renderSetup\nimport os\nimport sys\nfrom functools import partial\n\n# -----------------------------------------------------------------------------\n# GLOBALS\n# -----------------------------------------------------------------------------\nWINDOW_ID   = \"rlAOVManagerWin\"\nRENDERER_ARNOLD   = \"arnold\"\nRENDERER_VRAY     = \"vray\"\nRENDERER_REDSHIFT = \"redshift\"\nRENDERER_MAYA_SW  = \"sw\"      # Maya Software\nRENDERER_MAYA_HW  = \"hw2\"    # Maya Hardware 2.0\n\n# -----------------------------------------------------------------------------\n# HELPERS – Render Layer\n# -----------------------------------------------------------------------------\n\ndef get_render_layers():\n    \"\"\"Return list of legacy render layer names (excluding defaultRenderLayer).\"\"\"\n    layers = cmds.ls(type=\"renderLayer\") or []\n    result = []\n    for layer in layers:\n        if layer == \"defaultRenderLayer\":\n            continue\n        # Only include layers that are set to renderable\n        result.append(layer)\n    return result\n\n\ndef is_layer_renderable(layer):\n    return cmds.getAttr(\"{}.renderable\".format(layer))\n\n\ndef set_layer_renderable(layer, state):\n    cmds.setAttr(\"{}.renderable\".format(layer), state)\n\n\ndef get_current_renderer():\n    return cmds.getAttr(\"defaultRenderGlobals.currentRenderer\")\n\n\ndef get_render_camera():\n    \"\"\"\n    Return the camera that should be used for rendering.\n    Priority:\n      1. Camera explicitly marked as renderable in the scene\n      2. First perspective camera found\n      3. 'persp' fallback\n    \"\"\"\n    all_cameras = cmds.ls(type=\"camera\") or []\n    renderable = [c for c in all_cameras if cmds.getAttr(\"{}.renderable\".format(c))]\n\n    if renderable:\n        # Prefer non-default cameras (not persp/top/front/side)\n        default_shapes = {\"perspShape\", \"topShape\", \"frontShape\", \"sideShape\"}\n        custom = [c for c in renderable if c not in default_shapes]\n        cam_shape = custom[0] if custom else renderable[0]\n    else:\n        # Fall back to persp\n        cam_shape = \"perspShape\"\n\n    # Return the transform, not the shape — renderSequence wants the transform\n    parents = cmds.listRelatives(cam_shape, parent=True, fullPath=False)\n    return parents[0] if parents else \"persp\"\n\n\ndef _setup_cryptomatte_aovs(wanted_aov_nodes):\n    \"\"\"\n    Cryptomatte AOVs use defaultArnoldDriver (the existing EXR driver).\n    The only thing needed is mergeAOVs=True so Arnold includes globalAov\n    AOVs in the render output. No separate driver is created.\n    \"\"\"\n    has_crypto = any(is_cryptomatte_aov(n) for n in wanted_aov_nodes)\n    if not has_crypto:\n        return\n    if cmds.objExists(\"defaultArnoldDriver\"):\n        if cmds.attributeQuery(\"mergeAOVs\", node=\"defaultArnoldDriver\", exists=True):\n            if not cmds.getAttr(\"defaultArnoldDriver.mergeAOVs\"):\n                cmds.setAttr(\"defaultArnoldDriver.mergeAOVs\", True)\n\n\ndef set_render_view_camera(camera_transform):\n    \"\"\"\n    Point the Render View at the given camera so renderSequence uses it.\n    This sets both the render globals default camera and the render view panel.\n    \"\"\"\n    # Set the camera on any existing renderWindowPanel\n    render_panels = cmds.getPanel(scriptType=\"renderWindowPanel\") or []\n    for panel in render_panels:\n        try:\n            cmds.renderWindowEditor(panel, edit=True, currentCamera=camera_transform)\n        except Exception:\n            pass\n\n    # Also ensure it is the camera in the render globals (redundant safety)\n    try:\n        mel.eval('setCurrentRenderer \"{}\"'.format(\n            cmds.getAttr(\"defaultRenderGlobals.currentRenderer\")\n        ))\n    except Exception:\n        pass\n\n\n# -----------------------------------------------------------------------------\n# HELPERS – AOV detection per renderer\n# -----------------------------------------------------------------------------\n\ndef is_cryptomatte_aov(node):\n    \"\"\"True if this aiAOV node is a Cryptomatte pass.\"\"\"\n    if not cmds.objExists(node):\n        return False\n    name = (cmds.getAttr(\"{}.name\".format(node)) or \"\").lower()\n    return name.startswith(\"crypto_\")\n\n\ndef get_aovs():\n    \"\"\"\n    Returns a dict:  { aov_node_name : { 'label': str, 'enabled': bool } }\n    Supports Arnold, VRay, Redshift.\n    \"\"\"\n    renderer = get_current_renderer()\n    aovs = {}\n\n    if renderer == RENDERER_ARNOLD:\n        aov_nodes = cmds.ls(type=\"aiAOV\") or []\n        for node in aov_nodes:\n            label   = cmds.getAttr(\"{}.name\".format(node))\n            enabled = cmds.getAttr(\"{}.enabled\".format(node))\n            aovs[node] = {\"label\": label, \"enabled\": enabled, \"is_crypto\": is_cryptomatte_aov(node)}\n\n    elif renderer == RENDERER_VRAY:\n        # VRay stores AOVs as renderElements\n        re_nodes = cmds.ls(type=\"VRayRenderElement\") or []\n        for node in re_nodes:\n            label   = node\n            enabled = cmds.getAttr(\"{}.enabled\".format(node)) if cmds.attributeQuery(\"enabled\", node=node, exists=True) else True\n            aovs[node] = {\"label\": label, \"enabled\": enabled}\n\n    elif renderer == RENDERER_REDSHIFT:\n        aov_nodes = cmds.ls(type=\"RedshiftAOV\") or []\n        for node in aov_nodes:\n            label   = cmds.getAttr(\"{}.name\".format(node)) if cmds.attributeQuery(\"name\", node=node, exists=True) else node\n            enabled = cmds.getAttr(\"{}.enabled\".format(node)) if cmds.attributeQuery(\"enabled\", node=node, exists=True) else True\n            aovs[node] = {\"label\": label, \"enabled\": enabled}\n\n    else:\n        # Maya Software / Hardware – render passes\n        pass_nodes = cmds.ls(type=\"renderPass\") or []\n        for node in pass_nodes:\n            label   = node\n            enabled = cmds.getAttr(\"{}.renderable\".format(node)) if cmds.attributeQuery(\"renderable\", node=node, exists=True) else True\n            aovs[node] = {\"label\": label, \"enabled\": enabled}\n\n    return aovs\n\n\ndef set_aov_enabled(node, state):\n    renderer = get_current_renderer()\n    if renderer == RENDERER_ARNOLD:\n        cmds.setAttr(\"{}.enabled\".format(node), state)\n    elif renderer == RENDERER_VRAY:\n        if cmds.attributeQuery(\"enabled\", node=node, exists=True):\n            cmds.setAttr(\"{}.enabled\".format(node), state)\n    elif renderer == RENDERER_REDSHIFT:\n        if cmds.attributeQuery(\"enabled\".format(), node=node, exists=True):\n            cmds.setAttr(\"{}.enabled\".format(node), state)\n    else:\n        if cmds.attributeQuery(\"renderable\", node=node, exists=True):\n            cmds.setAttr(\"{}.renderable\".format(node), state)\n\n\n# -----------------------------------------------------------------------------\n# HELPERS – Output path\n# -----------------------------------------------------------------------------\n\ndef get_output_dir():\n    \"\"\"Return the project images dir.\"\"\"\n    proj  = cmds.workspace(q=True, rootDirectory=True)\n    img   = cmds.workspace(fileRuleEntry=\"images\") or \"images\"\n    return os.path.join(proj, img)\n\n\ndef get_layer_output_dir(layer_name):\n    # Kept for legacy reference — no longer used for folder creation\n    base = get_output_dir()\n    return os.path.join(base, layer_name)\n\n\n# -----------------------------------------------------------------------------\n# BATCH RENDER CORE\n# -----------------------------------------------------------------------------\n\nclass BatchRenderJob(object):\n    \"\"\"\n    Manages sequential layer-by-layer batch rendering with per-layer AOV sets.\n\n    layer_aov_map  –  { layer_name : [aov_node, ...] }\n    all_aov_nodes  –  complete list of all AOV nodes in scene\n    \"\"\"\n\n    def __init__(self, layer_aov_map, all_aov_nodes,\n                 start_frame=None, end_frame=None, frame_step=1,\n                 render_camera=None, output_dir=None,\n                 progress_cb=None, done_cb=None):\n        self.layer_aov_map  = layer_aov_map\n        self.all_aov_nodes  = all_aov_nodes\n        self.progress_cb    = progress_cb or (lambda msg: None)\n        self.done_cb        = done_cb or (lambda: None)\n        self.layers_order   = list(layer_aov_map.keys())\n\n        # Frame range — fall back to scene render globals if not specified\n        self.start_frame = start_frame if start_frame is not None else cmds.getAttr(\"defaultRenderGlobals.startFrame\")\n        self.end_frame   = end_frame   if end_frame   is not None else cmds.getAttr(\"defaultRenderGlobals.endFrame\")\n        self.frame_step  = frame_step\n\n        self.render_camera = render_camera  # None = auto-detect per layer\n        self.output_dir    = output_dir or get_output_dir()\n        self._original_renderable  = {}\n        self._original_aov_states  = {}\n        self._original_frame_start  = cmds.getAttr(\"defaultRenderGlobals.startFrame\")\n        self._original_frame_end    = cmds.getAttr(\"defaultRenderGlobals.endFrame\")\n        self._original_frame_step   = cmds.getAttr(\"defaultRenderGlobals.byFrameStep\")\n        self._original_img_prefix   = cmds.getAttr(\"defaultRenderGlobals.imageFilePrefix\") or \"\"\n        self._original_merge_aovs   = None  # no longer used\n\n    # -- backup / restore ----------------------------------------------------\n\n    def _backup_states(self):\n        for layer in get_render_layers():\n            self._original_renderable[layer] = is_layer_renderable(layer)\n        for node, info in get_aovs().items():\n            self._original_aov_states[node] = info[\"enabled\"]\n\n    def _restore_states(self):\n        for layer, state in self._original_renderable.items():\n            try:\n                set_layer_renderable(layer, state)\n            except Exception:\n                pass\n        for node, state in self._original_aov_states.items():\n            try:\n                set_aov_enabled(node, state)\n            except Exception:\n                pass\n        # Restore frame range, image prefix and mergeAOVs\n        try:\n            cmds.setAttr(\"defaultRenderGlobals.startFrame\",    self._original_frame_start)\n            cmds.setAttr(\"defaultRenderGlobals.endFrame\",      self._original_frame_end)\n            cmds.setAttr(\"defaultRenderGlobals.byFrameStep\",   self._original_frame_step)\n            cmds.setAttr(\"defaultRenderGlobals.imageFilePrefix\", self._original_img_prefix, type=\"string\")\n        except Exception:\n            pass\n        try:\n            if self._original_merge_aovs is not None:\n                cmds.setAttr(\"defaultArnoldDriver.mergeAOVs\", self._original_merge_aovs)\n        except Exception:\n            pass\n\n    # -- layer setup ---------------------------------------------------------\n\n    def _set_only_layer_renderable(self, target_layer):\n        \"\"\"Disable every layer except target_layer.\"\"\"\n        for layer in get_render_layers():\n            set_layer_renderable(layer, layer == target_layer)\n\n    def _apply_aov_set(self, wanted_aov_nodes):\n        \"\"\"Enable only the AOVs in wanted_aov_nodes.\"\"\"\n        wanted = set(wanted_aov_nodes)\n        for node in self.all_aov_nodes:\n            set_aov_enabled(node, node in wanted)\n        # Cryptomatte gets a dedicated EXR driver — handled separately\n        if get_current_renderer() == RENDERER_ARNOLD:\n            _setup_cryptomatte_aovs(list(wanted))\n\n    def _set_output_prefix(self, layer_name):\n        \"\"\"\n        Output structure:\n            <output_dir>/<layer_name>/<layer_name>_<RenderPass>_pass.####.exr\n        e.g.\n            renders/beauty/beauty_specular_direct_pass.0001.exr\n            renders/beauty/beauty_crypto_object_pass.0001.exr\n        \"\"\"\n        renderer = get_current_renderer()\n        if renderer == RENDERER_ARNOLD:\n            token = \"<RenderPass>\"\n        elif renderer == RENDERER_VRAY:\n            token = \"<RenderElement>\"\n        elif renderer == RENDERER_REDSHIFT:\n            token = \"<AOV>\"\n        else:\n            token = \"<RenderPass>\"\n\n        # Create the layer subfolder\n        layer_dir = os.path.join(self.output_dir, layer_name)\n        if not os.path.exists(layer_dir):\n            os.makedirs(layer_dir)\n\n        # imageFilePrefix is an absolute path without extension/frame\n        prefix = os.path.join(\n            layer_dir, \"{}_{}\".format(layer_name, token) + \"_pass\"\n        ).replace(\"\\\\\", \"/\")\n\n        cmds.setAttr(\"defaultRenderGlobals.imageFilePrefix\", prefix, type=\"string\")\n        self.progress_cb(\"  Output: {}\".format(layer_dir))\n\n    def _set_frame_range(self, start, end, step):\n        \"\"\"Override render globals frame range for this sequence.\"\"\"\n        cmds.setAttr(\"defaultRenderGlobals.startFrame\", start)\n        cmds.setAttr(\"defaultRenderGlobals.endFrame\",   end)\n        cmds.setAttr(\"defaultRenderGlobals.byFrameStep\", step)\n        # Make sure animation mode is on so renderSequence renders the range\n        cmds.setAttr(\"defaultRenderGlobals.animation\", 1)\n        cmds.setAttr(\"defaultRenderGlobals.putFrameBeforeExt\", 1)\n        cmds.setAttr(\"defaultRenderGlobals.extensionPadding\", 4)\n\n    # -- render one layer ----------------------------------------------------\n\n    def _render_layer(self, layer_name):\n        self.progress_cb(\"Setting up layer: {}\".format(layer_name))\n\n        # Switch to that render layer\n        cmds.editRenderLayerGlobals(currentRenderLayer=layer_name)\n\n        # AOVs\n        wanted = self.layer_aov_map[layer_name]\n        self._apply_aov_set(wanted)\n        self.progress_cb(\"  AOVs enabled: {}\".format(\n            [get_aovs()[n][\"label\"] for n in wanted if n in get_aovs()]\n        ))\n\n        # Output prefix — uses <RenderPass> token so Arnold names each AOV file\n        # automatically: layerName_aovName_pass.####.exr\n        self._set_output_prefix(layer_name)\n\n        # Frame range\n        self._set_frame_range(self.start_frame, self.end_frame, self.frame_step)\n\n        # Camera\n        render_cam = self.render_camera if self.render_camera else get_render_camera()\n        self.progress_cb(\"  Camera: {}\".format(render_cam))\n\n        start = int(self.start_frame)\n        end   = int(self.end_frame)\n        step  = int(self.frame_step)\n\n        self.progress_cb(\"  Rendering frames {}-{} (step {}) for layer: {}\".format(\n            start, end, step, layer_name\n        ))\n\n        # -- Render Sequence via Maya's native render sequence proc ---------\n        # Uses the same code path as Render > Render Sequence in the menu.\n        # This is stable with Arnold — no crash, no IPR window, saves to disk\n        # via imageFilePrefix. Camera is set on the render globals before call.\n\n        # Point render globals at our camera\n        cmds.setAttr(\"defaultRenderGlobals.camera\", render_cam, type=\"string\") if cmds.attributeQuery(\"camera\", node=\"defaultRenderGlobals\", exists=True) else None\n\n        # Ensure the renderView panel exists (Maya needs it for renderSequence)\n        render_panels = cmds.getPanel(scriptType=\"renderWindowPanel\") or []\n        if not render_panels:\n            mel.eval(\"RenderViewWindow\")\n            render_panels = cmds.getPanel(scriptType=\"renderWindowPanel\") or []\n        panel = render_panels[0] if render_panels else \"renderView\"\n\n        # Set camera on the render view panel\n        try:\n            cmds.renderWindowEditor(panel, edit=True, currentCamera=render_cam)\n        except Exception:\n            pass\n\n        # RenderSequence is the exact MEL command Maya's\n        # Render > Render Sequence menu item calls. No arguments.\n        # Camera is already set on the render view panel above.\n        mel.eval(\"RenderSequence\")\n\n        self.progress_cb(\"  ? Sequence done for: {}\".format(layer_name))\n\n    # -- public API ----------------------------------------------------------\n\n    def run(self):\n        self._backup_states()\n        try:\n            for layer_name in self.layers_order:\n                self._set_only_layer_renderable(layer_name)\n                self._render_layer(layer_name)\n        finally:\n            self._restore_states()\n            self.done_cb()\n            self.progress_cb(\"All layers submitted. Scene state restored.\")\n\n\n# -----------------------------------------------------------------------------\n# HELPERS – Arnold Sampling\n# -----------------------------------------------------------------------------\n\nSAMPLING_ATTRS = [\n    (\"Camera (AA)\",     \"AASamples\",              1, 16),\n    (\"Diffuse\",         \"GIDiffuseSamples\",        0, 16),\n    (\"Specular\",        \"GISpecularSamples\",        0, 16),\n    (\"Transmission\",    \"GITransmissionSamples\",    0, 16),\n    (\"SSS\",             \"GISssSamples\",             0, 16),\n    (\"Volume Indirect\", \"GIVolumeSamples\",          0, 16),\n]\n\ndef get_sampling_values():\n    opt = \"defaultArnoldRenderOptions\"\n    out = {}\n    if not cmds.objExists(opt):\n        return out\n    for _, attr, mn, _ in SAMPLING_ATTRS:\n        if cmds.attributeQuery(attr, node=opt, exists=True):\n            out[attr] = max(int(cmds.getAttr(\"{}.{}\".format(opt, attr))), mn)\n    return out\n\ndef set_sampling_value(attr, value):\n    opt = \"defaultArnoldRenderOptions\"\n    if cmds.objExists(opt) and cmds.attributeQuery(attr, node=opt, exists=True):\n        cmds.setAttr(\"{}.{}\".format(opt, attr), value)\n\n\n# -----------------------------------------------------------------------------\n# HELPERS – Available AOV types from Arnold\n# -----------------------------------------------------------------------------\n\n# Full Arnold AOV list matching what Render Settings > AOVs dropdown shows\n# Grouped to match Arnold's categories\nARNOLD_AOV_TYPES = [\n    # Beauty\n    \"RGBA\", \"RGB\", \"A\",\n    # Lighting\n    \"diffuse\",          \"diffuse_direct\",       \"diffuse_indirect\",     \"diffuse_albedo\",\n    \"specular\",         \"specular_direct\",       \"specular_indirect\",    \"specular_albedo\",\n    \"coat\",             \"coat_direct\",           \"coat_indirect\",        \"coat_albedo\",\n    \"transmission\",     \"transmission_direct\",   \"transmission_indirect\",\n    \"sss\",              \"sss_direct\",            \"sss_indirect\",\n    \"volume\",           \"volume_direct\",         \"volume_indirect\",\n    \"emission\",         \"background\",\n    \"shadow\",           \"shadow_diff\",           \"shadow_mask\",          \"shadow_matte\",\n    \"light_groups\",\n    # Utility\n    \"albedo\",           \"direct\",                \"indirect\",\n    \"N\",                \"Ng\",                    \"P\",                    \"Pref\",\n    \"Z\",                \"raycount\",              \"motionvector\",\n    \"opacity\",          \"sheen\",                 \"sheen_direct\",         \"sheen_indirect\",\n    \"sheen_albedo\",     \"thin_film\",\n    # Denoiser\n    \"denoise_albedo\",   \"denoise_normal\",\n    # Cryptomatte\n    \"crypto_object\",    \"crypto_material\",       \"crypto_asset\",\n    # AOV shaders / custom\n    \"aov_write_float\",  \"aov_write_rgb\",         \"aov_write_int\",\n    # ID passes\n    \"object_id\",        \"material_id\",           \"instance_id\",\n    # Light AOVs (common names)\n    \"specular_lighting\",\"diffuse_lighting\",\n]\n\ndef get_available_aov_names():\n    \"\"\"Return list of AOV names not yet in the scene, preserving category order.\"\"\"\n    existing = set()\n    for node in cmds.ls(type=\"aiAOV\") or []:\n        existing.add(cmds.getAttr(\"{}.name\".format(node)))\n    return [n for n in ARNOLD_AOV_TYPES if n not in existing]\n\n\ndef remove_arnold_aov(node):\n    \"\"\"\n    Remove an aiAOV node cleanly:\n      - Disconnect from defaultArnoldRenderOptions.aovList\n      - Disconnect driver/filter\n      - Delete the node\n    \"\"\"\n    if not cmds.objExists(node):\n        return\n    # Disconnect from aovList\n    if cmds.objExists(\"defaultArnoldRenderOptions\"):\n        indices = cmds.getAttr(\n            \"defaultArnoldRenderOptions.aovList\", multiIndices=True) or []\n        for i in indices:\n            conns = cmds.listConnections(\n                \"defaultArnoldRenderOptions.aovList[{}]\".format(i),\n                source=True, plugs=False) or []\n            if node in conns:\n                try:\n                    cmds.disconnectAttr(\n                        \"{}.message\".format(node),\n                        \"defaultArnoldRenderOptions.aovList[{}]\".format(i))\n                except Exception:\n                    pass\n                break\n    # Delete the node\n    try:\n        cmds.delete(node)\n    except Exception:\n        pass\n\ndef add_arnold_aov(aov_name):\n    \"\"\"\n    Create an aiAOV node exactly as Arnold's Render Settings UI does:\n      1. Create aiAOV node named aiAOV_<name>\n      2. Set .name attribute\n      3. Connect defaultArnoldDriver  -> outputs[0].driver\n      4. Connect defaultArnoldFilter  -> outputs[0].filter\n      5. Connect defaultArnoldRenderOptions -> nodeMessage (registers with Arnold)\n    \"\"\"\n    # Already exists?\n    for node in cmds.ls(type=\"aiAOV\") or []:\n        if cmds.getAttr(\"{}.name\".format(node)) == aov_name:\n            return node\n\n    node_name = \"aiAOV_{}\".format(aov_name)\n    # Ensure unique name\n    if cmds.objExists(node_name):\n        node_name = cmds.uniqueName(node_name)\n\n    node = cmds.createNode(\"aiAOV\", name=node_name)\n    cmds.setAttr(\"{}.name\".format(node), aov_name, type=\"string\")\n\n    # Connect driver\n    if cmds.objExists(\"defaultArnoldDriver\"):\n        cmds.connectAttr(\n            \"defaultArnoldDriver.message\",\n            \"{}.outputs[0].driver\".format(node),\n            force=True\n        )\n\n    # Connect filter\n    if cmds.objExists(\"defaultArnoldFilter\"):\n        cmds.connectAttr(\n            \"defaultArnoldFilter.message\",\n            \"{}.outputs[0].filter\".format(node),\n            force=True\n        )\n\n    # Register with Arnold render options — this is what makes it show up\n    # in Render Settings > AOVs list\n    if cmds.objExists(\"defaultArnoldRenderOptions\"):\n        # Find next free index in aovList array\n        indices = cmds.getAttr(\n            \"defaultArnoldRenderOptions.aovList\",\n            multiIndices=True\n        ) or []\n        next_idx = (max(indices) + 1) if indices else 0\n        try:\n            cmds.connectAttr(\n                \"{}.message\".format(node),\n                \"defaultArnoldRenderOptions.aovList[{}]\".format(next_idx),\n                force=True\n            )\n        except Exception:\n            pass\n\n    return node\n\n\n# -----------------------------------------------------------------------------\n# UI\n# -----------------------------------------------------------------------------\n\nclass RenderLayerAOVUI(object):\n\n    def __init__(self):\n        self.layers               = []\n        self.aovs                 = {}\n        self.layer_aov_selection  = {}\n        self.selected_layers      = []\n        self.win                  = None\n        self.layer_list_ctrl      = None\n        self.aov_check_map        = {}\n        self.aov_node_map         = {}\n        self.aov_panel_label      = None\n        self.aov_col              = None\n        self.aov_scroll           = None\n        self.search_field         = None\n        self.add_aov_menu         = None\n        self.start_frame_field    = None\n        self.end_frame_field      = None\n        self.step_frame_field     = None\n        self.camera_menu          = None\n        self.output_field         = None\n        self.sampling_fields      = {}\n        self._scene_start         = 1\n        self._scene_end           = 1\n        self._scene_step          = 1\n\n    # -------------------------------------------------------------------------\n    def build(self):\n        self.layers = get_render_layers()\n        self.aovs   = get_aovs()\n        if not self.layers:\n            cmds.confirmDialog(title=\"No Render Layers\",\n                message=\"No legacy render layers found.\\nCreate at least one first.\",\n                button=[\"OK\"])\n            return\n        for layer in self.layers:\n            self.layer_aov_selection[layer] = set(\n                n for n, info in self.aovs.items() if info[\"enabled\"])\n        self._scene_start = int(cmds.getAttr(\"defaultRenderGlobals.startFrame\"))\n        self._scene_end   = int(cmds.getAttr(\"defaultRenderGlobals.endFrame\"))\n        self._scene_step  = int(cmds.getAttr(\"defaultRenderGlobals.byFrameStep\"))\n        self._build_window()\n\n    # -------------------------------------------------------------------------\n    def _build_window(self):\n        if cmds.window(WINDOW_ID, exists=True):\n            cmds.deleteUI(WINDOW_ID)\n\n        self.win = cmds.window(\n            WINDOW_ID,\n            title=\"Render Layer & AOV Manager  |  {}\".format(\n                get_current_renderer().upper()),\n            widthHeight=(980, 720),\n            sizeable=True)\n\n        # root formLayout — 4 rows: top_bar | pane | settings_strip | footer\n        root = cmds.formLayout(parent=self.win)\n\n        # -- ROW 1: Output Path ------------------------------------------------\n        top_bar = cmds.frameLayout(\n            label=\"Output Path\", collapsable=False,\n            marginWidth=6, marginHeight=3, parent=root)\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=2,\n                       columnOffset3=(2, 4, 2))\n        cmds.text(label=\"Path\", font=\"smallBoldLabelFont\", width=34)\n        self.output_field = cmds.textField(\n            text=get_output_dir(),\n            changeCommand=self._on_output_path_change)\n        cmds.button(label=\"Browse…\", width=72,\n                    command=lambda *_: self._browse_output())\n        cmds.setParent(root)\n\n        # -- ROW 4: Footer -----------------------------------------------------\n        footer = cmds.rowLayout(numberOfColumns=3, adjustableColumn=1,\n                                columnOffset3=(8, 4, 4), parent=root)\n        cmds.text(\n            label=\"Structure:  <output>/<layer>/<layer>_<aov>_pass.####.exr\",\n            align=\"left\", font=\"smallPlainLabelFont\")\n        cmds.button(label=\"?  Render Sequence\",\n                    backgroundColor=(0.18, 0.45, 0.18),\n                    height=28, width=164,\n                    command=lambda *_: self._start_render())\n        cmds.button(label=\"Close\", height=28, width=72,\n                    command=lambda *_: cmds.deleteUI(WINDOW_ID))\n        cmds.setParent(root)\n\n        # -- ROW 3: Settings strip (frame range + camera + sampling) -----------\n        settings_strip = cmds.frameLayout(\n            label=\"\", labelVisible=False,\n            collapsable=False, marginWidth=6, marginHeight=4,\n            parent=root)\n        # Frame range — two separate rows to stay within columnOffset6 limit\n        cmds.rowLayout(numberOfColumns=6,\n                       columnWidth6=(36,52,36,52,36,52),\n                       columnAlign6=(\"right\",\"left\",\"right\",\"left\",\"right\",\"left\"),\n                       columnOffset6=(2,4,8,4,8,4))\n        cmds.text(label=\"Start\", font=\"smallBoldLabelFont\")\n        self.start_frame_field = cmds.intField(\n            value=self._scene_start, minValue=0, width=52)\n        cmds.text(label=\"End\",  font=\"smallBoldLabelFont\")\n        self.end_frame_field   = cmds.intField(\n            value=self._scene_end,   minValue=0, width=52)\n        cmds.text(label=\"Step\", font=\"smallBoldLabelFont\")\n        self.step_frame_field  = cmds.intField(\n            value=self._scene_step,  minValue=1, width=52)\n        cmds.setParent(settings_strip)\n        cmds.button(label=\"?  Reset to Scene Range\", height=20,\n                    command=lambda *_: self._reset_frame_range(\n                        self._scene_start, self._scene_end, self._scene_step))\n        cmds.setParent(settings_strip)\n\n        cmds.separator(height=4, style=\"in\")\n\n        cmds.rowLayout(numberOfColumns=4, adjustableColumn=4,\n                       columnOffset4=(2, 6, 12, 6))\n        # Camera\n        cmds.text(label=\"Camera\", font=\"smallBoldLabelFont\", width=48)\n        all_shapes = cmds.ls(type=\"camera\") or []\n        cam_names  = []\n        for s in all_shapes:\n            p = cmds.listRelatives(s, parent=True, fullPath=False) or []\n            if p: cam_names.append(p[0])\n        cam_names = list(dict.fromkeys(cam_names))\n        detected  = get_render_camera()\n        def_idx   = cam_names.index(detected) + 1 if detected in cam_names else 1\n        self.camera_menu = cmds.optionMenu(width=180)\n        for c in cam_names:\n            cmds.menuItem(label=c)\n        if cam_names:\n            cmds.optionMenu(self.camera_menu, edit=True, select=def_idx)\n        cmds.button(label=\"?\", width=28,\n                    command=lambda *_: self._refresh_camera_menu())\n        # Arnold Sampling inline — collapsible via frameLayout in same strip\n        cmds.text(label=\"\")  # spacer\n        cmds.setParent(settings_strip)\n\n        cmds.separator(height=4, style=\"in\")\n\n        # Arnold Sampling rows\n        samp_frame = cmds.frameLayout(\n            label=\"Arnold Sampling\", collapsable=True, collapse=True,\n            marginWidth=4, marginHeight=3)\n        samp_vals = get_sampling_values()\n        for lbl, attr, mn, mx in SAMPLING_ATTRS:\n            val = max(samp_vals.get(attr, mn), mn)\n            cmds.rowLayout(numberOfColumns=2,\n                           columnWidth2=(140, 52),\n                           columnAlign2=(\"right\", \"left\"),\n                           columnOffset2=(4, 6))\n            cmds.text(label=lbl, font=\"smallBoldLabelFont\", align=\"right\")\n            field = cmds.intField(value=val, minValue=mn, maxValue=mx, width=48,\n                                  changeCommand=partial(self._on_sampling_change, attr))\n            self.sampling_fields[attr] = field\n            cmds.setParent(samp_frame)\n        cmds.setParent(root)\n\n        # -- ROW 2: Main split pane --------------------------------------------\n        pane = cmds.paneLayout(configuration=\"vertical2\",\n                               paneSize=[(1, 30, 100), (2, 70, 100)],\n                               parent=root)\n\n        # Anchor everything with formLayout\n        cmds.formLayout(root, edit=True,\n            attachForm=[\n                (top_bar,        \"top\",    0),\n                (top_bar,        \"left\",   0),\n                (top_bar,        \"right\",  0),\n                (footer,         \"bottom\", 2),\n                (footer,         \"left\",   0),\n                (footer,         \"right\",  0),\n                (settings_strip, \"left\",   0),\n                (settings_strip, \"right\",  0),\n                (pane,           \"left\",   0),\n                (pane,           \"right\",  0),\n            ],\n            attachControl=[\n                (pane,           \"top\",    0, top_bar),\n                (pane,           \"bottom\", 0, settings_strip),\n                (settings_strip, \"bottom\", 0, footer),\n            ]\n        )\n\n        # ------------------------------------------------------------------------\n        # LEFT PANE — Render Layers\n        # ------------------------------------------------------------------------\n        left_root = cmds.formLayout(parent=pane)\n\n        layers_frame = cmds.frameLayout(\n            label=\"Render Layers  ({})\".format(len(self.layers)),\n            collapsable=False, marginWidth=4, marginHeight=2,\n            parent=left_root)\n        self.layer_list_ctrl = cmds.textScrollList(\n            allowMultiSelection=True,\n            height=100,  # will stretch via formLayout\n            selectCommand=self._on_layer_select)\n        for layer in self.layers:\n            tag = \"? \" if is_layer_renderable(layer) else \"? \"\n            cmds.textScrollList(self.layer_list_ctrl, edit=True,\n                                append=\"{}{}\".format(tag, layer))\n        cmds.setParent(left_root)\n\n        layer_btns = cmds.rowLayout(\n            numberOfColumns=2, adjustableColumn=2,\n            columnWidth2=(110, 110), parent=left_root)\n        cmds.button(label=\"Enable All\",\n                    command=lambda *_: self._toggle_all_layers(True))\n        cmds.button(label=\"Disable All\",\n                    command=lambda *_: self._toggle_all_layers(False))\n        cmds.setParent(left_root)\n\n        cmds.formLayout(left_root, edit=True,\n            attachForm=[\n                (layers_frame, \"top\",    0),\n                (layers_frame, \"left\",   0),\n                (layers_frame, \"right\",  0),\n                (layer_btns,   \"left\",   0),\n                (layer_btns,   \"right\",  0),\n                (layer_btns,   \"bottom\", 0),\n            ],\n            attachControl=[\n                (layers_frame, \"bottom\", 0, layer_btns),\n            ]\n        )\n\n        # ------------------------------------------------------------------------\n        # RIGHT PANE — AOVs\n        # ------------------------------------------------------------------------\n        right_root = cmds.formLayout(parent=pane)\n\n        aov_frame = cmds.frameLayout(\n            label=\"AOVs\", collapsable=False,\n            marginWidth=4, marginHeight=2,\n            parent=right_root)\n\n        self.aov_panel_label = cmds.text(\n            label=\"  ? select a layer\",\n            align=\"left\", font=\"smallBoldLabelFont\", height=20)\n\n        cmds.separator(height=3, style=\"in\")\n\n        # Search + Add + Refresh\n        cmds.rowLayout(numberOfColumns=4, adjustableColumn=2,\n                       columnOffset4=(2, 4, 4, 4))\n        self.search_field = cmds.textField(\n            placeholderText=\"  search AOVs…\",\n            width=130, height=22,\n            changeCommand=lambda v, *_: self._filter_aov_list(v))\n        self.add_aov_menu = cmds.optionMenu(width=160)\n        for aov_name in get_available_aov_names():\n            cmds.menuItem(label=aov_name)\n        cmds.button(label=\"+ Add\", width=52, height=22,\n                    command=lambda *_: self._add_aov())\n        cmds.button(label=\"?\",     width=26, height=22,\n                    command=lambda *_: self._refresh_add_aov_menu())\n        cmds.setParent(aov_frame)\n\n        cmds.separator(height=3, style=\"in\")\n\n        # Scrollable checkbox list\n        self.aov_scroll = cmds.scrollLayout(childResizable=True, height=100)\n        self.aov_col    = cmds.columnLayout(\n            adjustableColumn=True, rowSpacing=0,\n            parent=self.aov_scroll)\n        self._rebuild_aov_checkboxes()\n        cmds.setParent(right_root)  # exit aov_frame back to right_root\n\n        # Bottom buttons — explicitly parented to right_root so formLayout can see them\n        aov_btns = cmds.rowLayout(\n            numberOfColumns=3,\n            columnWidth3=(80, 80, 100),\n            parent=right_root)\n        cmds.button(label=\"All On\",\n                    command=lambda *_: self._toggle_all_aovs(True))\n        cmds.button(label=\"All Off\",\n                    command=lambda *_: self._toggle_all_aovs(False))\n        cmds.button(label=\"Reset to Scene\",\n                    command=lambda *_: self._reset_aovs_to_scene())\n        cmds.setParent(right_root)\n\n        cmds.formLayout(right_root, edit=True,\n            attachForm=[\n                (aov_frame, \"top\",    0),\n                (aov_frame, \"left\",   0),\n                (aov_frame, \"right\",  0),\n                (aov_btns,  \"left\",   0),\n                (aov_btns,  \"right\",  0),\n                (aov_btns,  \"bottom\", 0),\n            ],\n            attachControl=[\n                (aov_frame, \"bottom\", 0, aov_btns),\n            ]\n        )\n\n        cmds.showWindow(self.win)\n        if self.layers:\n            cmds.textScrollList(self.layer_list_ctrl, edit=True,\n                                selectIndexedItem=1)\n            self._on_layer_select()\n\n    # -- AOV helpers -----------------------------------------------------------\n\n    def _rebuild_aov_checkboxes(self, filter_text=\"\"):\n        kids = cmds.columnLayout(self.aov_col, q=True, childArray=True) or []\n        for k in kids:\n            try: cmds.deleteUI(k)\n            except: pass\n        self.aov_check_map = {}\n        self.aov_node_map  = {}\n\n        if not self.aovs:\n            cmds.text(label=\"  No AOVs found.\", align=\"left\",\n                      font=\"smallPlainLabelFont\", parent=self.aov_col)\n            return\n\n        active = self._combined_active_set()\n        ft     = filter_text.lower().strip()\n\n        for node, info in self.aovs.items():\n            lbl = info[\"label\"]\n            if ft and ft not in lbl.lower():\n                continue\n            is_c    = info.get(\"is_crypto\", False)\n            display = (\"  [crypto]  \" if is_c else \"  \") + lbl\n\n            row = cmds.rowLayout(numberOfColumns=1, adjustableColumn=1,\n                                 parent=self.aov_col)\n            cb  = cmds.checkBox(\n                label=display,\n                value=(node in active),\n                changeCommand=partial(self._on_aov_toggle, node),\n                parent=row)\n            self.aov_check_map[node] = cb\n            self.aov_node_map[node]  = row\n\n            pm = cmds.popupMenu(parent=cb, button=3)\n            cmds.menuItem(\n                label=\"Remove  '{}'  from scene\".format(lbl),\n                command=partial(self._remove_aov_node, node),\n                parent=pm)\n            cmds.setParent(self.aov_col)\n\n    def _combined_active_set(self):\n        if not self.selected_layers:\n            return set()\n        sets = [self.layer_aov_selection.get(l, set())\n                for l in self.selected_layers]\n        result = sets[0].copy()\n        for s in sets[1:]:\n            result &= s\n        return result\n\n    def _filter_aov_list(self, text, *args):\n        self._rebuild_aov_checkboxes(filter_text=text)\n\n    def _add_aov(self):\n        if not self.add_aov_menu:\n            return\n        aov_name = cmds.optionMenu(self.add_aov_menu, q=True, value=True)\n        if not aov_name:\n            return\n        node = add_arnold_aov(aov_name)\n        if node:\n            self.aovs = get_aovs()\n            for layer in self.layers:\n                self.layer_aov_selection[layer].add(node)\n            ft = cmds.textField(self.search_field, q=True, text=True)\n            self._rebuild_aov_checkboxes(filter_text=ft)\n            self._refresh_add_aov_menu()\n\n    def _remove_aov_node(self, node, *args):\n        if not cmds.objExists(node):\n            return\n        try:\n            lbl = cmds.getAttr(\"{}.name\".format(node))\n        except Exception:\n            lbl = node\n        confirm = cmds.confirmDialog(\n            title=\"Remove AOV\",\n            message=\"Remove  \\'{}\\'  from the scene?\".format(lbl),\n            button=[\"Remove\", \"Cancel\"],\n            defaultButton=\"Remove\", cancelButton=\"Cancel\")\n        if confirm != \"Remove\":\n            return\n        remove_arnold_aov(node)\n        self.aovs = get_aovs()\n        for layer in self.layers:\n            self.layer_aov_selection[layer].discard(node)\n        ft = cmds.textField(self.search_field, q=True, text=True)\n        self._rebuild_aov_checkboxes(filter_text=ft)\n        self._refresh_add_aov_menu()\n\n    def _refresh_add_aov_menu(self):\n        existing = cmds.optionMenu(self.add_aov_menu, q=True,\n                                   itemListLong=True) or []\n        for item in existing:\n            cmds.deleteUI(item)\n        for aov_name in get_available_aov_names():\n            cmds.menuItem(label=aov_name, parent=self.add_aov_menu)\n\n    # -- callbacks -------------------------------------------------------------\n\n    def _on_layer_select(self, *args):\n        sel = cmds.textScrollList(self.layer_list_ctrl,\n                                  q=True, selectIndexedItem=True) or []\n        self.selected_layers = [self.layers[i - 1] for i in sel]\n        if not self.selected_layers:\n            return\n        if len(self.selected_layers) == 1:\n            cmds.text(self.aov_panel_label, edit=True,\n                      label=\"  Layer:  {}\".format(self.selected_layers[0]))\n        else:\n            cmds.text(self.aov_panel_label, edit=True,\n                      label=\"  {} layers selected  (showing intersection)\".format(\n                          len(self.selected_layers)))\n        active = self._combined_active_set()\n        for node, cb in self.aov_check_map.items():\n            try: cmds.checkBox(cb, edit=True, value=(node in active))\n            except: pass\n\n    def _on_aov_toggle(self, node, value, *args):\n        for layer in self.selected_layers:\n            if value:\n                self.layer_aov_selection[layer].add(node)\n            else:\n                self.layer_aov_selection[layer].discard(node)\n\n    def _on_sampling_change(self, attr, value, *args):\n        set_sampling_value(attr, value)\n\n    def _on_output_path_change(self, value, *args):\n        pass\n\n    def _toggle_all_layers(self, state):\n        for layer in self.layers:\n            set_layer_renderable(layer, state)\n        cmds.textScrollList(self.layer_list_ctrl, edit=True, removeAll=True)\n        for layer in self.layers:\n            tag = \"? \" if is_layer_renderable(layer) else \"? \"\n            cmds.textScrollList(self.layer_list_ctrl, edit=True,\n                                append=\"{}{}\".format(tag, layer))\n\n    def _toggle_all_aovs(self, state):\n        for layer in self.selected_layers:\n            self.layer_aov_selection[layer] = (\n                set(self.aovs.keys()) if state else set())\n        for node, cb in self.aov_check_map.items():\n            try: cmds.checkBox(cb, edit=True, value=state)\n            except: pass\n\n    def _reset_aovs_to_scene(self):\n        for layer in self.selected_layers:\n            self.layer_aov_selection[layer] = set(\n                n for n, info in self.aovs.items() if info[\"enabled\"])\n        active = self._combined_active_set()\n        for node, cb in self.aov_check_map.items():\n            try: cmds.checkBox(cb, edit=True, value=(node in active))\n            except: pass\n\n    def _reset_frame_range(self, start, end, step):\n        cmds.intField(self.start_frame_field, edit=True, value=start)\n        cmds.intField(self.end_frame_field,   edit=True, value=end)\n        cmds.intField(self.step_frame_field,  edit=True, value=step)\n\n    def _browse_output(self):\n        current = cmds.textField(self.output_field, q=True, text=True)\n        result  = cmds.fileDialog2(dialogStyle=2, fileMode=3,\n                                   startingDirectory=current,\n                                   caption=\"Select Output Directory\")\n        if result:\n            cmds.textField(self.output_field, edit=True, text=result[0])\n\n    def _get_output_path(self):\n        return cmds.textField(self.output_field, q=True, text=True)\n\n    def _refresh_camera_menu(self):\n        all_shapes = cmds.ls(type=\"camera\") or []\n        names = []\n        for s in all_shapes:\n            p = cmds.listRelatives(s, parent=True, fullPath=False) or []\n            if p: names.append(p[0])\n        names = list(dict.fromkeys(names))\n        for item in cmds.optionMenu(self.camera_menu, q=True,\n                                    itemListLong=True) or []:\n            cmds.deleteUI(item)\n        for c in names:\n            cmds.menuItem(label=c, parent=self.camera_menu)\n        detected = get_render_camera()\n        if detected in names:\n            cmds.optionMenu(self.camera_menu, edit=True,\n                            select=names.index(detected) + 1)\n\n    def _get_selected_camera(self):\n        return cmds.optionMenu(self.camera_menu, q=True, value=True)\n\n    # -- render ----------------------------------------------------------------\n\n    def _start_render(self):\n        renderable = [l for l in self.layers if is_layer_renderable(l)]\n        if not renderable:\n            cmds.confirmDialog(title=\"Nothing to Render\",\n                message=\"No layers are set as renderable.\", button=[\"OK\"])\n            return\n        confirm = cmds.confirmDialog(\n            title=\"Confirm Render Sequence\",\n            message=\"Render {} layer(s)?\\n\\n{}\".format(\n                len(renderable), \"\\n\".join(renderable)),\n            button=[\"Render\", \"Cancel\"],\n            defaultButton=\"Render\", cancelButton=\"Cancel\")\n        if confirm != \"Render\":\n            return\n\n        start    = cmds.intField(self.start_frame_field, q=True, value=True)\n        end      = cmds.intField(self.end_frame_field,   q=True, value=True)\n        step     = cmds.intField(self.step_frame_field,  q=True, value=True)\n        camera   = self._get_selected_camera()\n        out_path = self._get_output_path()\n\n        BatchRenderJob(\n            layer_aov_map = {l: list(self.layer_aov_selection.get(l, set()))\n                             for l in renderable},\n            all_aov_nodes = list(self.aovs.keys()),\n            start_frame   = start,\n            end_frame     = end,\n            frame_step    = step,\n            render_camera = camera,\n            output_dir    = out_path,\n            progress_cb   = lambda msg: sys.stdout.write(msg + \"\\n\"),\n            done_cb       = lambda: None\n        ).run()\n\n\n# -----------------------------------------------------------------------------\n# ENTRY POINT\n# -----------------------------------------------------------------------------\n\ndef show():\n    RenderLayerAOVUI().build()\n\nif __name__ == \"__main__\":\n    show()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
