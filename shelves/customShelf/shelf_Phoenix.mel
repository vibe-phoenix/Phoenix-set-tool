        -image1 "C:/icons-phoenix/fileNode/sRGB.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef update_file_nodes_to_srgb():\n    # Get selected file nodes\n    selected = cmds.ls(selection=True, type='file')\n\n    if not selected:\n        cmds.warning(\"No file nodes selected.\")\n        return\n\n    for node in selected:\n        try:\n            # Turn on 'Ignore Color Space File Rules'\n            cmds.setAttr(f\"{node}.ignoreColorSpaceFileRules\", 1)\n\n            # Turn off 'Alpha is Luminance'\n            cmds.setAttr(f\"{node}.alphaIsLuminance\", 0)\n\n            # Set Color Space to 'sRGB'\n            cmds.setAttr(f\"{node}.colorSpace\", \"sRGB\", type=\"string\")\n\n            print(f\"Updated to sRGB: {node}\")\n        except Exception as e:\n            print(f\"Failed to update {node}: {e}\")\n\nupdate_file_nodes_to_srgb()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
