        -command "import maya.cmds as cmds\nimport os\n\ndefault_dir = r\"C:\\icons-phoenix\\light rig\"\nif not os.path.exists(default_dir):\n    os.makedirs(default_dir)\n\nfile_path = cmds.fileDialog2(fileFilter='Maya ASCII (*.ma)', dialogStyle=2, caption=\"Export Selection As .ma\",\n                              startingDirectory=default_dir, fileMode=0)\n\nif file_path:\n    path = file_path[0]\n    if not path.lower().endswith('.ma'):\n        path += '.ma'\n\n    selection = cmds.ls(sl=True, long=True)\n    if not selection:\n        cmds.warning(\"No objects selected for export.\")\n    else:\n        try:\n            cmds.file(path, force=True, exportSelected=True, type='mayaAscii')\n            cmds.inViewMessage(amg=f'?? Exported selection to: {os.path.basename(path)}', pos='midCenterTop', fade=True)\n        except Exception as e:\n            cmds.warning(f\"Export failed: {e}\")\n" 
