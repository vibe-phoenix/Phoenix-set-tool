        -command "import maya.cmds as cmds\nimport maya.mel as mel\n\ndef toggle_poly_interactive_creation_with_popup():\n    # 1) Toggle via MEL (same as running: ToggleCreatePolyPrimitivesAsTool;)\n    mel.eval(\"ToggleCreatePolyPrimitivesAsTool;\")\n    \n    # 2) Figure out the current state (optionVar name can vary across versions)\n    candidate_vars = [\n        \"createPolyPrimitiveAsTool\",\n        \"createPolyPrimitivesAsTool\",\n        \"CreatePolyPrimitiveAsTool\",\n        \"CreatePolyPrimitivesAsTool\",\n    ]\n    state = None\n    for var in candidate_vars:\n        if cmds.optionVar(exists=var):\n            try:\n                state = cmds.optionVar(q=var)\n                break\n            except Exception:\n                pass\n    \n    # Fallback: if we couldn't read the optionVar reliably, assume OFF = 0\n    if state not in (0, 1, True, False):\n        state = 0\n\n    # 3) Show an in-view HUD-style popup\n    msg = \"Interactive Creation: <hl>ON</hl>\" if int(state) == 1 else \"Interactive Creation: <hl>OFF</hl>\"\n    try:\n        cmds.inViewMessage(amg=msg, pos='topCenter', fade=True, alpha=0.9, dragKill=True)\n    except Exception:\n        # Fallback to a dialog if inViewMessage isn't available\n        cmds.confirmDialog(title='Interactive Creation', message=msg.replace(\"<hl>\", \"\").replace(\"</hl>\", \"\"), button=['OK'])\n\n# Run it:\ntoggle_poly_interactive_creation_with_popup()\n  " 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
