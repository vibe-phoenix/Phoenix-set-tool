        -command "// =======================================================\n// Nth Edge Selector (Ring/Loop) + \"Nth Ring ? Full Loop\"\n// Phoenix / m341\n// =======================================================\n//\n// Run UI:\n//   m341_NthEdgeSelectorUI();\n//\n// Buttons:\n//  • Select Nth (Ring/Loop) — uses chosen Mode + N\n//  • Select Nth Ring ? Full Loop(s) — forces edgeRing + N, then expands to full loops\n//\n// Notes:\n// - Works from current selection (edges/verts/faces). Converts to edges if needed.\n// - Uses Maya's built-in: polySelectEdgesEveryN\n// - Loop expansion uses SelectEdgeLoopSp\n// =======================================================\n\n\n// --- Loop conversion (kept as provided)\nglobal proc SelectEdgeLoopFromSelection()\n{\n    string $sel[] = `ls -sl -fl`;\n    if (size($sel) == 0)\n    {\n        warning \"Please select at least one edge first.\";\n        return;\n    }\n\n    string $edges[] = `filterExpand -sm 32 -ex true $sel`;\n    if (size($edges) == 0)\n    {\n        warning \"No edges selected. Please select polygon edges.\";\n        return;\n    }\n\n    select -r $edges;\n    SelectEdgeLoopSp; // built-in Maya MEL procedure to select edge loops\n    print \"// Edge loop(s) selected\\n\";\n}\n\n\n// --- Helper: ensure edge components\nglobal proc string[] m341_getEdgesFromAnySelection()\n{\n    string $sel[] = `ls -sl -fl`;\n    if (!size($sel)) return {};\n\n    // Try edges directly\n    string $edges[] = `filterExpand -ex 1 -sm 32 $sel`;\n    if (size($edges)) return $edges;\n\n    // Convert verts/faces/etc ? edges\n    string $toEdges[] = `polyListComponentConversion -te $sel`;\n    $edges = `filterExpand -ex 1 -sm 32 $toEdges`;\n    return $edges;\n}\n\n\n// --- Core: select every Nth by Ring/Loop (based on UI)\nglobal proc m341_selectNthEdges(int $n, string $mode)\n{\n    if ($n < 1) $n = 1;\n    if ($mode != \"edgeRing\" && $mode != \"edgeLoop\") $mode = \"edgeRing\";\n\n    string $edges[] = `m341_getEdgesFromAnySelection`;\n    if (!size($edges))\n    {\n        warning \"No polygon edges found in selection.\";\n        return;\n    }\n\n    select -r $edges;\n    polySelectEdgesEveryN $mode $n;\n\n    print (\"// Selected every \" + $n + \" edge(s) using \" + $mode + \".\\n\");\n}\n\n\n// --- Force Ring at N, then expand to full loops\nglobal proc m341_selectNthRingToFull(int $n)\n{\n    if ($n < 1) $n = 1;\n\n    string $edges[] = `m341_getEdgesFromAnySelection`;\n    if (!size($edges))\n    {\n        warning \"No polygon edges found in selection.\";\n        return;\n    }\n\n    // 1) Select Nth with edgeRing\n    select -r $edges;\n    polySelectEdgesEveryN \"edgeRing\" $n;\n\n    // 2) Expand result to full loops\n    SelectEdgeLoopFromSelection();\n\n    print (\"// Selected every \" + $n + \"th edge RING and expanded to full loop(s).\\n\");\n}\n\n\n// --- UI handlers\nglobal proc m341_NthEdgeSelectorApply(string $rbg, string $isg)\n{\n    int $modeIdx = `radioButtonGrp -q -sl $rbg`; // 1=Ring, 2=Loop\n    string $mode = ($modeIdx == 1) ? \"edgeRing\" : \"edgeLoop\";\n    int $n = `intSliderGrp -q -v $isg`;\n    m341_selectNthEdges($n, $mode);\n}\n\nglobal proc m341_NthEdgeSelectorApplyRingToFull(string $isg)\n{\n    int $n = `intSliderGrp -q -v $isg`;\n    m341_selectNthRingToFull($n);\n}\n\n\n// --- UI\nglobal proc m341_NthEdgeSelectorUI()\n{\n    string $win = \"m341_NthEdgeSelectorWin\";\n    if (`window -ex $win`) deleteUI -window $win;\n\n    window -t \"Nth Edge Selector\" -s 0 $win;\n    columnLayout -adj 1 -rs 6;\n\n        string $rbg = `radioButtonGrp -nrb 2 -la2 \"Ring\" \"Loop\" -sl 1 -cw2 80 80 -l \"Mode:\"`;\n        string $isg = `intSliderGrp -l \"Every Nth:\" -min 1 -max 200 -v 2 -f 1`;\n\n        button -l \"Select Nth (Ring/Loop)\" -h 30\n            -c (\"m341_NthEdgeSelectorApply(\\\"\"+$rbg+\"\\\",\\\"\"+$isg+\"\\\")\");\n\n        button -l \"Select Nth Ring ? Full Loop(s)\" -h 30\n            -c (\"m341_NthEdgeSelectorApplyRingToFull(\\\"\"+$isg+\"\\\")\");\n\n        separator -h 8 -style \"none\";\n        text -al \"left\" -l\n            \"Tips:\\n• Pre-select edges (or verts/faces).\\n• Set N.\\n• Use either ‘Ring/Loop’ or force ‘Ring ? Full’.\";\n\n    showWindow $win;\n}\n\n\nm341_NthEdgeSelectorUI;\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
