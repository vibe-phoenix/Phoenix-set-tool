        -command "import maya.cmds as cmds\n\ndef delete_all_reference_display_layers():\n    layers = cmds.ls(type=\"displayLayer\")\n\n    if not layers:\n        cmds.warning(\"No display layers found.\")\n        return\n\n    deleted = []\n\n    for layer in layers:\n        if layer == \"defaultLayer\":\n            continue  # never touch default\n\n        # Check if it's a Reference layer\n        display_type = cmds.getAttr(layer + \".displayType\")\n\n        if display_type == 2:  # Reference\n            try:\n                cmds.delete(layer)\n                deleted.append(layer)\n            except:\n                cmds.warning(\"Could not delete: {}\".format(layer))\n\n    if deleted:\n        print(\"Deleted Reference Layers:\", deleted)\n    else:\n        cmds.warning(\"No Reference display layers found.\")\n\n\ndelete_all_reference_display_layers()" 
        -sourceType "python" 
        -doubleClickCommand "import maya.cmds as cmds\n\ndef delete_all_reference_layers():\n    layers = cmds.ls(type=\"displayLayer\")\n    \n    if not layers:\n        cmds.warning(\"No display layers found.\")\n        return\n\n    deleted = []\n\n    for layer in layers:\n        if layer == \"defaultLayer\":\n            continue\n\n        try:\n            display_type = cmds.getAttr(layer + \".displayType\")\n            \n            # 2 = Reference\n            if display_type == 2:\n                cmds.delete(layer)\n                deleted.append(layer)\n        except:\n            pass\n\n    if deleted:\n        print(\"Deleted reference layers:\")\n        for l in deleted:\n            print(\" -\", l)\n    else:\n        print(\"No reference layers found.\")\n\n\ndelete_all_reference_layers()" 
        -commandRepeatable 1
        -flat 1
