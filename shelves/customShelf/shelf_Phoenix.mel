        -command "import maya.cmds as cmds\n\ndef arrange_between_first_two_all_axes():\n    selection = cmds.ls(selection=True, long=True)\n\n    if len(selection) < 3:\n        cmds.warning(\"Select at least 3 objects: first 2 define the start and end, rest are arranged.\")\n        return\n\n    start_obj = selection[0]\n    end_obj = selection[1]\n    middle_objs = selection[2:]\n\n    # Get world positions\n    start_pos = cmds.xform(start_obj, q=True, ws=True, t=True)\n    end_pos = cmds.xform(end_obj, q=True, ws=True, t=True)\n\n    num_middle = len(middle_objs)\n\n    for i, obj in enumerate(middle_objs, 1):\n        t = i / (num_middle + 1)  # Even spacing factor (0 < t < 1)\n\n        # Linearly interpolate position between start and end\n        new_pos = [\n            start_pos[0] + t * (end_pos[0] - start_pos[0]),\n            start_pos[1] + t * (end_pos[1] - start_pos[1]),\n            start_pos[2] + t * (end_pos[2] - start_pos[2])\n        ]\n\n        cmds.xform(obj, ws=True, t=new_pos)\n\n    print(f\"Arranged {len(middle_objs)} objects between '{start_obj}' and '{end_obj}' across all axes.\")\n\n# Run it\narrange_between_first_two_all_axes()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
