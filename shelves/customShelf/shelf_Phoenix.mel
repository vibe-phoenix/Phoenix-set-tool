        -command "import maya.cmds as cmds\n\ndef set_uv_tiling_to_udim():\n    # Get selected file nodes\n    selected = cmds.ls(selection=True, type='file')\n\n    if not selected:\n        cmds.warning(\"No file nodes selected.\")\n        return\n\n    for node in selected:\n        try:\n            # Set UV Tiling Mode to UDIM (Mari)\n            cmds.setAttr(f\"{node}.uvTilingMode\", 3)\n            print(f\"Set UDIM Tiling on: {node}\")\n        except Exception as e:\n            print(f\"Failed to update {node}: {e}\")\n\nset_uv_tiling_to_udim()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
