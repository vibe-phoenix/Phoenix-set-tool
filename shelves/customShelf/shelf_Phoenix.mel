        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef assign_test_lambert_active_or_hilite():\n    shader = \"testLambert_shd\"\n    sg     = \"test_Lambert\"\n\n    # --- 1) Gather selection; if empty, use hilited ---\n    sel = cmds.ls(sl=True, long=True) or []\n    if not sel:\n        # hilited components/objects (works when in component mode with nothing selected)\n        sel = cmds.ls(hl=True, long=True) or []\n    if not sel:\n        cmds.warning(\"Select or highlight an object (or its components) to assign 'test_Lambert'.\")\n        return\n\n    # Derive transforms from selection/hilite\n    transforms = []\n    for s in sel:\n        node = s.split('.')[0]  # strip component if any\n        if cmds.objectType(node, isAType=\"shape\"):\n            transforms += (cmds.listRelatives(node, p=True, f=True) or [])\n        else:\n            transforms.append(node)\n    transforms = list(set(transforms))\n    if not transforms:\n        cmds.warning(\"Could not resolve transforms from selection/hilite.\")\n        return\n\n    # Collect renderable, non-intermediate shapes\n    shapes = []\n    for tr in transforms:\n        shapes += (cmds.listRelatives(tr, s=True, ni=True, f=True) or [])\n    valid_types = {\"mesh\", \"nurbsSurface\", \"subdiv\", \"nurbsCurve\"}\n    shapes = [sh for sh in shapes if cmds.objectType(sh) in valid_types]\n    if not shapes:\n        cmds.warning(\"No renderable shapes found under the selected/hilited objects.\")\n        return\n\n    # --- 2) Ensure shader & SG exist ---\n    if not cmds.objExists(shader):\n        shader = cmds.shadingNode(\"lambert\", asShader=True, name=shader)\n    if not cmds.objExists(sg):\n        sg = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=sg)\n\n    # --- 3) Force-connect shader -> SG ---\n    surf_attr = sg + \".surfaceShader\"\n    out_attr  = shader + \".outColor\"\n\n    if cmds.getAttr(surf_attr, lock=True):\n        cmds.setAttr(surf_attr, lock=False)\n    for p in cmds.listConnections(surf_attr, plugs=True, s=True, d=False) or []:\n        try:\n            cmds.disconnectAttr(p, surf_attr)\n        except:\n            pass\n    if not cmds.isConnected(out_attr, surf_attr):\n        cmds.connectAttr(out_attr, surf_attr, f=True)\n\n    # --- 4) Set shader color (S=0, V=0.2 => RGB 0.2) ---\n    cmds.setAttr(shader + \".color\", 0.2, 0.2, 0.2, type=\"double3\")\n\n    # --- 5) Assign SG to shapes ---\n    cmds.sets(shapes, e=True, forceElement=sg)\n\n\n\nassign_test_lambert_active_or_hilite()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Dup" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Dup" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "dup" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "duplicateCurve.png" 
        -image1 "duplicateCurve.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# ============================================================\n# Duplicate: Linear & Radial (Auto-Rotate / Fixed Radius)\n# Keeps all previous features + adds true radial auto-rotate\n# ============================================================\nimport maya.cmds as cmds\nimport math\n\nWIN = \"DuplicateAlongAxis_AllModes_UI\"\n\n# ------------------------ math helpers ------------------------\ndef _norm(v):\n    m = math.sqrt(v[0]*v[0] + v[1]*v[1] + v[2]*v[2])\n    return (v[0]/m, v[1]/m, v[2]/m) if m != 0.0 else (0.0,0.0,0.0)\n\ndef _dot(a,b): return a[0]*b[0] + a[1]*b[1] + a[2]*b[2]\ndef _cross(a,b): return (a[1]*b[2]-a[2]*b[1], a[2]*b[0]-a[0]*b[2], a[0]*b[1]-a[1]*b[0])\ndef _scale(v,s): return (v[0]*s, v[1]*s, v[2]*s)\ndef _add(a,b): return (a[0]+b[0], a[1]+b[1], a[2]+b[2])\n\ndef _object_pivot_ws(obj):\n    rp = cmds.xform(obj, q=True, rp=True, ws=True)\n    return (rp[0], rp[1], rp[2])\n\ndef _get_axis_vec(obj, axis='x', space='world'):\n    axis = axis.lower()\n    if space == 'world':\n        return {'x':(1.0,0.0,0.0), 'y':(0.0,1.0,0.0), 'z':(0.0,0.0,1.0)}[axis]\n    # object space: pull from world matrix columns\n    m = cmds.xform(obj, q=True, m=True, ws=True)\n    if axis == 'x': v = (m[0], m[1], m[2])\n    elif axis == 'y': v = (m[4], m[5], m[6])\n    else: v = (m[8], m[9], m[10])\n    return _norm(v)\n\ndef _perp_frame(axis_vec):\n    A = _norm(axis_vec)\n    helper = (0.0, 1.0, 0.0) if abs(_dot(A, (0,1,0))) < 0.95 else (1.0, 0.0, 0.0)\n    U = _norm(_cross(A, helper))\n    if U == (0.0,0.0,0.0):\n        helper = (0.0, 0.0, 1.0)\n        U = _norm(_cross(A, helper))\n    V = _cross(A, U)\n    return U, V\n\ndef _rodrigues_rotate_point_around_axis(point, axis_point, axis_vec, angle_deg):\n    \"\"\"Rotate a point around the axis (axis_point + t*axis_vec) by angle.\"\"\"\n    ux,uy,uz = _norm(axis_vec)\n    px,py,pz = point[0]-axis_point[0], point[1]-axis_point[1], point[2]-axis_point[2]\n    ang = math.radians(angle_deg)\n    c, s = math.cos(ang), math.sin(ang)\n    crossx = uy*pz - uz*py\n    crossy = uz*px - ux*pz\n    crossz = ux*py - uy*px\n    dotkv  = ux*px + uy*py + uz*pz\n    rx = px*c + crossx*s + ux*dotkv*(1-c)\n    ry = py*c + crossy*s + uy*dotkv*(1-c)\n    rz = pz*c + crossz*s + uz*dotkv*(1-c)\n    return (rx+axis_point[0], ry+axis_point[1], rz+axis_point[2])\n\n# ------------------------ core ops ------------------------\ndef _duplicate_linear(sel, axis='x', count=5, spacing=2.0, negative=False,\n                      as_instance=False, group_it=True, space='world'):\n    made = []\n    for src in sel:\n        step_dir = _get_axis_vec(src, axis=axis, space=space)\n        if negative:\n            step_dir = (-step_dir[0], -step_dir[1], -step_dir[2])\n        step = _scale(step_dir, spacing)\n\n        grp = None\n        if group_it:\n            base = src.split('|')[-1]\n            name = f\"{base}_{axis.upper()}_{space}_dups\"\n            grp = cmds.group(empty=True, name=name) if not cmds.objExists(name) else cmds.group(empty=True, name=name+\"#\")\n\n        for i in range(1, int(count)+1):\n            dup = cmds.instance(src)[0] if as_instance else cmds.duplicate(src, rr=True)[0]\n            offs = _scale(step, i)\n            cmds.move(offs[0], offs[1], offs[2], dup, r=True, ws=True)\n            if group_it and grp:\n                cmds.parent(dup, grp)\n            made.append(dup)\n    return made\n\ndef _duplicate_radial_fixed(sel, axis='x', count=8, radius=5.0, start_deg=0.0, sweep_deg=360.0,\n                            as_instance=False, group_it=True, space='world', center_mode='object'):\n    \"\"\"Place duplicates on a circle with fixed radius; choose center.\"\"\"\n    made = []\n    for src in sel:\n        A = _get_axis_vec(src, axis=axis, space=space)\n        U, V = _perp_frame(A)\n        C = (0.0, 0.0, 0.0) if center_mode == 'world' else _object_pivot_ws(src)\n\n        step = sweep_deg / float(count)\n        grp = None\n        if group_it:\n            base = src.split('|')[-1]\n            name = f\"{base}_RADFIX_{axis.upper()}_{space}_dups\"\n            grp = cmds.group(empty=True, name=name) if not cmds.objExists(name) else cmds.group(empty=True, name=name+\"#\")\n\n        for i in range(count):\n            ang = math.radians(start_deg + i*step)\n            p = _add(C, _add(_scale(U, radius*math.cos(ang)), _scale(V, radius*math.sin(ang))))\n            dup = cmds.instance(src)[0] if as_instance else cmds.duplicate(src, rr=True)[0]\n            cmds.xform(dup, ws=True, t=p)\n            if group_it and grp:\n                cmds.parent(dup, grp)\n            made.append(dup)\n    return made\n\ndef _duplicate_radial_auto_rotate(sel, axis='x', count=8, start_deg=0.0, sweep_deg=360.0,\n                                  as_instance=False, group_it=True, space='world',\n                                  spin_orientation=True):\n    \"\"\"\n    True radial: compute radius as distance from the axis line, then rotate about the axis.\n    - World axis: line through world origin in world X/Y/Z.\n    - Object axis: line through the object's pivot along its local axis.\n    \"\"\"\n    made = []\n    step = sweep_deg / float(count)\n\n    for src in sel:\n        # axis direction\n        A = _get_axis_vec(src, axis=axis, space=space)\n        # axis line point\n        axis_point = (0.0, 0.0, 0.0) if space == 'world' else _object_pivot_ws(src)\n\n        base_piv = _object_pivot_ws(src)\n\n        grp = None\n        if group_it:\n            base = src.split('|')[-1]\n            name = f\"{base}_RADAUTO_{axis.upper()}_{space}_dups\"\n            grp = cmds.group(empty=True, name=name) if not cmds.objExists(name) else cmds.group(empty=True, name=name+\"#\")\n\n        for i in range(1, count+1):\n            ang = start_deg + i*step\n            dup = cmds.instance(src)[0] if as_instance else cmds.duplicate(src, rr=True)[0]\n\n            # move: rotate pivot around the axis line\n            new_p = _rodrigues_rotate_point_around_axis(base_piv, axis_point, A, ang)\n            delta = (new_p[0]-base_piv[0], new_p[1]-base_piv[1], new_p[2]-base_piv[2])\n            cmds.move(delta[0], delta[1], delta[2], dup, r=True, ws=True)\n\n            # rotate orientation about the axis (spin with the rotation)\n            if spin_orientation:\n                # relative rotation in OBJECT space keeps local spin sensible\n                cmds.rotate(A[0]*ang, A[1]*ang, A[2]*ang, dup, r=True, os=True)\n\n            if group_it and grp:\n                cmds.parent(dup, grp)\n            made.append(dup)\n    return made\n\n# ------------------------ UI ------------------------\ndef _build_ui():\n    if cmds.window(WIN, exists=True):\n        cmds.deleteUI(WIN, window=True)\n\n    cmds.window(WIN, title=\"Duplicate – Linear & Radial (All Modes)\", sizeable=False, mnb=False, mxb=False)\n    form = cmds.formLayout()\n    col  = cmds.columnLayout(adj=True, rs=8)\n\n    # Mode\n    mode_rbg = cmds.radioButtonGrp(\n        label='Mode', numberOfRadioButtons=2,\n        labelArray2=['Linear', 'Radial'], select=1, cw3=[60, 100, 100], columnAlign=[1,'left']\n    )\n\n    # Radial subtype\n    rad_sub_rbg = cmds.radioButtonGrp(\n        label='Radial Type', numberOfRadioButtons=2,\n        labelArray2=['Auto (Rotate Around Axis)', 'Fixed Radius (By Distance)'],\n        select=1, cw3=[100, 190, 210], columnAlign=[1,'left']\n    )\n\n    # Axis & Space\n    axis_rbg = cmds.radioButtonGrp(label='Axis', numberOfRadioButtons=3,\n                                   labelArray3=['X','Y','Z'], select=1, cw4=[60,60,60,60], columnAlign=[1,'left'])\n    space_rbg = cmds.radioButtonGrp(label='Space', numberOfRadioButtons=2,\n                                    labelArray2=['World','Object (Local)'], select=1, cw3=[60,120,140], columnAlign=[1,'left'])\n\n    # Common: Count / Instance / Group\n    row_common = cmds.rowLayout(nc=4, adj=2, cw4=(70, 100, 70, 100))\n    cmds.text(l=\"Count\")\n    count_if = cmds.intField(value=8, minValue=1)\n    cmds.text(l=\"Instance?\")\n    inst_cb  = cmds.checkBox(value=False, label='')\n    cmds.setParent('..')\n    group_cb = cmds.checkBox(label=\"Group duplicates per source\", value=True)\n\n    # Linear frame\n    frame_lin = cmds.frameLayout(label=\"Linear Options\", collapsable=False, mw=6, mh=6)\n    row_lin = cmds.rowLayout(nc=4, adj=2, cw4=(70, 100, 70, 100))\n    cmds.text(l=\"Spacing\")\n    spacing_ff = cmds.floatField(value=2.0, pre=3)\n    cmds.text(l=\"Negative\")\n    neg_cb = cmds.checkBox(value=False, label='')\n    cmds.setParent('..')\n    cmds.setParent('..')\n\n    # Radial frame\n    frame_rad = cmds.frameLayout(label=\"Radial Options\", collapsable=False, mw=6, mh=6)\n    row_r1 = cmds.rowLayout(nc=4, adj=2, cw4=(70, 120, 70, 120))\n    cmds.text(l=\"Start°\")\n    start_ff = cmds.floatField(value=0.0, pre=2)\n    cmds.text(l=\"Sweep°\")\n    sweep_ff = cmds.floatField(value=360.0, pre=2)\n    cmds.setParent('..')\n\n    row_r2 = cmds.rowLayout(nc=4, adj=2, cw4=(110, 120, 120, 140))\n    spin_cb = cmds.checkBox(label=\"Spin orientation with axis\", value=True)\n    cmds.text(l=\"(Fixed Radius only)  Radius\")\n    radius_ff = cmds.floatField(value=5.0, pre=3, minValue=0.0)\n    cmds.setParent('..')\n\n    center_rbg = cmds.radioButtonGrp(\n        label='Center (Fixed Radius)', numberOfRadioButtons=2,\n        labelArray2=['Object Pivot', 'World Origin'], select=1,\n        cw3=[120, 120, 140], columnAlign=[1,'left']\n    )\n    cmds.setParent('..')  # end frame_rad\n\n    # Small logic to enable/disable fixed-radius inputs\n    def _update_rad_controls(*_):\n        is_rad = cmds.radioButtonGrp(mode_rbg, q=True, select=True) == 2\n        is_fixed = cmds.radioButtonGrp(rad_sub_rbg, q=True, select=True) == 2\n        # Enable/disable the fixed-radius widgets\n        cmds.floatField(radius_ff, e=True, enable=is_rad and is_fixed)\n        cmds.radioButtonGrp(center_rbg, e=True, enable=is_rad and is_fixed)\n\n    cmds.radioButtonGrp(mode_rbg, e=True, cc=_update_rad_controls)\n    cmds.radioButtonGrp(rad_sub_rbg, e=True, cc=_update_rad_controls)\n    _update_rad_controls()\n\n    # Buttons\n    btn_row = cmds.rowLayout(nc=3, adj=1, cw3=(240, 140, 100))\n    def _on_duplicate(*_):\n        mode     = {1:'linear', 2:'radial'}[cmds.radioButtonGrp(mode_rbg, q=True, select=True)]\n        rad_sub  = {1:'auto', 2:'fixed'}[cmds.radioButtonGrp(rad_sub_rbg, q=True, select=True)]\n        axis     = {1:'x', 2:'y', 3:'z'}[cmds.radioButtonGrp(axis_rbg, q=True, select=True)]\n        space    = {1:'world', 2:'object'}[cmds.radioButtonGrp(space_rbg, q=True, select=True)]\n        count    = cmds.intField(count_if, q=True, value=True)\n        as_inst  = cmds.checkBox(inst_cb, q=True, value=True)\n        group_it = cmds.checkBox(group_cb, q=True, value=True)\n\n        sel = cmds.ls(sl=True, transforms=True)\n        if not sel:\n            cmds.warning(\"Select at least one transform object.\")\n            return\n\n        made = []\n        if mode == 'linear':\n            spacing  = cmds.floatField(spacing_ff, q=True, value=True)\n            negative = cmds.checkBox(neg_cb, q=True, value=True)\n            made = _duplicate_linear(sel, axis=axis, count=count, spacing=spacing,\n                                     negative=negative, as_instance=as_inst,\n                                     group_it=group_it, space=space)\n            msg = f\"Linear {'instances' if as_inst else 'copies'} along {axis.upper()} in {space}\"\n        else:\n            start = cmds.floatField(start_ff, q=True, value=True)\n            sweep = cmds.floatField(sweep_ff, q=True, value=True)\n            if rad_sub == 'auto':\n                spin = cmds.checkBox(spin_cb, q=True, value=True)\n                made = _duplicate_radial_auto_rotate(sel, axis=axis, count=count,\n                                                     start_deg=start, sweep_deg=sweep,\n                                                     as_instance=as_inst, group_it=group_it,\n                                                     space=space, spin_orientation=spin)\n                msg = f\"Radial AUTO {'instances' if as_inst else 'copies'} around {axis.upper()} in {space}\"\n            else:\n                radius = cmds.floatField(radius_ff, q=True, value=True)\n                center = {1:'object', 2:'world'}[cmds.radioButtonGrp(center_rbg, q=True, select=True)]\n                made = _duplicate_radial_fixed(sel, axis=axis, count=count, radius=radius,\n                                               start_deg=start, sweep_deg=sweep,\n                                               as_instance=as_inst, group_it=group_it,\n                                               space=space, center_mode=center)\n                msg = f\"Radial FIXED {'instances' if as_inst else 'copies'} around {axis.upper()} in {space}\"\n\n        try:\n            cmds.inViewMessage(amg=f'{msg}: <hl>{len(made)}</hl> made', pos='topCenter', fade=True)\n        except:\n            pass\n\n    def _select_groups(*_):\n        grps = [g for g in (cmds.ls(type='transform') or []) if g.endswith('_dups') or '_dups' in g]\n        if grps:\n            cmds.select(grps, r=True)\n        else:\n            cmds.warning(\"No duplicate groups found.\")\n\n    cmds.button(label=\"Duplicate\", h=30, c=_on_duplicate)\n    cmds.button(label=\"Select Group(s)\", h=30, c=_select_groups)\n    cmds.button(label=\"Close\", h=30, c=lambda *_: cmds.deleteUI(WIN, window=True))\n    cmds.setParent('..')\n\n    cmds.formLayout(form, e=True,\n        attachForm=[(col,'top',10),(col,'left',10),(col,'right',10),(col,'bottom',10)]\n    )\n    cmds.showWindow(WIN)\n\ndef duplicate_all_modes_ui():\n    _build_ui()\n\n# Run UI on paste\nduplicate_all_modes_ui()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
