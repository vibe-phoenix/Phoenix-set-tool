        -command "# Phoenix Set Tools - Smart Loader (Shelf Button)\n# Runs cached instantly, checks updates in background, auto-reopens on update\n\nimport os\nimport sys\nimport threading\nimport time\nimport maya.cmds as cmds\n\n# -- Config ---------------------------------------------------------------------\nRAW_URL   = \"https://raw.githubusercontent.com/vibe-phoenix/Phoenix-set-tool/main/phoenix-set-tools.py\"\nETAG_URL  = \"https://api.github.com/repos/vibe-phoenix/Phoenix-set-tool/contents/phoenix-set-tools.py\"\nTOOL_FILE = \"phoenix-set-tools.py\"\nETAG_FILE = \"phoenix-set-tools.etag\"\nFOLDER    = \"phoenixtools\"\n# -------------------------------------------------------------------------------\n\nPY3 = sys.version_info[0] >= 3\n\ndef get_tools_dir():\n    maya_app_dir = cmds.internalVar(userAppDir=True)\n    tools_dir    = os.path.join(maya_app_dir, FOLDER)\n    if not os.path.exists(tools_dir):\n        os.makedirs(tools_dir)\n    return tools_dir\n\ndef http_get(url, headers=None):\n    try:\n        if PY3:\n            import urllib.request, ssl\n            req = urllib.request.Request(url, headers=headers or {})\n            ctx = ssl._create_unverified_context()\n            with urllib.request.urlopen(req, context=ctx, timeout=6) as r:\n                return r.status, r.read().decode(\"utf-8\")\n        else:\n            import urllib2\n            req = urllib2.Request(url, headers=headers or {})\n            r   = urllib2.urlopen(req, timeout=6)\n            return r.getcode(), r.read()\n    except Exception:\n        return None, None\n\ndef read_cached_etag(tools_dir):\n    path = os.path.join(tools_dir, ETAG_FILE)\n    if os.path.exists(path):\n        with open(path, \"r\", encoding=\"utf-8\") as f:\n            return f.read().strip()\n    return None\n\ndef write_cached_etag(tools_dir, etag):\n    path = os.path.join(tools_dir, ETAG_FILE)\n    with open(path, \"w\", encoding=\"utf-8\") as f:\n        f.write(etag)\n\ndef get_remote_etag():\n    import json\n    status, body = http_get(ETAG_URL, headers={\"User-Agent\": \"PhoenixTools-Maya\"})\n    if status == 200 and body:\n        try:\n            return json.loads(body).get(\"sha\", \"\")\n        except Exception:\n            pass\n    return None\n\ndef read_cached_script(tools_dir):\n    path = os.path.join(tools_dir, TOOL_FILE)\n    if os.path.exists(path):\n        with open(path, \"r\", encoding=\"utf-8\") as f:\n            return f.read()\n    return None\n\ndef write_cached_script(tools_dir, code):\n    path = os.path.join(tools_dir, TOOL_FILE)\n    with open(path, \"w\", encoding=\"utf-8\") as f:\n        f.write(code)\n\ndef run_script(tools_dir, code):\n    if tools_dir not in sys.path:\n        sys.path.insert(0, tools_dir)\n    exec(compile(code, os.path.join(tools_dir, TOOL_FILE), \"exec\"),\n         {\"__file__\": os.path.join(tools_dir, TOOL_FILE)})\n\ndef reopen_tool(tools_dir):\n    \"\"\"Re-executes the updated script on the main thread via evalDeferred.\"\"\"\n    code = read_cached_script(tools_dir)\n    if code:\n        try:\n            run_script(tools_dir, code)\n        except Exception as e:\n            cmds.warning(\"[PhoenixTools] Error on reopen: \" + str(e))\n\ndef check_for_update(tools_dir, cached_etag):\n    \"\"\"Runs in background thread. Downloads update and auto-reopens if found.\"\"\"\n    remote_etag = get_remote_etag()\n\n    if not remote_etag:\n        # Offline — nothing to do, cached version already running\n        return\n\n    if remote_etag == cached_etag:\n        # Up to date — nothing to do\n        return\n\n    # -- Update found ----------------------------------------------------------\n    status, code = http_get(RAW_URL)\n    if status != 200 or not code:\n        cmds.evalDeferred(\n            \"import maya.cmds as cmds; cmds.warning('[PhoenixTools] Update download failed.')\"\n        )\n        return\n\n    write_cached_script(tools_dir, code)\n    write_cached_etag(tools_dir, remote_etag)\n\n    # Toast: update found, reopening\n    cmds.evalDeferred(\n        \"import maya.cmds as cmds; cmds.inViewMessage(\"\n        \"amg=\\\"<span style='color:#7DF7B4'>\\u2605 Phoenix Set Tools \\u2014 Update found, reopening...</span>\\\",\"\n        \"pos='topCenter', fade=True, fst=1200)\"\n    )\n\n    # Wait for toast to be readable, then reopen on main thread\n    time.sleep(1.5)\n\n    # Store tools_dir in a known global so evalDeferred can reach it\n    import __main__\n    __main__.__phoenix_tools_dir__ = tools_dir\n\n    cmds.evalDeferred(\n        \"import __main__, maya.cmds as cmds\\n\"\n        \"from __main__ import __phoenix_tools_dir__ as _d\\n\"\n        \"import os, sys\\n\"\n        \"def _run():\\n\"\n        \"    p = os.path.join(_d, 'phoenix-set-tools.py')\\n\"\n        \"    with open(p, 'r', encoding='utf-8') as f:\\n\"\n        \"        code = f.read()\\n\"\n        \"    if _d not in sys.path:\\n\"\n        \"        sys.path.insert(0, _d)\\n\"\n        \"    exec(compile(code, p, 'exec'), {'__file__': p})\\n\"\n        \"_run()\"\n    )\n\ndef load_phoenix_tools():\n    tools_dir   = get_tools_dir()\n    cached_code = read_cached_script(tools_dir)\n    cached_etag = read_cached_etag(tools_dir)\n\n    if cached_code:\n        # -- Run instantly from cache -------------------------------------------\n        try:\n            run_script(tools_dir, cached_code)\n        except Exception as e:\n            cmds.error(\"[PhoenixTools] Error running script: \" + str(e))\n            return\n\n        # -- Background update check --------------------------------------------\n        t = threading.Thread(target=check_for_update, args=(tools_dir, cached_etag))\n        t.daemon = True\n        t.start()\n\n    else:\n        # -- First time / no cache — must download -----------------------------\n        cmds.inViewMessage(\n            amg=\"<span style='color:#F7C97D'>\\u23F3 Phoenix Set Tools \\u2014 First run, downloading...</span>\",\n            pos=\"topCenter\", fade=True, fst=800\n        )\n        remote_etag = get_remote_etag()\n        if remote_etag:\n            status, code = http_get(RAW_URL)\n            if status == 200 and code:\n                write_cached_script(tools_dir, code)\n                write_cached_etag(tools_dir, remote_etag)\n                try:\n                    run_script(tools_dir, code)\n                    cmds.inViewMessage(\n                        amg=\"<span style='color:#7DF7B4'>\\u2713 Phoenix Set Tools \\u2014 Ready</span>\",\n                        pos=\"topCenter\", fade=True, fst=600\n                    )\n                except Exception as e:\n                    cmds.error(\"[PhoenixTools] Error running script: \" + str(e))\n            else:\n                cmds.error(\"[PhoenixTools] Download failed. Check your internet connection.\")\n        else:\n            cmds.error(\"[PhoenixTools] Offline and no cached script found. Connect to internet and try once.\")\n\nload_phoenix_tools()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
