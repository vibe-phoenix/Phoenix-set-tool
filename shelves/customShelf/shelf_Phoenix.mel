        -command "import maya.cmds as cmds\n\ndef toggle_selection_highlighting_current():\n    p = cmds.getPanel(withFocus=True)\n    if p and cmds.getPanel(typeOf=p) == 'modelPanel':\n        cur = cmds.modelEditor(p, q=True, sel=True)\n        cmds.modelEditor(p, e=True, sel=not cur)\n    else:\n        cmds.warning(\"Focus a viewport (modelPanel) first.\")\n\ntoggle_selection_highlighting_current()\n" 
