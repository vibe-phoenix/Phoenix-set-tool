        -command "import maya.cmds as cmds\nimport maya.mel as mel\n\nWIN_TITLE = \"Viewport View Switcher\"\nWC_NAME   = \"phoenix_viewSwitcherWC\"\nUI_ROOT   = \"phoenix_viewSwitcherUI\"\nSCENE_CAM_COL = \"phoenix_sceneCameraColumn\"\n\nEXCLUDE_CAM_XFORMS = {\"persp\", \"top\", \"front\", \"side\", \"left\", \"right\"}\n\n\n# -------------------------\n# Outliner reorder (NOT parenting)\n# -------------------------\n\ndef reorder_after(node, after_node):\n    if not cmds.objExists(node) or not cmds.objExists(after_node):\n        return\n\n    node_parent  = (cmds.listRelatives(node, parent=True, fullPath=True) or [None])[0]\n    after_parent = (cmds.listRelatives(after_node, parent=True, fullPath=True) or [None])[0]\n    if node_parent != after_parent:\n        return\n\n    def _siblings():\n        return cmds.ls(assemblies=True) if node_parent is None else (cmds.listRelatives(node_parent, children=True, fullPath=False) or [])\n\n    sib = _siblings()\n    if node not in sib or after_node not in sib:\n        return\n\n    try:\n        cmds.reorder(node, back=True)\n    except:\n        return\n\n    safety = 500\n    while safety > 0:\n        sib = _siblings()\n        if node not in sib or after_node not in sib:\n            break\n        target_index = sib.index(after_node) + 1\n        if sib.index(node) == target_index:\n            break\n        try:\n            cmds.reorder(node, front=True)\n        except:\n            break\n        safety -= 1\n\n\n# -------------------------\n# Active viewport (modelPanel)\n# -------------------------\n\ndef _active_model_panel():\n    try:\n        p = cmds.playblast(activeEditor=True)\n        if p and cmds.getPanel(typeOf=p) == \"modelPanel\":\n            return p\n    except:\n        pass\n\n    p = cmds.getPanel(withFocus=True)\n    if p and cmds.getPanel(typeOf=p) == \"modelPanel\":\n        return p\n\n    for vp in (cmds.getPanel(visiblePanels=True) or []):\n        if cmds.getPanel(typeOf=vp) == \"modelPanel\":\n            return vp\n\n    return None\n\n\ndef _focus_panel(panel):\n    try:\n        cmds.setFocus(panel)\n    except:\n        pass\n\n\ndef _update_model_panel_bar(panel):\n    try:\n        mel.eval('updateModelPanelBar \"%s\";' % panel)\n    except:\n        pass\n\n\n# -------------------------\n# Views (viewSet)\n# -------------------------\n\ndef _viewset(which):\n    panel = _active_model_panel()\n    if not panel:\n        cmds.warning(\"No active viewport (modelPanel) found. Click inside a viewport first.\")\n        return\n    _focus_panel(panel)\n    try:\n        mel.eval('viewSet -%s;' % which)\n    except Exception as e:\n        cmds.warning(\"viewSet -%s failed: %s\" % (which, e))\n    _update_model_panel_bar(panel)\n\n\n# -------------------------\n# Look Through (Selected Camera)\n# -------------------------\n\ndef _camera_transform_from_selection():\n    sel = cmds.ls(selection=True, long=True) or []\n    if not sel:\n        return None\n\n    node = sel[0]\n    ntype = cmds.nodeType(node)\n\n    if ntype == \"camera\":\n        parent = cmds.listRelatives(node, parent=True, fullPath=True) or []\n        return parent[0] if parent else None\n\n    if ntype == \"transform\":\n        shapes = cmds.listRelatives(node, shapes=True, type=\"camera\", fullPath=True) or []\n        return node if shapes else None\n\n    return None\n\n\ndef look_through_selected():\n    panel = _active_model_panel()\n    if not panel:\n        cmds.warning(\"No active viewport (modelPanel) found. Click inside a viewport first.\")\n        return\n\n    cam_xform = _camera_transform_from_selection()\n    if not cam_xform:\n        sel = cmds.ls(selection=True, long=True) or []\n        if sel:\n            cmds.warning(\"'%s' is not a camera transform (select a camera).\" % sel[0])\n        else:\n            cmds.warning(\"Nothing selected. Select a camera to look through.\")\n        return\n\n    _focus_panel(panel)\n    try:\n        cmds.lookThru(panel, cam_xform)\n        _update_model_panel_bar(panel)\n    except Exception as e:\n        cmds.warning(\"lookThru failed: %s\" % e)\n\n\n# -------------------------\n# Left / Right cameras fallback (creates left/right if needed)\n# -------------------------\n\ndef _has_dR_DoCmd():\n    try:\n        return bool(mel.eval('exists dR_DoCmd'))\n    except:\n        return False\n\n\ndef _do_dR(view_token):\n    panel = _active_model_panel()\n    if not panel:\n        return False\n    _focus_panel(panel)\n    try:\n        mel.eval('dR_DoCmd(\"%s\");' % view_token)\n        _update_model_panel_bar(panel)\n        return True\n    except:\n        return False\n\n\ndef _ensure_lr_cameras_and_reorder():\n    dist = 100.0\n    if cmds.objExists(\"side\"):\n        try:\n            dist = abs(cmds.getAttr(\"side.translateX\"))\n            if dist < 0.001:\n                dist = 100.0\n        except:\n            dist = 100.0\n\n    def _make_ortho(name, tx, ry):\n        if cmds.objExists(name):\n            shapes = cmds.listRelatives(name, shapes=True, fullPath=True) or []\n            if not shapes or cmds.nodeType(shapes[0]) != \"camera\":\n                cmds.warning(\"'%s' exists but is not a camera transform.\" % name)\n                return None\n            cam_shape = shapes[0]\n            try:\n                cmds.setAttr(cam_shape + \".orthographic\", 1)\n            except:\n                pass\n            try:\n                cmds.setAttr(name + \".translateX\", tx)\n                cmds.setAttr(name + \".translateY\", 0)\n                cmds.setAttr(name + \".translateZ\", 0)\n            except:\n                pass\n            try:\n                cmds.setAttr(name + \".rotateX\", 0)\n                cmds.setAttr(name + \".rotateY\", ry)\n                cmds.setAttr(name + \".rotateZ\", 0)\n            except:\n                pass\n            return name\n\n        cam_x, cam_s = cmds.camera(name=name)\n        try:\n            cmds.setAttr(cam_s + \".orthographic\", 1)\n        except:\n            pass\n        try:\n            cmds.setAttr(cam_x + \".translateX\", tx)\n            cmds.setAttr(cam_x + \".translateY\", 0)\n            cmds.setAttr(cam_x + \".translateZ\", 0)\n        except:\n            pass\n        try:\n            cmds.setAttr(cam_x + \".rotateX\", 0)\n            cmds.setAttr(cam_x + \".rotateY\", ry)\n            cmds.setAttr(cam_x + \".rotateZ\", 0)\n        except:\n            pass\n        return cam_x\n\n    left_cam  = _make_ortho(\"left\",  -dist,  90)\n    right_cam = _make_ortho(\"right\",  dist, -90)\n\n    if left_cam and cmds.objExists(\"side\"):\n        reorder_after(left_cam, \"side\")\n    if right_cam and left_cam:\n        reorder_after(right_cam, left_cam)\n\n\ndef _set_viewport_camera(cam_xform):\n    panel = _active_model_panel()\n    if not panel:\n        cmds.warning(\"No active viewport (modelPanel) found. Click inside a viewport first.\")\n        return\n    if not cmds.objExists(cam_xform):\n        cmds.warning(\"Camera not found: %s\" % cam_xform)\n        return\n\n    _focus_panel(panel)\n    try:\n        cmds.modelPanel(panel, e=True, camera=cam_xform)\n        _update_model_panel_bar(panel)\n    except Exception as e:\n        cmds.warning(\"Failed to set camera: %s\" % e)\n\n\ndef _left_view():\n    if _has_dR_DoCmd() and _do_dR(\"viewLeft\"):\n        return\n    _ensure_lr_cameras_and_reorder()\n    _set_viewport_camera(\"left\")\n\n\ndef _right_view():\n    if _has_dR_DoCmd() and _do_dR(\"viewRight\"):\n        return\n    _ensure_lr_cameras_and_reorder()\n    _set_viewport_camera(\"right\")\n\n\n# -------------------------\n# Backface Culling (selection) -> <shape>.backfaceCulling\n# -------------------------\n\ndef _selected_shapes():\n    sel = cmds.ls(sl=True, long=True) or []\n    if not sel:\n        return []\n\n    shapes = []\n    for node in sel:\n        ntype = cmds.nodeType(node)\n        if ntype in (\"mesh\", \"nurbsSurface\", \"subdiv\", \"nurbsCurve\"):\n            shapes.append(node)\n        elif ntype == \"transform\":\n            sh = cmds.listRelatives(node, shapes=True, fullPath=True) or []\n            shapes.extend(sh)\n\n    out, seen = [], set()\n    for s in shapes:\n        if s and cmds.objExists(s) and s not in seen:\n            out.append(s)\n            seen.add(s)\n    return out\n\n\ndef _set_backface_attr_selected(value):\n    shapes = _selected_shapes()\n    if not shapes:\n        cmds.warning(\"Select objects first.\")\n        return\n\n    changed = 0\n    for s in shapes:\n        if cmds.attributeQuery(\"backfaceCulling\", node=s, exists=True):\n            try:\n                cmds.setAttr(s + \".backfaceCulling\", int(value))\n                changed += 1\n            except:\n                pass\n\n    if changed == 0:\n        cmds.warning(\"No selected shapes had a writable 'backfaceCulling' attribute.\")\n\n\n# -------------------------\n# Scene Cameras list\n# -------------------------\n\ndef _list_scene_camera_transforms():\n    cam_shapes = cmds.ls(type=\"camera\") or []\n    xforms = []\n    for shp in cam_shapes:\n        parents = cmds.listRelatives(shp, parent=True) or []\n        if not parents:\n            continue\n        x = parents[0]\n        if x in EXCLUDE_CAM_XFORMS:\n            continue\n        xforms.append(x)\n    return sorted(set(xforms))\n\n\ndef _rebuild_scene_camera_buttons():\n    if not cmds.control(SCENE_CAM_COL, exists=True):\n        return\n\n    kids = cmds.columnLayout(SCENE_CAM_COL, q=True, childArray=True) or []\n    for k in kids:\n        try:\n            cmds.deleteUI(k)\n        except:\n            pass\n\n    cams = _list_scene_camera_transforms()\n    if not cams:\n        cmds.text(label=\"No extra scene cameras found.\", align=\"left\", parent=SCENE_CAM_COL)\n        return\n\n    for cam in cams:\n        cmds.button(\n            label=cam,\n            height=26,\n            parent=SCENE_CAM_COL,\n            command=lambda *_ , c=cam: _set_viewport_camera(c)\n        )\n\n\n# -------------------------\n# UI helpers\n# -------------------------\n\ndef _section_header(parent, text):\n    cmds.rowLayout(parent=parent, numberOfColumns=2, adjustableColumn=1, columnAlign2=(\"left\", \"right\"))\n    cmds.text(label=text, align=\"left\")\n    cmds.separator(style=\"none\", w=1)  # spacer\n    cmds.setParent(parent)\n\n\ndef _two_col_buttons(parent, left_label, left_cmd, right_label, right_cmd, h=30):\n    cmds.rowLayout(parent=parent, numberOfColumns=2, adjustableColumn=1, columnWidth2=(240, 240), columnAttach=[(1, \"both\", 0), (2, \"both\", 0)], columnAlign2=(\"center\", \"center\"))\n    cmds.button(label=left_label, height=h, command=left_cmd)\n    cmds.button(label=right_label, height=h, command=right_cmd)\n    cmds.setParent(parent)\n\n\n# -------------------------\n# Build UI\n# -------------------------\n\ndef build_ui():\n    if cmds.workspaceControl(WC_NAME, exists=True):\n        try:\n            cmds.deleteUI(WC_NAME)\n        except:\n            pass\n\n    cmds.workspaceControl(WC_NAME, label=WIN_TITLE, retain=False, floating=True, widthProperty=\"preferred\")\n\n    root = cmds.columnLayout(UI_ROOT, adjustableColumn=True, rowSpacing=8, parent=WC_NAME)\n\n    # ---- Views ----\n    cmds.frameLayout(labelVisible=False, collapsable=False, marginWidth=8, marginHeight=8, parent=root)\n    _section_header(cmds.setParent(q=True), \"Views\")\n\n    cmds.button(label=\"Perspective\", height=32, command=lambda *_: _viewset(\"persp\"))\n    _two_col_buttons(cmds.setParent(q=True), \"Front\", lambda *_: _viewset(\"front\"), \"Back\", lambda *_: _viewset(\"back\"))\n    _two_col_buttons(cmds.setParent(q=True), \"Left\",  lambda *_: _left_view(),      \"Right\", lambda *_: _right_view())\n    _two_col_buttons(cmds.setParent(q=True), \"Top\",   lambda *_: _viewset(\"top\"),   \"Bottom\", lambda *_: _viewset(\"bottom\"))\n\n    cmds.button(label=\"Look Through (Selected Camera)\", height=32, command=lambda *_: look_through_selected())\n    cmds.setParent(root)\n\n    # ---- Backface ----\n    cmds.frameLayout(labelVisible=False, collapsable=False, marginWidth=8, marginHeight=8, parent=root)\n    _section_header(cmds.setParent(q=True), \"Backface Culling (Selection)\")\n    _two_col_buttons(\n        cmds.setParent(q=True),\n        \"Full\", lambda *_: _set_backface_attr_selected(3),\n        \"Off\",  lambda *_: _set_backface_attr_selected(0),\n        h=28\n    )\n    cmds.setParent(root)\n\n    # ---- Scene Cameras ----\n    cmds.frameLayout(labelVisible=False, collapsable=False, marginWidth=8, marginHeight=8, parent=root)\n    cmds.rowLayout(numberOfColumns=2, adjustableColumn=1, columnAlign2=(\"left\", \"right\"))\n    cmds.text(label=\"Scene Cameras\", align=\"left\")\n    cmds.button(label=\"Refresh\", height=24, command=lambda *_: _rebuild_scene_camera_buttons())\n    cmds.setParent(cmds.setParent(q=True))  # back to frame\n\n    cmds.scrollLayout(childResizable=True, height=180)\n    cmds.columnLayout(SCENE_CAM_COL, adjustableColumn=True, rowSpacing=4)\n    _rebuild_scene_camera_buttons()\n\n    # back up\n    cmds.setParent(root)\n\n    return WC_NAME\n\n\n# Run\nbuild_ui()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "align to floor vertically" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "align to floor vertically" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
