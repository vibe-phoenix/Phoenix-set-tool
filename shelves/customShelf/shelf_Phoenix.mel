        -command "import maya.cmds as cmds\n\ndef create_aiLayerShader():\n    # Create Arnold Layer Shader\n    layer_shader = cmds.shadingNode(\"aiLayerShader\", asShader=True, name=\"aiLayerShader1\")\n\n    # Create a Shading Engine for rendering assignment\n    sg = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=layer_shader + \"SG\")\n    cmds.connectAttr(layer_shader + \".outColor\", sg + \".surfaceShader\", f=True)\n\n    print(\"? Created:\", layer_shader, \"with SG:\", sg)\n    return layer_shader, sg\n\n\n# Run it\ncreate_aiLayerShader()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
