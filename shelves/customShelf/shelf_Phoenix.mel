        -command "import maya.mel as mel\ntry:\n    from PySide6 import QtWidgets, QtCore, QtGui\n    import maya.OpenMayaUI as omui\n    from shiboken6 import wrapInstance\nexcept ImportError:\n    from PySide2 import QtWidgets, QtCore, QtGui\n    import maya.OpenMayaUI as omui\n    from shiboken2 import wrapInstance\n\ndef create_aiNormalMap():\n    # Focus the hypershade node editor first\n    ptr = omui.MQtUtil.findControl(\"hyperShadePrimaryNodeEditor\")\n    if ptr:\n        widget = wrapInstance(int(ptr), QtWidgets.QWidget)\n        widget.setFocus(QtCore.Qt.MouseFocusReason)\n\n    mel.eval('hyperShadePanelKeyPressCmd \"hyperShadePrimaryNodeEditor\" \"Tab\"')\n    mel.eval('lookdevNodeTypes({\"aiNormalMap\"})')\n    mel.eval('nodeEdCreateNodeCommand \"aiNormalMap\"')\n    mel.eval('hyperShadePanelKeyReleaseCmd \"hyperShadePrimaryNodeEditor\" \"Return\"')\n\n    widget = QtWidgets.QApplication.focusWidget()\n    if widget:\n        event = QtGui.QKeyEvent(QtCore.QEvent.KeyPress, QtCore.Qt.Key_Escape, QtCore.Qt.NoModifier)\n        QtWidgets.QApplication.sendEvent(widget, event)\n\ncreate_aiNormalMap()" 
