        -preventOverride 0
        -annotation "spherify" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "spherify" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "spherify" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "sphere.png" 
        -image1 "sphere.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport math\n\ndef spherify_auto_average():\n    \"\"\"\n    Pushes all verts of selected mesh toward a sphere automatically.\n    - Sphere center: bounding box center.\n    - Sphere radius: average of the three bounding box extents / 2.\n    Works on the whole mesh or only on selected vertices.\n    \"\"\"\n    sel = cmds.ls(sl=True, long=True) or []\n    if not sel:\n        cmds.error(\"Select a mesh or its vertices.\")\n\n    # Get transform node\n    if \".\" in sel[0]:\n        transform = sel[0].split(\".\")[0]\n    else:\n        transform = sel[0]\n\n    # Verify mesh shape\n    shapes = cmds.listRelatives(transform, shapes=True, noIntermediate=True, fullPath=True) or []\n    shapes = [s for s in shapes if cmds.nodeType(s) == \"mesh\"]\n    if not shapes:\n        cmds.error(\"Selection does not contain a mesh: {}\".format(transform))\n\n    # Bounding box center and extents\n    xmin, ymin, zmin, xmax, ymax, zmax = cmds.exactWorldBoundingBox(transform)\n    center = ((xmin + xmax) * 0.5, (ymin + ymax) * 0.5, (zmin + zmax) * 0.5)\n    sx, sy, sz = (xmax - xmin, ymax - ymin, zmax - zmin)\n\n    # Average radius\n    radius = 0.5 * ( (sx + sy + sz) / 3.0 )\n\n    # Vertex list (selected verts or all verts)\n    sel_verts = cmds.ls(sel, fl=True, long=True)\n    verts = [v for v in sel_verts if \".vtx[\" in v]\n    if not verts:\n        verts = cmds.ls(transform + \".vtx[*]\", fl=True, long=True)\n\n    if not verts:\n        cmds.error(\"No vertices found to spherify.\")\n\n    # Move vertices to sphere\n    cmds.undoInfo(openChunk=True)\n    try:\n        cx, cy, cz = center\n        for v in verts:\n            pos = cmds.pointPosition(v, w=True)\n            dx, dy, dz = pos[0] - cx, pos[1] - cy, pos[2] - cz\n            length = math.sqrt(dx*dx + dy*dy + dz*dz)\n            if length > 1e-12:\n                k = radius / length\n                new_pos = (cx + dx*k, cy + dy*k, cz + dz*k)\n                cmds.xform(v, ws=True, t=new_pos)\n    finally:\n        cmds.undoInfo(closeChunk=True)\n\n    print(\"Spherified '{}' to radius {:.4f} (avg of bbox) with {} vertices.\"\n          .format(transform, radius, len(verts)))\n\n# --- USAGE ---\n# Select your mesh or its vertices and run:\nspherify_auto_average()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
