        -image1 "blinn.svg" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef assign_test_blinn():\n    # --- 0) Remember the original selection exactly as-is ---\n    original_sel = cmds.ls(sl=True, long=True) or []\n    if not original_sel:\n        cmds.warning(\"Select objects or components to assign 'test_blinn'.\")\n        return\n\n    shader = \"testBlinn_shd\"   # blinn node name\n    sg     = \"test_blinn\"      # shadingEngine (SG) name\n\n    # --- 1) Create/ensure shader & SG ---\n    if not cmds.objExists(shader):\n        shader = cmds.shadingNode(\"blinn\", asShader=True, name=shader)\n    if not cmds.objExists(sg):\n        sg = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=sg)\n\n    # --- 2) Force-connect shader -> SG.surfaceShader ---\n    surf_attr = sg + \".surfaceShader\"\n    out_attr  = shader + \".outColor\"\n    # Disconnect any existing surfaceShader inputs, then connect ours\n    for p in cmds.listConnections(surf_attr, plugs=True, s=True, d=False) or []:\n        try:\n            cmds.disconnectAttr(p, surf_attr)\n        except:\n            pass\n    if not cmds.isConnected(out_attr, surf_attr):\n        cmds.connectAttr(out_attr, surf_attr, f=True)\n\n    # --- 3) Set shader attributes (HSV S=0, V=0.022 => RGB 0.022) ---\n    cmds.setAttr(shader + \".color\", 0.022, 0.022, 0.022, type=\"double3\")   # dark grey\n    cmds.setAttr(shader + \".specularColor\", 1.0, 1.0, 1.0, type=\"double3\") # pure white\n    cmds.setAttr(shader + \".reflectivity\", 1.0)\n\n    # --- 4) Build assignment targets from the ORIGINAL selection ---\n    targets = []\n\n    # If component selection, assign directly to those components\n    comp_sel = [s for s in original_sel if \".\" in s]\n    if comp_sel:\n        targets.extend(comp_sel)\n\n    # For transforms/shapes, find non-intermediate renderable shapes\n    xforms_or_shapes = [s for s in original_sel if \".\" not in s]\n    if xforms_or_shapes:\n        shapes = []\n        for s in xforms_or_shapes:\n            if cmds.objectType(s, isAType=\"shape\"):\n                shapes.append(s)\n            else:\n                shapes += cmds.listRelatives(s, s=True, ni=True, f=True) or []\n        valid_types = {\"mesh\", \"nurbsSurface\", \"subdiv\", \"nurbsCurve\"}\n        shapes = [sh for sh in shapes if cmds.objectType(sh) in valid_types]\n        targets.extend(shapes)\n\n    if not targets:\n        cmds.warning(\"No valid shapes/components found under the original selection.\")\n        return\n\n    # --- 5) Assign the SG to targets ---\n    try:\n        cmds.sets(targets, e=True, forceElement=sg)\n    except Exception as e:\n        cmds.warning(\"Assignment failed: {}\".format(e))\n        return\n\n    # --- 6) Restore original selection (optional, for user convenience) ---\n    try:\n        cmds.select(original_sel, r=True)\n    except:\n        pass\n\n    # --- 7) Quick verify & notify ---\n    # Check a few shapes for SG membership\n    check_shapes = [t for t in targets if cmds.objectType(t, isAType=\"shape\")]\n    verified = True\n    if check_shapes:\n        for sh in check_shapes[:5]:\n            if sg not in (cmds.listConnections(sh, type=\"shadingEngine\") or []):\n                verified = False\n                break\n\n\n\nassign_test_blinn()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
