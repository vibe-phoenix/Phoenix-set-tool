        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef phx_strip_namespace_and_rename_to_namespace(use_full_namespace=False,\n                                                attr_name='phoenix_origNamespace',\n                                                rename_shapes=True):\n    \"\"\"\n    For each selected item:\n      - Records its namespace to an attribute.\n      - Removes that namespace from the Namespace Editor.\n      - Renames the transform to its namespace text.\n      - Optionally renames child shapes to <TransformName>Shape.\n    \"\"\"\n    sel = cmds.ls(sl=True, long=True) or []\n    if not sel:\n        cmds.warning(\"Select one or more objects and run again.\")\n        return\n\n    def to_transform(n):\n        if cmds.nodeType(n) in ('mesh','nurbsCurve','nurbsSurface','locator','camera'):\n            p = cmds.listRelatives(n, parent=True, fullPath=True) or []\n            return p[0] if p else n\n        return n\n\n    transforms = list({to_transform(n) for n in sel})\n\n    records = []\n    namespaces_to_remove = set()\n\n    for t in transforms:\n        if not cmds.objExists(t):\n            continue\n        short = cmds.ls(t, shortNames=True)[0]\n\n        if ':' in short:\n            full_ns = short.rsplit(':', 1)[0]\n            last_seg = full_ns.split(':')[-1]\n            ns_abs = ':' + full_ns\n            namespaces_to_remove.add(ns_abs)\n        else:\n            full_ns = ''\n            last_seg = ''\n\n        uuid_val = cmds.ls(t, uuid=True)[0]  # ? fixed: boolean arg\n        records.append({\n            'uuid': uuid_val,\n            'orig_node': t,\n            'full_ns': full_ns,\n            'last_seg': last_seg\n        })\n\n    if not namespaces_to_remove:\n        cmds.warning(\"No namespaces found on the selected objects.\")\n        return\n\n    cmds.undoInfo(openChunk=True)\n    try:\n        for r in records:\n            t = r['orig_node']\n            if not cmds.objExists(t):\n                continue\n            if not cmds.attributeQuery(attr_name, node=t, exists=True):\n                cmds.addAttr(t, ln=attr_name, dt='string')\n            cmds.setAttr(f\"{t}.{attr_name}\", r['full_ns'], type='string')\n\n        for ns_abs in sorted(list(namespaces_to_remove), key=lambda s: s.count(':'), reverse=True):\n            if not cmds.namespace(exists=ns_abs):\n                continue\n            try:\n                cmds.namespace(removeNamespace=ns_abs, mergeNamespaceWithRoot=True)\n            except:\n                try:\n                    cmds.namespace(moveNamespace=(ns_abs, ':'), force=True)\n                    cmds.namespace(removeNamespace=ns_abs, mergeNamespaceWithRoot=True)\n                except:\n                    pass\n\n        for r in records:\n            full_ns = r['full_ns']\n            if not full_ns:\n                continue\n\n            paths = cmds.ls(r['uuid'], uuid=True) or []\n            t_now = paths[0] if paths else None\n            if not t_now or not cmds.objExists(t_now):\n                continue\n\n            desired = (r['full_ns'].replace(':', '_') if use_full_namespace else r['last_seg'])\n            final_name = desired\n            if cmds.objExists(final_name):\n                i = 1\n                while cmds.objExists(f\"{desired}_{i}\"):\n                    i += 1\n                final_name = f\"{desired}_{i}\"\n\n            t_now = cmds.rename(t_now, final_name)\n\n            if rename_shapes:\n                shapes = cmds.listRelatives(t_now, shapes=True, fullPath=False) or []\n                for idx, s in enumerate(shapes):\n                    base_name = f\"{final_name}Shape\" if idx == 0 else f\"{final_name}Shape{idx}\"\n                    if cmds.objExists(base_name):\n                        j = 1\n                        while cmds.objExists(f\"{base_name}_{j}\"):\n                            j += 1\n                        base_name = f\"{base_name}_{j}\"\n                    cmds.rename(s, base_name)\n\n        \n\n    finally:\n        cmds.undoInfo(closeChunk=True)\n\n# Run directly\nphx_strip_namespace_and_rename_to_namespace()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "remove namespace" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "R-NS" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "R-NS" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "text.png" 
        -image1 "text.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef _split_ns_and_base(short_name):\n    \"\"\"Return (namespace_path, base). 'a:b:c' -> ('a:b','c'); 'c' -> (None,'c').\"\"\"\n    if ':' not in short_name:\n        return (None, short_name)\n    return short_name.rsplit(':', 1)\n\ndef _ensure_ns_colon(ns):\n    return (':' + ns) if (ns and not ns.startswith(':')) else ns\n\ndef _unique_rename(current, target):\n    \"\"\"Rename current to target. If taken, use Maya's increment style.\"\"\"\n    if current == target:\n        return current\n    if not cmds.objExists(target):\n        return cmds.rename(current, target)\n    return cmds.rename(current, cmds.incrementName(target))\n\ndef _namespace_is_empty(ns):\n    \"\"\"Return True if the namespace has no nodes and no child namespaces.\"\"\"\n    ns = _ensure_ns_colon(ns)\n    if not ns or not cmds.namespace(exists=ns):\n        return True\n    # Any child namespaces?\n    children = cmds.namespaceInfo(ns, listNamespace=True) or []\n    if children:\n        return False\n    # Any dependency nodes?\n    deps = cmds.namespaceInfo(ns, listOnlyDependencyNodes=True, dagPath=True) or []\n    return len(deps) == 0\n\ndef strip_ns_on_selected_only_and_cleanup():\n    sel = cmds.ls(sl=True, long=True) or []\n    if not sel:\n        cmds.warning(\"Select one or more objects to rename.\")\n        return\n\n    results = []\n    touched_namespaces = set()\n\n    # 1) Rename ONLY the selected nodes\n    for node in sel:\n        if not cmds.objExists(node):\n            results.append((node, \"<missing>\", \"Skipped (no longer exists)\"))\n            continue\n\n        short = node.split('|')[-1]\n        ns_path, base = _split_ns_and_base(short)\n\n        if ns_path is None:\n            results.append((node, short, \"No namespace ? unchanged\"))\n            continue\n\n        try:\n            new_name = _unique_rename(short, base)\n            results.append((node, new_name, f\"Renamed to '{base}'\"))\n            touched_namespaces.add(ns_path)\n        except RuntimeError as e:\n            results.append((node, short, \"Rename failed: \" + str(e)))\n\n    # 2) Try to delete ONLY the namespaces we touched — but ONLY if empty\n    ns_report = []\n    # Deepest-first so ':A:B' is attempted before ':A'\n    for ns in sorted(touched_namespaces, key=lambda s: (s.count(':'), len(s)), reverse=True):\n        ns_full = _ensure_ns_colon(ns)\n        try:\n            if cmds.namespace(exists=ns_full) and _namespace_is_empty(ns):\n                cmds.namespace(removeNamespace=ns_full, mergeNamespaceWithRoot=True)\n                ns_report.append((ns, \"Deleted (was empty)\"))\n            else:\n                ns_report.append((ns, \"Kept (not empty)\"))\n        except RuntimeError as e:\n            ns_report.append((ns, \"Delete failed: \" + str(e)))\n\n    # 3) Report\n    print(\"=== Selected-Only Namespace Strip Report ===\")\n    for src, dst, status in results:\n        print(\"{:<60} -> {:<30} [{}]\".format(src, dst, status))\n\n    print(\"\\n=== Namespace Cleanup Report (only touched namespaces) ===\")\n    for ns, status in ns_report:\n        print(\"{:<30} [{}]\".format(ns, status))\n\n# Run\nstrip_ns_on_selected_only_and_cleanup()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
