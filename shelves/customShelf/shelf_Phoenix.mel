        -command "import maya.cmds as cmds\n\ndef select_root_group():\n    sel = cmds.ls(selection=True)\n    if not sel:\n        cmds.warning(\"Nothing selected.\")\n        return\n\n    roots = []\n    for obj in sel:\n        current = obj\n        while True:\n            parent = cmds.listRelatives(current, parent=True, fullPath=True)\n            if not parent:\n                break\n            current = parent[0]\n        roots.append(current)\n\n    cmds.select(roots, replace=True)\n\nselect_root_group()" 
