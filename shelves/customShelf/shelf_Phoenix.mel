        -command "import maya.cmds as cmds\n\ndef turn_off_uv_tiling_mode():\n    # Get selected file nodes\n    selected = cmds.ls(selection=True, type='file')\n\n    if not selected:\n        cmds.warning(\"No file nodes selected.\")\n        return\n\n    for node in selected:\n        try:\n            # Set UV Tiling Mode to Off\n            cmds.setAttr(f\"{node}.uvTilingMode\", 0)\n            print(f\"UV Tiling Mode turned off for: {node}\")\n        except Exception as e:\n            print(f\"Failed to update {node}: {e}\")\n\nturn_off_uv_tiling_mode()\n" 
