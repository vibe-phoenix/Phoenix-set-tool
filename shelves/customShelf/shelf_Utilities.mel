        -command "import maya.cmds as cmds\nimport os\n\nlight_rig_dir = r\"C:\\icons-phoenix\\light rig\"\n\nif not os.path.exists(light_rig_dir):\n    cmds.warning(\"Light rig folder does not exist.\")\nelse:\n    ma_files = [f for f in os.listdir(light_rig_dir) if f.endswith(\".ma\")]\n    if not ma_files:\n        cmds.warning(\"No .ma files found in light rig folder.\")\n    else:\n        # If only one file, import directly\n        if len(ma_files) == 1:\n            selected_file = os.path.join(light_rig_dir, ma_files[0])\n        else:\n            # Show option dialog\n            result = cmds.confirmDialog(\n                title='Choose Light Rig File',\n                message='Select a light rig to import:',\n                button=ma_files,\n                defaultButton=ma_files[0],\n                cancelButton=ma_files[-1],\n                dismissString=ma_files[-1]\n            )\n            selected_file = os.path.join(light_rig_dir, result) if result in ma_files else None\n\n        # Import the selected file\n        if selected_file and os.path.exists(selected_file):\n            try:\n                cmds.file(selected_file,\n                          i=True,\n                          type=\"mayaAscii\",\n                          ignoreVersion=True,\n                          ra=True,\n                          mergeNamespacesOnClash=True,\n                          namespace=\":\",\n                          options=\"v=0;\",\n                          pr=True)\n                cmds.inViewMessage(amg=f'?? Imported {os.path.basename(selected_file)}', pos='midCenterTop', fade=True)\n            except Exception as e:\n                cmds.warning(f\"Import failed: {e}\")\n        else:\n            cmds.warning(\"No file was selected or file no longer exists.\")\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
