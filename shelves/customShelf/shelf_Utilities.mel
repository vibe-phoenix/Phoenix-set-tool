        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef set_arnold_subdiv_catclark():\n    # --- Ask user for subdivision iterations ---\n    result = cmds.promptDialog(\n        title=\"Catclark Subdivision\",\n        message=\"Enter Catclark Subdivision Iterations (0–10 recommended):\",\n        button=[\"OK\", \"Cancel\"],\n        defaultButton=\"OK\",\n        cancelButton=\"Cancel\",\n        dismissString=\"Cancel\"\n    )\n\n    if result != \"OK\":\n        cmds.warning(\"Operation cancelled.\")\n        return\n\n    # Extract and validate\n    user_input = cmds.promptDialog(query=True, text=True).strip()\n\n    if not user_input.isdigit():\n        cmds.error(\"Please enter a valid integer.\")\n        return\n\n    iterations = int(user_input)\n\n    # --- Warning for high values ---\n    if iterations >= 5:\n        confirm = cmds.confirmDialog(\n            title=\"High Subdivision Warning\",\n            message=\"You entered {} iterations.\\nThis may slow down viewport & renders.\\nContinue?\".format(iterations),\n            button=[\"Yes\", \"No\"],\n            defaultButton=\"Yes\",\n            cancelButton=\"No\",\n            dismissString=\"No\"\n        )\n        if confirm != \"Yes\":\n            cmds.warning(\"Operation cancelled due to high iteration warning.\")\n            return\n\n    # --- Get selection ---\n    sel = cmds.ls(sl=True, long=True) or []\n    if not sel:\n        cmds.warning(\"Select one or more objects first.\")\n        return\n\n    # Load Arnold plugin if needed\n    try:\n        if not cmds.pluginInfo('mtoa', q=True, loaded=True):\n            cmds.loadPlugin('mtoa')\n    except:\n        pass\n\n    applied = 0\n\n    # --- Apply subdivision settings ---\n    for obj in sel:\n        shapes = cmds.listRelatives(obj, s=True, ni=True, f=True) or []\n        for s in shapes:\n            if cmds.nodeType(s) != 'mesh':\n                continue\n            if not cmds.attributeQuery('aiSubdivType', node=s, exists=True):\n                continue\n\n            # Get enum index for \"catclark\"\n            enum_str = cmds.attributeQuery('aiSubdivType', node=s, listEnum=True)[0]\n            options = enum_str.split(':')\n            idx = options.index('catclark') if 'catclark' in options else 1  # fallback\n\n            for attr, val in [('aiSubdivType', idx), ('aiSubdivIterations', iterations)]:\n                attr_full = s + '.' + attr\n                try:\n                    if cmds.getAttr(attr_full, l=True):  # unlock\n                        cmds.setAttr(attr_full, l=False)\n                    cmds.setAttr(attr_full, val)\n                except:\n                    pass\n\n            applied += 1\n\n    print(\"Arnold Subdivision set to 'catclark' (iterations = {}) on {} shape(s).\".format(iterations, applied))\n\n\n# Run\nset_arnold_subdiv_catclark()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
