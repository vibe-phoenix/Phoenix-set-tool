        -command "import maya.cmds as cmds\n\ndef set_uv_boundary_preserve():\n    # Get the selected objects\n    selection = cmds.ls(sl=True, long=True, dag=True, type=\"transform\")\n    if not selection:\n        cmds.warning(\"No objects selected.\")\n        return\n    \n    for obj in selection:\n        # Get shape nodes of the object\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n        for shape in shapes:\n            if cmds.objExists(shape + \".osdFvarBoundary\"):\n                try:\n                    cmds.setAttr(shape + \".osdFvarBoundary\", 1)\n                    print(\"Set UV boundary preserve on:\", shape)\n                except Exception as e:\n                    cmds.warning(\"Could not set attribute on {}: {}\".format(shape, e))\n\n# Run the function\nset_uv_boundary_preserve()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
