        -annotation "place 2d texture controls" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "place 2d texture controls" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "p2dCtrl" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\n\ntry:\n    from PySide6 import QtWidgets, QtCore\nexcept ImportError:\n    from PySide2 import QtWidgets, QtCore\n\n\nclass Place2DUniformUI(QtWidgets.QDialog):\n    def __init__(self, parent=None):\n        super().__init__(parent)\n\n        self.setWindowTitle(\"Uniform Place2D Tool\")\n        self.setWindowFlags(self.windowFlags() | QtCore.Qt.WindowStaysOnTopHint)\n        self.setMinimumWidth(420)\n\n        self.place_nodes = self._get_place_nodes()\n        if not self.place_nodes:\n            cmds.warning(\"Select place2dTexture or file nodes first.\")\n            self.close()\n            return\n\n        self.controls = {}\n\n        main_layout = QtWidgets.QVBoxLayout(self)\n        main_layout.setContentsMargins(10, 10, 10, 10)\n        main_layout.setSpacing(8)\n\n        # ---- REPEAT UV (uniform only) ----\n        self._add_section_label(main_layout, \"REPEAT UV (Uniform)\")\n        self._add_single_control(\n            main_layout,\n            key=\"repeatUV\",\n            min_val=1.0,\n            max_val=50.0,\n            default=1.0,\n        )\n\n        # ---- ROTATE UV ----\n        self._add_section_label(main_layout, \"ROTATE UV\")\n        self._add_single_control(\n            main_layout,\n            key=\"rotateUV\",\n            min_val=-360.0,\n            max_val=360.0,\n            default=0.0,\n        )\n\n        # ---- OFFSET (uniform / separate) ----\n        self._add_group_section(\n            main_layout,\n            group_key=\"offset\",\n            title=\"OFFSET\",\n            attrs=(\"offsetU\", \"offsetV\"),\n            min_val=-5.0,\n            max_val=5.0,\n            default=0.0,\n        )\n\n        # ---- NOISE (uniform / separate) ----\n        self._add_group_section(\n            main_layout,\n            group_key=\"noise\",\n            title=\"NOISE\",\n            attrs=(\"noiseU\", \"noiseV\"),\n            min_val=0.0,\n            max_val=5.0,\n            default=0.0,\n        )\n\n        # ---- ROTATE FRAME ----\n        self._add_section_label(main_layout, \"ROTATE FRAME\")\n        self._add_single_control(\n            main_layout,\n            key=\"rotateFrame\",\n            min_val=-360.0,\n            max_val=360.0,\n            default=0.0,\n        )\n\n        main_layout.addSpacing(8)\n\n        # Close button\n        close_btn = QtWidgets.QPushButton(\"Close\")\n        close_btn.clicked.connect(self.close)\n        main_layout.addWidget(close_btn, alignment=QtCore.Qt.AlignRight)\n\n        main_layout.addStretch(1)\n\n    # ---------------- UI BUILD HELPERS ----------------\n\n    def _add_section_label(self, layout, text):\n        label = QtWidgets.QLabel(text)\n        font = label.font()\n        font.setBold(True)\n        label.setFont(font)\n        layout.addWidget(label)\n\n    def _create_slider(self, min_val, max_val, default):\n        slider = QtWidgets.QSlider(QtCore.Qt.Horizontal)\n        slider.setRange(0, 1000)\n        slider.setValue(int((default - min_val) / (max_val - min_val) * 1000))\n        slider._min = min_val\n        slider._max = max_val\n        slider._lastVal = slider.value()\n\n        slider.sliderPressed.connect(self._start_undo)\n        slider.sliderReleased.connect(self._end_undo)\n\n        return slider\n\n    def _create_spinbox(self, min_val, max_val, default):\n        spin = QtWidgets.QDoubleSpinBox()\n        spin.setRange(min_val, max_val)\n        spin.setDecimals(3)\n        spin.setValue(default)\n        spin.setMinimumWidth(70)\n        spin.editingFinished.connect(self.apply_values)\n        return spin\n\n    def _link_slider_spin(self, slider, spin):\n        \"\"\"\n        Slider controls spin using Maya-like precision:\n        - drag = normal\n        - Ctrl + drag = slower\n        - Ctrl + Shift + drag = very slow\n        \"\"\"\n        def on_slider_changed(v):\n            mods = QtWidgets.QApplication.keyboardModifiers()\n            factor = 1.0\n            if mods & QtCore.Qt.ControlModifier:\n                factor = 0.2\n                if mods & QtCore.Qt.ShiftModifier:\n                    factor = 0.05\n\n            delta = v - slider._lastVal\n            slider._lastVal = v\n\n            rng = slider._max - slider._min\n            step = rng / 1000.0\n\n            new_val = spin.value() + delta * step * factor\n            new_val = max(slider._min, min(slider._max, new_val))\n\n            spin.blockSignals(True)\n            spin.setValue(new_val)\n            spin.blockSignals(False)\n\n            self.apply_values()\n\n        slider.valueChanged.connect(on_slider_changed)\n\n    def _add_single_control(self, layout, key, min_val, max_val, default):\n        row = QtWidgets.QWidget()\n        row_layout = QtWidgets.QHBoxLayout(row)\n        row_layout.setContentsMargins(0, 0, 0, 0)\n        row_layout.setSpacing(8)\n\n        slider = self._create_slider(min_val, max_val, default)\n        spin = self._create_spinbox(min_val, max_val, default)\n        self._link_slider_spin(slider, spin)\n\n        row_layout.addWidget(slider, stretch=5)\n        row_layout.addWidget(spin, stretch=1)\n\n        layout.addWidget(row)\n\n        self.controls[key] = {\n            \"type\": \"single\",\n            \"spin\": spin\n        }\n\n    def _add_group_section(self, layout, group_key, title, attrs, min_val, max_val, default):\n        # Header row: label + \"Uniform\" toggle\n        header = QtWidgets.QWidget()\n        header_layout = QtWidgets.QHBoxLayout(header)\n        header_layout.setContentsMargins(0, 0, 0, 0)\n        header_layout.setSpacing(6)\n\n        label = QtWidgets.QLabel(title)\n        font = label.font()\n        font.setBold(True)\n        label.setFont(font)\n\n        uniform_chk = QtWidgets.QCheckBox(\"Uniform\")\n        uniform_chk.setChecked(True)\n        uniform_chk.stateChanged.connect(self._update_group_visibility)\n\n        header_layout.addWidget(label)\n        header_layout.addStretch(1)\n        header_layout.addWidget(uniform_chk)\n\n        layout.addWidget(header)\n\n        # Uniform row\n        uni_row = QtWidgets.QWidget()\n        uni_layout = QtWidgets.QHBoxLayout(uni_row)\n        uni_layout.setContentsMargins(0, 0, 0, 0)\n        uni_layout.setSpacing(8)\n\n        uni_slider = self._create_slider(min_val, max_val, default)\n        uni_spin = self._create_spinbox(min_val, max_val, default)\n        self._link_slider_spin(uni_slider, uni_spin)\n\n        uni_layout.addWidget(uni_slider, stretch=5)\n        uni_layout.addWidget(uni_spin, stretch=1)\n\n        layout.addWidget(uni_row)\n\n        # Separate rows (U / V)\n        sep_widget = QtWidgets.QWidget()\n        sep_layout = QtWidgets.QFormLayout(sep_widget)\n        sep_layout.setContentsMargins(16, 0, 0, 0)\n        sep_layout.setSpacing(4)\n\n        sep_spins = {}\n\n        for a in attrs:\n            sub_row = QtWidgets.QWidget()\n            sub_layout = QtWidgets.QHBoxLayout(sub_row)\n            sub_layout.setContentsMargins(0, 0, 0, 0)\n            sub_layout.setSpacing(8)\n\n            s = self._create_slider(min_val, max_val, default)\n            sp = self._create_spinbox(min_val, max_val, default)\n            self._link_slider_spin(s, sp)\n\n            sub_layout.addWidget(s, stretch=5)\n            sub_layout.addWidget(sp, stretch=1)\n\n            label_char = a[-1].upper()  # U / V\n            sep_layout.addRow(label_char, sub_row)\n\n            sep_spins[a] = sp\n\n        sep_widget.hide()  # default uniform\n\n        layout.addWidget(sep_widget)\n\n        self.controls[group_key] = {\n            \"type\": \"group\",\n            \"toggle\": uniform_chk,\n            \"uniform_spin\": uni_spin,\n            \"separate_spins\": sep_spins,\n            \"uniform_row\": uni_row,\n            \"separate_widget\": sep_widget,\n            \"attrs\": attrs\n        }\n\n    # ---------------- UTILS & APPLY ----------------\n\n    def _get_place_nodes(self):\n        sel = cmds.ls(sl=True) or []\n        place = set()\n        for n in sel:\n            if cmds.nodeType(n) == \"place2dTexture\":\n                place.add(n)\n            else:\n                con = cmds.listConnections(n, type=\"place2dTexture\") or []\n                place.update(con)\n        return list(place)\n\n    def _start_undo(self):\n        cmds.undoInfo(openChunk=True)\n\n    def _end_undo(self):\n        cmds.undoInfo(closeChunk=True)\n\n    def _update_group_visibility(self):\n        for key, data in self.controls.items():\n            if data[\"type\"] != \"group\":\n                continue\n            uni = data[\"uniform_row\"]\n            sep = data[\"separate_widget\"]\n            toggle = data[\"toggle\"]\n            if toggle.isChecked():\n                uni.show()\n                sep.hide()\n            else:\n                uni.hide()\n                sep.show()\n\n    def apply_values(self, *args):\n        for p in self.place_nodes:\n            for key, data in self.controls.items():\n                if data[\"type\"] == \"single\":\n                    val = data[\"spin\"].value()\n                    if key == \"repeatUV\":\n                        cmds.setAttr(p + \".repeatU\", val)\n                        cmds.setAttr(p + \".repeatV\", val)\n                    elif key == \"rotateUV\":\n                        cmds.setAttr(p + \".rotateUV\", val)\n                    elif key == \"rotateFrame\":\n                        cmds.setAttr(p + \".rotateFrame\", val)\n\n                elif data[\"type\"] == \"group\":\n                    toggle = data[\"toggle\"]\n                    attrs = data[\"attrs\"]\n                    if toggle.isChecked():\n                        # Uniform\n                        v = data[\"uniform_spin\"].value()\n                        if key == \"offset\":\n                            cmds.setAttr(p + \".offsetU\", v)\n                            cmds.setAttr(p + \".offsetV\", v)\n                        elif key == \"noise\":\n                            cmds.setAttr(p + \".noiseU\", v)\n                            cmds.setAttr(p + \".noiseV\", v)\n                    else:\n                        # Separate U/V\n                        for attr_name, spin in data[\"separate_spins\"].items():\n                            v = spin.value()\n                            cmds.setAttr(p + \".\" + attr_name, v)\n\n\ndef open_place2d_uniform_tool():\n    global _place2d_ui\n    try:\n        _place2d_ui.close()\n        _place2d_ui.deleteLater()\n    except:\n        pass\n\n    _place2d_ui = Place2DUniformUI()\n    _place2d_ui.show()\n\n\nopen_place2d_uniform_tool()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
