        -marginWidth 0
        -marginHeight 1
        -command "#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\n#********************************\n# Copyright 2021 Toshi Kosaka\n#\n# GORIOSHI SCRIPTS\n#********************************\n'''****************************************************************************\n*** quadPatcher_v1.0.py\n***\n*** Scripted in Maya 2020\n*** Tested in Maya 2020 and 2022\n*** \n*** Please do not copy, distribute, or modify without permission of the author.\n****************************************************************************'''\n\nimport maya.cmds as mc\nimport maya.mel as mel\nimport maya.OpenMaya as om\nimport random\n\nwindowName = 'quadPatcher'\n\ndef faceChecker(arg=None):\n    sel = mc.ls(sl=True, fl=True)\n    if mc.polyEvaluate(sel, ec=True) or mc.polyEvaluate(sel, vc=True) > 0> 0:\n        mc.error('No Faces are selected')\n    if mc.polyEvaluate(sel, fc=True) == 0:\n        mc.error('No faces are selected')\n    mc.select(sel)\n    for each in mc.ls(mc.polyListComponentConversion(sel, te=True), fl=True):\n        currentEdge = []\n        currentEdge = mc.polySelect(eb=int(each.split('[')[1].split(']')[0]), q=True)\n        if currentEdge != None:\n            mc.error('Face cannot be adjacent to the border')\n    mc.ConvertSelectionToEdgePerimeter()\n    if len(mc.ls(sl=True, fl=True)) % 2 != 0:\n        mc.select(sel)\n        mc.error('Selection edge perimeter count is odd. Needs even for quads.')\n    mc.select(sel)\n    \ndef edgeChecker(arg=None):\n    sel = mc.ls(sl=True, fl=True)\n    if mc.polyEvaluate(sel, fc=True) or mc.polyEvaluate(sel, vc=True) > 0:\n        mc.error('None edges selected for Edge Border Mode')\n    if mc.polyEvaluate(sel, ec=True) == 0:\n        mc.error('No Edges are selected for Edge Boder Mode')\n    if len(mc.ls(mc.polySelect(q=True, eb=int(sel[0].split('[')[1].split(']')[0]), ass=True), fl=True)) != len(sel):\n        mc.error('Complete edge border is not selected')\n    if len(sel) % 2 != 0:\n        mc.error('Edge count is odd. Needs even for quads.')\n    \ndef quadPatchInit(arg=None):\n    if isFaceMode == 0:\n        edgeChecker()\n    mc.button('edgeBorderMode', label='Edge Border Mode', en=0, e=True)\n    mc.button('faceMode', label='Face Mode', en=0, e=True)\n    mc.button('extrudeMode', label='Extrude Mode', en=0, e=True)\n    mc.intSliderGrp('extrudeSlider', en=0, e=True)\n    #mc.button('resetButton', en=0, e=True)\n    global objNameDup\n    global objNameOrig\n    global sideABridgeNode\n    global sideBBridgeNode\n    global sideCBridgeNode\n    global orderedEdges\n    global orderedEdgeComponents\n    global sideAEdges\n    global orderedEdgesExtended\n    global orderedEdgesComponentsExtended\n    global sideAEdgeComponents\n    global sideALen\n    global sideBLen\n    global sideBRemoveSet\n    global sideCRemoveSet\n    global divOffset\n    global dupBaseVerts\n    global dupEdgesSet\n    global newCreatedVerts\n    global insetNode\n    global relaxNodes\n    global smoothNodesOrig\n    global smoothNodes\n    global dupFacesToHide\n    global selEdgesOrig\n    global FMtransferAttributesNode\n    global wrapBaseMesh\n    \n    #Source object\n    selEdgesOrig = mc.ls(sl=True, fl=True)\n    selVertsOrig = mc.polyListComponentConversion(selEdgesOrig, tv=True)\n    selFacesOrig = mc.polyListComponentConversion(selVertsOrig, tf=True)\n    objNameOrig = selEdgesOrig[0].split('.')[0]\n    allFacesOrig = mc.polyListComponentConversion(objNameOrig, tf=True)\n    #Duplicate\n    objNameDup = mc.duplicate(objNameOrig, n='quadPatcher' + str(random.randint(1000,9999)) + '_' + objNameOrig)[0]\n    selEdges = []\n    for each in selEdgesOrig:\n        selEdges.append(objNameDup + '.' + each.split('.')[1])\n    mc.select(selEdges)\n    dupEdgesSet = mc.sets(n='quadPatcher' + str(random.randint(1000,9999)) + '_' + 'dupSet')\n    selVerts = mc.ls(mc.polyListComponentConversion(selEdges, tv=True), fl=True)\n    selFaces = mc.ls(mc.polyListComponentConversion(selVerts, tf=True), fl=True)\n    dupFaceDeleteSet = [x for x in mc.ls(mc.polyListComponentConversion(objNameDup, tf=True), fl=True) if x not in selFaces]\n    mc.delete(dupFaceDeleteSet)\n    mc.select(dupEdgesSet)\n    selEdges = mc.ls(sl=True, fl=True)\n    dupBaseVerts = mc.ls(mc.polyListComponentConversion(objNameDup, tv=True), fl=True)\n        \n    sideALen = int(len(selEdges)/4)\n    sideBLen = int((len(selEdges)-(sideALen*2))/2)\n    if len(selEdges) == 12:\n        sideALen = 1\n        sideBLen = 5\n    if len(selEdges) == 10:\n        sideALen = 1\n        sideBLen = 4\n    if len(selEdges) == 8:\n        sideALen = 1\n        sideBLen = 3\n    \n    orderedEdges = initiate(selEdges)    \n    orderedEdgeComponents = []\n    for each in orderedEdges:\n        orderedEdgeComponents.append(objNameDup + '.e[' + str(each) + ']')\n    \n    #Wrap dup edges to original obj\n    mc.select(selEdges, objNameOrig)\n    mc.CreateWrap()\n    wrapNode = mc.listConnections(objNameOrig, type='wrap')[0]\n    wrapBaseMesh = mc.listConnections(wrapNode + '.basePoints')\n    mc.setAttr(wrapNode + '.weightThreshold', 0)\n    mc.setAttr(wrapNode + '.maxDistance', 1)\n    mc.setAttr(wrapNode + '.autoWeightThreshold', 1)\n    mc.setAttr(wrapNode + '.exclusiveBind', 0)\n\n    \n    #SideA\n    orderedEdgesExtended = orderedEdges + orderedEdges + orderedEdges\n    orderedEdgesComponentsExtended = orderedEdgeComponents + orderedEdgeComponents + orderedEdgeComponents\n    \n    mc.intSliderGrp('rotationSlider', e=True, v=sideALen)\n    offsetNum = sideALen*2\n    mc.intSliderGrp('rotationSlider', e=True, v=offsetNum)\n    sideAEdges = orderedEdgesExtended[0+offsetNum:sideALen+offsetNum] + orderedEdgesExtended[sideALen+sideBLen+offsetNum:sideALen*2+sideBLen+offsetNum]\n    sideAEdgeComponents = orderedEdgesComponentsExtended[0+offsetNum:sideALen+offsetNum] + orderedEdgesComponentsExtended[sideALen+sideBLen+offsetNum:sideALen*2+sideBLen+offsetNum]\n\n    #SideB\n    sideBRemove = [orderedEdgesComponentsExtended[0+offsetNum+sideALen], orderedEdgesComponentsExtended[sideALen+offsetNum+sideBLen-1]]\n    mc.select(sideBRemove)\n    sideBRemoveSet = mc.sets(n='quadPatcher' + str(random.randint(1000,9999)) + '_' + 'sideBRemoveSet')\n    \n    #SideC\n    sideCRemove = [orderedEdgesComponentsExtended[0+offsetNum+(2*sideALen)+sideBLen], orderedEdgesComponentsExtended[(2*sideALen)+offsetNum+(2*sideBLen)-1]]\n    mc.select(sideCRemove)\n    sideCRemoveSet = mc.sets(n='quadPatcher' + str(random.randint(1000,9999)) + '_' + 'sideCRemoveSet')\n   \n    #Transform Component\n    smoothNodes = []\n    for i in range(0,3):\n        smoothNodes.append(mc.polyMoveEdge(selEdgesOrig, ch=1, random=0, localCenter=0, lsx=1)[0])\n    \n    #Make SideA Bridge\n    mc.select(sideAEdgeComponents, r=True)\n    sideABridgeNode = mc.polyBridgeEdge(divisions=sideBLen-3, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n    \n    #Make SideB Bridge\n    sideBEdgeLoop = mc.ls(mc.polySelect(q=True, eb=orderedEdgesExtended[offsetNum+sideALen], ass=True), fl=True)\n    sideBEdgeRemove = mc.sets(sideBRemoveSet, q=True)\n    sideBEdgeComponents = [x for x in sideBEdgeLoop if x not in sideBEdgeRemove]\n    mc.select(sideBEdgeComponents, r=True)\n    sideBBridgeNode = mc.polyBridgeEdge(divisions=0, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n    \n    #Make SideC Bridge\n    sideCEdgeLoop = mc.ls(mc.polySelect(q=True, eb=orderedEdgesExtended[offsetNum+(2*sideALen)+sideBLen], ass=True), fl=True)\n    sideCEdgeRemove = mc.sets(sideCRemoveSet, q=True)\n    sideCEdgeComponents = [x for x in sideCEdgeLoop if x not in sideCEdgeRemove]\n    mc.select(sideCEdgeComponents, r=True)\n    sideCBridgeNode = mc.polyBridgeEdge(divisions=0, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n    \n    mc.select(cl=True)\n    mc.intSliderGrp('rotationSlider', e=True, v=sideALen*2, max=len(orderedEdges), min=0)\n    mc.intSliderGrp('divisionSlider', e=True, v=mc.getAttr(sideABridgeNode[0] + '.divisions'), max=(sideBLen-2)*2-(sideBLen-sideALen))\n    divOffset = 0\n    \n    #new verts faces\n    newCreatedVerts = [x for x in mc.ls(mc.polyListComponentConversion(objNameDup,tv=True), fl=True) if x not in dupBaseVerts]\n    newCreatedFaces = mc.ls(mc.polyListComponentConversion(newCreatedVerts, tf=True), fl=True)\n    \n    #inset Extrude\n    insetNode = mc.polyExtrudeFacet(newCreatedFaces, nds=1, off=0, d=0)\n    \n    #Average Vertex\n    relaxNodes = []\n    for i in range(0,10):\n        relaxNodes.append(mc.polyAverageVertex(newCreatedVerts, i=10, ch=1)[0])\n    \n    #Transfer Attributes FACE MODE\n    if isFaceMode == 1:\n        FMtransferAttributesNode = mc.transferAttributes(liveObj, objNameDup, pos=1, nml=0, uvs=1, suv='map1', tuv='map1', col=2, spa=0, sus='map1', tus='map1', sm=0, fuv=0, clb=1)\n        mc.transferAttributes(liveObj, selEdgesOrig, pos=1, nml=0, uvs=1, suv='map1', tuv='map1', col=2, spa=0, sus='map1', tus='map1', sm=3, fuv=0, clb=1)\n\n    dupFacesToHide = [x for x in mc.ls(mc.polyListComponentConversion(objNameDup,tf=True), fl=True) if x not in newCreatedFaces]\n    mc.select(dupFacesToHide)\n    mc.HideSelectedObjects()\n    mc.select(cl=True)\n    \n    \ndef rotateSlider(arg=None):\n    mc.undoInfo(swf=False)\n    \n    offsetNum = mc.intSliderGrp('rotationSlider', q=True, v=True)\n\n    #Node state off B and C bridges and inset\n    mc.setAttr(sideBBridgeNode[0] + '.nodeState', 1)\n    mc.setAttr(sideCBridgeNode[0] + '.nodeState', 1)\n    mc.setAttr(insetNode[0] + '.nodeState', 1)\n    if isFaceMode == 1:\n        mc.setAttr(FMtransferAttributesNode[0] + '.nodeState', 0)\n\n    #sideA Bridge First\n    sideAEdges = orderedEdgesExtended[0+offsetNum:sideALen+offsetNum+divOffset] + orderedEdgesExtended[sideALen+sideBLen+offsetNum:sideALen*2+sideBLen+offsetNum+divOffset]\n    sideAEdgeComponents = orderedEdgesComponentsExtended[0+offsetNum:sideALen+offsetNum] + orderedEdgesComponentsExtended[sideALen+sideBLen+offsetNum:sideALen*2+sideBLen+offsetNum]\n    sideAEdgesString = ''\n    for each in sideAEdges:\n        sideAEdgesString = sideAEdgesString + ' ' + '\"e[' + str(each) + ']\"'\n    inputComponentStrA = 'setAttr -type \"componentList\" ( \"' + sideABridgeNode[0] + '.inputComponents\" ) ' + str(len(sideAEdges)) + ' ' + sideAEdgesString\n\n    mel.eval(inputComponentStrA)\n\n    #sideB Adjust\n    sideBEdgeRemove = [orderedEdgesComponentsExtended[0+offsetNum+sideALen+divOffset], orderedEdgesComponentsExtended[sideALen+offsetNum+sideBLen-1]]\n    sideBEdgeLoop = mc.ls(mc.polySelect(objNameDup, q=True, eb=orderedEdgesExtended[offsetNum+sideALen+divOffset], ass=True), fl=True)\n    sideBEdgeComponents = [x for x in sideBEdgeLoop if x not in sideBEdgeRemove]\n    sideBEdgesString = ''\n    for each in sideBEdgeComponents:\n        sideBEdgesString = sideBEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    inputComponentStrB = 'setAttr -type \"componentList\" ( \"' + sideBBridgeNode[0] + '.inputComponents\" ) ' + str(len(sideBEdgeComponents)) + ' ' + sideBEdgesString\n    \n    #sideC Adjust\n    sideCEdgeRemove = [orderedEdgesComponentsExtended[0+offsetNum+(2*sideALen)+sideBLen+divOffset], orderedEdgesComponentsExtended[(2*sideALen)+offsetNum+(2*sideBLen)-1]]\n    sideCEdgeLoop = mc.ls(mc.polySelect(objNameDup, q=True, eb=orderedEdgesExtended[offsetNum+(2*sideALen)+sideBLen+1+divOffset], ass=True), fl=True)\n    sideCEdgeComponents = [x for x in sideCEdgeLoop if x not in sideCEdgeRemove]\n    sideCEdgesString = ''\n    for each in sideCEdgeComponents:\n        sideCEdgesString = sideCEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    inputComponentStrC = 'setAttr -type \"componentList\" ( \"' + sideCBridgeNode[0] + '.inputComponents\" ) ' + str(len(sideCEdgeComponents)) + ' ' + sideCEdgesString\n\n    #Execute Adjustment\n    mel.eval(inputComponentStrB)\n    mc.setAttr(sideBBridgeNode[0] + '.nodeState', 0)\n    mel.eval(inputComponentStrC)\n    mc.setAttr(sideCBridgeNode[0] + '.nodeState', 0)\n    #Inset status check\n    insetStatus = mc.checkBox('insetCheckbox', q=True, v=True)\n    if insetStatus == 1:\n        mc.setAttr(insetNode[0] + '.nodeState', 0)\n    if isFaceMode == 1:\n        mc.setAttr(FMtransferAttributesNode[0] + '.nodeState', 0)\n        \n    \ndef divideSlider(arg=None):\n    global divOffset\n    mc.undoInfo(swf=False)\n    \n    divNum = mc.intSliderGrp('divisionSlider', q=True, v=True)\n    offsetNum = mc.intSliderGrp('rotationSlider', q=True, v=True)\n    \n    #Node state off B and C bridges and inset\n    mc.setAttr(sideBBridgeNode[0] + '.nodeState', 1)\n    mc.setAttr(sideCBridgeNode[0] + '.nodeState', 1)\n    mc.setAttr(insetNode[0] + '.nodeState', 1)\n    \n    #sideA Bridge divisions set\n    mc.setAttr(sideABridgeNode[0] + '.divisions', divNum)\n    \n    divOffset = sideALen-3-divNum+(sideBLen-sideALen)\n    \n    sideAEdges = orderedEdgesExtended[0+offsetNum:sideALen+offsetNum+divOffset] + orderedEdgesExtended[sideALen+sideBLen+offsetNum:sideALen*2+sideBLen+offsetNum+divOffset]\n    sideAEdgeComponents = orderedEdgesComponentsExtended[0+offsetNum:sideALen+offsetNum] + orderedEdgesComponentsExtended[sideALen+sideBLen+offsetNum:sideALen*2+sideBLen+offsetNum]\n    sideAEdgesString = ''\n    for each in sideAEdges:\n        sideAEdgesString = sideAEdgesString + ' ' + '\"e[' + str(each) + ']\"'\n    inputComponentStrA = 'setAttr -type \"componentList\" ( \"' + sideABridgeNode[0] + '.inputComponents\" ) ' + str(len(sideAEdges)) + ' ' + sideAEdgesString\n\n    mel.eval(inputComponentStrA)\n    \n    #sideB Bridge divisions\n    sideBEdgeRemove = [orderedEdgesComponentsExtended[0+offsetNum+sideALen+divOffset], orderedEdgesComponentsExtended[sideALen+offsetNum+sideBLen-1]]\n    sideBEdgeLoop = mc.ls(mc.polySelect(objNameDup, q=True, eb=orderedEdgesExtended[offsetNum+sideALen+divOffset], ass=True), fl=True)\n    sideBEdgeComponents = [x for x in sideBEdgeLoop if x not in sideBEdgeRemove]\n    sideBEdgesString = ''\n    for each in sideBEdgeComponents:\n        sideBEdgesString = sideBEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    inputComponentStrB = 'setAttr -type \"componentList\" ( \"' + sideBBridgeNode[0] + '.inputComponents\" ) ' + str(len(sideBEdgeComponents)) + ' ' + sideBEdgesString\n\n    #sideC Bridge divisions\n    sideCEdgeRemove = [orderedEdgesComponentsExtended[0+offsetNum+(2*sideALen)+sideBLen+divOffset], orderedEdgesComponentsExtended[(2*sideALen)+offsetNum+(2*sideBLen)-1]]\n    sideCEdgeLoop = mc.ls(mc.polySelect(objNameDup, q=True, eb=orderedEdgesExtended[offsetNum+(2*sideALen)+sideBLen+1+divOffset], ass=True), fl=True)\n    sideCEdgeComponents = [x for x in sideCEdgeLoop if x not in sideCEdgeRemove]\n    sideCEdgesString = ''\n    for each in sideCEdgeComponents:\n        sideCEdgesString = sideCEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    inputComponentStrC = 'setAttr -type \"componentList\" ( \"' + sideCBridgeNode[0] + '.inputComponents\" ) ' + str(len(sideCEdgeComponents)) + ' ' + sideCEdgesString\n\n\n    mel.eval(inputComponentStrB)\n    mc.setAttr(sideBBridgeNode[0] + '.nodeState', 0)\n    mel.eval(inputComponentStrC)\n    mc.setAttr(sideCBridgeNode[0] + '.nodeState', 0)\n    #Inset status check\n    insetStatus = mc.checkBox('insetCheckbox', q=True, v=True)\n    if insetStatus == 1:\n        mc.setAttr(insetNode[0] + '.nodeState', 0)\n    updateRelax()\n    updateInset()\n    \ndef relaxSlider(arg=None):\n    mc.undoInfo(swf=False)\n    relaxNum = mc.intSliderGrp('relaxSlider', q=True, v=True)\n    for each in relaxNodes:\n        mc.setAttr(each + '.iterations', relaxNum)\n        \ndef smoothBorderSlider(arg=None):\n    mc.undoInfo(swf=False)\n    smoothNum = (mc.floatSliderGrp('smoothBorderSlider', q=True, v=True)-1)*-1\n    for each in smoothNodes:\n        mc.setAttr(each + '.localScaleX', smoothNum)\n    \ndef activateInset(arg=None):\n    mc.undoInfo(swf=False)\n    updateInset()\n    insetStatus = mc.checkBox('insetCheckbox', q=True, v=True)\n    \n    if insetStatus == 1:\n        mc.setAttr(insetNode[0] + '.nodeState', 0)\n        mc.setAttr(insetNode[0] + '.offset', 0)\n        mc.setAttr(insetNode[0] + '.divisions', 1)\n    else:\n        mc.setAttr(insetNode[0] + '.nodeState', 1)\n    \n    updateRelax()\n    mc.undoInfo(swf=True)\n\ndef insetDivMinus(arg=None):\n    mc.undoInfo(swf=False)\n    currentDivNum = mc.getAttr(insetNode[0] + '.divisions')\n    \n    if currentDivNum > 1:\n        mc.setAttr(insetNode[0] + '.divisions', currentDivNum-1)\n\n    updateRelax()\n    mc.undoInfo(swf=True)\n    \ndef insetDivPlus(arg=None):\n    mc.undoInfo(swf=False)\n    currentDivNum = mc.getAttr(insetNode[0] + '.divisions')\n    \n    mc.setAttr(insetNode[0] + '.divisions', currentDivNum+1)\n\n    updateRelax()\n    mc.undoInfo(swf=True) \n    \ndef updateRelax(arg=None):\n    newCreatedVerts = [x for x in mc.ls(mc.polyListComponentConversion(objNameDup,tv=True), fl=True) if x not in dupBaseVerts]\n    newVertsString = ''\n    for each in newCreatedVerts:\n        newVertsString = newVertsString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    for each in relaxNodes:\n        inputComponentString = 'setAttr -type \"componentList\" ( \"' + each + '.inputComponents\" ) ' + str(len(newCreatedVerts)) + ' ' + newVertsString\n        mel.eval(inputComponentString)\n\ndef updateInset(arg=None):\n    newCreatedVerts = [x for x in mc.ls(mc.polyListComponentConversion(objNameDup,tv=True), fl=True) if x not in dupBaseVerts]\n    newCreatedFaces = mc.ls(mc.polyListComponentConversion(newCreatedVerts, tf=True), fl=True)\n    newFacesString = ''\n    for each in newCreatedFaces:\n        newFacesString = newFacesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    inputComponentString = 'setAttr -type \"componentList\" ( \"' + insetNode[0] + '.inputComponents\" ) ' + str(len(newCreatedFaces)) + ' ' + newFacesString\n    mel.eval(inputComponentString)\n\ndef undoInfoON(arg=None):\n    mc.undoInfo(swf=True)\n    \ndef initiate(edges):\n    mc.select(edges)\n    sel = om.MSelectionList()\n    om.MGlobal.getActiveSelectionList(sel)\n\n    dag = om.MDagPath()\n    component = om.MObject()\n    sel.getDagPath(0, dag, component)\n\n    mItEdge = om.MItMeshEdge(dag, component)\n\n    checkedEdge = [int(mItEdge.index())]\n    currentEdge = mItEdge.index()\n    orderedList = [mItEdge.index()]\n    for count in range(mItEdge.count()):\n        while not mItEdge.isDone():\n            if mItEdge.connectedToEdge(currentEdge):\n                if mItEdge.index() not in checkedEdge:\n                    orderedList.append(mItEdge.index())\n                    currentEdge = mItEdge.index()\n                    checkedEdge.append(int(mItEdge.index()))\n                    break\n            mItEdge.next()\n        mItEdge.reset()\n    return orderedList\n    \ndef patchIt(arg=None):\n    mc.delete(dupFacesToHide)\n    facesOrig = mc.ls(mc.polyListComponentConversion(objNameDup, tf=True), fl=True)\n\n    edgesToMerge = []\n    for each in selEdgesOrig:\n        edgesToMerge.append(each.split('.')[1])\n    mergedObj = mc.polyUnite([objNameOrig, objNameDup], ch=1, mergeUVSets=1, centerPivot=True)[0]\n    objNameNew = mc.rename(mergedObj, objNameOrig)\n    for each in mc.sets(dupEdgesSet, q=True):\n        if each != 'transform*':\n            edgesToMerge.append(each.split('.')[1])\n    if mc.objExists('quadPatcher*_*Set'):\n        mc.delete('quadPatcher*_*Set')\n    mc.DeleteHistory()\n    vertsToMerge = []\n    \n    for each in edgesToMerge:\n        vertsToMerge.append(objNameNew + '.' + each)\n    mc.polyMergeVertex(vertsToMerge, d=0.001, am=1, ch=1)\n\n    if isFaceMode == 1:\n        mc.delete(liveObj)\n    if mc.objExists(wrapBaseMesh[0]):\n        mc.delete(wrapBaseMesh)\n    if mc.objExists('mergedObjSet'):    \n        mc.delete('mergedObjeSet')\n    mc.DeleteHistory()\n    mc.select(objNameNew)\n    \n    resetUI(windowName)\n    \ndef resetUI(windw, *args):\n    allwindows = mc.lsUI(type=\"window\")\n    for win in allwindows:\n        if win == windw:\n            mc.deleteUI(win)\n    mc.evalDeferred(quadPatcherUI)\n\ndef faceModeInit(arg=None):\n    faceChecker()\n    mc.button('edgeBorderMode', label='Edge Border Mode', en=0, e=True)\n    mc.button('faceMode', label='Face Mode', en=0, e=True)\n    mc.button('extrudeMode', label='Extrude Mode', en=0, e=True)\n    mc.intSliderGrp('extrudeSlider', en=0, e=True)\n    #mc.button('resetButton', en=0, e=True)\n    global liveObj\n    global faceModeEdgeComponentsOrigSet\n    global isFaceMode\n    isFaceMode = 1\n    \n    selFacesOrig = mc.ls(sl=True, fl=True)\n    objNameOrig = selFacesOrig[0].split('.')[0]\n    \n    liveObj = mc.duplicate(objNameOrig, n='quadPatcher' + str(random.randint(1000,9999)) + '_live')\n    liveObjFaces = []\n    for each in selFacesOrig:\n        liveObjFaces.append(liveObj[0] + '.' + each.split('.')[1])\n    mc.delete([x for x in mc.ls(mc.polyListComponentConversion(liveObj, tf=True), fl=True) if x not in liveObjFaces])\n    mc.hide(liveObj)\n    mc.ConvertSelectionToEdgePerimeter()\n    faceModeEdgeComponentsOrigSet = mc.sets(n='quadPatcher' + str(random.randint(1000,9999)) + '_' + objNameOrig + 'Set')\n    \n    mc.delete(selFacesOrig)\n    mc.select(faceModeEdgeComponentsOrigSet)\n    quadPatchInit()\n\ndef extrudeSlider(arg=None):\n    mc.undoInfo(swf=False)\n    endOffset = mc.intSliderGrp('extrudeSlider', q=True, v=True)\n    \n    mc.setAttr(closeSideABridgeNode[0] + '.nodeState', 1)\n    mc.setAttr(closeSideBBridgeNode[0] + '.nodeState', 1)\n    mc.setAttr(closeSideCBridgeNode[0] + '.nodeState', 1)\n    \n    divNumII = endOffset - 1\n    \n    #initial bridge\n    sideAEdgesString = '\\\"' + str(sideB1Edges[endOffset].split('.')[1]) + '\\\" \\\"' + str(sideC1Edges[endOffset].split('.')[1]) + '\\\"'\n    inputComponentStrI = 'setAttr -type \"componentList\" ( \"' + closeBridgeNode[0] + '.inputComponents\" ) ' + '2' + ' ' + sideAEdgesString\n    mel.eval(inputComponentStrI)\n    \n    #side A\n    newWholeBorder = mc.ls(mc.polySelect(selObj, q=True, eb=orderedEdges[0], ass=True), fl=True)\n    tempXEdges = sideB1Edges[0:endOffset] + sideC1Edges[0:endOffset]\n    tempXEdges = mc.ls(\n    mc.polyListComponentConversion(\n    mc.polyListComponentConversion(tempXEdges, tv=True), te=True), fl=True)\n    newBridgeEdges = [x for x in newWholeBorder if x not in tempXEdges]\n    sideAEdgesString = ''\n    for each in newBridgeEdges:\n        sideAEdgesString = sideAEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    inputComponentStrA = 'setAttr -type \"componentList\" ( \"' + closeSideABridgeNode[0] + '.inputComponents\" ) ' + str(len(newBridgeEdges)) + ' ' + sideAEdgesString\n\n    mel.eval(inputComponentStrA)\n    mc.setAttr(closeSideABridgeNode[0] + '.divisions', divNumII)\n    mc.setAttr(closeSideABridgeNode[0] + '.nodeState', 0)\n    \n    #Side B\n    extSideBEdgesI = sideB1Edges[0:endOffset]\n    extSideBEdgesWhole = mc.ls(mc.polySelect(selObj, q=True, eb=int(extSideBEdgesI[0].split('[')[1].split(']')[0]), ass=True), fl=True)\n    extSideBRemove = mc.ls(mc.polyListComponentConversion(mc.polyListComponentConversion(extSideBEdgesI, tv=True), te=True), fl=True)\n    extSideBEdgesII = [x for x in extSideBEdgesWhole if x not in extSideBRemove]    \n    sideBEdgeComponents = extSideBEdgesI + extSideBEdgesII\n    sideBEdgesString = ''\n    for each in sideBEdgeComponents:\n        sideBEdgesString = sideBEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    sideBEdgesString = 'setAttr -type \"componentList\" ( \"' + closeSideBBridgeNode[0] + '.inputComponents\" ) ' + str(len(sideBEdgeComponents)) + ' ' + sideBEdgesString\n    mel.eval(sideBEdgesString)\n    mc.setAttr(closeSideBBridgeNode[0] + '.nodeState', 0)\n    \n    #Side C\n    extSideCEdgesI = sideC1Edges[0:endOffset]\n    extSideCEdgesWhole = mc.ls(mc.polySelect(selObj, q=True, eb=int(extSideCEdgesI[0].split('[')[1].split(']')[0]), ass=True), fl=True)\n    extSideCRemove = mc.ls(mc.polyListComponentConversion(mc.polyListComponentConversion(extSideCEdgesI, tv=True), te=True), fl=True)\n    extSideCEdgesII = [x for x in extSideCEdgesWhole if x not in extSideCRemove]\n    sideCEdgeComponents = extSideCEdgesI + extSideCEdgesII\n    sideCEdgesString = ''\n    for each in sideCEdgeComponents:\n        sideCEdgesString = sideCEdgesString + ' ' + '\\\"' + each.split('.')[1] + '\\\"'\n    sideCEdgesString = 'setAttr -type \"componentList\" ( \"' + closeSideCBridgeNode[0] + '.inputComponents\" ) ' + str(len(sideCEdgeComponents)) + ' ' + sideCEdgesString\n    mel.eval(sideCEdgesString)\n    mc.setAttr(closeSideCBridgeNode[0] + '.nodeState', 0)\n\ndef extrudeModeInit(arg=None):\n    mc.button('edgeBorderMode', label='Edge Border Mode', en=0, e=True)\n    mc.button('faceMode', label='Face Mode', en=0, e=True)\n    mc.button('extrudeMode', label='Extrude Mode', en=0, e=True)\n    mc.intSliderGrp('rotationSlider', en=0, e=True)\n    mc.intSliderGrp('divisionSlider', en=0, e=True)\n    mc.intSliderGrp('relaxSlider', en=0, e=True)\n    mc.floatSliderGrp('smoothBorderSlider', en=0, e=True)\n    #mc.intSliderGrp('extrudeSlider', en=0, e=True)\n    mc.checkBox('insetCheckbox', en=0, e=True)\n    mc.button('minusButton', l='-', en=0, e=True)\n    mc.button('plusButton', l='+', en=0, e=True)\n    mc.button('patchItButton', l='Patch It!', en=0, e=True)\n    global selEdges\n    global selObj\n    global endOffset\n    global orderedwholeBorderComponents\n    global orderedwholeBorderComponentsExt\n    global orderedEdges\n    global orderedEdgeComponents\n    global wholeBorder\n    global orderedwholeBorder\n    global orderedwholeBorderComponents\n    global closeBridgeNode\n    global endAOrig\n    global endBOrig\n    global closeSideABridgeNode\n    global closeSideBBridgeNode\n    global closeSideCBridgeNode\n    global sideB1Edges\n    global sideC1Edges\n    \n    selEdges = mc.ls(sl=True, fl=True)\n    selObj = selEdges[0].split('.')[0]\n    orderedEdges = initiate(selEdges)\n    if len(orderedEdges) < len(selEdges):\n        for i in range(0, len(selEdges)-len(orderedEdges)):\n            options = mc.ls(mc.polyListComponentConversion(mc.polyListComponentConversion(selObj + '.e[' + str(orderedEdges[0]) + ']', tv=True), te=True), fl=True)\n            \n            orderedEdgeComponents = []\n            for each in orderedEdges:\n                orderedEdgeComponents.append(selEdges[0].split('.')[0] + '.e[' + str(each) + ']')\n                \n            key = [x for x in selEdges if x not in orderedEdgeComponents]\n            selected = [x for x in options if x in key]\n            orderedEdges.insert(0, int(selected[0].split('[')[1].split(']')[0]))\n        \n    orderedEdgeComponents = []\n    for each in orderedEdges:\n        orderedEdgeComponents.append(selEdges[0].split('.')[0] + '.e[' + str(each) + ']')\n    \n    wholeBorder = mc.polySelect(q=True, eb=orderedEdges[0], ass=True)\n    orderedwholeBorder = initiate(wholeBorder)\n    orderedwholeBorderComponents = []\n    for each in orderedwholeBorder:\n        orderedwholeBorderComponents.append(selEdges[0].split('.')[0] + '.e[' + str(each) + ']')\n    orderedwholeBorderComponentsExt = orderedwholeBorderComponents + orderedwholeBorderComponents + orderedwholeBorderComponents\n\n    mc.intSliderGrp('extrudeSlider', e=True, min=1, max=(len(orderedwholeBorder)-(len(selEdges)))/2-2)\n    \n    if orderedwholeBorderComponents[0] == orderedEdgeComponents[0]:\n        if orderedwholeBorderComponents.index(orderedEdgeComponents[1]) == 1:\n            sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[len(orderedEdgeComponents)-1])+1\n        else:\n            sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[0])+1\n    elif orderedwholeBorderComponents.index(orderedEdgeComponents[len(orderedEdgeComponents)-1]) > orderedwholeBorderComponents.index(orderedEdgeComponents[0]):\n        if orderedwholeBorderComponents[0] in orderedEdgeComponents:\n            sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[0])+1\n        else:\n            sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[len(orderedEdgeComponents)-1])+1\n    else:\n        if orderedwholeBorderComponents.index(orderedEdgeComponents[0]) == len(orderedwholeBorderComponents)-1:\n            if orderedwholeBorderComponents[0] in orderedEdgeComponents:\n                sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[len(orderedEdgeComponents)-1])+1\n            else:\n                sideB1StartIndex = 0\n        elif orderedwholeBorderComponents[0] in orderedEdgeComponents:\n            sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[len(orderedEdgeComponents)-1])+1\n        else:\n            sideB1StartIndex = orderedwholeBorderComponents.index(orderedEdgeComponents[0])+1\n    sideB1Edges = []\n    for i in range(sideB1StartIndex,sideB1StartIndex+len(orderedwholeBorderComponents)-len(selEdges)):\n        if i < len(orderedwholeBorderComponents):\n            sideB1Edges.append(orderedwholeBorderComponents[i])\n        else:\n            sideB1Edges.append(orderedwholeBorderComponents[i-len(orderedwholeBorderComponents)])\n    sideC1Edges = sideB1Edges[::-1]\n    \n    #initial Bridge\n    divNum = len(selEdges) - 1\n    endAOrig = orderedEdgeComponents[0]\n    endBOrig = orderedEdgeComponents[len(selEdges)-1]\n    endOffset = mc.intSliderGrp('extrudeSlider', q=True, v=True)\n    divNumII = endOffset - 1\n    \n    initBridgeEdges = [sideB1Edges[endOffset], sideC1Edges[endOffset]]\n    mc.select(initBridgeEdges)\n    closeBridgeNode = mc.polyBridgeEdge(divisions=divNum, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n    \n    #Side A bridge\n    newWholeBorder = mc.ls(mc.polySelect(selObj, q=True, eb=orderedEdges[0], ass=True), fl=True)\n    tempXEdges = sideB1Edges[0:endOffset] + sideC1Edges[0:endOffset]\n    tempXEdges = mc.ls(\n    mc.polyListComponentConversion(\n    mc.polyListComponentConversion(tempXEdges, tv=True), te=True), fl=True)\n    newBridgeEdges = [x for x in newWholeBorder if x not in tempXEdges]\n    mc.select(newBridgeEdges, orderedEdgeComponents[1:len(selEdges)-1])\n    closeSideABridgeNode = mc.polyBridgeEdge(divisions=divNumII, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n\n    #Side B bridge\n    extSideBEdgesI = sideB1Edges[0:endOffset]\n    extSideBEdgesWhole = mc.ls(mc.polySelect(q=True, eb=int(extSideBEdgesI[0].split('[')[1].split(']')[0]), ass=True), fl=True)\n    extSideBRemove = mc.ls(mc.polyListComponentConversion(mc.polyListComponentConversion(extSideBEdgesI, tv=True), te=True), fl=True)\n    extSideBEdgesII = [x for x in extSideBEdgesWhole if x not in extSideBRemove]\n    mc.select(extSideBEdgesI, extSideBEdgesII)\n    closeSideBBridgeNode = mc.polyBridgeEdge(divisions=0, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n\n    #Side C bridge\n    extSideCEdgesI = sideC1Edges[0:endOffset]\n    extSideCEdgesWhole = mc.ls(mc.polySelect(q=True, eb=int(extSideCEdgesI[0].split('[')[1].split(']')[0]), ass=True), fl=True)\n    extSideCRemove = mc.ls(mc.polyListComponentConversion(mc.polyListComponentConversion(extSideCEdgesI, tv=True), te=True), fl=True)\n    extSideCEdgesII = [x for x in extSideCEdgesWhole if x not in extSideCRemove]\n    mc.select(extSideCEdgesI, extSideCEdgesII)\n    closeSideCBridgeNode = mc.polyBridgeEdge(divisions=0, ch=True, twist=0, taper=1, curveType=0, smoothingAngle=30)\n    \n    mc.select(cl=True)\n    \ndef quadPatcherUI():\n    global windowName\n    global isFaceMode\n    \n    isFaceMode = 0\n    windowSize = (400, 200)\n    if (mc.window(windowName , exists=True)):\n        mc.deleteUI(windowName)\n    quad_window = mc.window( windowName, title='Quad Patcher', widthHeight=(windowSize[0], windowSize[1]) )\n    mc.columnLayout( \"mainColumn\", adjustableColumn=True )\n    mc.rowLayout(parent='mainColumn', nc=3)\n    mc.button('edgeBorderMode', label='Edge Border Mode', c=quadPatchInit)\n    mc.button('faceMode', label='Face Mode', c=faceModeInit)\n    mc.button('extrudeMode', label='Extrude Mode', c=extrudeModeInit)\n    \n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.text(l='Rotation: ', w=80, al='left')\n    mc.intSliderGrp('rotationSlider', field=True, dc=rotateSlider, w=310, min=0, max=1, value=0, cc=undoInfoON)\n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.text(l='Proportion: ', w=80, al='left')\n    mc.intSliderGrp('divisionSlider', field=True, dc=divideSlider, w=310, min=1, max=2, value=0, cc=undoInfoON)\n    \n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.text(l='Relax: ', w=80, al='left')\n    mc.intSliderGrp('relaxSlider', field=True, dc=relaxSlider, w=310, min=0, max=10, value=10, cc=undoInfoON)\n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.text(l='Smooth Border: ', w=80, al='left')\n    mc.floatSliderGrp('smoothBorderSlider', field=True, dc=smoothBorderSlider, w=310, min=0, max=1, value=0, cc=undoInfoON)\n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.text(l='Extrude Mode: ', w=80, al='left')\n    mc.intSliderGrp('extrudeSlider', field=True, dc=extrudeSlider, w=310, min=0, max=1, value=1, cc=undoInfoON)\n\n\n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.text(l='Inset: ')\n    mc.checkBox('insetCheckbox', l='', cc=activateInset)\n    mc.rowLayout(parent='mainColumn', nc=3)\n    mc.text(l='Inset Divisions:')\n    mc.button('minusButton', l='-', w=20, c=insetDivMinus)\n    mc.button('plusButton', l='+', w=20, c=insetDivPlus)\n    \n    mc.rowLayout(parent='mainColumn', nc=2)\n    mc.button('patchItButton', l='Patch It!', c=patchIt)\n    mc.button('resetButton', l='RESET', c=resetUI)\n\n    mc.showWindow(quad_window)\n    \nif __name__ == \"__main__\":\n    quadPatcherUI()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "frsnl" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "frsnl" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Frsnl" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/icons-phoenix/fileNode/fresnel.png" 
        -image1 "C:/icons-phoenix/fileNode/fresnel.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef build_facing_ratio_mask_auto():\n\n    sel = cmds.ls(sl=True) or []\n    if not sel:\n        cmds.error(\"Select 1 file node and 1 aiStandardSurface shader.\")\n\n    # ------------------------------------------------------------\n    # AUTO DETECT FILE + SHADER\n    # ------------------------------------------------------------\n    file_nodes = [s for s in sel if cmds.nodeType(s) == \"file\"]\n    shaders = [s for s in sel if cmds.nodeType(s) == \"aiStandardSurface\"]\n\n    # Error checking\n    if len(file_nodes) != 1:\n        cmds.error(\"ERROR: Select EXACTLY 1 file texture node.\\nFound: %d\" % len(file_nodes))\n\n    if len(shaders) != 1:\n        cmds.error(\"ERROR: Select EXACTLY 1 aiStandardSurface shader.\\nFound: %d\" % len(shaders))\n\n    file_node = file_nodes[0]\n    shader = shaders[0]\n\n    # Base name for new nodes\n    base = file_node\n\n    # ------------------------------------------------------------\n    # CREATE layeredTexture WITH TWO INPUTS\n    # ------------------------------------------------------------\n    layered = cmds.shadingNode(\"layeredTexture\", asTexture=True, name=base + \"_layeredTexture\")\n    cmds.setAttr(layered + \".inputs\", size=2)\n\n    cmds.setAttr(layered + \".inputs[0].blendMode\", 1)\n    cmds.setAttr(layered + \".inputs[1].blendMode\", 0)\n\n    cmds.connectAttr(layered + \".outColor\", shader + \".baseColor\", f=True)\n\n    # ------------------------------------------------------------\n    # aiColorCorrect (MASKED LAYER)\n    # ------------------------------------------------------------\n    cc = cmds.shadingNode(\"aiColorCorrect\", asUtility=True, name=base + \"_aiColorCorrect\")\n    cmds.connectAttr(file_node + \".outColor\", cc + \".input\", f=True)\n\n    # Add = 0.2 0.2 0.2\n    cmds.setAttr(cc + \".add\", 0.2, 0.2, 0.2, type=\"double3\")\n\n    # aiColorCorrect ? masked layer\n    cmds.connectAttr(cc + \".outColor\", layered + \".inputs[0].color\", f=True)\n\n    # ------------------------------------------------------------\n    # Solid_blue file ? BASE layer (layer 1)\n    # ------------------------------------------------------------\n    cmds.connectAttr(file_node + \".outColor\", layered + \".inputs[1].color\", f=True)\n\n    # ------------------------------------------------------------\n    # RAMP NODE\n    # ------------------------------------------------------------\n    ramp = cmds.shadingNode(\"ramp\", asTexture=True, name=base + \"_ramp\")\n\n    # DELETE the default place2dTexture that Maya creates\n    incoming = cmds.listConnections(ramp + \".uvCoord\", s=True, d=False) or []\n    incoming += cmds.listConnections(ramp + \".uvFilterSize\", s=True, d=False) or []\n\n    for node in set(incoming):\n        if cmds.nodeType(node) == \"place2dTexture\":\n            cmds.delete(node)\n\n    # ------------------------------------------------------------\n    # samplerInfo (facing ratio)\n    # ------------------------------------------------------------\n    sampler = cmds.shadingNode(\"samplerInfo\", asUtility=True, name=base + \"_samplerInfo\")\n\n    cmds.connectAttr(sampler + \".facingRatio\", ramp + \".uvCoord.uCoord\", f=True)\n    cmds.connectAttr(sampler + \".facingRatio\", ramp + \".uvCoord.vCoord\", f=True)\n\n    # Ramp ? masked layer alpha\n    cmds.connectAttr(ramp + \".outAlpha\", layered + \".inputs[0].alpha\", f=True)\n\n    # Ramp COLORS\n    cmds.setAttr(ramp + \".colorEntryList[0].color\", 0, 0, 0, type=\"double3\")\n    cmds.setAttr(ramp + \".colorEntryList[1].color\", 1, 1, 1, type=\"double3\")\n\n    # Ramp POSITIONS\n    cmds.setAttr(ramp + \".colorEntryList[0].position\", 0.85336)\n    cmds.setAttr(ramp + \".colorEntryList[1].position\", 0.195519)\n\n    # ------------------------------------------------------------\n    # Arnold Refresh\n    # ------------------------------------------------------------\n    try:\n        cmds.arnoldRenderView(opt=(\"Update Full Scene\", \"True\"))\n    except:\n        pass\n\n    cmds.inViewMessage(\n        amg=f\"<hl>{base}</hl> Fresnel Network Created ?\",\n        pos=\"midCenter\",\n        fade=True\n    )\n\n\n# RUN\nbuild_facing_ratio_mask_auto()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Frnl-X" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Frnl-X" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Frnl-X" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/icons-phoenix/fileNode/fresnel.png" 
        -image1 "C:/icons-phoenix/fileNode/fresnel.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport re\nimport os\n\ndef detect_udim_in_filename(filepath):\n    \"\"\"\n    Detect if filename contains UDIM pattern (e.g., _1001, _1021, etc.)\n    \"\"\"\n    if not filepath:\n        return False\n    \n    filename = os.path.basename(filepath)\n    # Pattern matches _1001 to _1999 (UDIM range)\n    udim_pattern = r'_1\\d{3}'\n    return bool(re.search(udim_pattern, filename))\n\n\ndef show_file_selection_dialog(selected_files):\n    \"\"\"\n    Show intelligent dialog to assign file nodes to different parts of the network\n    - Always shows 3 options (Top, Bottom, Mix Alpha)\n    - Bottom is auto-assigned based on Top and Mix Alpha selections\n    - For 2 files: Top and Mix Alpha have 'none' option\n    - For 3 files: Only 2 dropdowns are editable (Top and Mix Alpha)\n    \"\"\"\n    window_name = \"fileAssignmentWindow\"\n    \n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    num_files = len(selected_files)\n    \n    if num_files not in [2, 3]:\n        return None\n    \n    # Create window\n    window = cmds.window(window_name, title=\"Assign File Nodes\", sizeable=True)\n    main_layout = cmds.columnLayout(adjustableColumn=True, rowSpacing=10, columnOffset=('both', 15))\n    \n    cmds.text(label=\"Assign file nodes to network groups:\", height=30, font=\"boldLabelFont\")\n    cmds.separator(height=15, style='in')\n    \n    option_menus = {}\n    \n    # Prepare file list with \"none\" option for 2-file case\n    file_options = ['none'] + selected_files if num_files == 2 else selected_files\n    \n    # Top Group dropdown\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(150, 250), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Top Group:\", align='right')\n    option_menus['top'] = cmds.optionMenu(changeCommand=lambda x: update_bottom_assignment())\n    for f in file_options:\n        cmds.menuItem(label=f)\n    if num_files == 2:\n        cmds.optionMenu(option_menus['top'], edit=True, value=selected_files[0])  # Select first file\n    cmds.setParent('..')\n    \n    # Bottom Group - will be auto-assigned (disabled)\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(150, 250), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Bottom Group:\", align='right')\n    option_menus['bottom'] = cmds.optionMenu(enable=False)\n    for f in selected_files:\n        cmds.menuItem(label=f)\n    cmds.setParent('..')\n    \n    # Mix Alpha dropdown\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(150, 250), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Mix Alpha:\", align='right')\n    option_menus['mix_alpha'] = cmds.optionMenu(changeCommand=lambda x: update_bottom_assignment())\n    for f in file_options:\n        cmds.menuItem(label=f)\n    if num_files == 3:\n        cmds.optionMenu(option_menus['mix_alpha'], edit=True, select=3)  # Default to third file\n    else:\n        cmds.optionMenu(option_menus['mix_alpha'], edit=True, value='none')  # Default to none for 2 files\n    cmds.setParent('..')\n    \n    cmds.separator(height=10, style='none')\n    \n    # Toggle for using top file in bottom\n    use_same_checkbox = cmds.checkBox(label=\"Use Top file for Bottom\", value=False, \n                                       changeCommand=lambda x: update_bottom_assignment())\n    \n    def update_bottom_assignment(*args):\n        \"\"\"Automatically assign bottom based on top and mix alpha selections\"\"\"\n        use_same = cmds.checkBox(use_same_checkbox, query=True, value=True)\n        \n        if use_same:\n            # Use same file as top\n            top_selection = cmds.optionMenu(option_menus['top'], query=True, value=True)\n            if top_selection != 'none':\n                # Find index of top selection in selected_files\n                try:\n                    idx = selected_files.index(top_selection) + 1\n                    cmds.optionMenu(option_menus['bottom'], edit=True, select=idx)\n                except ValueError:\n                    pass\n        else:\n            # Auto-assign based on what's not selected\n            top_selection = cmds.optionMenu(option_menus['top'], query=True, value=True)\n            mix_selection = cmds.optionMenu(option_menus['mix_alpha'], query=True, value=True)\n            \n            # Get files that are NOT selected in top or mix\n            used_files = []\n            if top_selection != 'none':\n                used_files.append(top_selection)\n            if mix_selection != 'none':\n                used_files.append(mix_selection)\n            \n            available = [f for f in selected_files if f not in used_files]\n            \n            if available:\n                # Set bottom to first available file\n                try:\n                    idx = selected_files.index(available[0]) + 1\n                    cmds.optionMenu(option_menus['bottom'], edit=True, select=idx)\n                except ValueError:\n                    pass\n    \n    # Initialize bottom assignment\n    update_bottom_assignment()\n    \n    result_dict = {'menus': option_menus, 'checkbox': use_same_checkbox, 'selected_files': selected_files}\n    \n    cmds.separator(height=20, style='in')\n    \n    # Buttons\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(215, 215), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    def on_ok():\n        # Get selections\n        top_val = cmds.optionMenu(option_menus['top'], query=True, value=True)\n        bottom_val = cmds.optionMenu(option_menus['bottom'], query=True, value=True)\n        mix_val = cmds.optionMenu(option_menus['mix_alpha'], query=True, value=True)\n        use_same = cmds.checkBox(use_same_checkbox, query=True, value=True)\n        \n        result = {\n            'top': None if top_val == 'none' else top_val,\n            'bottom': bottom_val,\n            'mix_alpha': None if mix_val == 'none' else mix_val,\n            'use_same_for_bottom': use_same,\n            'selected_files': selected_files\n        }\n        \n        cmds.deleteUI(window_name)\n        show_suffix_dialog(result)\n    \n    def on_cancel():\n        cmds.deleteUI(window_name)\n    \n    cmds.button(label=\"Continue\", command=lambda x: on_ok(), height=35, backgroundColor=(0.3, 0.5, 0.3))\n    cmds.button(label=\"Cancel\", command=lambda x: on_cancel(), height=35, backgroundColor=(0.5, 0.3, 0.3))\n    \n    cmds.setParent('..')  # Exit rowLayout\n    \n    cmds.separator(height=15, style='none')\n    \n    cmds.setParent('..')  # Exit main columnLayout\n    \n    cmds.showWindow(window)\n\n\ndef show_suffix_dialog(file_assignments=None):\n    \"\"\"\n    Show a dialog to select a single suffix for all network nodes\n    \"\"\"\n    window_name = \"suffixSelectorWindow\"\n    \n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    window = cmds.window(window_name, title=\"Select Node Suffix\", sizeable=True)\n    \n    main_layout = cmds.columnLayout(adjustableColumn=True, rowSpacing=8, columnAttach=('both', 15))\n    \n    cmds.text(label=\"Select suffix for all network nodes:\", height=25, font=\"boldLabelFont\")\n    cmds.separator(height=8, style='in')\n    \n    suffixes = ['col', 'rgh', 'nrm', 'hgt', 'opc', 'mtl', 'custom', 'none']\n    \n    # Suffix dropdown\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(120, 240), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Suffix:\", align='right')\n    suffix_menu = cmds.optionMenu(changeCommand=lambda x: update_custom_field())\n    for suffix in suffixes:\n        cmds.menuItem(label=suffix)\n    cmds.optionMenu(suffix_menu, edit=True, value='col')\n    cmds.setParent('..')\n    \n    # Custom suffix text field (initially disabled)\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(120, 240), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Custom Suffix:\", align='right')\n    custom_field = cmds.textField(enable=False, placeholderText=\"Enter custom suffix\")\n    cmds.setParent('..')\n    \n    def update_custom_field():\n        \"\"\"Enable/disable custom field based on dropdown selection\"\"\"\n        selected = cmds.optionMenu(suffix_menu, query=True, value=True)\n        cmds.textField(custom_field, edit=True, enable=(selected == 'custom'))\n    \n    cmds.separator(height=10, style='in')\n    \n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(190, 190), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    def on_create():\n        selected = cmds.optionMenu(suffix_menu, query=True, value=True)\n        \n        if selected == 'custom':\n            # Get custom suffix from text field\n            suffix = cmds.textField(custom_field, query=True, text=True).strip()\n            if not suffix:\n                cmds.warning(\"Please enter a custom suffix or select a predefined one.\")\n                return\n        elif selected == 'none':\n            suffix = ''\n        else:\n            suffix = selected\n        \n        cmds.deleteUI(window_name)\n        recreate_shading_network(suffix, file_assignments)\n    \n    def on_cancel():\n        cmds.deleteUI(window_name)\n    \n    cmds.button(label=\"Create Network\", command=lambda x: on_create(), height=35, backgroundColor=(0.3, 0.5, 0.3))\n    cmds.button(label=\"Cancel\", command=lambda x: on_cancel(), height=35, backgroundColor=(0.5, 0.3, 0.3))\n    \n    cmds.setParent('..')  # Exit rowLayout\n    \n    cmds.separator(height=10, style='none')\n    \n    cmds.setParent('..')  # Exit main columnLayout\n    \n    cmds.showWindow(window)\n\n\ndef configure_file_node(file_node, suffix, is_mix_alpha=False):\n    \"\"\"\n    Configure file node based on suffix type\n    \"\"\"\n    try:\n        # Always turn on ignoreColorSpaceFileRules\n        cmds.setAttr(f\"{file_node}.ignoreColorSpaceFileRules\", 1)\n        \n        # Check for UDIM in filename\n        filepath = cmds.getAttr(f\"{file_node}.fileTextureName\")\n        if detect_udim_in_filename(filepath):\n            cmds.setAttr(f\"{file_node}.uvTilingMode\", 3)\n            print(f\"  Set UDIM Tiling on: {file_node}\")\n        \n        # Configure based on suffix or if it's mix alpha\n        if is_mix_alpha or suffix in ['rgh', 'mtl', 'hgt', 'opc', 'nrm']:\n            # Raw color space, alphaIsLuminance ON\n            cmds.setAttr(f\"{file_node}.alphaIsLuminance\", 1)\n            cmds.setAttr(f\"{file_node}.colorSpace\", \"Raw\", type=\"string\")\n            print(f\"  Configured as Raw/Alpha: {file_node}\")\n        elif suffix == 'col':\n            # sRGB color space, alphaIsLuminance OFF\n            cmds.setAttr(f\"{file_node}.alphaIsLuminance\", 0)\n            cmds.setAttr(f\"{file_node}.colorSpace\", \"sRGB\", type=\"string\")\n            print(f\"  Configured as sRGB: {file_node}\")\n        \n    except Exception as e:\n        print(f\"  Warning: Failed to configure {file_node}: {e}\")\n\n\ndef get_base_name_from_file(file_node_name):\n    \"\"\"\n    Extract base name from file node name (remove path and extension)\n    \"\"\"\n    base = os.path.basename(file_node_name)\n    # Remove extension\n    base = os.path.splitext(base)[0]\n    return base\n\n\ndef recreate_shading_network(suffix='', file_assignments=None):\n    \"\"\"\n    Recreate the MEL shading network with Python\n    \n    Args:\n        suffix: Single suffix to apply to all nodes (e.g., 'col', 'rgh', etc.)\n        file_assignments: Optional dict with file node assignments and selected file nodes\n    \"\"\"\n    print(\"\\n=== Creating Shading Network ===\\n\")\n    \n    def add_suffix(base_name):\n        \"\"\"Add suffix to node name if provided\"\"\"\n        if suffix:\n            return f\"{base_name}_{suffix}\"\n        return base_name\n    \n    # Check if we're using existing file nodes or creating new ones\n    use_existing_files = False\n    existing_file_nodes = {}\n    \n    if file_assignments and 'selected_files' in file_assignments:\n        # User selected file nodes - we'll connect them directly\n        use_existing_files = True\n        \n        # Map the assignments to actual file nodes\n        if file_assignments.get('top'):\n            existing_file_nodes['top'] = file_assignments['top']\n        if file_assignments.get('bottom'):\n            existing_file_nodes['bottom'] = file_assignments['bottom']\n        if file_assignments.get('mix_alpha'):\n            existing_file_nodes['mix_alpha'] = file_assignments['mix_alpha']\n    \n    # Create layered texture nodes\n    print(\"Creating layered texture nodes...\")\n    top1 = cmds.shadingNode('layeredTexture', asTexture=True, name=add_suffix('top1'))\n    cmds.setAttr(f\"{top1}.inputs[0].color\", 0.2, 0.7, 0.3, type=\"double3\")\n    cmds.setAttr(f\"{top1}.inputs[0].alpha\", 1)\n    \n    bottom = cmds.shadingNode('layeredTexture', asTexture=True, name=add_suffix('bottom'))\n    cmds.setAttr(f\"{bottom}.inputs[0].color\", 0.2, 0.7, 0.3, type=\"double3\")\n    cmds.setAttr(f\"{bottom}.inputs[0].alpha\", 1)\n    \n    mix = cmds.shadingNode('layeredTexture', asTexture=True, name=add_suffix('mix'))\n    cmds.setAttr(f\"{mix}.inputs[0].color\", 0.2, 0.7, 0.3, type=\"double3\")\n    cmds.setAttr(f\"{mix}.inputs[0].alpha\", 1)\n    \n    # Create samplerInfo nodes\n    print(\"Creating samplerInfo nodes...\")\n    samplerInfo1 = cmds.shadingNode('samplerInfo', asUtility=True, name=add_suffix('samplerInfo1'))\n    print(f\"  Created: {samplerInfo1}\")\n    \n    samplerInfo2 = cmds.shadingNode('samplerInfo', asUtility=True, name=add_suffix('samplerInfo2'))\n    print(f\"  Created: {samplerInfo2}\")\n    \n    # Create ramp nodes (NO place2dTexture for these)\n    print(\"Creating ramp nodes...\")\n    ramp1 = cmds.shadingNode('ramp', asTexture=True, name=add_suffix('ramp1'))\n    print(f\"  Created: {ramp1}\")\n    \n    ramp2 = cmds.shadingNode('ramp', asTexture=True, name=add_suffix('ramp2'))\n    print(f\"  Created: {ramp2}\")\n    \n    # Set ramp values\n    cmds.setAttr(f\"{ramp1}.colorEntryList[0].position\", 0.3)\n    cmds.setAttr(f\"{ramp1}.colorEntryList[0].color\", 1, 1, 1, type=\"double3\")\n    cmds.setAttr(f\"{ramp1}.colorEntryList[1].position\", 0.7)\n    cmds.setAttr(f\"{ramp1}.colorEntryList[1].color\", 0, 0, 0, type=\"double3\")\n    \n    cmds.setAttr(f\"{ramp2}.colorEntryList[0].position\", 0.3)\n    cmds.setAttr(f\"{ramp2}.colorEntryList[0].color\", 1, 1, 1, type=\"double3\")\n    cmds.setAttr(f\"{ramp2}.colorEntryList[1].position\", 0.7)\n    cmds.setAttr(f\"{ramp2}.colorEntryList[1].color\", 0, 0, 0, type=\"double3\")\n    \n    # Connect samplerInfo to ramps (directly, no place2dTexture)\n    print(\"Connecting samplerInfo to ramps...\")\n    cmds.connectAttr(f\"{samplerInfo1}.facingRatio\", f\"{ramp1}.uCoord\", force=True)\n    cmds.connectAttr(f\"{samplerInfo1}.facingRatio\", f\"{ramp1}.vCoord\", force=True)\n    cmds.connectAttr(f\"{samplerInfo2}.facingRatio\", f\"{ramp2}.uCoord\", force=True)\n    cmds.connectAttr(f\"{samplerInfo2}.facingRatio\", f\"{ramp2}.vCoord\", force=True)\n    \n    # Handle file nodes - either use existing or create new\n    print(\"Setting up file nodes...\")\n    \n    if use_existing_files:\n        # Use existing file nodes directly\n        print(\"  Using existing file nodes...\")\n        file1 = existing_file_nodes.get('top')\n        file2 = existing_file_nodes.get('bottom')\n        file3 = existing_file_nodes.get('mix_alpha')\n        \n        # Configure existing file nodes\n        if file1:\n            configure_file_node(file1, suffix, is_mix_alpha=False)\n        if file2:\n            configure_file_node(file2, suffix, is_mix_alpha=False)\n        if file3:\n            configure_file_node(file3, suffix, is_mix_alpha=True)\n    else:\n        # Create new file nodes with place2dTexture\n        print(\"  Creating new file nodes...\")\n        \n        # File 1 (Top) - use filename if provided\n        file1_name = add_suffix('file1')\n        if file_assignments and file_assignments.get('top'):\n            base_name = get_base_name_from_file(file_assignments['top'])\n            file1_name = add_suffix(base_name)\n        \n        file1 = cmds.shadingNode('file', asTexture=True, isColorManaged=True, name=file1_name)\n        place2d1 = cmds.shadingNode('place2dTexture', asUtility=True)\n        \n        # Connect all place2dTexture attributes to file1\n        cmds.connectAttr(f\"{place2d1}.coverage\", f\"{file1}.coverage\", force=True)\n        cmds.connectAttr(f\"{place2d1}.translateFrame\", f\"{file1}.translateFrame\", force=True)\n        cmds.connectAttr(f\"{place2d1}.rotateFrame\", f\"{file1}.rotateFrame\", force=True)\n        cmds.connectAttr(f\"{place2d1}.mirrorU\", f\"{file1}.mirrorU\", force=True)\n        cmds.connectAttr(f\"{place2d1}.mirrorV\", f\"{file1}.mirrorV\", force=True)\n        cmds.connectAttr(f\"{place2d1}.stagger\", f\"{file1}.stagger\", force=True)\n        cmds.connectAttr(f\"{place2d1}.wrapU\", f\"{file1}.wrapU\", force=True)\n        cmds.connectAttr(f\"{place2d1}.wrapV\", f\"{file1}.wrapV\", force=True)\n        cmds.connectAttr(f\"{place2d1}.repeatUV\", f\"{file1}.repeatUV\", force=True)\n        cmds.connectAttr(f\"{place2d1}.offset\", f\"{file1}.offset\", force=True)\n        cmds.connectAttr(f\"{place2d1}.rotateUV\", f\"{file1}.rotateUV\", force=True)\n        cmds.connectAttr(f\"{place2d1}.noiseUV\", f\"{file1}.noiseUV\", force=True)\n        cmds.connectAttr(f\"{place2d1}.vertexUvOne\", f\"{file1}.vertexUvOne\", force=True)\n        cmds.connectAttr(f\"{place2d1}.vertexUvTwo\", f\"{file1}.vertexUvTwo\", force=True)\n        cmds.connectAttr(f\"{place2d1}.vertexUvThree\", f\"{file1}.vertexUvThree\", force=True)\n        cmds.connectAttr(f\"{place2d1}.vertexCameraOne\", f\"{file1}.vertexCameraOne\", force=True)\n        cmds.connectAttr(f\"{place2d1}.outUV\", f\"{file1}.uv\", force=True)\n        cmds.connectAttr(f\"{place2d1}.outUvFilterSize\", f\"{file1}.uvFilterSize\", force=True)\n        \n        # Assign file path if provided\n        if file_assignments and file_assignments.get('top'):\n            filepath = cmds.getAttr(f\"{file_assignments['top']}.fileTextureName\") if cmds.objExists(file_assignments['top']) else file_assignments['top']\n            cmds.setAttr(f\"{file1}.fileTextureName\", filepath, type=\"string\")\n            print(f\"  Assigned file to {file1}: {filepath}\")\n        \n        configure_file_node(file1, suffix, is_mix_alpha=False)\n        \n        # File 2 (Bottom)\n        file2_name = add_suffix('file2')\n        if file_assignments and file_assignments.get('bottom'):\n            base_name = get_base_name_from_file(file_assignments['bottom'])\n            file2_name = add_suffix(base_name)\n        \n        file2 = cmds.shadingNode('file', asTexture=True, isColorManaged=True, name=file2_name)\n        place2d2 = cmds.shadingNode('place2dTexture', asUtility=True)\n        \n        cmds.connectAttr(f\"{place2d2}.coverage\", f\"{file2}.coverage\", force=True)\n        cmds.connectAttr(f\"{place2d2}.translateFrame\", f\"{file2}.translateFrame\", force=True)\n        cmds.connectAttr(f\"{place2d2}.rotateFrame\", f\"{file2}.rotateFrame\", force=True)\n        cmds.connectAttr(f\"{place2d2}.mirrorU\", f\"{file2}.mirrorU\", force=True)\n        cmds.connectAttr(f\"{place2d2}.mirrorV\", f\"{file2}.mirrorV\", force=True)\n        cmds.connectAttr(f\"{place2d2}.stagger\", f\"{file2}.stagger\", force=True)\n        cmds.connectAttr(f\"{place2d2}.wrapU\", f\"{file2}.wrapU\", force=True)\n        cmds.connectAttr(f\"{place2d2}.wrapV\", f\"{file2}.wrapV\", force=True)\n        cmds.connectAttr(f\"{place2d2}.repeatUV\", f\"{file2}.repeatUV\", force=True)\n        cmds.connectAttr(f\"{place2d2}.offset\", f\"{file2}.offset\", force=True)\n        cmds.connectAttr(f\"{place2d2}.rotateUV\", f\"{file2}.rotateUV\", force=True)\n        cmds.connectAttr(f\"{place2d2}.noiseUV\", f\"{file2}.noiseUV\", force=True)\n        cmds.connectAttr(f\"{place2d2}.vertexUvOne\", f\"{file2}.vertexUvOne\", force=True)\n        cmds.connectAttr(f\"{place2d2}.vertexUvTwo\", f\"{file2}.vertexUvTwo\", force=True)\n        cmds.connectAttr(f\"{place2d2}.vertexUvThree\", f\"{file2}.vertexUvThree\", force=True)\n        cmds.connectAttr(f\"{place2d2}.vertexCameraOne\", f\"{file2}.vertexCameraOne\", force=True)\n        cmds.connectAttr(f\"{place2d2}.outUV\", f\"{file2}.uv\", force=True)\n        cmds.connectAttr(f\"{place2d2}.outUvFilterSize\", f\"{file2}.uvFilterSize\", force=True)\n        \n        if file_assignments and file_assignments.get('bottom'):\n            filepath = cmds.getAttr(f\"{file_assignments['bottom']}.fileTextureName\") if cmds.objExists(file_assignments['bottom']) else file_assignments['bottom']\n            cmds.setAttr(f\"{file2}.fileTextureName\", filepath, type=\"string\")\n            print(f\"  Assigned file to {file2}: {filepath}\")\n        \n        configure_file_node(file2, suffix, is_mix_alpha=False)\n        \n        # File 3 (Mix Alpha)\n        file3_name = add_suffix('file3')\n        if file_assignments and file_assignments.get('mix_alpha'):\n            base_name = get_base_name_from_file(file_assignments['mix_alpha'])\n            file3_name = add_suffix(base_name)\n        \n        file3 = cmds.shadingNode('file', asTexture=True, isColorManaged=True, name=file3_name)\n        place2d3 = cmds.shadingNode('place2dTexture', asUtility=True)\n        \n        cmds.connectAttr(f\"{place2d3}.coverage\", f\"{file3}.coverage\", force=True)\n        cmds.connectAttr(f\"{place2d3}.translateFrame\", f\"{file3}.translateFrame\", force=True)\n        cmds.connectAttr(f\"{place2d3}.rotateFrame\", f\"{file3}.rotateFrame\", force=True)\n        cmds.connectAttr(f\"{place2d3}.mirrorU\", f\"{file3}.mirrorU\", force=True)\n        cmds.connectAttr(f\"{place2d3}.mirrorV\", f\"{file3}.mirrorV\", force=True)\n        cmds.connectAttr(f\"{place2d3}.stagger\", f\"{file3}.stagger\", force=True)\n        cmds.connectAttr(f\"{place2d3}.wrapU\", f\"{file3}.wrapU\", force=True)\n        cmds.connectAttr(f\"{place2d3}.wrapV\", f\"{file3}.wrapV\", force=True)\n        cmds.connectAttr(f\"{place2d3}.repeatUV\", f\"{file3}.repeatUV\", force=True)\n        cmds.connectAttr(f\"{place2d3}.offset\", f\"{file3}.offset\", force=True)\n        cmds.connectAttr(f\"{place2d3}.rotateUV\", f\"{file3}.rotateUV\", force=True)\n        cmds.connectAttr(f\"{place2d3}.noiseUV\", f\"{file3}.noiseUV\", force=True)\n        cmds.connectAttr(f\"{place2d3}.vertexUvOne\", f\"{file3}.vertexUvOne\", force=True)\n        cmds.connectAttr(f\"{place2d3}.vertexUvTwo\", f\"{file3}.vertexUvTwo\", force=True)\n        cmds.connectAttr(f\"{place2d3}.vertexUvThree\", f\"{file3}.vertexUvThree\", force=True)\n        cmds.connectAttr(f\"{place2d3}.vertexCameraOne\", f\"{file3}.vertexCameraOne\", force=True)\n        cmds.connectAttr(f\"{place2d3}.outUV\", f\"{file3}.uv\", force=True)\n        cmds.connectAttr(f\"{place2d3}.outUvFilterSize\", f\"{file3}.uvFilterSize\", force=True)\n        \n        if file_assignments and file_assignments.get('mix_alpha'):\n            filepath = cmds.getAttr(f\"{file_assignments['mix_alpha']}.fileTextureName\") if cmds.objExists(file_assignments['mix_alpha']) else file_assignments['mix_alpha']\n            cmds.setAttr(f\"{file3}.fileTextureName\", filepath, type=\"string\")\n            print(f\"  Assigned file to {file3}: {filepath}\")\n        \n        configure_file_node(file3, suffix, is_mix_alpha=True)\n    \n    # Check if Arnold nodes are available\n    has_ai_nodes = cmds.pluginInfo('mtoa', query=True, loaded=True) if cmds.pluginInfo('mtoa', query=True, registered=True) else False\n    \n    if has_ai_nodes:\n        print(\"Creating Arnold color correction nodes...\")\n        aiColorCorrect1 = cmds.shadingNode('aiColorCorrect', asUtility=True, name=add_suffix('aiColorCorrect1'))\n        aiColorCorrect2 = cmds.shadingNode('aiColorCorrect', asUtility=True, name=add_suffix('aiColorCorrect2'))\n        print(f\"  Created: {aiColorCorrect1}, {aiColorCorrect2}\")\n    else:\n        print(\"Arnold nodes not available, connecting files directly...\")\n    \n    # Connect network\n    print(\"\\nConnecting network...\")\n    \n    if file1:\n        if has_ai_nodes:\n            # Create layers for top1\n            cmds.setAttr(f\"{top1}.inputs[1].color\", 0, 0, 0, type=\"double3\")\n            \n            # Connect through aiColorCorrect\n            cmds.connectAttr(f\"{file1}.outColor\", f\"{aiColorCorrect1}.input\", force=True)\n            cmds.connectAttr(f\"{file1}.outColor\", f\"{top1}.inputs[1].color\", force=True)\n            cmds.connectAttr(f\"{aiColorCorrect1}.outColor\", f\"{top1}.inputs[0].color\", force=True)\n            cmds.connectAttr(f\"{ramp1}.outAlpha\", f\"{top1}.inputs[0].alpha\", force=True)\n            cmds.setAttr(f\"{top1}.inputs[0].blendMode\", 1)\n            \n            cmds.setAttr(f\"{aiColorCorrect1}.add\", 0.4, 0.4, 0.4, type=\"double3\")\n        else:\n            # Create layers for top1\n            cmds.setAttr(f\"{top1}.inputs[1].color\", 0, 0, 0, type=\"double3\")\n            \n            # Direct connection\n            cmds.connectAttr(f\"{file1}.outColor\", f\"{top1}.inputs[1].color\", force=True)\n            cmds.connectAttr(f\"{file1}.outColor\", f\"{top1}.inputs[0].color\", force=True)\n            cmds.connectAttr(f\"{ramp1}.outAlpha\", f\"{top1}.inputs[0].alpha\", force=True)\n            cmds.setAttr(f\"{top1}.inputs[0].blendMode\", 1)\n    \n    if file2:\n        if has_ai_nodes:\n            # Create layers for bottom\n            cmds.setAttr(f\"{bottom}.inputs[1].color\", 0, 0, 0, type=\"double3\")\n            \n            # Connect through aiColorCorrect\n            cmds.connectAttr(f\"{file2}.outColor\", f\"{aiColorCorrect2}.input\", force=True)\n            cmds.connectAttr(f\"{file2}.outColor\", f\"{bottom}.inputs[1].color\", force=True)\n            cmds.connectAttr(f\"{aiColorCorrect2}.outColor\", f\"{bottom}.inputs[0].color\", force=True)\n            cmds.connectAttr(f\"{ramp2}.outAlpha\", f\"{bottom}.inputs[0].alpha\", force=True)\n            cmds.setAttr(f\"{bottom}.inputs[0].blendMode\", 1)\n            \n            cmds.setAttr(f\"{aiColorCorrect2}.add\", 0.4, 0.4, 0.4, type=\"double3\")\n        else:\n            # Create layers for bottom\n            cmds.setAttr(f\"{bottom}.inputs[1].color\", 0, 0, 0, type=\"double3\")\n            \n            # Direct connection\n            cmds.connectAttr(f\"{file2}.outColor\", f\"{bottom}.inputs[1].color\", force=True)\n            cmds.connectAttr(f\"{file2}.outColor\", f\"{bottom}.inputs[0].color\", force=True)\n            cmds.connectAttr(f\"{ramp2}.outAlpha\", f\"{bottom}.inputs[0].alpha\", force=True)\n            cmds.setAttr(f\"{bottom}.inputs[0].blendMode\", 1)\n    \n    # Connect to mix layer\n    print(\"Connecting mix layer...\")\n    \n    # Create layer 1 for mix\n    cmds.setAttr(f\"{mix}.inputs[1].color\", 0, 0, 0, type=\"double3\")\n    \n    # Connect both layers\n    cmds.connectAttr(f\"{top1}.outColor\", f\"{mix}.inputs[0].color\", force=True)\n    if file3:\n        cmds.connectAttr(f\"{file3}.outAlpha\", f\"{mix}.inputs[0].alpha\", force=True)\n    cmds.connectAttr(f\"{bottom}.outColor\", f\"{mix}.inputs[1].color\", force=True)\n    \n    print(\"\\n=== Network Created Successfully ===\")\n    print(f\"Output node: {mix}\")\n    print(\"Connect mix.outColor to your shader's baseColor\\n\")\n\n\ndef start_workflow():\n    \"\"\"\n    Main entry point for the workflow\n    \"\"\"\n    # Check for selected file nodes\n    selection = cmds.ls(selection=True, type='file')\n    \n    if len(selection) in [2, 3]:\n        # Files selected, show assignment dialog\n        print(f\"Found {len(selection)} selected file nodes\")\n        show_file_selection_dialog(selection)\n    else:\n        # No files selected, go straight to suffix dialog\n        print(\"No file nodes selected, creating new files\")\n        show_suffix_dialog(None)\n\n\n# Example usage:\n# start_workflow()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Connect Place2dTexture Nodes" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Connect Place2dTexture Nodes" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "ConP2d" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "nodeGrapherRemoveNodes.png" 
        -image1 "nodeGrapherRemoveNodes.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef unify_place2dtexture():\n    sel = cmds.ls(sl=True) or []\n    \n    if not sel:\n        cmds.warning(\"Select file or place2dTexture nodes.\")\n        return\n\n    file_nodes = set()\n    place2d_nodes = set()\n\n    # Scan selection and find related file + place2d nodes\n    for node in sel:\n        type_ = cmds.nodeType(node)\n\n        if type_ == \"file\":\n            file_nodes.add(node)\n\n        elif type_ == \"place2dTexture\":\n            place2d_nodes.add(node)\n\n        else:\n            # If user selects other nodes, find connected file nodes\n            con_files = cmds.listConnections(node, type=\"file\") or []\n            file_nodes.update(con_files)\n\n    # If only place2dTexture selected ? find files they control\n    if place2d_nodes and not file_nodes:\n        for p in place2d_nodes:\n            con_files = cmds.listConnections(p, type=\"file\") or []\n            file_nodes.update(con_files)\n\n    if not file_nodes:\n        cmds.warning(\"No file nodes found connected to selection.\")\n        return\n\n    # Create or pick master place2dTexture\n    if not place2d_nodes:\n        main_place = cmds.shadingNode(\"place2dTexture\", asUtility=True)\n        place2d_nodes.add(main_place)\n    else:\n        main_place = list(place2d_nodes)[0]\n\n    # Delete extras\n    for p in list(place2d_nodes)[1:]:\n        cmds.delete(p)\n\n    # Attribute mapping\n    attr_map = [\n        (\"coverage\", \"coverage\"),\n        (\"translateFrame\", \"translateFrame\"),\n        (\"rotateFrame\", \"rotateFrame\"),\n        (\"mirrorU\", \"mirrorU\"),\n        (\"mirrorV\", \"mirrorV\"),\n        (\"stagger\", \"stagger\"),\n        (\"wrapU\", \"wrapU\"),\n        (\"wrapV\", \"wrapV\"),\n        (\"repeatUV\", \"repeatUV\"),\n        (\"offset\", \"offset\"),\n        (\"rotateUV\", \"rotateUV\"),\n        (\"noiseUV\", \"noiseUV\"),\n        (\"vertexUvOne\", \"vertexUvOne\"),\n        (\"vertexUvTwo\", \"vertexUvTwo\"),\n        (\"vertexUvThree\", \"vertexUvThree\"),\n        (\"vertexCameraOne\", \"vertexCameraOne\"),\n        (\"outUV\", \"uvCoord\"),\n        (\"outUvFilterSize\", \"uvFilterSize\")\n    ]\n\n    # Connect master place2d to all file nodes\n    for fn in file_nodes:\n        for src, dest in attr_map:\n            src_attr = f\"{main_place}.{src}\"\n            dest_attr = f\"{fn}.{dest}\"\n\n            if cmds.objExists(src_attr) and cmds.objExists(dest_attr):\n                try:\n                    cmds.connectAttr(src_attr, dest_attr, f=True)\n                except:\n                    pass\n\n    cmds.inViewMessage(amg=f\"<hl>? Unified Place2D: </hl>{main_place}\", pos=\"midCenter\", fade=True)\n    print(f\"? {main_place} connected to {len(file_nodes)} file nodes\")\n\n\n# Run it!\nunify_place2dtexture()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Link all files to shaders" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Link all files to shaders" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Fl>LT>SH" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/icons-phoenix/fileNode/F-S link.png" 
        -image1 "C:/icons-phoenix/fileNode/F-S link.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport re\n\ndef connect_maps_multi():\n    sel = cmds.ls(sl=True) or []\n    if not sel:\n        cmds.error(\"Select shaders + file nodes in any order.\")\n        return\n    \n    shaders = []\n    file_nodes = []\n    \n    # Identify shaders and file nodes, order independent\n    for node in sel:\n        if cmds.nodeType(node) == \"aiStandardSurface\":\n            shaders.append(node)\n        elif cmds.nodeType(node) == \"file\":\n            file_nodes.append(node)\n    \n    if not shaders:\n        cmds.error(\"No aiStandardSurface shaders selected.\")\n    if not file_nodes:\n        cmds.error(\"No file nodes selected.\")\n    \n    print(\"\\nShaders Detected =\", shaders)\n    print(\"File Nodes =\", file_nodes)\n    \n    # Clean shader names into identifiers\n    def clean_shader_name(name):\n        return name.replace(\"_shd\", \"\").lower()\n    \n    shader_keys = {s: clean_shader_name(s) for s in shaders}\n    \n    # Map suffix ? usage\n    suffix_map = {\n        \"col\": r\"_col($|[^a-zA-Z])\",\n        \"rgh\": r\"_rgh($|[^a-zA-Z])\",\n        \"nrm\": r\"_nrm($|[^a-zA-Z])\",\n        \"hgt\": r\"_hgt($|[^a-zA-Z])\",\n        \"mtl\": r\"_mtl($|[^a-zA-Z])\",\n        \"opc\": r\"_opc($|[^a-zA-Z])\"\n    }\n    \n    # UDIM detector\n    def is_udim(name):\n        name = name.lower()\n        m = re.search(r\"(col|rgh|nrm|hgt|mtl|opc)_(1\\d{3})\", name)\n        return bool(m)\n    \n    # Color management helpers\n    def set_raw(node):\n        cmds.setAttr(f\"{node}.ignoreColorSpaceFileRules\", 1)\n        cmds.setAttr(f\"{node}.alphaIsLuminance\", 1)\n        cmds.setAttr(f\"{node}.colorSpace\", \"Raw\", type=\"string\")\n    \n    def set_srgb(node):\n        cmds.setAttr(f\"{node}.ignoreColorSpaceFileRules\", 1)\n        cmds.setAttr(f\"{node}.alphaIsLuminance\", 0)\n        cmds.setAttr(f\"{node}.colorSpace\", \"sRGB\", type=\"string\")\n    \n    # Helper: Get or create layeredTexture for a specific shader attribute\n    def get_or_create_layered_texture(shader, attr_name):\n        \"\"\"\n        Returns a layeredTexture node connected to shader.attr_name.\n        Creates one if it doesn't exist.\n        \"\"\"\n        full_attr = f\"{shader}.{attr_name}\"\n        existing = cmds.listConnections(full_attr, s=True, d=False, type=\"layeredTexture\")\n        \n        if existing:\n            return existing[0]\n        \n        # Create new layeredTexture\n        lt = cmds.shadingNode(\"layeredTexture\", asTexture=True, \n                              name=f\"{shader}_{attr_name}_layered\")\n        \n        # Connect to shader\n        if attr_name == \"normalCamera\":\n            # For normal maps, we need aiNormalMap in between\n            ai_node = cmds.shadingNode(\"aiNormalMap\", asUtility=True,\n                                       name=f\"{shader}_aiNormalMap\")\n            cmds.connectAttr(f\"{lt}.outColor\", f\"{ai_node}.input\", f=True)\n            cmds.connectAttr(f\"{ai_node}.outValue\", full_attr, f=True)\n        else:\n            # Direct connection\n            if attr_name in [\"specularRoughness\", \"metalness\", \"subsurface\"]:\n                cmds.connectAttr(f\"{lt}.outAlpha\", full_attr, f=True)\n            else:\n                cmds.connectAttr(f\"{lt}.outColor\", full_attr, f=True)\n        \n        return lt\n    \n    # Process each FILE NODE and auto-route to correct SHADER\n    for file_node in file_nodes:\n        fname = file_node.lower()\n        \n        # Match file ? shader by name keyword\n        matched_shader = None\n        for shd, key in shader_keys.items():\n            if key in fname:\n                matched_shader = shd\n                break\n        \n        if not matched_shader:\n            print(f\"!! No shader matched for file: {file_node}\")\n            continue\n        \n        shader = matched_shader\n        print(f\"\\nFILE {file_node} MATCHED TO SHADER {shader}\")\n        \n        # Detect map type\n        map_type = None\n        for k, patt in suffix_map.items():\n            if re.search(patt, fname):\n                map_type = k\n                break\n        \n        if not map_type:\n            print(f\"!! No map type detected for {file_node}\")\n            continue\n        \n        # UDIM auto set\n        if is_udim(fname):\n            cmds.setAttr(f\"{file_node}.uvTilingMode\", 3)\n            print(f\"? UDIM enabled ? {file_node}\")\n        \n        # Color management\n        if map_type == \"col\":\n            set_srgb(file_node)\n        else:\n            set_raw(file_node)\n        \n        # =======================================================\n        #    PER-MAP CONNECTIONS (THROUGH LAYERED TEXTURE)\n        # =======================================================\n        \n        if map_type == \"col\":\n            lt = get_or_create_layered_texture(shader, \"baseColor\")\n            # Find next available input slot\n            inputs = cmds.getAttr(f\"{lt}.inputs\", mi=True) or []\n            next_idx = max(inputs) + 1 if inputs else 0\n            cmds.connectAttr(f\"{file_node}.outColor\", f\"{lt}.inputs[{next_idx}].color\", f=True)\n            print(f\"? Connected color ? layeredTexture[{next_idx}] ? baseColor\")\n        \n        elif map_type == \"rgh\":\n            lt = get_or_create_layered_texture(shader, \"specularRoughness\")\n            inputs = cmds.getAttr(f\"{lt}.inputs\", mi=True) or []\n            next_idx = max(inputs) + 1 if inputs else 0\n            cmds.connectAttr(f\"{file_node}.outAlpha\", f\"{lt}.inputs[{next_idx}].alpha\", f=True)\n            print(f\"? Connected roughness ? layeredTexture[{next_idx}] ? specularRoughness\")\n        \n        elif map_type == \"mtl\":\n            lt = get_or_create_layered_texture(shader, \"metalness\")\n            inputs = cmds.getAttr(f\"{lt}.inputs\", mi=True) or []\n            next_idx = max(inputs) + 1 if inputs else 0\n            cmds.connectAttr(f\"{file_node}.outAlpha\", f\"{lt}.inputs[{next_idx}].alpha\", f=True)\n            print(f\"? Connected metalness ? layeredTexture[{next_idx}] ? metalness\")\n        \n        elif map_type == \"opc\":\n            lt = get_or_create_layered_texture(shader, \"subsurface\")\n            inputs = cmds.getAttr(f\"{lt}.inputs\", mi=True) or []\n            next_idx = max(inputs) + 1 if inputs else 0\n            cmds.connectAttr(f\"{file_node}.outAlpha\", f\"{lt}.inputs[{next_idx}].alpha\", f=True)\n            print(f\"? Connected OPC ? layeredTexture[{next_idx}] ? subsurface\")\n            \n            # If shader also has COLOR for same prefix, connect to subsurfaceColor\n            for f2 in file_nodes:\n                if f2 == file_node:\n                    continue\n                if clean_shader_name(shader) in f2.lower() and re.search(suffix_map[\"col\"], f2.lower()):\n                    lt_ss = get_or_create_layered_texture(shader, \"subsurfaceColor\")\n                    ss_inputs = cmds.getAttr(f\"{lt_ss}.inputs\", mi=True) or []\n                    ss_idx = max(ss_inputs) + 1 if ss_inputs else 0\n                    cmds.connectAttr(f\"{f2}.outColor\", f\"{lt_ss}.inputs[{ss_idx}].color\", f=True)\n                    print(f\"? Connected color ? layeredTexture[{ss_idx}] ? subsurfaceColor\")\n        \n        elif map_type == \"nrm\":\n            lt = get_or_create_layered_texture(shader, \"normalCamera\")\n            inputs = cmds.getAttr(f\"{lt}.inputs\", mi=True) or []\n            next_idx = max(inputs) + 1 if inputs else 0\n            cmds.connectAttr(f\"{file_node}.outColor\", f\"{lt}.inputs[{next_idx}].color\", f=True)\n            print(f\"? Connected normal ? layeredTexture[{next_idx}] ? aiNormalMap ? normalCamera\")\n        \n        elif map_type == \"hgt\":\n            # Displacement through SG (with layeredTexture)\n            sg = cmds.listConnections(shader, type=\"shadingEngine\")[0]\n            \n            # Get or create displacement shader\n            existing = cmds.listConnections(f\"{sg}.displacementShader\", s=True, d=False)\n            if existing:\n                disp = existing[0]\n            else:\n                disp = cmds.shadingNode(\"displacementShader\", asUtility=True,\n                                        name=f\"{shader}_displacement\")\n            \n            # Get or create layeredTexture for displacement\n            lt_disp_attr = f\"{disp}.displacement\"\n            existing_lt = cmds.listConnections(lt_disp_attr, s=True, d=False, type=\"layeredTexture\")\n            \n            if existing_lt:\n                lt = existing_lt[0]\n            else:\n                lt = cmds.shadingNode(\"layeredTexture\", asTexture=True,\n                                     name=f\"{shader}_displacement_layered\")\n                cmds.connectAttr(f\"{lt}.outAlpha\", lt_disp_attr, f=True)\n            \n            # Connect file node to layeredTexture\n            inputs = cmds.getAttr(f\"{lt}.inputs\", mi=True) or []\n            next_idx = max(inputs) + 1 if inputs else 0\n            cmds.connectAttr(f\"{file_node}.outAlpha\", f\"{lt}.inputs[{next_idx}].alpha\", f=True)\n            \n            # Connect displacement to SG\n            cmds.connectAttr(f\"{disp}.displacement\", f\"{sg}.displacementShader\", f=True)\n            \n            print(f\"? Connected displacement ? layeredTexture[{next_idx}] ? displacementShader ? SG\")\n\n# RUN\nconnect_maps_multi()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Catclark_3" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Catclark_3" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Catclrk" 
        -overlayLabelColor 0.8 0.8 0.8 
