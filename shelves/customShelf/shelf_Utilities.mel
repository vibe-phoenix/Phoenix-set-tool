    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "UV planar mapping" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "UV planar mapping" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "planar" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "polyPlanProjLarge.png" 
        -image1 "polyPlanProjLarge.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nfrom maya import OpenMayaUI as omui\n\ntry:\n    from PySide6.QtWidgets import (\n        QWidget, QVBoxLayout, QHBoxLayout, QPushButton,\n        QLabel, QCheckBox, QLineEdit, QFrame, QSizePolicy\n    )\n    from PySide6.QtCore import Qt\n    from shiboken6 import wrapInstance\nexcept ImportError:\n    from PySide2.QtWidgets import (\n        QWidget, QVBoxLayout, QHBoxLayout, QPushButton,\n        QLabel, QCheckBox, QLineEdit, QFrame, QSizePolicy\n    )\n    from PySide2.QtCore import Qt\n    from shiboken2 import wrapInstance\n\nWINDOW_TITLE  = \"UV Planar Mapping\"\nWINDOW_OBJECT = \"PhoenixUVPlanarWin\"\n\nSTYLE = \"\"\"\nQWidget#PhoenixUVPlanar {\n    background: #1e1e24;\n    color: #d4d4dc;\n    font-family: \"Segoe UI\", \"SF Pro Text\", sans-serif;\n    font-size: 12px;\n}\nQPushButton#btn_x {\n    background: #4a1a1a;\n    border: 1px solid #7a2a2a;\n    border-radius: 6px;\n    color: #f08080;\n    font-size: 13px;\n    font-weight: 700;\n    padding: 7px 0px;\n}\nQPushButton#btn_x:hover   { background: #5e2222; border-color: #b04040; color: #ffaaaa; }\nQPushButton#btn_x:pressed { background: #2e1010; }\n\nQPushButton#btn_y {\n    background: #1a3a1a;\n    border: 1px solid #2a6a2a;\n    border-radius: 6px;\n    color: #80d880;\n    font-size: 13px;\n    font-weight: 700;\n    padding: 7px 0px;\n}\nQPushButton#btn_y:hover   { background: #225a22; border-color: #40aa40; color: #aaffaa; }\nQPushButton#btn_y:pressed { background: #101e10; }\n\nQPushButton#btn_z {\n    background: #1a2a4a;\n    border: 1px solid #2a4a8a;\n    border-radius: 6px;\n    color: #80a8f0;\n    font-size: 13px;\n    font-weight: 700;\n    padding: 7px 0px;\n}\nQPushButton#btn_z:hover   { background: #22386e; border-color: #4070c8; color: #aac8ff; }\nQPushButton#btn_z:pressed { background: #10182e; }\n\nQPushButton#btn_cam {\n    background: #3a3010;\n    border: 1px solid #6a5818;\n    border-radius: 6px;\n    color: #d4aa40;\n    font-size: 13px;\n    font-weight: 700;\n    padding: 7px 0px;\n}\nQPushButton#btn_cam:hover   { background: #524418; border-color: #a08828; color: #f0cc70; }\nQPushButton#btn_cam:pressed { background: #221c08; }\n\nQFrame#divider {\n    background: #2e2e3c;\n    max-height: 1px;\n    margin: 2px 0px;\n}\nQCheckBox {\n    color: #9090a8;\n    font-size: 11px;\n    spacing: 6px;\n}\nQCheckBox::indicator {\n    width: 14px; height: 14px;\n    border: 1px solid #4a4a6a;\n    border-radius: 3px;\n    background: #26262e;\n}\nQCheckBox::indicator:checked { background: #4a6aaa; border-color: #6a8adf; }\nQCheckBox:hover { color: #c0c0d8; }\n\nQLabel#field_label {\n    color: #6c6c80;\n    font-size: 11px;\n    min-width: 80px;\n}\nQLineEdit#uv_name {\n    background: #26262e;\n    border: 1px solid #3a3a4e;\n    border-radius: 4px;\n    color: #c8c8d8;\n    padding: 4px 8px;\n    font-size: 11px;\n}\nQLineEdit#uv_name:focus    { border-color: #5a5a8a; }\nQLineEdit#uv_name:disabled { background: #1e1e26; border-color: #28282e; color: #44445a; }\n\"\"\"\n\ndef maya_main_window():\n    ptr = omui.MQtUtil.mainWindow()\n    return wrapInstance(int(ptr), QWidget)\n\ndef toast(msg):\n    cmds.inViewMessage(amg=\"<hl>{}</hl>\".format(msg),\n                       pos=\"topCenter\", fade=True, fst=700, fad=400)\n\ndef run_planar_projection(direction, use_new_uv_set=False, uv_set_name=\"\"):\n    sel = cmds.ls(sl=True, long=True)\n    if not sel:\n        toast(\"Nothing selected.\")\n        return\n\n    # Convert selection to faces — exactly what Maya does internally\n    faces = cmds.polyListComponentConversion(sel, toFace=True)\n    faces = cmds.filterExpand(faces, selectionMask=34, expand=True)\n\n    if not faces:\n        toast(\"Could not resolve faces from selection.\")\n        return\n\n    # Resolve mesh transforms for UV set creation\n    objects = cmds.ls(sel, objectsOnly=True, long=True)\n\n    # Create / switch UV set before projecting\n    if use_new_uv_set and uv_set_name.strip():\n        name = uv_set_name.strip()\n        for obj in objects:\n            try:\n                existing = cmds.polyUVSet(obj, q=True, allUVSets=True) or []\n                if name not in existing:\n                    cmds.polyUVSet(obj, create=True, uvSet=name)\n                cmds.polyUVSet(obj, currentUVSet=True, uvSet=name)\n            except Exception as e:\n                cmds.warning(\"UV set error on {}: {}\".format(obj, e))\n\n    dir_map = {\"X\": \"x\", \"Y\": \"y\", \"Z\": \"z\", \"Cam\": \"c\"}\n\n    try:\n        cmds.polyProjection(\n            faces,\n            type=\"Planar\",\n            mapDirection=dir_map[direction],\n            keepImageRatio=True,\n            insertBeforeDeformers=True,\n            constructionHistory=True,\n        )\n        toast(\"Planar {} applied.\".format(direction))\n    except Exception as e:\n        cmds.warning(\"Projection failed: {}\".format(e))\n\n\nclass PhoenixUVPlanar(QWidget):\n\n    def __init__(self, parent=None):\n        super(PhoenixUVPlanar, self).__init__(parent, Qt.Window)\n        self.setObjectName(\"PhoenixUVPlanar\")\n        self.setWindowTitle(WINDOW_TITLE)\n        self.setStyleSheet(STYLE)\n        self.setMinimumWidth(280)\n        self.setMaximumWidth(340)\n        self.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Minimum)\n        self._build_ui()\n\n    def _build_ui(self):\n        root = QVBoxLayout(self)\n        root.setContentsMargins(10, 10, 10, 12)\n        root.setSpacing(8)\n\n        # -- Axis buttons --------------------------------------\n        btn_row = QHBoxLayout()\n        btn_row.setSpacing(6)\n\n        self.btn_x   = QPushButton(\"X\")\n        self.btn_y   = QPushButton(\"Y\")\n        self.btn_z   = QPushButton(\"Z\")\n        self.btn_cam = QPushButton(\"CAM\")\n\n        for btn, obj_name in [\n            (self.btn_x,   \"btn_x\"),\n            (self.btn_y,   \"btn_y\"),\n            (self.btn_z,   \"btn_z\"),\n            (self.btn_cam, \"btn_cam\"),\n        ]:\n            btn.setObjectName(obj_name)\n            btn.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)\n            btn_row.addWidget(btn)\n\n        self.btn_x.clicked.connect(lambda: self._fire(\"X\"))\n        self.btn_y.clicked.connect(lambda: self._fire(\"Y\"))\n        self.btn_z.clicked.connect(lambda: self._fire(\"Z\"))\n        self.btn_cam.clicked.connect(lambda: self._fire(\"Cam\"))\n\n        root.addLayout(btn_row)\n\n        # -- Divider -------------------------------------------\n        root.addWidget(self._divider())\n\n        # -- New UV Set toggle ---------------------------------\n        self.chk_new_uv = QCheckBox(\"New UV Set\")\n        self.chk_new_uv.setChecked(False)\n        self.chk_new_uv.toggled.connect(self._on_toggle)\n        root.addWidget(self.chk_new_uv)\n\n        # -- UV Set name field ---------------------------------\n        name_row = QHBoxLayout()\n        name_row.setSpacing(8)\n        lbl = QLabel(\"UV Set Name\")\n        lbl.setObjectName(\"field_label\")\n        name_row.addWidget(lbl)\n        self.uv_name = QLineEdit()\n        self.uv_name.setObjectName(\"uv_name\")\n        self.uv_name.setPlaceholderText(\"e.g. uvChannel_01\")\n        self.uv_name.setEnabled(False)\n        name_row.addWidget(self.uv_name)\n        root.addLayout(name_row)\n\n    def _divider(self):\n        d = QFrame()\n        d.setObjectName(\"divider\")\n        d.setFrameShape(QFrame.HLine)\n        return d\n\n    def _on_toggle(self, state):\n        self.uv_name.setEnabled(state)\n\n    def _fire(self, direction):\n        run_planar_projection(\n            direction,\n            self.chk_new_uv.isChecked(),\n            self.uv_name.text(),\n        )\n\n\ndef launch():\n    parent = maya_main_window()\n    for widget in parent.findChildren(QWidget, WINDOW_OBJECT):\n        widget.close()\n        widget.deleteLater()\n    win = PhoenixUVPlanar(parent=parent)\n    win.setObjectName(WINDOW_OBJECT)\n    win.show()\n    win.raise_()\n\n\nlaunch()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;

} 
