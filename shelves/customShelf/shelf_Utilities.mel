        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Fl>SH" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/icons-phoenix/fileNode/F-S link.png" 
        -image1 "C:/icons-phoenix/fileNode/F-S link.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# --- SAVE SHADER ENGINES (stand-alone) ---\n\nimport maya.cmds as cmds\n\n# This variable is stored on the Maya module itself\n# so it persists without needing external globals.\nimport __main__\nif not hasattr(__main__, \"PHX_SAVED_ENGINES\"):\n    __main__.PHX_SAVED_ENGINES = []\n\n\ndef save_shader_engines():\n    engines = set()\n    sel = cmds.ls(sl=True) or []\n\n    for node in sel:\n        if cmds.nodeType(node) == \"shadingEngine\":\n            engines.add(node)\n            continue\n\n        sgs = cmds.listConnections(node, s=True, d=False, type=\"shadingEngine\") or []\n        engines.update(sgs)\n\n        if cmds.attributeQuery(\"instObjGroups\", node=node, exists=True):\n            iog = cmds.listConnections(node + \".instObjGroups\", type=\"shadingEngine\") or []\n            engines.update(iog)\n\n    __main__.PHX_SAVED_ENGINES = list(engines)\n\n    cmds.inViewMessage(\n        amg=\"Saved <hl>%d</hl> shaderEngines\" % len(engines),\n        pos=\"midCenter\", fade=True\n    )\n\n\n# Run immediately\nsave_shader_engines()\n\n\n\n\n\nimport maya.cmds as cmds\nimport re\n\ndef connect_maps_multi():\n    sel = cmds.ls(sl=True) or []\n\n    if not sel:\n        cmds.error(\"Select shaders + file nodes in any order.\")\n        return\n\n    shaders = []\n    file_nodes = []\n\n    # Identify shaders and file nodes, order independent\n    for node in sel:\n        if cmds.nodeType(node) == \"aiStandardSurface\":\n            shaders.append(node)\n        elif cmds.nodeType(node) == \"file\":\n            file_nodes.append(node)\n\n    if not shaders:\n        cmds.error(\"No aiStandardSurface shaders selected.\")\n\n    if not file_nodes:\n        cmds.error(\"No file nodes selected.\")\n\n    print(\"\\nShaders Detected =\", shaders)\n    print(\"File Nodes =\", file_nodes)\n\n    # Clean shader names into identifiers\n    def clean_shader_name(name):\n        return name.replace(\"_shd\", \"\").lower()\n\n    shader_keys = {s: clean_shader_name(s) for s in shaders}\n\n    # Map suffix ? usage\n    suffix_map = {\n        \"col\": r\"_col($|[^a-zA-Z])\",\n        \"rgh\": r\"_rgh($|[^a-zA-Z])\",\n        \"nrm\": r\"_nrm($|[^a-zA-Z])\",\n        \"hgt\": r\"_hgt($|[^a-zA-Z])\",\n        \"mtl\": r\"_mtl($|[^a-zA-Z])\",\n        \"opc\": r\"_opc($|[^a-zA-Z])\"\n    }\n\n    # UDIM detector\n    # --- UDIM detector (suffix-based, strict) ---\n    def is_udim(name):\n        name = name.lower()   # safety\n\n        # Detect patterns like col_1015, rgh_1008, nrm_1020, etc.\n        m = re.search(r\"(col|rgh|nrm|hgt|mtl|opc)_(1\\d{3})\", name)\n        return bool(m)\n\n\n    # Color management helpers\n    def set_raw(node):\n        cmds.setAttr(f\"{node}.ignoreColorSpaceFileRules\", 1)\n        cmds.setAttr(f\"{node}.alphaIsLuminance\", 1)\n        cmds.setAttr(f\"{node}.colorSpace\", \"Raw\", type=\"string\")\n\n    def set_srgb(node):\n        cmds.setAttr(f\"{node}.ignoreColorSpaceFileRules\", 1)\n        cmds.setAttr(f\"{node}.alphaIsLuminance\", 0)\n        cmds.setAttr(f\"{node}.colorSpace\", \"sRGB\", type=\"string\")\n\n    # Process each FILE NODE and auto-route to correct SHADER\n    for file_node in file_nodes:\n\n        fname = file_node.lower()\n\n        # -------- Match file ? shader by name keyword --------\n        matched_shader = None\n\n        for shd, key in shader_keys.items():\n            if key in fname:\n                matched_shader = shd\n                break\n\n        if not matched_shader:\n            print(f\"!! No shader matched for file: {file_node}\")\n            continue\n\n        shader = matched_shader\n        print(f\"\\nFILE {file_node} MATCHED TO SHADER {shader}\")\n\n        # -------- Detect map type --------\n        map_type = None\n        for k, patt in suffix_map.items():\n            if re.search(patt, fname):\n                map_type = k\n                break\n\n        if not map_type:\n            print(f\"!! No map type detected for {file_node}\")\n            continue\n\n        # -------- UDIM auto set --------\n        if is_udim(fname):\n            cmds.setAttr(f\"{file_node}.uvTilingMode\", 3)\n            print(f\"? UDIM enabled ? {file_node}\")\n\n        # -------- Color management --------\n        if map_type == \"col\":\n            set_srgb(file_node)\n        else:\n            set_raw(file_node)\n\n        # =======================================================\n        #                PER-MAP CONNECTIONS\n        # =======================================================\n        if map_type == \"col\":\n            cmds.connectAttr(file_node + \".outColor\", shader + \".baseColor\", f=True)\n            print(\"? Connected color\")\n\n        elif map_type == \"rgh\":\n            cmds.connectAttr(file_node + \".outAlpha\", shader + \".specularRoughness\", f=True)\n            print(\"? Connected roughness\")\n\n        elif map_type == \"mtl\":\n            cmds.connectAttr(file_node + \".outAlpha\", shader + \".metalness\", f=True)\n            print(\"? Connected metalness\")\n\n        elif map_type == \"opc\":\n            # OPC ? subsurface\n            old = cmds.listConnections(shader + \".subsurface\", s=True, d=False, plugs=True)\n            if old:\n                cmds.disconnectAttr(old[0], shader + \".subsurface\")\n            cmds.connectAttr(file_node + \".outAlpha\", shader + \".subsurface\", f=True)\n            print(\"? Connected OPC ? subsurface\")\n\n            # If shader also has COLOR for same prefix, connect to subsurfaceColor\n            for f2 in file_nodes:\n                if f2 == file_node:\n                    continue\n                if clean_shader_name(shader) in f2.lower() and re.search(suffix_map[\"col\"], f2.lower()):\n                    cmds.defaultNavigation(connectToExisting=True,\n                                           source=f2,\n                                           destination=shader + \".subsurfaceColor\")\n                    cmds.connectAttr(f2 + \".outColor\", shader + \".subsurfaceColor\", f=True)\n                    print(\"? Connected color ? subsurfaceColor\")\n\n        elif map_type == \"nrm\":\n            ai_node = cmds.shadingNode(\"aiNormalMap\", asUtility=True,\n                                       name=shader + \"_aiNormalMap\")\n            cmds.connectAttr(file_node + \".outColor\", ai_node + \".input\", f=True)\n            cmds.connectAttr(ai_node + \".outValue\", shader + \".normalCamera\", f=True)\n            print(\"? Connected normal map (aiNormalMap)\")\n\n        elif map_type == \"hgt\":\n            # Displacement through SG\n            sg = cmds.listConnections(shader, type=\"shadingEngine\")[0]\n            existing = cmds.listConnections(sg + \".displacementShader\", s=True, d=False)\n\n            if existing:\n                disp = existing[0]\n            else:\n                disp = cmds.shadingNode(\"displacementShader\", asUtility=True,\n                                        name=shader + \"_displacement\")\n\n            before = set(cmds.ls(type=\"displacementShader\"))\n\n            cmds.defaultNavigation(connectToExisting=True,\n                                   source=file_node,\n                                   destination=sg + \".displacementShader\")\n\n            cmds.connectAttr(file_node + \".outAlpha\", disp + \".displacement\", f=True)\n            cmds.connectAttr(disp + \".displacement\", sg + \".displacementShader\", f=True)\n\n            after = set(cmds.ls(type=\"displacementShader\"))\n            extras = after - before\n\n            for node in extras:\n                if node != disp:\n                    cmds.delete(node)\n\n            print(\"? Connected displacement\")\n\n    # =======================================================\n    # SELECT all objects using all involved shaders\n    # AND open Hypershade graph\n    # =======================================================\n\n\n\n# RUN\nconnect_maps_multi()\n\n# --- RESELECT SAVED SHADER ENGINES (stand-alone) ---\n\nimport maya.cmds as cmds\nimport __main__\n\ndef reselect_shader_engines():\n    if not hasattr(__main__, \"PHX_SAVED_ENGINES\"):\n        cmds.warning(\"No shader engines saved.\")\n        return\n\n    engines = [e for e in __main__.PHX_SAVED_ENGINES if cmds.objExists(e)]\n\n    if not engines:\n        cmds.warning(\"Saved shaderEngines no longer exist.\")\n        return\n\n    cmds.select(engines, r=True)\n\n    cmds.inViewMessage(\n        amg=\"Reselected <hl>%d</hl> shaderEngines\" % len(engines),\n        pos=\"midCenter\", fade=True\n    )\n\n\n# Run immediately\nreselect_shader_engines()\n\n\n# --- GRAPH MATERIALS IN HYPERSHADE (FINAL STEP) ---\n\nimport maya.mel as mel\n\ntry:\n    # Open Hypershade if not open\n    if not cmds.window(\"hyperShadePanel1Window\", exists=True):\n        mel.eval(\"HypershadeWindow;\")\n\n    mel.eval('hyperShadePanelGraphCommand(\"hyperShadePanel1\", \"graphMaterials\");')\n    cmds.inViewMessage(amg=\"? Hypershade linked\", pos=\"midCenter\", fade=True)\n\nexcept Exception as e:\n    cmds.warning(\"Could not graph materials: %s\" % e)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
