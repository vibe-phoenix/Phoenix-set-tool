        -command "import maya.cmds as cmds\n\ndef update_selected_file_nodes():\n    # Get selected file nodes\n    selected = cmds.ls(selection=True, type='file')\n\n    if not selected:\n        cmds.warning(\"No file nodes selected.\")\n        return\n\n    for node in selected:\n        try:\n            # Turn on 'Ignore Color Space File Rules'\n            cmds.setAttr(f\"{node}.ignoreColorSpaceFileRules\", 1)\n\n            # Turn on 'Alpha is Luminance'\n            cmds.setAttr(f\"{node}.alphaIsLuminance\", 1)\n\n            # Change Color Space to 'Raw'\n            cmds.setAttr(f\"{node}.colorSpace\", \"Raw\", type=\"string\")\n\n            print(f\"Updated: {node}\")\n        except Exception as e:\n            print(f\"Failed to update {node}: {e}\")\n\nupdate_selected_file_nodes()\n" 
