        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport re\nimport os\n\ndef detect_udim_in_filename(filepath):\n    \"\"\"\n    Detect if filename contains UDIM pattern (e.g., _1001, _1021, etc.)\n    \"\"\"\n    if not filepath:\n        return False\n    \n    filename = os.path.basename(filepath)\n    # Pattern matches _1001 to _1999 (UDIM range)\n    udim_pattern = r'_1\\d{3}'\n    return bool(re.search(udim_pattern, filename))\n\n\ndef show_file_selection_dialog(selected_files):\n    \"\"\"\n    Show dialog to assign file nodes:\n    - Base Layer (bottom/inputs[1])\n    - Top Layer (top/inputs[0])\n    - Alpha Mask (for top layer alpha)\n    \"\"\"\n    window_name = \"simpleLayeredTextureWindow\"\n    \n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    num_files = len(selected_files)\n    \n    if num_files not in [2, 3]:\n        cmds.warning(\"Please select 2 or 3 file nodes\")\n        return None\n    \n    # Create window\n    window = cmds.window(window_name, title=\"Assign File Nodes\", sizeable=True)\n    main_layout = cmds.columnLayout(adjustableColumn=True, rowSpacing=10, columnOffset=('both', 15))\n    \n    cmds.text(label=\"Assign file nodes to layered texture:\", height=30, font=\"boldLabelFont\")\n    cmds.separator(height=15, style='in')\n    \n    option_menus = {}\n    \n    # Prepare file list with \"none\" option for alpha mask\n    file_options_with_none = ['none'] + selected_files\n    \n    # Base Layer (inputs[1]) - always required\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(150, 250), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Base Layer:\", align='right')\n    option_menus['base'] = cmds.optionMenu()\n    for f in selected_files:\n        cmds.menuItem(label=f)\n    cmds.setParent('..')\n    \n    # Top Layer (inputs[0]) - always required\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(150, 250), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Top Layer:\", align='right')\n    option_menus['top'] = cmds.optionMenu()\n    for f in selected_files:\n        cmds.menuItem(label=f)\n    if num_files >= 2:\n        cmds.optionMenu(option_menus['top'], edit=True, select=2)  # Default to second file\n    cmds.setParent('..')\n    \n    # Alpha Mask - optional\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(150, 250), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Alpha Mask:\", align='right')\n    option_menus['alpha'] = cmds.optionMenu()\n    for f in file_options_with_none:\n        cmds.menuItem(label=f)\n    if num_files == 3:\n        cmds.optionMenu(option_menus['alpha'], edit=True, select=4)  # Default to third file (index 4 because 'none' is first)\n    else:\n        cmds.optionMenu(option_menus['alpha'], edit=True, value='none')\n    cmds.setParent('..')\n    \n    cmds.separator(height=20, style='in')\n    \n    # Buttons\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(215, 215), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    def on_ok():\n        # Get selections\n        base_val = cmds.optionMenu(option_menus['base'], query=True, value=True)\n        top_val = cmds.optionMenu(option_menus['top'], query=True, value=True)\n        alpha_val = cmds.optionMenu(option_menus['alpha'], query=True, value=True)\n        \n        result = {\n            'base': base_val,\n            'top': top_val,\n            'alpha': None if alpha_val == 'none' else alpha_val,\n            'selected_files': selected_files\n        }\n        \n        cmds.deleteUI(window_name)\n        show_suffix_dialog(result)\n    \n    def on_cancel():\n        cmds.deleteUI(window_name)\n    \n    cmds.button(label=\"Continue\", command=lambda x: on_ok(), height=35, backgroundColor=(0.3, 0.5, 0.3))\n    cmds.button(label=\"Cancel\", command=lambda x: on_cancel(), height=35, backgroundColor=(0.5, 0.3, 0.3))\n    \n    cmds.setParent('..')  # Exit rowLayout\n    \n    cmds.separator(height=15, style='none')\n    \n    cmds.setParent('..')  # Exit main columnLayout\n    \n    cmds.showWindow(window)\n\n\ndef show_suffix_dialog(file_assignments=None):\n    \"\"\"\n    Show a dialog to select a single suffix for the layered texture node\n    \"\"\"\n    window_name = \"suffixSelectorWindow\"\n    \n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    window = cmds.window(window_name, title=\"Select Node Suffix\", sizeable=True)\n    \n    main_layout = cmds.columnLayout(adjustableColumn=True, rowSpacing=8, columnAttach=('both', 15))\n    \n    cmds.text(label=\"Select suffix for layered texture node:\", height=25, font=\"boldLabelFont\")\n    cmds.separator(height=8, style='in')\n    \n    suffixes = ['col', 'rgh', 'nrm', 'hgt', 'opc', 'mtl', 'custom', 'none']\n    \n    # Suffix dropdown\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(120, 240), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Suffix:\", align='right')\n    suffix_menu = cmds.optionMenu(changeCommand=lambda x: update_custom_field())\n    for suffix in suffixes:\n        cmds.menuItem(label=suffix)\n    cmds.optionMenu(suffix_menu, edit=True, value='col')\n    cmds.setParent('..')\n    \n    # Custom suffix text field (initially disabled)\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(120, 240), columnAttach=[(1, 'right', 10), (2, 'left', 5)])\n    cmds.text(label=\"Custom Suffix:\", align='right')\n    custom_field = cmds.textField(enable=False, placeholderText=\"Enter custom suffix\")\n    cmds.setParent('..')\n    \n    def update_custom_field():\n        \"\"\"Enable/disable custom field based on dropdown selection\"\"\"\n        selected = cmds.optionMenu(suffix_menu, query=True, value=True)\n        cmds.textField(custom_field, edit=True, enable=(selected == 'custom'))\n    \n    cmds.separator(height=10, style='in')\n    \n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(190, 190), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    def on_create():\n        selected = cmds.optionMenu(suffix_menu, query=True, value=True)\n        \n        if selected == 'custom':\n            # Get custom suffix from text field\n            suffix = cmds.textField(custom_field, query=True, text=True).strip()\n            if not suffix:\n                cmds.warning(\"Please enter a custom suffix or select a predefined one.\")\n                return\n        elif selected == 'none':\n            suffix = ''\n        else:\n            suffix = selected\n        \n        cmds.deleteUI(window_name)\n        create_layered_texture(suffix, file_assignments)\n    \n    def on_cancel():\n        cmds.deleteUI(window_name)\n    \n    cmds.button(label=\"Create Network\", command=lambda x: on_create(), height=35, backgroundColor=(0.3, 0.5, 0.3))\n    cmds.button(label=\"Cancel\", command=lambda x: on_cancel(), height=35, backgroundColor=(0.5, 0.3, 0.3))\n    \n    cmds.setParent('..')  # Exit rowLayout\n    \n    cmds.separator(height=10, style='none')\n    \n    cmds.setParent('..')  # Exit main columnLayout\n    \n    cmds.showWindow(window)\n\n\ndef configure_file_node(file_node, suffix, is_alpha_mask=False):\n    \"\"\"\n    Configure file node based on suffix type\n    \"\"\"\n    try:\n        # Always turn on ignoreColorSpaceFileRules\n        cmds.setAttr(f\"{file_node}.ignoreColorSpaceFileRules\", 1)\n        \n        # Check for UDIM in filename\n        filepath = cmds.getAttr(f\"{file_node}.fileTextureName\")\n        if detect_udim_in_filename(filepath):\n            cmds.setAttr(f\"{file_node}.uvTilingMode\", 3)\n            print(f\"  Set UDIM Tiling on: {file_node}\")\n        \n        # Configure based on suffix or if it's alpha mask\n        if is_alpha_mask or suffix in ['rgh', 'mtl', 'hgt', 'opc', 'nrm']:\n            # Raw color space, alphaIsLuminance ON\n            cmds.setAttr(f\"{file_node}.alphaIsLuminance\", 1)\n            cmds.setAttr(f\"{file_node}.colorSpace\", \"Raw\", type=\"string\")\n            print(f\"  Configured as Raw/Alpha: {file_node}\")\n        elif suffix == 'col':\n            # sRGB color space, alphaIsLuminance OFF\n            cmds.setAttr(f\"{file_node}.alphaIsLuminance\", 0)\n            cmds.setAttr(f\"{file_node}.colorSpace\", \"sRGB\", type=\"string\")\n            print(f\"  Configured as sRGB: {file_node}\")\n        \n    except Exception as e:\n        print(f\"  Warning: Failed to configure {file_node}: {e}\")\n\n\ndef create_layered_texture(suffix='', file_assignments=None):\n    \"\"\"\n    Create a simple layered texture setup:\n    - Base layer (inputs[1])\n    - Top layer (inputs[0]) with optional alpha mask\n    \n    Mimics this MEL pattern:\n        connectAttr base.outColor layeredTexture.inputs[1].color;\n        connectAttr top.outColor layeredTexture.inputs[0].color;\n        connectAttr mask.outAlpha layeredTexture.inputs[0].alpha;\n    \"\"\"\n    print(\"\\n=== Creating Layered Texture Setup ===\\n\")\n    \n    def add_suffix(base_name):\n        \"\"\"Add suffix to node name if provided\"\"\"\n        if suffix:\n            return f\"{base_name}_{suffix}\"\n        return base_name\n    \n    # Check if we're using existing file nodes\n    use_existing_files = False\n    base_file = None\n    top_file = None\n    alpha_file = None\n    \n    if file_assignments and 'selected_files' in file_assignments:\n        use_existing_files = True\n        base_file = file_assignments.get('base')\n        top_file = file_assignments.get('top')\n        alpha_file = file_assignments.get('alpha')\n        \n        print(f\"Using existing file nodes:\")\n        print(f\"  Base: {base_file}\")\n        print(f\"  Top: {top_file}\")\n        print(f\"  Alpha: {alpha_file if alpha_file else 'None'}\")\n    \n    # Create layered texture node\n    print(\"\\nCreating layered texture node...\")\n    layered_tex = cmds.shadingNode('layeredTexture', asTexture=True, name=add_suffix('layeredTexture'))\n    \n    # Set default values for inputs[0]\n    cmds.setAttr(f\"{layered_tex}.inputs[0].color\", 0.2, 0.7, 0.3, type=\"double3\")\n    cmds.setAttr(f\"{layered_tex}.inputs[0].alpha\", 1)\n    cmds.setAttr(f\"{layered_tex}.inputs[0].blendMode\", 1)\n    \n    print(f\"  Created: {layered_tex}\")\n    \n    # Configure file nodes if they exist\n    if use_existing_files:\n        print(\"\\nConfiguring file nodes...\")\n        \n        if base_file:\n            configure_file_node(base_file, suffix, is_alpha_mask=False)\n        \n        if top_file:\n            configure_file_node(top_file, suffix, is_alpha_mask=False)\n        \n        if alpha_file:\n            configure_file_node(alpha_file, suffix, is_alpha_mask=True)\n    \n    # Make connections\n    print(\"\\nMaking connections...\")\n    \n    if base_file:\n        # Connect base to inputs[1].color\n        cmds.connectAttr(f\"{base_file}.outColor\", f\"{layered_tex}.inputs[1].color\", force=True)\n        print(f\"  Connected {base_file}.outColor -> {layered_tex}.inputs[1].color (Base Layer)\")\n    \n    if top_file:\n        # Connect top to inputs[0].color\n        cmds.connectAttr(f\"{top_file}.outColor\", f\"{layered_tex}.inputs[0].color\", force=True)\n        print(f\"  Connected {top_file}.outColor -> {layered_tex}.inputs[0].color (Top Layer)\")\n    \n    if alpha_file:\n        # Connect alpha mask to inputs[0].alpha\n        cmds.connectAttr(f\"{alpha_file}.outAlpha\", f\"{layered_tex}.inputs[0].alpha\", force=True)\n        print(f\"  Connected {alpha_file}.outAlpha -> {layered_tex}.inputs[0].alpha (Alpha Mask)\")\n    \n    print(\"\\n=== Layered Texture Created Successfully ===\")\n    print(f\"Output node: {layered_tex}\")\n    print(\"Connect {}.outColor to your shader's input\\n\".format(layered_tex))\n    \n    # Select the layered texture node\n    cmds.select(layered_tex, replace=True)\n    \n    return layered_tex\n\n\ndef start_simple_layered_workflow():\n    \"\"\"\n    Main entry point for simple layered texture workflow\n    \"\"\"\n    # Check for selected file nodes\n    selection = cmds.ls(selection=True, type='file')\n    \n    if len(selection) in [2, 3]:\n        # Files selected, show assignment dialog\n        print(f\"Found {len(selection)} selected file nodes\")\n        show_file_selection_dialog(selection)\n    else:\n        # Wrong number of files\n        cmds.warning(\"Please select 2 or 3 file nodes:\\n  - 2 files: Base + Top\\n  - 3 files: Base + Top + Alpha Mask\")\n\n\nstart_simple_layered_workflow()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
