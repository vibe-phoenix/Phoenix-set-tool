        -command "import maya.cmds as cmds\nfrom PySide6 import QtWidgets, QtCore\nimport maya.OpenMayaUI as omui\nimport shiboken6\n\nwindow_instance = None\n\n\ndef get_maya_main_window():\n    ptr = omui.MQtUtil.mainWindow()\n    return shiboken6.wrapInstance(int(ptr), QtWidgets.QWidget)\n\n\n# Arnold actions\ndef arnold_update_tex():\n    cmds.arnoldRenderView(opt=(\"Update Full Scene\", \"True\"))\n\ndef arnold_ipr_play():\n    cmds.arnoldRenderView(opt=(\"Run IPR\", \"True\"))\n\ndef arnold_ipr_pause():\n    cmds.arnoldRenderView(opt=(\"Run IPR\", \"False\"))\n\n\nclass ArnoldControlWindow(QtWidgets.QDialog):\n    def __init__(self, parent=None):\n        super().__init__(parent)\n\n        self.setObjectName(\"ArnoldUpdateWindow\")\n        self.setWindowTitle(\"Arnold Controls\")\n\n        self.setWindowFlags(\n            QtCore.Qt.Tool |\n            QtCore.Qt.FramelessWindowHint |\n            QtCore.Qt.WindowStaysOnTopHint\n        )\n\n        self.setMinimumWidth(260)\n        self.setMinimumHeight(60)\n\n        layout = QtWidgets.QHBoxLayout(self)\n        layout.setContentsMargins(5, 5, 5, 5)\n        layout.setSpacing(8)\n\n        # ----------------------------------------------------\n        # BUTTON ORDER YOU REQUESTED:\n        # Update Tex  |  ? Play  |  ? Pause\n        # ----------------------------------------------------\n\n        # Update Tex\n        btn_update = QtWidgets.QPushButton(\"Update Tex\")\n        btn_update.setMinimumHeight(40)\n        btn_update.clicked.connect(arnold_update_tex)\n        layout.addWidget(btn_update)\n\n        # ? Play\n        btn_play = QtWidgets.QPushButton(\"?\")\n        btn_play.setMinimumHeight(40)\n        btn_play.setFixedWidth(40)\n        btn_play.clicked.connect(arnold_ipr_play)\n        layout.addWidget(btn_play)\n\n        # ? Pause\n        btn_pause = QtWidgets.QPushButton(\"?\")\n        btn_pause.setMinimumHeight(40)\n        btn_pause.setFixedWidth(40)\n        btn_pause.clicked.connect(arnold_ipr_pause)\n        layout.addWidget(btn_pause)\n\n        # Drag logic\n        self._dragging = False\n        self._drag_position = None\n\n    # ----- Mouse events -----\n\n    def mousePressEvent(self, event):\n        if event.button() == QtCore.Qt.MiddleButton:\n            self.close()\n            return\n        if event.button() == QtCore.Qt.RightButton:\n            self._dragging = True\n            self._drag_position = event.globalPosition().toPoint()\n            return\n        super().mousePressEvent(event)\n\n    def mouseMoveEvent(self, event):\n        if self._dragging and (event.buttons() & QtCore.Qt.RightButton):\n            new_pos = event.globalPosition().toPoint()\n            delta = new_pos - self._drag_position\n            self.move(self.pos() + delta)\n            self._drag_position = new_pos\n            return\n        super().mouseMoveEvent(event)\n\n    def mouseReleaseEvent(self, event):\n        if event.button() == QtCore.Qt.RightButton:\n            self._dragging = False\n            return\n        super().mouseReleaseEvent(event)\n\n\ndef show_arnold_control_window():\n    global window_instance\n\n    if window_instance:\n        try:\n            window_instance.close()\n            window_instance.deleteLater()\n        except:\n            pass\n\n    parent = get_maya_main_window()\n    window_instance = ArnoldControlWindow(parent)\n    window_instance.show()\n    window_instance.raise_()\n    window_instance.activateWindow()\n\n\n# Auto-run\nshow_arnold_control_window()\n" 
        -sourceType "python" 
        -doubleClickCommand "# Close Update Tex Panel (Frameless)\nimport maya.OpenMayaUI as omui\nimport shiboken6\nfrom PySide6 import QtWidgets\n\nptr = omui.MQtUtil.findWindow(\"UpdateTexFrameless\")\nif ptr:\n    win = shiboken6.wrapInstance(int(ptr), QtWidgets.QWidget)\n    win.close()\n" 
        -commandRepeatable 1
        -flat 1
